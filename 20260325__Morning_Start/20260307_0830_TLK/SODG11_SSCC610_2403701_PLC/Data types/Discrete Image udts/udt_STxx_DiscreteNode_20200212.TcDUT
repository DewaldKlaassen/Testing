  <DUT Name="udt_STxx_DiscreteNode_20200212" Id="{0c67052d-649d-402d-8057-17dc7a62bc2b}">
    <Declaration><![CDATA[(*
udt (user defined type) for Visualization of Stud Weld Controller Discrete I/O Module
