TYPE udt_STxx_DiscreteNode_20200212 :
	STRUCT
		T01: udt_EK1100;						(*Ecat Bus Coupler*)
		T02_STAT: udt_EL6900_STAT_20160426;	(*EL Safety CPU status*)
		T02_CMD: udt_EL6900_CMD_20121204;	(*EL Safety CPU command*)
		T03: udt_EL1904_v2;					(*EL Safety Inputs*)
		T04: udt_EL2904RO_v2;				(*EL Safety Outputs, Set to "I" as this terminal is safety rated, therefore read only!*)
		T05: udt_EL6731;						(*EL Profibus Mater Terminal*)
		Profinode_Stat: udt_ProfiNode_Status; 	(*Status Image of Profibus Node*)
	END_STRUCT
END_TYPE]]></Declaration>
