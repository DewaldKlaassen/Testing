		OK_ToEnter_HumanInterf4: BOOL;
		OK_ToEnter_HumanInterf5: BOOL;
		OK_ToEnter_HumanInterf6: BOOL;
		OK_ToEnter_HumanInterf7: BOOL;
		OK_ToEnter_HumanInterf8: BOOL;

		OK_ToEnter_RobotInterfs: UINT;

		Fix_ID: ARRAY [0..17] OF UINT;
		EOAT_ID: ARRAY [0..17] OF UINT;
