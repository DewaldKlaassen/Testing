		Task_ID: ARRAY [0..17] OF UINT;
		PeripheralReq_Ack: ARRAY [0..17] OF UINT;
		AuxReq_Ack: ARRAY [0..17] OF UINT;

		Proceed_From_Pounce: ARRAY[0..17] OF BOOL;
		Complete_Ack: ARRAY[0..17] OF BOOL;

	END_STRUCT
END_TYPE]]></Declaration>
