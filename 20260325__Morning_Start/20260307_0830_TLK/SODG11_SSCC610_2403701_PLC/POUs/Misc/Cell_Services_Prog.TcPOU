					(*Allow Robot To Proceed*)
					TDRobot_8_Proceed:= TRUE;
			ELSE
					Start_TDRobot_8:= FALSE;
					TDRobot_8_Proceed:= FALSE;
			END_IF;

			(*Robot 9*)
			IF (Robot9_Reqs_TipDress OR Human_Reqs_TipDressR9)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R9.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_9:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_9_Proceed:= TRUE;
			ELSE
					Start_TDRobot_9:= FALSE;
					TDRobot_9_Proceed:= FALSE;
			END_IF;

			(*Robot 10*)
			IF (Robot10_Reqs_TipDress OR Human_Reqs_TipDressR10)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R10.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_10:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_10_Proceed:= TRUE;
			ELSE
					Start_TDRobot_10:= FALSE;
					TDRobot_10_Proceed:= FALSE;
			END_IF;

			(*Robot 11*)
			IF (Robot11_Reqs_TipDress OR Human_Reqs_TipDressR11)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
