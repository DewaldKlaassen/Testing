(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Auto Run Cycle >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
	(*Control of Auto_Run*)
	Auto_Run:= Enable_Motion AND NOT Cycle_Complete;

	(*Auto Run Enables All Other Auto Cycle Code*)
	IF Auto_Run
		THEN
			(*----------Start Master Test Robots----------*)
			IF NOT Cycle_Complete AND (A_Robot_Reqs_MasterTest OR Human_Reqs_MasterTest)
				THEN
					(*Start All Robots*)
					Start_All_MTRobots:= TRUE;
					(*Allow Robots To Proceed*)
					All_MTRobots_Proceed:= All_Robots_WorkingOK;
			ELSE
					Start_All_MTRobots:= FALSE;
					All_MTRobots_Proceed:= FALSE;
			END_IF;
			(*-------Start Brake Test Robots----------*)
			IF NOT Cycle_Complete AND (All_RobotsReq_BrakeTest OR Human_Reqs_BrakeTest)
					AND NOT Start_All_MTRobots
				THEN
					(*Start All Robots*)
					Start_All_BTRobots:= TRUE;
					(*Allow Robots To Proceed*)
					All_BTRobots_Proceed:= All_Robots_WorkingOK;
			ELSE
					Start_All_BTRobots:= FALSE;
					All_BTRobots_Proceed:= FALSE;
			END_IF;
			(*---------Start Tip Change Robots-------------*)
			IF NOT Cycle_Complete AND (Human_Reqs_TipChange OR Robot_Reqs_TipChange)
					AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots
				THEN
					(*Start All Robots*)
					Start_All_TCRobots:= TRUE;
					(*Allow Robots To Proceed*)
					All_TCRobots_Proceed:= All_Robots_WorkingOK;
			ELSE
					Start_All_TCRobots:= FALSE;
					All_TCRobots_Proceed:= FALSE;
			END_IF;

			(*---------Common Tip Dress-------------*)
			IF NOT Cycle_Complete AND Robot_Reqs_TipDress
					AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots
				THEN
					(*Start All Robots*)
					Start_All_TDRobots:= TRUE;
					(*Allow Robots To Proceed*)
					All_TDRobots_Proceed:= All_Robots_WorkingOK;
			ELSE
					Start_All_TDRobots:= FALSE;
					All_TDRobots_Proceed:= FALSE;
			END_IF;
			
			(*---------Common TraccTCP-------------*) 
			IF NOT Cycle_Complete AND Robot_Reqs_TraccTCP
					AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots
					AND NOT Start_All_TDRobots
				THEN
					(*Start All Robots*)
					Start_All_TraccTCP:= TRUE;
					(*Allow Robots To Proceed*)
					All_TraccTCP_Proceed:= All_Robots_WorkingOK;
			ELSE
					Start_All_TraccTCP:= FALSE;
					All_TraccTCP_Proceed:= FALSE;
			END_IF;

			(*------------Seperated Dresses--------------*)
			(*Robot 1*)
			IF (Robot1_Reqs_TipDress OR Human_Reqs_TipDressR1)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R1.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_1:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_1_Proceed:= TRUE;
			ELSE
					Start_TDRobot_1:= FALSE;
					TDRobot_1_Proceed:= FALSE;
			END_IF;

			(*Robot 2*)
			IF (Robot2_Reqs_TipDress OR Human_Reqs_TipDressR2)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R2.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_2:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_2_Proceed:= TRUE;
			ELSE
					Start_TDRobot_2:= FALSE;
					TDRobot_2_Proceed:= FALSE;
			END_IF;

			(*Robot 3*)
			IF (Robot3_Reqs_TipDress OR Human_Reqs_TipDressR3)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R3.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_3:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_3_Proceed:= TRUE;
			ELSE
					Start_TDRobot_3:= FALSE;
					TDRobot_3_Proceed:= FALSE;
			END_IF;

			(*Robot 4*)
			IF (Robot4_Reqs_TipDress OR Human_Reqs_TipDressR4)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R4.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_4:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_4_Proceed:= TRUE;
			ELSE
					Start_TDRobot_4:= FALSE;
					TDRobot_4_Proceed:= FALSE;
			END_IF;

			(*Robot 5*)
			IF (Robot5_Reqs_TipDress OR Human_Reqs_TipDressR5)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R5.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
					Start_TDRobot_5:= TRUE;
					(*Allow Robot To Proceed*)
					TDRobot_5_Proceed:= TRUE;
			ELSE
					Start_TDRobot_5:= FALSE;
					TDRobot_5_Proceed:= FALSE;
			END_IF;

			(*Robot 6*)
			IF (Robot6_Reqs_TipDress OR Human_Reqs_TipDressR6)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R6.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
