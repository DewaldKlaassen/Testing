	Repo_Ack.1:= Repo_Reqs.1 AND MAIN.R2.Reamer[1].WireCutter_ACK AND (MAIN.R2.Task_ID_Ack=Tip_Dress); 
	Repo_Ack.2:= Repo_Reqs.2 AND MAIN.R2.Reamer[1].Injector_ACK AND (MAIN.R2.Task_ID_Ack=Tip_Dress);
	Repo_Ack.3:= Repo_Reqs.3 AND MAIN.R2.Reamer[1].LifterUp_ACK AND (MAIN.R2.Task_ID_Ack=Tip_Dress);
	Repo_Ack.4:= Repo_Reqs.4 AND MAIN.R2.Reamer[1].Clamp_ACK AND (MAIN.R2.Task_ID_Ack=Tip_Dress);
	Repo_ACk.5:= Repo_Reqs.5 AND MAIN.R2.Reamer[1].Reaming_Complete AND (MAIN.R2.Task_ID_Ack=Tip_Dress);*)

