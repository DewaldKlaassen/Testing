			ELSE
					Start_TDRobot_6:= FALSE;
					TDRobot_6_Proceed:= FALSE;
			END_IF;

			(*Robot 7*)
			IF (Robot7_Reqs_TipDress OR Human_Reqs_TipDressR7)
					AND ((NOT Start_All_MTRobots AND NOT Start_All_BTRobots
					AND NOT Start_All_TCRobots AND NOT Start_All_TDRobots)
					OR (MAIN.R7.Task_ID_Ack=Tip_Dress))
				THEN
					(*Start Robot*)
