    <Implementation>
      <ST><![CDATA[

	(*Set FB_OK to True*)
	Prog_OK:= TRUE;
(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Discrete I/O Node*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Safety Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Standard Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Master Test Request from any IC*)
	IF In_From_ICxx.Force_Master_Test
		THEN
			Human_Reqs_MasterTest:= TRUE; (*Reset at Master_Test_Complete*)
	END_IF;
(*Master Test Reqs from any Robot*)
	IF NOT GTAC_CONFIG.Under_Construction
		AND (MAIN.R1.Master_Test_Reqd
			OR MAIN.R2.Master_Test_Reqd
			OR MAIN.R3.Master_Test_Reqd
			OR MAIN.R4.Master_Test_Reqd
			OR MAIN.R5.Master_Test_Reqd
			OR MAIN.R6.Master_Test_Reqd
			OR MAIN.R7.Master_Test_Reqd
			OR MAIN.R8.Master_Test_Reqd
			OR MAIN.R9.Master_Test_Reqd
			OR MAIN.R10.Master_Test_Reqd
			OR MAIN.R11.Master_Test_Reqd
			OR MAIN.R12.Master_Test_Reqd
			OR MAIN.R13.Master_Test_Reqd
			OR MAIN.R14.Master_Test_Reqd
			OR MAIN.R15.Master_Test_Reqd
			OR MAIN.R16.Master_Test_Reqd
			OR MAIN.R17.Master_Test_Reqd
			OR MAIN.R18.Master_Test_Reqd
			OR MAIN.R19.Master_Test_Reqd
			OR MAIN.R20.Master_Test_Reqd
			OR MAIN.R21.Master_Test_Reqd
			OR MAIN.R22.Master_Test_Reqd
			OR MAIN.R23.Master_Test_Reqd
			OR MAIN.R24.Master_Test_Reqd
			OR MAIN.R25.Master_Test_Reqd
			OR MAIN.R26.Master_Test_Reqd
			OR MAIN.R27.Master_Test_Reqd
			OR MAIN.R28.Master_Test_Reqd
			OR MAIN.R29.Master_Test_Reqd
			OR MAIN.R30.Master_Test_Reqd)
	THEN

                   	A_Robot_Reqs_MasterTest := TRUE;  (*Reset at Master Test_Complete*)

	END_IF;



(*Brake Test Request from any IC*)
	IF In_From_ICxx.Force_Brake_Test
		THEN
			Human_Reqs_BrakeTest:= TRUE; (*Reset at Brake_Test_Complete*)
	END_IF;
(*Brake Test Reqs from any Robot*)
	IF NOT GTAC_CONFIG.Under_Construction
 		AND NOT All_RobotsReq_BrakeTest
                    AND (MAIN.R1.Brake_Test_Reqd
				OR MAIN.R2.Brake_Test_Reqd
				OR MAIN.R3.Brake_Test_Reqd
				OR MAIN.R4.Brake_Test_Reqd
				OR MAIN.R5.Brake_Test_Reqd
				OR MAIN.R6.Brake_Test_Reqd
				OR MAIN.R7.Brake_Test_Reqd
				OR MAIN.R8.Brake_Test_Reqd
				OR MAIN.R9.Brake_Test_Reqd
				OR MAIN.R10.Brake_Test_Reqd
				OR MAIN.R11.Brake_Test_Reqd
				OR MAIN.R12.Brake_Test_Reqd
				OR MAIN.R13.Brake_Test_Reqd
				OR MAIN.R14.Brake_Test_Reqd
				OR MAIN.R15.Brake_Test_Reqd
				OR MAIN.R16.Brake_Test_Reqd
				OR MAIN.R17.Brake_Test_Reqd
				OR MAIN.R18.Brake_Test_Reqd
				OR MAIN.R19.Brake_Test_Reqd
				OR MAIN.R20.Brake_Test_Reqd
