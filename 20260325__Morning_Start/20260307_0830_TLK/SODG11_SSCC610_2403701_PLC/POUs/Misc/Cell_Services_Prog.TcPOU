	R27_Data.PeripheralReq_Ack[16]:= Repo_Ack;
	R28_Data.PeripheralReq_Ack[16]:= Repo_Ack;
	R29_Data.PeripheralReq_Ack[16]:= Repo_Ack;
	R30_Data.PeripheralReq_Ack[16]:= Repo_Ack;

(*%%%%%%%%%%%%%% Call Robots to Tool and Give Them, Task ID, Fixture ID and Model ID %%%%%%%%%%%%%%%%%*)

	(* Perform Call To Service*)
	Service_Call_ForAllRobots:= (Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots)
								OR (NOT Start_All_MTRobots AND Start_All_BTRobots AND NOT Start_All_TCRobots)
								OR (NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND Start_All_TCRobots);

	Service_Call_ForRobot1:= (Start_TDRobot_1 OR Start_TraccTCP_1) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot2:= (Start_TDRobot_2 OR Start_TraccTCP_2) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot3:= (Start_TDRobot_3 OR Start_TraccTCP_3) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot4:= (Start_TDRobot_4 OR Start_TraccTCP_4) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot5:= (Start_TDRobot_5 OR Start_TraccTCP_5) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot6:= (Start_TDRobot_6 OR Start_TraccTCP_6) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot7:= (Start_TDRobot_7 OR Start_TraccTCP_7) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot8:= (Start_TDRobot_8 OR Start_TraccTCP_8) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot9:= (Start_TDRobot_9 OR Start_TraccTCP_9) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot10:= (Start_TDRobot_10 OR Start_TraccTCP_10) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot11:= (Start_TDRobot_11 OR Start_TraccTCP_11) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot12:= (Start_TDRobot_12 OR Start_TraccTCP_12) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot13:= (Start_TDRobot_13 OR Start_TraccTCP_13) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot14:= (Start_TDRobot_14 OR Start_TraccTCP_14) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot15:= (Start_TDRobot_15 OR Start_TraccTCP_15) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot16:= (Start_TDRobot_16 OR Start_TraccTCP_16) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot17:= (Start_TDRobot_17 OR Start_TraccTCP_17) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot18:= (Start_TDRobot_18 OR Start_TraccTCP_18) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
