	(*Peripheral Req Acks*)
	R1_Data.PeripheralReq_Ack[16]:= Repo_Ack;
	
	IF MAIN.R1.Task_ID_Ack=Tip_Dress THEN
		R1_Data.PeripheralReq_Ack[16].1 := MAIN.R1.Peripheral_Req.1 AND MAIN.R1.Reamer[1].Ream_Delay.Q  AND MAIN.R1.Reamer[1].Ream_Clamp_Open; 
		R1_Data.PeripheralReq_Ack[16].2 := MAIN.R1.Peripheral_Req.2 AND MAIN.R1.Reamer[1].Spray_Delay.Q; 
		R1_Data.PeripheralReq_Ack[16].4 := MAIN.R1.Peripheral_Req.4 AND MAIN.R1.Reamer[1].WireCutter_Delay.Q; 
	END_IF
	
	R2_Data.PeripheralReq_Ack[16]:= Repo_Ack;
	
