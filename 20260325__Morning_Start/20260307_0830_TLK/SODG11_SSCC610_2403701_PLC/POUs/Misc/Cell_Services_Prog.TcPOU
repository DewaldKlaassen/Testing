		(MAIN.R11.Task_ID_Ack=Tip_Change AND MAIN.R11.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<11) AND
		(MAIN.R12.Task_ID_Ack=Tip_Change AND MAIN.R12.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<12) AND
		(MAIN.R13.Task_ID_Ack=Tip_Change AND MAIN.R13.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<13) AND
		(MAIN.R14.Task_ID_Ack=Tip_Change AND MAIN.R14.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<14) AND
		(MAIN.R15.Task_ID_Ack=Tip_Change AND MAIN.R15.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<15) AND
		(MAIN.R16.Task_ID_Ack=Tip_Change AND MAIN.R16.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<16) AND
		(MAIN.R17.Task_ID_Ack=Tip_Change AND MAIN.R17.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<17) AND
		(MAIN.R18.Task_ID_Ack=Tip_Change AND MAIN.R18.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<18) AND
		(MAIN.R19.Task_ID_Ack=Tip_Change AND MAIN.R19.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<19) AND
		(MAIN.R20.Task_ID_Ack=Tip_Change AND MAIN.R20.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<20) AND
		(MAIN.R21.Task_ID_Ack=Tip_Change AND MAIN.R21.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<21) AND
		(MAIN.R22.Task_ID_Ack=Tip_Change AND MAIN.R22.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<22) AND
		(MAIN.R23.Task_ID_Ack=Tip_Change AND MAIN.R23.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<23) AND
		(MAIN.R24.Task_ID_Ack=Tip_Change AND MAIN.R24.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<24) AND
		(MAIN.R25.Task_ID_Ack=Tip_Change AND MAIN.R25.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<25) AND
		(MAIN.R26.Task_ID_Ack=Tip_Change AND MAIN.R26.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<26) AND
		(MAIN.R27.Task_ID_Ack=Tip_Change AND MAIN.R27.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<27) AND
		(MAIN.R28.Task_ID_Ack=Tip_Change AND MAIN.R28.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<28) AND
		(MAIN.R29.Task_ID_Ack=Tip_Change AND MAIN.R29.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<29) AND
		(MAIN.R30.Task_ID_Ack=Tip_Change AND MAIN.R30.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<30)
		THEN
			Repo_Reqs.0:= TRUE;
	END_IF;
	(*Reposition Request#2*)
	IF (MAIN.R1.Peripheral_Req.1) AND (MAIN.R1.Task_ID_Ack=Tip_Dress)
		THEN
			Repo_Reqs.1:= TRUE;
	END_IF;
	(*Reposition Request#3*)
	IF (MAIN.R2.Peripheral_Req.2) AND (MAIN.R2.Task_ID_Ack=Tip_Dress)
		THEN
			Repo_Reqs.2:= TRUE;
	END_IF;
	(*Reposition Request#4*)
	IF (MAIN.R3.Peripheral_Req.3) AND (MAIN.R3.Task_ID_Ack=Tip_Dress)
		THEN
			Repo_Reqs.3:= TRUE;
	END_IF;
	(*Reposition Request#5*)
	IF (MAIN.R4.Peripheral_Req.4) AND (MAIN.R4.Task_ID_Ack=Tip_Dress)
		THEN
			Repo_Reqs.4:= TRUE;
	END_IF;
	(*----Add more as required-----*)
	(*----Add more as required-----*)


	(*Reset All Reposition Acks At the End Of Cycle*)
	IF Cycle_Complete
		THEN
			Repo_Reqs:= 0;
	END_IF;
(*------------------------- Reposition Acks ---------------------*)
	Repo_Ack.0:= Repo_Reqs.0 AND In_From_ICxx.TipChange_Complete;
