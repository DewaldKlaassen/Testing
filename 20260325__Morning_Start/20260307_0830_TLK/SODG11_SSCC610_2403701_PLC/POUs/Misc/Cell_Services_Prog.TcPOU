	(*Set Cycle Complete*)
	IF Auto_Run AND (Master_Tests_Complete OR Brake_Tests_Complete OR Tip_Change_Complete OR Tip_Dress_CompleteAll OR TraccTCP_CompleteAll)
		THEN Cycle_Complete:= TRUE;
	END_IF;
	(*Reset All Completes*)
	IF Cycle_Complete AND All_Robots_Clear
		THEN
					Reset_All_Completes:= TRUE;
	END_IF;
	(*Perform Actual Reset*)
		IF Reset_All_Completes
			THEN
				Cycle_Complete:= FALSE;
				Human_Reqs_MasterTest := FALSE;
				A_Robot_Reqs_MasterTest :=FALSE;
				Master_Tests_Complete:= FALSE;
				Human_Reqs_BrakeTest := FALSE;
				A_Robot_Reqs_BrakeTest := FALSE;
				All_RobotsReq_BrakeTest := FALSE;
				Brake_Tests_Complete:= FALSE;
				Tip_Change_Complete:= FALSE;
				Tip_Dress_CompleteAll:= FALSE;
				TraccTCP_CompleteAll:= FALSE;
				Reset_All_Completes:= FALSE;
		END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Production Counter $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Increment Tip Change Counter*)
	Prod_Inc.CLK:= Tip_Change_Complete;
	Prod_Inc();
	IF Prod_Inc.Q
		THEN
		Production_Count:= Production_Count+1;
	END_IF;
	IF Discrete_In.ResetProd
		THEN
		Production_Count:= 0;
	END_IF;
	Prod_Count_Out:= Production_Count;
(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Cycle Time Counters ~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Move Previous To Register*)
	Cycle_Time_Pulse.CLK:= Tip_Change_Complete;
	Cycle_Time_Pulse();
	IF Cycle_Time_Pulse.Q
		THEN
		PrevCycle_Time_Out:= Cycle_Time_Out;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_Time.PT:= T#9999S;
		Cycle_Time.IN:= Auto_Run AND NOT Cycle_Complete;
		Cycle_Time();
		Cycle_Time_Out:= Cycle_Time.ET;

