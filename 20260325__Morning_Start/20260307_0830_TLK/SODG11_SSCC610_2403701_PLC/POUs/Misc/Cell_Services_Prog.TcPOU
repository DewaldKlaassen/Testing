	Service_Call_ForRobot20:= (Start_TDRobot_20 OR Start_TraccTCP_20) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot21:= (Start_TDRobot_21 OR Start_TraccTCP_21) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot22:= (Start_TDRobot_22 OR Start_TraccTCP_22) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot23:= (Start_TDRobot_23 OR Start_TraccTCP_23) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot24:= (Start_TDRobot_24 OR Start_TraccTCP_24) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot25:= (Start_TDRobot_25 OR Start_TraccTCP_25) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot26:= (Start_TDRobot_26 OR Start_TraccTCP_26) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot27:= (Start_TDRobot_27 OR Start_TraccTCP_27) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot28:= (Start_TDRobot_28 OR Start_TraccTCP_28) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot29:= (Start_TDRobot_29 OR Start_TraccTCP_29) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;
	Service_Call_ForRobot30:= (Start_TDRobot_30 OR Start_TraccTCP_30) AND NOT Start_All_MTRobots AND NOT Start_All_BTRobots AND NOT Start_All_TCRobots;

	(*Allow Robots to Proceed Into Tool*)
	(*!!!!!This is the final OK to allow Robots Into the Tool Area, So it Better Be Ready!!!!!!!*)
	IF Enable_Motion
		THEN
			IF (All_MTRobots_Proceed OR All_BTRobots_Proceed OR All_TCRobots_Proceed OR All_TraccTCP_Proceed) AND All_Robots_WorkingOK
				THEN Robots_Clear_ToProceed:=TRUE;
				ELSE Robots_Clear_ToProceed:= FALSE;
			END_IF;
		ELSE Robots_Clear_ToProceed:= FALSE;
	END_IF;

	(*Develop Task IDs - See Global Variable, "TaskID_Record"*)

	IF Start_All_MTRobots AND Enable_Motion
		THEN
			Task_ID:= Master_Test;
	ELSIF Start_All_BTRobots AND Enable_Motion
		THEN
			Task_ID:= Brake_Test;
	ELSIF Start_All_TCRobots AND Enable_Motion
		THEN
			Task_ID:= Tip_Change;
	ELSIF Start_All_TDRobots AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_1 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_2 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_3 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_4 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_5 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_6 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_7 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_8 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_9 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_10 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_11 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_12 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_13 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_14 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_15 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_16 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_17 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_18 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_19 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_20 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_21 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_22 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_23 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_24 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_25 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_26 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_27 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_28 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_29 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TDRobot_30 AND Enable_Motion
		THEN
			Task_ID:= Tip_Dress;
	ELSIF Start_TraccTCP_1 AND Enable_Motion
		THEN
			Task_ID:= Tracc_TCP;
	ELSIF Start_TraccTCP_2 AND Enable_Motion
		THEN
			Task_ID:= Tracc_TCP;
	ELSIF Start_TraccTCP_3 AND Enable_Motion
		THEN
			Task_ID:= Tracc_TCP;
	ELSIF Start_TraccTCP_4 AND Enable_Motion
		THEN
			Task_ID:= Tracc_TCP;		
(*ADD MORE*)			
	ELSE Task_ID:= 0;
	END_IF;



	(*Develop Fixture ID*)
	Fix_ID:= 1;					(*In Future Map Beckhoff Dip Switch Data From IP67 Block to Here*)
	(*Develop Model ID*)
	Model_ID:= Discrete_In.ModelData;		(*1 = AB Ring 4DR, 2 = AB Ring 5DR*)


(*+++++++++++++++++++++++++++++++++++++++++++++++ Task Complete Acks ++++++++++++++++++++++++++*)

	(*Complete Ack*)
	All_Complete_Ack:= All_Robots_Complete AND Cycle_Complete;



(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Tool Repositions !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

	(*Reposition Request#1*)
	IF MAIN.R1.Task_ID_Ack=Tip_Change AND MAIN.R1.Peripheral_Req.0 AND
		(MAIN.R2.Task_ID_Ack=Tip_Change AND MAIN.R2.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<2) AND
		(MAIN.R3.Task_ID_Ack=Tip_Change AND MAIN.R3.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<3) AND
		(MAIN.R4.Task_ID_Ack=Tip_Change AND MAIN.R4.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<4) AND
		(MAIN.R5.Task_ID_Ack=Tip_Change AND MAIN.R5.Peripheral_Req.0 OR GTAC_CONFIG.Option_Robot_Count<5) AND
