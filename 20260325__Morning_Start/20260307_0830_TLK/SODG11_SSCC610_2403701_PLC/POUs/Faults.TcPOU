		Main.Rxx.T02_STAT.SGs_FB_ERR.10 = Turntable Switch 1 Error (for Turntable type Kuka Robots)
		Main.Rxx.T02_STAT.SGs_FB_ERR.11 = Turntable Switch 2 Error (for Turntable type Kuka Robots)
	
		Main.Rxx.T02_STAT.SGs_FB_ERR.16 = Peri-Ready FB Error
	
		Main.Rxx.T02_STAT.SGs_FB_ERR.21 = Alarm Space MR1 FB Error (Pre robot FSoE)
		Main.Rxx.T02_STAT.SGs_FB_ERR.22 = Alarm Space MR2 FB Error (Pre robot FSoE)
		Main.Rxx.T02_STAT.SGs_FB_ERR.23 = Alarm Space MR3 FB Error (Pre robot FSoE)
		Main.Rxx.T02_STAT.SGs_FB_ERR.24 = Alarm Space MR4 FB Error (Pre robot FSoE)
	
		Main.Rxx.T02_STAT.SGs_FB_ERR.29 = Safe Space Enabled FB Error

	- Comm Faults
		Main.Rxx.T02_STAT.SGs_COM_ERR.0 = Local Comm Error, IE Comm Error Between Rxx 6900 and Local Input or output terminal
		Main.Rxx.T02_STAT.SGs_COM_ERR.1 = Remote Comm Error, IE Comm Error Between Rxx 6900 and 6900 In IC01 Cabinet

	- Output Faults
		MAIN.ICR.T02_STAT.SGs_OUT_ERR.0 = Output Fault

