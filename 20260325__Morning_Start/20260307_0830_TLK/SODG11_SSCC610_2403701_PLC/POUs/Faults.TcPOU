<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="Faults" Id="{e3e9c687-6dd1-49e4-a7be-79cb18cbd94e}" SpecialFunc="None">
    <Declaration><![CDATA[(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
	Fault Routine for generating faults to display on UI

----------------------------------------------------------------------------------------------------------------------
REVISION NOTES:
	A long time ago: 
	- Initial Concept, b.lekx-toniolo
	13-Jan-2016:
	- Increased fault area from 0-999 to 0-1499, b.lekx-toniolo 
	14-Sept-2016:
	- Increased fault area from 0-1499 to 0-1639, b.lekx-toniolo 
	08-Feb-2020:
	- Added in fault115 for PD safety gate relays (bug correction, found by j.underhill), b.lekx-toniolo
	01-March-2021
	- Added fault 125/ 126 for SS EDM faults, b.lekx-toniolo
	Winter 2021
	- Changes as requred for TcUI migration project, b.lekx-toniolo / c.drees
	Fall 2024
	- Added in MDxx Component, b.lekx-toniolo
-----------------------------------------------------------------------------------------------------------------------
*)


PROGRAM Faults

VAR_INPUT
	Enable_Prog: BOOL;
END_VAR

VAR
	(*Major Fault that will stop all automation in machine*)
	System_Major_Fault: BOOL;
	(*Minor Fault that will NOT stop all automation*)
	System_Minor_Fault: BOOL;
	(*General Controls Fault - Used for flag on UI*)
	General_Controls_Fault: BOOL;
	(*Index for Loops*)
	Loop_Index_ConfigFLT: INT;
	Loop_Index_Major: INT;
	Loop_Index_Minor: INT;

	(*Fault Timers*)
	Fault_Tmrs: ARRAY [0..1639] OF TON;
	Long_Faults: TIME:=T#5s;
	Medium_Faults: TIME:=T#2.5s;
	Short_Faults: TIME:=T#1.0S;
	No_Timer: TIME:=T#0.0s;

(*TOFs for capturing Light Curtain Faults*)
	VLC_Capture11_TOF: TOF;
	VLC_Capture12_TOF: TOF;
	VLC_Capture21_TOF: TOF;
	VLC_Capture22_TOF: TOF;
	VLC_Capture31_TOF: TOF;
	VLC_Capture32_TOF: TOF;
	VLC_Capture41_TOF: TOF;
	VLC_Capture42_TOF: TOF;
	VLC_Capture51_TOF: TOF;
	VLC_Capture52_TOF: TOF;
	VLC_Capture61_TOF: TOF;
	VLC_Capture62_TOF: TOF;
	VLC_Capture71_TOF: TOF;
	VLC_Capture72_TOF: TOF;
	VLC_Capture81_TOF: TOF;
	VLC_Capture82_TOF: TOF;
	VLC_Capture91_TOF: TOF;
	VLC_Capture92_TOF: TOF;
	VLC_Capture101_TOF: TOF;
	VLC_Capture102_TOF: TOF;
	VLC_Capture111_TOF: TOF;
	VLC_Capture112_TOF: TOF;
	VLC_Capture121_TOF: TOF;
	VLC_Capture122_TOF: TOF;
	VLC_Capture131_TOF: TOF;
	VLC_Capture132_TOF: TOF;
	VLC_Capture141_TOF: TOF;
	VLC_Capture142_TOF: TOF;
	VLC_Capture151_TOF: TOF;
	VLC_Capture152_TOF: TOF;
	VLC_Capture161_TOF: TOF;
	VLC_Capture162_TOF: TOF;

	HLC_Capture11_TOF: TOF;
	HLC_Capture12_TOF: TOF;
	HLC_Capture13_TOF: TOF;
	HLC_Capture21_TOF: TOF;
	HLC_Capture22_TOF: TOF;
	HLC_Capture23_TOF: TOF;
	HLC_Capture31_TOF: TOF;
	HLC_Capture32_TOF: TOF;
	HLC_Capture33_TOF: TOF;
	HLC_Capture41_TOF: TOF;
	HLC_Capture42_TOF: TOF;
	HLC_Capture43_TOF: TOF;
	HLC_Capture51_TOF: TOF;
	HLC_Capture52_TOF: TOF;
	HLC_Capture53_TOF: TOF;
	HLC_Capture61_TOF: TOF;
	HLC_Capture62_TOF: TOF;
	HLC_Capture63_TOF: TOF;
	HLC_Capture71_TOF: TOF;
	HLC_Capture72_TOF: TOF;
	HLC_Capture73_TOF: TOF;
	HLC_Capture81_TOF: TOF;
	HLC_Capture82_TOF: TOF;
	HLC_Capture83_TOF: TOF;
	HLC_Capture91_TOF: TOF;
	HLC_Capture92_TOF: TOF;
	HLC_Capture93_TOF: TOF;
	HLC_Capture101_TOF: TOF;
	HLC_Capture102_TOF: TOF;
	HLC_Capture103_TOF: TOF;
	HLC_Capture111_TOF: TOF;
	HLC_Capture112_TOF: TOF;
	HLC_Capture113_TOF: TOF;
	HLC_Capture121_TOF: TOF;
	HLC_Capture122_TOF: TOF;
	HLC_Capture123_TOF: TOF;
	HLC_Capture131_TOF: TOF;
	HLC_Capture132_TOF: TOF;
	HLC_Capture133_TOF: TOF;
	HLC_Capture141_TOF: TOF;
	HLC_Capture142_TOF: TOF;
	HLC_Capture143_TOF: TOF;
	HLC_Capture151_TOF: TOF;
	HLC_Capture152_TOF: TOF;
	HLC_Capture153_TOF: TOF;
	HLC_Capture161_TOF: TOF;
	HLC_Capture162_TOF: TOF;
	HLC_Capture163_TOF: TOF;

	R1_BaseLS_OK: BOOL;
	R2_BaseLS_OK: BOOL;
	R3_BaseLS_OK: BOOL;
	R4_BaseLS_OK: BOOL;
	R5_BaseLS_OK: BOOL;
	R6_BaseLS_OK: BOOL;
	R7_BaseLS_OK: BOOL;
	R8_BaseLS_OK: BOOL;
	R9_BaseLS_OK: BOOL;
	R10_BaseLS_OK: BOOL;
	R11_BaseLS_OK: BOOL;
	R12_BaseLS_OK: BOOL;
	R13_BaseLS_OK: BOOL;
	R14_BaseLS_OK: BOOL;
	R15_BaseLS_OK: BOOL;
	R16_BaseLS_OK: BOOL;
	R17_BaseLS_OK: BOOL;
	R18_BaseLS_OK: BOOL;
	R19_BaseLS_OK: BOOL;
	R20_BaseLS_OK: BOOL;
	R21_BaseLS_OK: BOOL;
	R22_BaseLS_OK: BOOL;
	R23_BaseLS_OK: BOOL;
	R24_BaseLS_OK: BOOL;
	R25_BaseLS_OK: BOOL;
	R26_BaseLS_OK: BOOL;
	R27_BaseLS_OK: BOOL;
	R28_BaseLS_OK: BOOL;
	R29_BaseLS_OK: BOOL;
	R30_BaseLS_OK: BOOL;

	
	

END_VAR

VAR_OUTPUT
		Prog_Ok: BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[	(*Set Prog_OK to True*)
	Prog_OK:= TRUE;
(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Global Fault Routine For Entire Machine !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
(* All Faults From 0 to 990 will Stop All Machine Automation, all Faults from 991 to 1639 Will NOT Stop All Machine Automation*)

(*Start with Config Fault, if Configuration is Faulted, Blank all other faults*)
(*Fault0 - GTAC-Configuration File Data Fault!!!!!!!!!!!!!*)
	Fault_Tmrs[0].PT:=No_Timer;
	Fault_Tmrs[0]();
	Fault_Tmrs[0].IN:= GTAC_CONFIG.Fault.0;
	Out_To_ICxx.System_Faults[0]:=Fault_Tmrs[0].Q;

(*If Configuration is Faulted then Blank All other faults*)
IF Out_To_ICxx.System_Faults[0]
	THEN

		FOR Loop_Index_ConfigFLT:= 1 TO 1639 DO
			IF (Loop_Index_ConfigFLT>=1) AND (Loop_Index_ConfigFLT<1640) (*Ensure to check bounds to not run out of Array*)
				THEN Out_To_ICxx.System_Faults[Loop_Index_ConfigFLT]:= FALSE;
			END_IF;
		END_FOR;

(*If Configuration is OK, then Run Normal Fault Checking*)
ELSIF NOT Out_To_ICxx.System_Faults[0]
	THEN
	(*Fault1 - No Control Power*)
		Fault_Tmrs[1].PT:=Short_Faults;
		Fault_Tmrs[1]();
		Fault_Tmrs[1].IN:= NOT MAIN.Control_Power_ON;
		Out_To_ICxx.System_Faults[1]:=Fault_Tmrs[1].Q;
	(*Fault2 - IC01 CPU Over Temperature*)
		Fault_Tmrs[2].PT:=Short_Faults;
		Fault_Tmrs[2]();
		Fault_Tmrs[2].IN:= MAIN.Mother_Board.Temp_MB>=85			(*Mother Board Temperature*)
						OR MAIN.Mother_Board.Temp_0>=85;		(*CPU Temperature*)
		Out_To_ICxx.System_Faults[2]:=Fault_Tmrs[2].Q;
	(*Fault3 - IC01 ETHERCAT Master DevState Not Zero*)
		Fault_Tmrs[3].PT:= No_Timer;
		Fault_Tmrs[3]();
		Fault_Tmrs[3].IN:= MAIN.ECAT_Master.Discrete_Image.HW.DevState<>0;			(*DevState Not Zero Indicates EtherCAT Segment Fault*)
		Out_To_ICxx.System_Faults[3]:=Fault_Tmrs[3].Q;



	(*Fault5 - ESW01 Removed From Nest*)
		Fault_Tmrs[5].PT:=Short_Faults;
		Fault_Tmrs[5]();
		Fault_Tmrs[5].IN:= (GTAC_CONFIG.Option_ESW_Count>=1) AND
							MAIN.ESW01.Enabling_Switch_Active AND NOT MAIN.ESW01.Enabling_Switch_On ;
		Out_To_ICxx.System_Faults[5]:=Fault_Tmrs[5].Q;
	(*Fault6 - ESW02 Removed From Nest*)
		Fault_Tmrs[6].PT:=Short_Faults;
		Fault_Tmrs[6]();
		Fault_Tmrs[6].IN:= (GTAC_CONFIG.Option_ESW_Count>=2) AND
							MAIN.ESW02.Enabling_Switch_Active AND NOT MAIN.ESW02.Enabling_Switch_On ;
		Out_To_ICxx.System_Faults[6]:=Fault_Tmrs[6].Q;
	(*Fault7 - ESW03 Removed From Nest*)
		Fault_Tmrs[7].PT:=Short_Faults;
		Fault_Tmrs[7]();
		Fault_Tmrs[7].IN:= (GTAC_CONFIG.Option_ESW_Count>=3) AND
							MAIN.ESW03.Enabling_Switch_Active AND NOT MAIN.ESW03.Enabling_Switch_On ;
		Out_To_ICxx.System_Faults[7]:=Fault_Tmrs[7].Q;
	(*Fault8 - ESW04 Removed From Nest*)
		Fault_Tmrs[8].PT:=Short_Faults;
		Fault_Tmrs[8]();
		Fault_Tmrs[8].IN:= (GTAC_CONFIG.Option_ESW_Count>=4) AND
							MAIN.ESW04.Enabling_Switch_Active AND NOT MAIN.ESW04.Enabling_Switch_On ;
		Out_To_ICxx.System_Faults[8]:=Fault_Tmrs[8].Q;



	(*Fault10 - Main Water#1 Flow Fault *)
		Fault_Tmrs[10].PT:= Long_Faults;
		Fault_Tmrs[10]();
		Fault_Tmrs[10].IN:= GTAC_CONFIG.Option_Water1 AND
							FALSE;
		Out_To_ICxx.System_Faults[10]:=Fault_Tmrs[10].Q;
	(*Fault11 - Main Water#2 Flow Fault *)
		Fault_Tmrs[11].PT:= Long_Faults;
		Fault_Tmrs[11]();
		Fault_Tmrs[11].IN:= GTAC_CONFIG.Option_Water2 AND
							FALSE;
		Out_To_ICxx.System_Faults[11]:=Fault_Tmrs[11].Q;
	(*Fault12 - Main Water#1 Temperature Fault *)
		Fault_Tmrs[12].PT:= Long_Faults;
		Fault_Tmrs[12]();
		Fault_Tmrs[12].IN:= GTAC_CONFIG.Option_Water1 AND
							FALSE;
		Out_To_ICxx.System_Faults[12]:=Fault_Tmrs[12].Q;
	(*Fault13 - Main Water#2 Temperature Fault *)
		Fault_Tmrs[13].PT:= Long_Faults;
		Fault_Tmrs[13]();
		Fault_Tmrs[13].IN:= GTAC_CONFIG.Option_Water2 AND
							FALSE;
		Out_To_ICxx.System_Faults[13]:=Fault_Tmrs[13].Q;

	(*Fault15 - Main Air Pressure Low*)
		Fault_Tmrs[15].PT:=Medium_Faults;
		Fault_Tmrs[15]();
		Fault_Tmrs[15].IN:= GTAC_CONFIG.Option_Air1 AND
							MAIN.All_Estops_OK AND
							NOT MAIN.SS01.Air_PressureOK;
		Out_To_ICxx.System_Faults[15]:=Fault_Tmrs[15].Q;
	(*Fault16 - Main Air Pressure Low*)
		Fault_Tmrs[16].PT:=Medium_Faults;
		Fault_Tmrs[16]();
		Fault_Tmrs[16].IN:= GTAC_CONFIG.Option_Air2 AND
							MAIN.All_Estops_OK AND
							NOT MAIN.SS02.Air_PressureOK;
		Out_To_ICxx.System_Faults[16]:=Fault_Tmrs[16].Q;

	(*Fault19 - Tip Change Count Exceeds Maximum, QA Must Verfiy Tip Count VS Change Times*)
		Fault_Tmrs[19].PT:=Short_Faults;
		Fault_Tmrs[19]();
		Fault_Tmrs[19].IN:= Out_To_ICxx.Change_Count>10;
		Out_To_ICxx.System_Faults[19]:=Fault_Tmrs[19].Q;

	(*----------------------------------------------------------------------------------- Safety Gate LOK and Latch Faults ---------------------------------------------------------*)
	(*Fault20 - Safety Gate LOK Faulted (Master Key)*)
		Fault_Tmrs[20].PT:=Short_Faults;
		Fault_Tmrs[20]();
		Fault_Tmrs[20].IN:= FALSE;
		Out_To_ICxx.System_Faults[20]:=Fault_Tmrs[20].Q;
	(*Fault21 - Safety Gate Latch#1 Faulted (Actual Door Interlock)*)
		Fault_Tmrs[21].PT:=Short_Faults;
		Fault_Tmrs[21]();
		Fault_Tmrs[21].IN:= NOT MAIN.IC01.SafetyGate_Latch_OK;
		Out_To_ICxx.System_Faults[21]:=Fault_Tmrs[21].Q;
	(*Fault22 - Safety Gate Latch#2 Faulted (Actual Door Interlock)*)
		Fault_Tmrs[22].PT:=Short_Faults;
		Fault_Tmrs[22]();
		Fault_Tmrs[22].IN:= NOT MAIN.IC03.SafetyGate_Latch_OK;
		Out_To_ICxx.System_Faults[22]:=Fault_Tmrs[22].Q;
	(*Fault23 - Safety Gate Latch#3 Faulted (Actual Door Interlock)*)
		Fault_Tmrs[23].PT:=Short_Faults;
		Fault_Tmrs[23]();
		Fault_Tmrs[23].IN:= NOT MAIN.IC02.SafetyGate_Latch_OK;
		Out_To_ICxx.System_Faults[23]:=Fault_Tmrs[23].Q;

	(*--------------------------------------------------------------------------------------------------- IC Estop Faults ---------------------------------------------------------------------*)
	(*Fault25 - Estop Pressed at IC01 OP1*)
		Fault_Tmrs[25].PT:=Short_Faults;
		Fault_Tmrs[25]();
		Fault_Tmrs[25].IN:= (GTAC_CONFIG.Option_IC_Count>=1)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.1= TRUE) AND
							NOT MAIN.IC01.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[25]:=Fault_Tmrs[25].Q;

	(*Fault26 - Estop Pressed at IC01 OP2*)
		Fault_Tmrs[26].PT:=Short_Faults;
		Fault_Tmrs[26]();
		Fault_Tmrs[26].IN:= (GTAC_CONFIG.Option_IC_Count>=1)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.2= TRUE) AND
							NOT MAIN.IC01.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[26]:=Fault_Tmrs[26].Q;

	(*Fault27 - Estop Pressed at Enable Switch, ESW01*)
		Fault_Tmrs[27].PT:=Short_Faults;
		Fault_Tmrs[27]();
		Fault_Tmrs[27].IN:= (GTAC_CONFIG.Option_ESW_Count>=1)  AND
							NOT MAIN.ESW01.EStopOK;
		Out_To_ICxx.System_Faults[27]:=Fault_Tmrs[27].Q;

	(*Fault28 - Estop Pressed at IC02 OP1*)
		Fault_Tmrs[28].PT:=Short_Faults;
		Fault_Tmrs[28]();
		Fault_Tmrs[28].IN:= (GTAC_CONFIG.Option_IC_Count>=2)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.3= TRUE) AND
							NOT MAIN.IC02.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[28]:=Fault_Tmrs[28].Q;

	(*Fault29 - Estop Pressed at IC02 OP2*)
		Fault_Tmrs[29].PT:=Short_Faults;
		Fault_Tmrs[29]();
		Fault_Tmrs[29].IN:= (GTAC_CONFIG.Option_IC_Count>=2)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.4= TRUE) AND
							NOT MAIN.IC02.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[29]:=Fault_Tmrs[29].Q;

	(*Fault30 - Estop Pressed at Enable Switch, ESW02*)
		Fault_Tmrs[30].PT:=Short_Faults;
		Fault_Tmrs[30]();
		Fault_Tmrs[30].IN:= (GTAC_CONFIG.Option_ESW_Count>=2)  AND
							NOT MAIN.ESW02.EStopOK;
		Out_To_ICxx.System_Faults[30]:=Fault_Tmrs[30].Q;

	(*Fault31 - Estop Pressed at IC03 OP1*)
		Fault_Tmrs[31].PT:=Short_Faults;
		Fault_Tmrs[31]();
		Fault_Tmrs[31].IN:= (GTAC_CONFIG.Option_IC_Count>=3)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.5= TRUE) AND
							NOT MAIN.IC03.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[31]:=Fault_Tmrs[31].Q;

	(*Fault32 - Estop Pressed at IC03 OP2*)
		Fault_Tmrs[32].PT:=Short_Faults;
		Fault_Tmrs[32]();
		Fault_Tmrs[32].IN:= (GTAC_CONFIG.Option_IC_Count>=3)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.6= TRUE) AND
							NOT MAIN.IC03.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[32]:=Fault_Tmrs[32].Q;

	(*Fault33 - Estop Pressed at Enable Switch, ESW03*)
		Fault_Tmrs[33].PT:=Short_Faults;
		Fault_Tmrs[33]();
		Fault_Tmrs[33].IN:= (GTAC_CONFIG.Option_ESW_Count>=3)  AND
							NOT MAIN.ESW03.EStopOK;
		Out_To_ICxx.System_Faults[33]:=Fault_Tmrs[33].Q;

	(*Fault34 - Estop Pressed at IC04 OP1*)
		Fault_Tmrs[34].PT:=Short_Faults;
		Fault_Tmrs[34]();
		Fault_Tmrs[34].IN:= (GTAC_CONFIG.Option_IC_Count>=4)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.7= TRUE) AND
							NOT MAIN.IC04.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[34]:=Fault_Tmrs[34].Q;

	(*Fault35 - Estop Pressed at IC04 OP2*)
		Fault_Tmrs[35].PT:=Short_Faults;
		Fault_Tmrs[35]();
		Fault_Tmrs[35].IN:= (GTAC_CONFIG.Option_IC_Count>=4)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.8= TRUE) AND
							NOT MAIN.IC04.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[35]:=Fault_Tmrs[35].Q;

	(*Fault36 - Estop Pressed at Enable Switch, ESW04*)
		Fault_Tmrs[36].PT:=Short_Faults;
		Fault_Tmrs[36]();
		Fault_Tmrs[36].IN:= (GTAC_CONFIG.Option_ESW_Count>=4)  AND
							NOT MAIN.ESW04.EStopOK;
		Out_To_ICxx.System_Faults[36]:=Fault_Tmrs[36].Q;

	(*Fault37 - Estop Pressed at IC05 OP1*)
		Fault_Tmrs[37].PT:=Short_Faults;
		Fault_Tmrs[37]();
		Fault_Tmrs[37].IN:= (GTAC_CONFIG.Option_IC_Count>=5)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.9= TRUE) AND
							NOT MAIN.IC05.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[37]:=Fault_Tmrs[37].Q;

	(*Fault38 - Estop Pressed at IC05 OP2*)
		Fault_Tmrs[38].PT:=Short_Faults;
		Fault_Tmrs[38]();
		Fault_Tmrs[38].IN:= (GTAC_CONFIG.Option_IC_Count>=5)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.10= TRUE) AND
							NOT MAIN.IC05.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[38]:=Fault_Tmrs[38].Q;

	(*Fault39 - Key Removed at Disabling Key DK01*)
		Fault_Tmrs[39].PT:=Short_Faults;
		Fault_Tmrs[39]();
		Fault_Tmrs[39].IN:= (GTAC_CONFIG.Option_ESW_Count>=1)  AND
							NOT MAIN.ESW01.Disabling_Key_OK;
		Out_To_ICxx.System_Faults[39]:=Fault_Tmrs[39].Q;

	(*Fault40 - Estop Pressed at IC06 OP1*)
		Fault_Tmrs[40].PT:=Short_Faults;
		Fault_Tmrs[40]();
		Fault_Tmrs[40].IN:= (GTAC_CONFIG.Option_IC_Count>=6)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.11= TRUE) AND
							NOT MAIN.IC06.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[40]:=Fault_Tmrs[40].Q;

	(*Fault41 - Estop Pressed at IC06 OP2*)
		Fault_Tmrs[41].PT:=Short_Faults;
		Fault_Tmrs[41]();
		Fault_Tmrs[41].IN:= (GTAC_CONFIG.Option_IC_Count>=6)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.12= TRUE) AND
							NOT MAIN.IC06.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[41]:=Fault_Tmrs[41].Q;

	(*Fault42 - Key Removed at Disabling Key DK02*)
		Fault_Tmrs[42].PT:=Short_Faults;
		Fault_Tmrs[42]();
		Fault_Tmrs[42].IN:= (GTAC_CONFIG.Option_ESW_Count>=2)  AND
							NOT MAIN.ESW02.Disabling_Key_OK;
		Out_To_ICxx.System_Faults[42]:=Fault_Tmrs[42].Q;

	(*Fault43 - Estop Pressed at IC07 OP1*)
		Fault_Tmrs[43].PT:=Short_Faults;
		Fault_Tmrs[43]();
		Fault_Tmrs[43].IN:= (GTAC_CONFIG.Option_IC_Count>=7)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.13= TRUE) AND
							NOT MAIN.IC07.OP1_Estop_OK;
		Out_To_ICxx.System_Faults[43]:=Fault_Tmrs[43].Q;

	(*Fault44 - Estop Pressed at IC07 OP2*)
		Fault_Tmrs[44].PT:=Short_Faults;
		Fault_Tmrs[44]();
		Fault_Tmrs[44].IN:= (GTAC_CONFIG.Option_IC_Count>=7)  AND
							(GTAC_CONFIG.Option_HumanFix_Enables.14= TRUE) AND
							NOT MAIN.IC07.OP2_Estop_OK;
		Out_To_ICxx.System_Faults[44]:=Fault_Tmrs[44].Q;

	(*Fault45 - Key Removed at Disabling Key DK03*)
		Fault_Tmrs[45].PT:=Short_Faults;
		Fault_Tmrs[45]();
		Fault_Tmrs[45].IN:= (GTAC_CONFIG.Option_ESW_Count>=3)  AND
							NOT MAIN.ESW03.Disabling_Key_OK;
		Out_To_ICxx.System_Faults[45]:=Fault_Tmrs[45].Q;

	(*Fault56 - Estop Pressed at IC08 OP1*)
		Fault_Tmrs[46].PT:=Short_Faults;
		Fault_Tmrs[46]();
		Fault_Tmrs[46].IN:= (GTAC_CONFIG.Option_IC_Count>=8)  AND
