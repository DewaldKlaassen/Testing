(*Gather Flags to Generate UI Prompting on Controls Button that links to Controls Menu*)
	General_Controls_Fault:=
		(*Configuration Fault*)
		Out_To_ICxx.System_Faults[0]
		(*Flags Generated Above*)
		OR (Out_To_ICxx.ICxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.Rxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.ISxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.STxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.SLxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.NWxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.MISCxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.SDxx_UI_FaultPrompts<>0)
		OR (Out_To_ICxx.VFDxx_UI_FaultPrompts<>0)
		(*Internal Fixture Ecat Faults*)
		OR Out_To_ICxx.System_Faults[617]
		OR Out_To_ICxx.System_Faults[618]
		OR Out_To_ICxx.System_Faults[619]
		OR Out_To_ICxx.System_Faults[620]
		OR Out_To_ICxx.System_Faults[621]
		OR Out_To_ICxx.System_Faults[622]
		OR Out_To_ICxx.System_Faults[623]
		OR Out_To_ICxx.System_Faults[624]
		OR Out_To_ICxx.System_Faults[625]
		OR Out_To_ICxx.System_Faults[626]
		OR Out_To_ICxx.System_Faults[627]
		OR Out_To_ICxx.System_Faults[628];


(*!!!!!!!!!!!!!!!!!!!!!!!! Check Each Fault to Check Status and Develop Major and Minor Fault Flags As a Result If Fault Exsists !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
(*!!!!!!!!!!!!!!!!!!!!!!!! Check Each Fault to Check Status and Develop Major and Minor Fault Flags As a Result If Fault Exsists !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
(*!!!!!!!!!!!!!!!!!!!!!!!! Check Each Fault to Check Status and Develop Major and Minor Fault Flags As a Result If Fault Exsists !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)

(*Check Major Faults*)
FOR Loop_Index_Major:= 0 TO 990 DO
	IF (Loop_Index_Major>=0) AND (Loop_Index_Major<991) (*Ensure to check bounds to not run out of Array*)
		THEN System_Major_Fault:= Out_To_ICxx.System_Faults[Loop_Index_Major];
		IF System_Major_Fault
			THEN EXIT; (*Exit Loop upon first Fault Flagged*)
		END_IF;
	END_IF;
END_FOR;


(*Check Minor Faults*)
FOR Loop_Index_Minor:= 991 TO 1639 DO
	IF (Loop_Index_Minor>=991) AND (Loop_Index_Minor<1640) (*Ensure to check bounds to not run out of Array*)
		THEN System_Minor_Fault:= Out_To_ICxx.System_Faults[Loop_Index_Minor];
		IF System_Minor_Fault
			THEN EXIT; (*Exit Loop upon first Fault Flagged*)
		END_IF;
	END_IF;
END_FOR;







