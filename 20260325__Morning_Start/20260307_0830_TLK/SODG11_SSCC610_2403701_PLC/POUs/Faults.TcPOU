	(*------------------- IC01 -----------------*)
	(*Fault991 - IC01OP1 Motion Faults*)
		Fault_Tmrs[991].PT:=Short_Faults;
		Fault_Tmrs[991]();
		Fault_Tmrs[991].IN:= GTAC_CONFIG.Option_HumanFix_Enables.1 AND
							Out_To_ICxx.Fix01_Discrete_Image.CLFaulted.0;
		Out_To_ICxx.System_Faults[991]:=Fault_Tmrs[991].Q;
	(*Fault992 - IC01OP1 Part Present Faults*)
		Fault_Tmrs[992].PT:=Short_Faults;
		Fault_Tmrs[992]();
		Fault_Tmrs[992].IN:= GTAC_CONFIG.Option_HumanFix_Enables.1 AND
							Out_To_ICxx.Fix01_Discrete_Image.PPFaulted.0;
		Out_To_ICxx.System_Faults[992]:=Fault_Tmrs[992].Q;
	(*Fault993 - IC01OP1 Vertical LC Broken While Robot(s) In Zone*)
		VLC_Capture11_TOF.PT:= T#2.0S;
		VLC_Capture11_TOF();
		(*Differentiate between Turtable type Fix01/02 and standard Fix01*)
		(*Turntable Type*)
		IF (MAIN.R1.FB_In.Robot_Type = KUKA_KRC4_SAFEOP_TurnTable) THEN
		VLC_Capture11_TOF.IN:= (GTAC_CONFIG.Option_IC_Count>=1) AND GTAC_CONFIG.Option_HumanFix_Enables.1 AND
								NOT MAIN.IC01.OP1_HumanVertLC_Clear AND NOT Fix01.All_Robots_Clear
								AND (Fix01.Turntable_WorkingOK OR Fix02.Turntable_WorkingOK);
		(*Standard Type*)						
		ELSE
		VLC_Capture11_TOF.IN:= (GTAC_CONFIG.Option_IC_Count>=1) AND GTAC_CONFIG.Option_HumanFix_Enables.1 AND
								NOT MAIN.IC01.OP1_HumanVertLC_Clear AND NOT Fix01.All_Robots_Clear;
		END_IF
		Out_To_ICxx.System_Faults[993]:= VLC_Capture11_TOF.Q;
	(*Fault994 - IC01OP1 Horizontal LC Broken While Robot(s) In Zone*)
		HLC_Capture12_TOF.PT:= T#2.0S;
		HLC_Capture12_TOF();
		(*Differentiate between Turtable type Fix01/02 and standard Fix01*)
		(*Turntable Type*)
		IF (MAIN.R1.FB_In.Robot_Type = KUKA_KRC4_SAFEOP_TurnTable) THEN
		HLC_Capture12_TOF.IN:= (GTAC_CONFIG.Option_IC_Count>=1) AND GTAC_CONFIG.Option_HumanFix_Enables.1 AND
								NOT MAIN.IC01.OP1_HumanHorizLC_Clear AND NOT Fix01.All_Robots_Clear
								AND (Fix01.Turntable_WorkingOK OR Fix02.Turntable_WorkingOK);
		(*Standard Type*)						
		ELSE
		HLC_Capture12_TOF.IN:= (GTAC_CONFIG.Option_IC_Count>=1) AND GTAC_CONFIG.Option_HumanFix_Enables.1 AND
								NOT MAIN.IC01.OP1_HumanHorizLC_Clear AND NOT Fix01.All_Robots_Clear;
		END_IF
		Out_To_ICxx.System_Faults[994]:= HLC_Capture12_TOF.Q;
	(*Fault995 - IC01OP1 Horizontal LC3 Broken While Robot(s) In Zone*)
		HLC_Capture13_TOF.PT:= T#2.0S;
		HLC_Capture13_TOF();
		(*Differentiate between Turtable type Fix01/02 and standard Fix01*)
