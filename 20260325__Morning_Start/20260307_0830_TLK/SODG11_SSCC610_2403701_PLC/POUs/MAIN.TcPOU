		R2.FB_In.AuxReq_Ack:= R2_Data.AuxReq_Ack[R2.Location_Index];
		R2.FB_In.User_Inputs.0:= R1.User_Outputs.0;
		R2.FB_In.User_Inputs.1:= FALSE;
		R2.FB_In.User_Inputs.2:= R1.User_Outputs.2;
		R2.FB_In.User_Inputs.3:= R1.User_Outputs.3;
		R2.FB_In.User_Inputs.4:= FALSE;
		R2.FB_In.User_Inputs.5:= FALSE;
		R2.FB_In.User_Inputs.6:= FALSE;
		R2.FB_In.User_Inputs.7:= FALSE;
			(*Configure Options Amounts*)
			R2.FB_In.Options.WeldCont_Amount:=0; 					(*Select amount of Spot Type Weld Controllers here (0 min, 4 max)*)
			R2.FB_In.Options.WaterStand_Amount:= 0;				(*Select amount of Water Stands here (0 min, 2 max)*)
			R2.FB_In.Options.MIGCont_Amount:= 1;					(*Select amount of MIG Type Weld Controllers here (0 min, 1 max)*)
			R2.FB_In.Options.Reamer_Amount:= 1;					(*Select amount of Tip Reamers here (0 min, 1 max)*)
			R2.FB_In.Options.EOAT_Amount:= 0;						(*Assign EOAT number to robot (0 min, 10 max)*)
			(*Configure Options Parameters*)

			R2.Reamer[1](
				(*FB Inputs*)
					Enable_Motion:= All_Estops_OK,
					Fronius_Ream:= TRUE,
                    Binzel_Ream:= FALSE,  (*optional*)
					
					Ream_REQ:= R2.Peripheral_Req.1 AND ((R2.Task_ID_Ack=Tip_Dress)OR (R2.In_T1 AND R2.Peripheral_Req.5)),
					Ream_Time:= T#2S,
					Ream_Clamp_Open:= R2.Reamer[1].N01.I.1,
					Spray_REQ:= R2.Peripheral_Req.2 AND ((R2.Task_ID_Ack=Tip_Dress)OR (R2.In_T1 AND R2.Peripheral_Req.5)),
					Spray_Time:= T#2S,
					F_WireCutter_REQ:= R2.Peripheral_Req.4 AND ((R2.Task_ID_Ack=Tip_Dress)OR (R2.In_T1 AND R2.Peripheral_Req.5)),
					F_WireCutter_Time:= T#1S,
					
				(*FB Outputs*)
					Reaming_Complete=> ,(*mapped in cell services*)
					(*The following are for Binzel type reamers only*)
					LifterUp_ACK=> , (*mapped in cell services*)
					Clamp_ACK=>,(*mapped in cell services*)
					Injector_ACK=> ,(*mapped in cell services*)
					WireCutter_ACK=> (*mapped in cell services*)
					);
			
			(*R2.Reamer[1](
