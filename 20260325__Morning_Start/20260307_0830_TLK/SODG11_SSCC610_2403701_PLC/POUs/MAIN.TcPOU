		R11.FB_In.Install_Zero_Orientation:= 0; 	(*Set this value between 0 and 359 to set the zero position of the robot physical install with reference to 12 o'clock symbol on UI screens*)
		R11.FB_In.Under_Construction:= GTAC_CONFIG.Under_Construction;
		R11.FB_In.In_SIM_Mode:= GTAC_CONFIG.In_SIM_Mode;
		R11.FB_In.SIM_StartWorkAround:= FALSE;  (*Main.SIM_WorkAround_StartRobots*)
		R11.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_Robot_Count>=11) AND Pulse_CoERead;
		R11.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
		R11.FB_In.Prev_EcatNode_Present:= NOT R10.EK1100_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
		R11.FB_In.Safety_RST:=SAFETY_RESET;
		R11.FB_In.Enable_Motion:= All_Estops_OK OR GTAC_CONFIG.Under_Construction;
		R11.FB_In.Alarm_RST:=In_From_ICxx.ControlPower1;
		R11.FB_In.Select_Play:=FALSE;
		R11.FB_In.Select_Teach:=FALSE;
		R11.FB_In.Select_Remote:=FALSE;
		R11.FB_In.Start_Scan:=In_From_ICxx.StartRobots;
		R11.FB_In.Stop_Scan:=In_From_ICxx.StopRobots;
		R11.FB_In.Stop_Scan2:=FALSE;
		R11.FB_In.In_DryCycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
		R11.FB_In.Low_Speed:= GTAC_CONFIG.Low_Speed_Enabled;
		R11.FB_In.Speed_Request:= In_From_ICxx.Global_Robot_Speed;
		R11.FB_In.Force_MasterTest_Req:= Cell_Services_Prog.Human_Reqs_MasterTest OR Cell_Services_Prog.A_Robot_Reqs_MasterTest;
		R11.FB_In.Force_BrakeTest_Req:= Cell_Services_Prog.Human_Reqs_BrakeTest OR Cell_Services_Prog.A_Robot_Reqs_BrakeTest;
		R11.FB_In.Major_Faults:= Faults.System_Major_Fault;
		R11.FB_In.Teach_Interlock:=R11_Data.Teach_Interlock;
		R11.FB_In.Weld_Inhibit:=In_From_ICxx.Rxx_Weld_Inhibit;
		R11.FB_In.Option_Disable_WaterFLT:= FALSE AND GTAC_CONFIG.Under_Construction OR (MAIN.R11.Task_ID_Ack=Tip_Change_EXT); (*Used to disable water fault if no water is present. use with caution*)
		R11.FB_In.OK_ToEnter_EquipInterf1:=R11_Data.OK_ToEnter_EquipInterf1;
		R11.FB_In.OK_ToEnter_EquipInterf2:=R11_Data.OK_ToEnter_EquipInterf2;
		R11.FB_In.OK_ToEnter_EquipInterf3:=R11_Data.OK_ToEnter_EquipInterf3;
		R11.FB_In.OK_ToEnter_EquipInterf4:=R11_Data.OK_ToEnter_EquipInterf4;
		R11.FB_In.OK_ToEnter_EquipInterf5:=R11_Data.OK_ToEnter_EquipInterf5;
		R11.FB_In.OK_ToEnter_EquipInterf6:=R11_Data.OK_ToEnter_EquipInterf6;
		R11.FB_In.OK_ToEnter_EquipInterf7:=R11_Data.OK_ToEnter_EquipInterf7;
		R11.FB_In.OK_ToEnter_EquipInterf8:=R11_Data.OK_ToEnter_EquipInterf8;
		R11.FB_In.OK_ToEnter_EquipInterf9:=R11_Data.OK_ToEnter_EquipInterf9;
		R11.FB_In.OK_ToEnter_HumanInterf1:=R11_Data.OK_ToEnter_HumanInterf1;
		R11.FB_In.OK_ToEnter_HumanInterf2:=R11_Data.OK_ToEnter_HumanInterf2;
		R11.FB_In.OK_ToEnter_HumanInterf3:=R11_Data.OK_ToEnter_HumanInterf3;
		R11.FB_In.OK_ToEnter_HumanInterf4:=R11_Data.OK_ToEnter_HumanInterf4;
		R11.FB_In.OK_ToEnter_HumanInterf5:=R11_Data.OK_ToEnter_HumanInterf5;
		R11.FB_In.OK_ToEnter_HumanInterf6:=R11_Data.OK_ToEnter_HumanInterf6;
		R11.FB_In.OK_ToEnter_HumanInterf7:=R11_Data.OK_ToEnter_HumanInterf7;
		R11.FB_In.OK_ToEnter_HumanInterf8:=R11_Data.OK_ToEnter_HumanInterf8;
		R11.FB_In.OK_ToEnter_RobotInterfs:= R11_Data.OK_ToEnter_RobotInterfs;
		R11.FB_In.Fix_ID:=R11_Data.Fix_ID[R11.Location_Index];
		R11.FB_In.Model_ID:=R11_Data.Model_ID[R11.Location_Index];
		R11.FB_In.Task_ID:=R11_Data.Task_ID[R11.Location_Index];
		R11.FB_In.Proceed_From_Pounce:=R11_Data.Proceed_From_Pounce[R11.Location_Index];
		R11.FB_In.Complete_Ack:=R11_Data.Complete_Ack[R11.Location_Index];
		R11.FB_In.PeripheralReq_Ack:=R11_Data.PeripheralReq_Ack[R11.Location_Index];
		R11.FB_In.AuxReq_Ack:=R11_Data.AuxReq_Ack[R11.Location_Index];
		R11.FB_In.User_Inputs.0:= FALSE;
		R11.FB_In.User_Inputs.1:= FALSE;
		R11.FB_In.User_Inputs.2:= FALSE;
		R11.FB_In.User_Inputs.3:= FALSE;
		R11.FB_In.User_Inputs.4:= FALSE;
		R11.FB_In.User_Inputs.5:= FALSE;
		R11.FB_In.User_Inputs.6:= FALSE;
		R11.FB_In.User_Inputs.7:= FALSE;
			(*Configure Options Amounts*)
			R11.FB_In.Options.WeldCont_Amount:= 0; 					(*Select amount of Spot Type Weld Controllers here (0 min, 4 max)*)
			R11.FB_In.Options.WaterStand_Amount:= 0;				(*Select amount of Water Stands here (0 min, 2 max)*)
			R11.FB_In.Options.MIGCont_Amount:= 1;					(*Select amount of MIG Type Weld Controllers here (0 min, 1 max)*)
			R11.FB_In.Options.Reamer_Amount:= 1;					(*Select amount of Tip Reamers here (0 min, 1 max)*)
			R11.FB_In.Options.EOAT_Amount:= 0;					(*Assign EOAT number to robot (0 min, 10 max)*)
			(*Configure Options Parameters*)
			(*R11.Reamer[1](
				(*FB Inputs*)
					Enable_Motion:= All_Estops_OK,
					Fronius_Ream:= TRUE,
                    Binzel_Ream:= FALSE,  (*optional*)
					Ream_REQ:= R11.Peripheral_Req.5 AND (R11.Task_ID_Ack=Tip_Dress),

				(*FB Outputs*)
					Reaming_Complete=> ,(*mapped in cell services*)
					);*)
		(*Call Actual Object*)
		R11();
		(*Output Data*)
		Out_To_ICxx.Robot[11].Robot_Type:= R11.FB_In.Robot_Type;
		(*To create less work, since there is no welding, changeing this number to 307 so we dont have to mess with the kuka FB, just screens. "us_Rxx_Status" - added 307 "inspecting"*)
		IF (R11.Status = 305) THEN
		Out_To_ICxx.Robot[11].Status:= 307; 
		ELSE
		Out_To_ICxx.Robot[11].Status:= R11.Status;
		END_IF
		Out_To_ICxx.Robot[11].Axis_Data[1]:= R11.S_Axis_Pos_Raw;
		Out_To_ICxx.Robot[11].In_Image:= R11.Input_Image;
		Out_To_ICxx.Robot[11].Out_Image:= R11.Output_Image;
		Out_To_ICxx.Robot[11].Discrete_ImageFSOE:= R11.Discrete_Image_FSoE;
		Out_To_ICxx.Robot[11].Options:= R11.FB_In.Options;
			Out_To_ICxx.Robot[11].WS_Discrete_Image[1]:= R11.WS[1].Discrete_Image;
			Out_To_ICxx.Robot[11].WS_Discrete_Image[2]:= R11.WS[2].Discrete_Image;
 			Out_To_ICxx.Robot[11].ATI_Discrete_Image:= R11.ATI[1].Discrete_Image;
			Out_To_ICxx.Robot[11].Reamer_Discrete_Image:= R11.Reamer[1].Discrete_Image;
			Out_To_ICxx.Robot[11].Fronius_Status:= R11.Fronius_Status;
		Out_To_ICxx.Robot[11].Ped_IO_ToShow[1]:= 0;			(*Set to Ped value if this robots ecat string contains the Ped's IO*)
		Out_To_ICxx.Robot[11].Ped_IO_ToShow[2]:= 0;			(*Set to Ped value if this robots ecat string contains the Ped's IO*)
		Out_To_ICxx.Robot[11].ECAT_Cable_Breaks:= R11.ECatSlave_Cable_Breaks;
		Out_To_ICxx.Robot[11].CT:= R11.CT;























(*end*)]]></ST>
      </Implementation>
    </Action>
