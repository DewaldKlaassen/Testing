		R1.FB_In.Stop_Scan2:=FALSE;
		R1.FB_In.In_DryCycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
		R1.FB_In.Low_Speed:= GTAC_CONFIG.Low_Speed_Enabled;
		R1.FB_In.Speed_Request:= In_From_ICxx.Global_Robot_Speed;
		R1.FB_In.Force_MasterTest_Req:= Cell_Services_Prog.Human_Reqs_MasterTest OR Cell_Services_Prog.A_Robot_Reqs_MasterTest;
		R1.FB_In.Force_BrakeTest_Req:= Cell_Services_Prog.Human_Reqs_BrakeTest OR Cell_Services_Prog.A_Robot_Reqs_BrakeTest;
		R1.FB_In.Major_Faults:= Faults.System_Major_Fault;
		R1.FB_In.Teach_Interlock:=R1_Data.Teach_Interlock;
		R1.FB_In.Weld_Inhibit:=In_From_ICxx.Rxx_Weld_Inhibit;
		R1.FB_In.Option_Disable_WaterFLT:= FALSE AND GTAC_CONFIG.Under_Construction OR (MAIN.R1.Task_ID_Ack=Tip_Change_EXT); (*Used to disable water fault if no water is present. use with caution*)
		R1.FB_In.OK_ToEnter_EquipInterf1:=R1_Data.OK_ToEnter_EquipInterf1;
		R1.FB_In.OK_ToEnter_EquipInterf2:=R1_Data.OK_ToEnter_EquipInterf2;
