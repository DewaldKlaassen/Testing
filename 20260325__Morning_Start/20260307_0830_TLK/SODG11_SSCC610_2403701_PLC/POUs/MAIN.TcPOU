    <Implementation>
      <ST><![CDATA[(*Develop 5.0ms Pulse for Reseting System During Boot-Up*)
	Starting_Scan_PulseTMR.PT:= T#5MS;
	Starting_Scan_PulseTMR.IN:= TRUE;
	Starting_Scan_PulseTMR();
	Starting_Scan_Pulse:= NOT Starting_Scan_PulseTMR.Q;

(*Send Mother Board Status, Task Data and Application Data to UI*)
	Out_To_ICxx.Appdata:= _AppInfo;
	Out_To_ICxx.TaskData:= _TaskInfo[1];
	
	(*Call TC3 required HW diag FB (not previouslly required in TC2)*)
	HardwareStat();
	Out_To_ICxx.MboardData:= HardwareStat.HardwareDiag;		

	
(*EtherCAT Master*)
	(*Inputs*)
	ECAT_Master.Blank_Config_Trigger:= Starting_Scan_Pulse;	 																(*Upon first start, blank config array*)
	ECAT_Master.Read_Config_Trigger:= NOT Starting_Scan_Pulse AND Pulse_CoERead AND NOT Out_To_ICxx.ControlPower1_OK;		(*When machine is past first scan, read config (except if runnng)*)
	ECAT_Master.Read_States_Trigger:= NOT Starting_Scan_Pulse AND Pulse_1S;
	ECAT_Master.Machine_Running:= Out_To_ICxx.ControlPower1_OK;									(*Stop Config Reads when Machne is ready to run*)
		(*Overrides may be placed immediatly after components automatically found in EtherCAT configuration
		the overrides are used to force display of Components created manually in the UIs but are not part of the standard set
		of components coded in the EtherCAT Master FB*)
		ECAT_Master.ComponentConfig_Overrides[41]:='SL01';
		ECAT_Master.ComponentConfig_Overrides[42]:='SL02';
		ECAT_Master.ComponentConfig_Overrides[43]:='SL03';
		ECAT_Master.ComponentConfig_Overrides[44]:='SL04';
		ECAT_Master.ComponentConfig_Overrides[45]:='LSR01';		
		ECAT_Master.ComponentConfig_Overrides[46]:='LSR02';		
	(*Actual Call*)
	ECAT_Master();
	(*Outputs*)
	(*Send Ecat Master Status to UIs*)
	Out_To_ICxx.EtherCat_Master_Image:= ECAT_Master.Discrete_Image;



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ The Main Progam $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*--------------------------------------------------------------------------------------- GTAC CONFIG -----------------------------------------------------------------------------------------------*)
	(*Run the Config to retreive Data for Code Re-action*)
	GTAC_CONFIG();

		Out_To_ICxx.Machine_Serial:= GTAC_CONFIG.Machine_Serial;
		Out_To_ICxx.Machine_Common_Name:= GTAC_CONFIG.Machine_Common_Name;
		Out_To_ICxx.Machine_Build_Used:= GTAC_Config.Machine_Build_Used;
		Out_To_ICxx.Machine_Appl_Dev:= GTAC_Config.Machine_Appl_Dev;
		(*Production Related Configuration Data to UI*)
		Out_To_ICxx.ProdConfig_Target_CycleTime:= GTAC_CONFIG.ProdConfig_Target_CycleTime;
		Out_To_ICxx.ProdConfig_Common:= GTAC_CONFIG.ProdConfig_Common;
		Out_To_ICxx.ProdConfig_Day:= FUN_GTAC_TODtoUDINT(GTAC_CONFIG.ProdConfig_Day);
		Out_To_ICxx.ProdConfig_Aft:= FUN_GTAC_TODtoUDINT(GTAC_CONFIG.ProdConfig_Aft);
		Out_To_ICxx.ProdConfig_Mid:= FUN_GTAC_TODtoUDINT(GTAC_CONFIG.ProdConfig_Mid);
		(*Machine Related Configuration Data to UI*)
		Out_To_ICxx.Option_Air1:= GTAC_CONFIG.Option_Air1;
		Out_To_ICxx.Option_Air2:= GTAC_CONFIG.Option_Air2;
		Out_To_ICxx.Option_Water1:= GTAC_CONFIG.Option_Water1;
		Out_To_ICxx.Option_Water2:= GTAC_CONFIG.Option_Water2;
		Out_To_ICxx.Option_WaterTimeOut_Enable:= GTAC_CONFIG.Option_WaterTimeOut_Enable;
		Out_To_ICxx.Option_WaterFlowTimeOut_SP:= GTAC_CONFIG.Option_WaterFlowTimeOut_SP;
		Out_To_ICxx.Option_WaterTempHighLimit1:= GTAC_CONFIG.Option_WaterTempHighLimit1;
		Out_To_ICxx.Option_WaterTempHighLimit2:= GTAC_CONFIG.Option_WaterTempHighLimit2;
		Out_To_ICxx.Option_WaterFlowLowLimit1:= GTAC_CONFIG.Option_WaterFlowLowLimit1;
		Out_To_ICxx.Option_WaterFlowLowLimit2:= GTAC_CONFIG.Option_WaterFlowLowLimit2;
		Out_To_ICxx.Option_ESW_Count:= GTAC_CONFIG.Option_ESW_Count;
		Out_To_ICxx.Option_MD_Count:= GTAC_CONFIG.Option_MD_Count;
		Out_To_ICxx.Option_IS_Count:= GTAC_CONFIG.Option_IS_Count;
		Out_To_ICxx.Option_IC_Count:= GTAC_CONFIG.Option_IC_Count;
		Out_To_ICxx.Option_HumanFix_Enables:= GTAC_CONFIG.Option_HumanFix_Enables;
		Out_To_ICxx.Option_InternalFix_Count:= GTAC_CONFIG.Option_InternalFix_Count;
		Out_To_ICxx.Option_Robot_Count:= GTAC_CONFIG.Option_Robot_Count;
		Out_To_ICxx.Option_Ped_Count:= GTAC_CONFIG.Option_Ped_Count;
		Out_To_ICxx.Option_SealController_Count:= GTAC_CONFIG.Option_SealController_Count;
		Out_To_ICxx.Option_StudController_Count:= GTAC_CONFIG.Option_StudController_Count;
		Out_To_ICxx.Option_NutWelder_Count:= GTAC_CONFIG.Option_NutWelder_Count;
		Out_To_ICxx.Option_SD_Count:= GTAC_CONFIG.Option_SD_Count;
		Out_To_ICxx.Option_VFD_Count:= GTAC_CONFIG.Option_VFD_Count;
		Out_To_ICxx.Config_Fault:= GTAC_CONFIG.Fault;

		(*Various Development States to UI*)
		Out_To_ICxx.InDryCycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
		IF NOT GTAC_CONFIG.Dry_Cycle_Enabled
			THEN
			Out_To_ICxx.In_Local_DryCycle:= GTAC_CONFIG.Local_DryCycle_Enables;
		ELSIF GTAC_CONFIG.Dry_Cycle_Enabled
			THEN
			Out_To_ICxx.In_Local_DryCycle:= 131070;		(*Set Bits .1 through .16 high to annunciate dry cycle on those tools*)
		END_IF;

		Out_To_ICxx.In_Low_Speed:=GTAC_CONFIG.Low_Speed_Enabled;
		Out_To_ICxx.Under_Construction:= GTAC_CONFIG.Under_Construction;
		Out_To_ICxx.In_Sim_Mode:= GTAC_CONFIG.In_SIM_Mode;
		Out_To_ICxx.CycleHold_OK:=  In_From_ICxx.Cycle_Hold;

		(*This Overrides the T1 zone disable so robot programmers can verify the monitoring space dimensions*)
		Safety_Zone_Test:= In_From_ICxx.T1_Zone_Test;
		Out_To_ICxx.T1_Zone_Test_ACK:= Safety_Zone_Test;

(*----------------------------------------------------------------------------- Main Status Of Machine Control Power-------------------------------------------------------------------------*)
	(*Estops*)
	Out_To_ICxx.Estops_OK:= All_Estops_OK; (*All_Estops_OK is a linked var in System Manager and is to be linked to Output of TwinSAFE FB in IC01 Called "Gather All Estops" (FB20)*)

	(*!!!All_EstopRLYs_Off is left to configure at Application Deployment time and not auto configured by GTAC Options!!!*)
	All_EstopRLYs_Off:=
						IS01.Estop_Relays_Off AND
						SS01.Valves_Off AND
						R1.Estop_Relays_Off AND R2.Estop_Relays_Off AND
						R3.Estop_Relays_Off AND R4.Estop_Relays_Off AND
						R5.Estop_Relays_Off AND R6.Estop_Relays_Off AND
						R7.Estop_Relays_Off AND R8.Estop_Relays_Off AND
						R9.Estop_Relays_Off AND R10.Estop_Relays_Off AND
						R11.Estop_Relays_Off;


	(*Safety Gates*)
	IC01.FB_In.Output_Req1:= In_From_ICxx.LockSGK1;
	Out_To_ICxx.Safety_Gates_OK:= All_SafetyGates_OK; (*All_SafetyGates_OK is a linked var in System Manager and is to be linked to Output of TwinSAFE FB in IC01 Called "Gather All Gates (FB35)*)

	(*OverAll Control Power Status*)
	Control_Power_ON:= All_Estops_Ok AND All_SafetyGates_OK AND
						((IS01.Estop_Relays_On AND IS01.Gate_Relays_On) OR GTAC_CONFIG.Option_IS_Count<1);

	Out_To_ICxx.ControlPower1_OK:= Control_Power_ON;

(*------------------------------------------------------------------------ Develop Safety Reset ---------------------------------------------------------------------------------------------------*)

	IF All_Estops_OK
		THEN
			SAFETY_RESET:= In_From_ICxx.ControlPower1;
	ELSIF NOT All_Estops_Ok AND All_EstopRLYs_Off
		THEN
			SAFETY_RESET:= In_From_ICxx.ControlPower1;                               (*Ensure no Estop Relays Are Stuck In On Position*)
	END_IF (*NOTE*)

(*!!!!!!!!!! use this to do the first reset !!!!!!!!!!!!!!!!!!*)
	SAFETY_RESET;

(*
NOTE - You should note that this is the one and only location that the semi colon is NOT used to close a conditional block of code.
That should lead you to note that the TCAT compiler will accept both cases (with and without semi colon closure).
So, which is more correct? There are two frames of thought:
	1. The semi is used to close every other piece of code outside of conditional statement blocks, therefore, for consistency, the semi is correct.
		Also, most documents pertaining to ST show the semi in place, offering more validity to the consistency argument.
		The semi was also required in legacy compilers such as Turbo Pascal, so the semi at the end of conditional code blocks also has historical value. 
	2. Syntactically, the semi is not required by the compiler. A semi found in this position by the compiler results in no actual CPU instruction generation so it's simply
		one more line the compiler must scan and "throw away".  So if we don't want to use it from a syntax perspective, then we should not be using it on any closure of a conditional
		block of code for consistency sake. However, please keep in mind that a semi not found in other places will be considered an error.
		So, if consistency is to be our driving force then, from a global syntax point of view, a semi is more valid as all other lines of code require semi closure (IE digression to point 1).
		So the only reason left is to avoid extra compiler load, which does hold some value. 
		However, I timed the compiler both with and without the semi and found no real difference (accurate to maybe +- 1  sec).

In this case both answers have some merit in "correctness". 
However I believe the argument clearly favors the points brought up in frame of thought 1.
The real value of this note is to spark an idea of digging deeper to find out the truth behind things and always ask "WHY".
Kudos to anyone who actually noticed the "semi colon paradox"
*)


	
(*------------------------------------------------------------------------- General Status Of Robots Within Machine -----------------------------------------------------------------------*)
	All_RobotsReady_Running:= (R1.Ready AND R1.Operating AND NOT R1.Faulted) AND
								(R2.Ready AND R2.Operating AND NOT R2.Faulted) AND
								(R3.Ready AND R3.Operating AND NOT R3.Faulted) AND
								(R4.Ready AND R4.Operating AND NOT R4.Faulted) AND
								(R5.Ready AND R5.Operating AND NOT R5.Faulted) AND
								(R6.Ready AND R6.Operating AND NOT R6.Faulted) AND
								(R7.Ready AND R7.Operating AND NOT R7.Faulted) AND
								(R8.Ready AND R8.Operating AND NOT R8.Faulted) AND
								(R9.Ready AND R9.Operating AND NOT R9.Faulted) AND
								(R10.Ready AND R10.Operating AND NOT R10.Faulted) AND
								(R11.Ready AND R11.Operating AND NOT R11.Faulted);


(*---------------------------------------------------------------------------------- Some General Purpose Code -------------------------------------------------------------------------------*)
	(*Pulse Generators*)
		(*1 Second On and Off Time*)
		Pulse_1S_FB.On_Time:=T#1.0S;
		Pulse_1S_FB.Off_Time:=T#1.0S;
		Pulse_1S_FB();
		Pulse_1S:=Pulse_1S_FB.Wave;
		(*0.5 Second On and Off Time*)
		Pulse_500ms_FB.On_Time:=T#500MS;
		Pulse_500ms_FB.Off_Time:=T#500MS;
		Pulse_500ms_FB();
		Pulse_500ms:=Pulse_500ms_FB.Wave;
		(*Pulse to Set Interval of CoE Reads*)
		Pulse_CoERead_FB.On_Time:=T#1S;
		Pulse_CoERead_FB.Off_Time:=T#30S;
		Pulse_CoERead_FB();
		Pulse_CoERead:=Pulse_CoERead_FB.Wave;

		(*Status Of PLC Running to UI (User Interface) "PLC Running" Indicator on all UI "IC01 Controls Overview" Screens*)
		Out_To_ICxx.Spare1:= TRUE;

(*--------------------------------------------------------------------------- Call Programs ---------------------------------------------------------------*)
(*Get Windows Time From Local Machine for Generating Production Report Frame Work*)
	Get_LocalMachine_TimeFB.START:= Pulse_500mS;
	Get_LocalMachine_TimeFB();
	Local_Time:= Get_LocalMachine_TimeFB.TIMESTR;

(*Call Fault Routine*)
	Faults();
	Out_To_ICxx.Faults_OK:= NOT Faults.System_Major_Fault; 					(*Pass Status to UI to drive Fault Warning Icon on General Status Object*)
	Out_To_ICxx.Overall_Controls_Fault.0:= Faults.General_Controls_Fault; 	(*Pass Status to UI to drive Red Flashing Prompt on Controls Icon*)
	
(*Call Robot InterLock_Map*)
	Robot_InterLock_Map();
(*Generate Task_ID Record*)
	Task_ID_Record();
(*Cell Services (Master Test, Brake Test, Tip Change, Tip Dress)*)
	(*Input Data*)
	Cell_Services_Prog.Enable_Motion:= All_Estops_OK;
	Cell_Services_Prog.Discrete_In.ModelData:= 1; (*Override to have single point selection*)
	Cell_Services_Prog.Discrete_In.ResetProd:= In_From_ICxx.Reset_ChangeCount;
	(*Call PROGRAM*)
	Cell_Services_Prog();
	(*Output Data*)
	Out_To_ICxx.MasterTest_Req_OK:= Cell_Services_Prog.Start_All_MTRobots;
	Out_To_ICxx.BrakeTest_Req_OK:= Cell_Services_Prog.Start_All_BTRobots;
	Out_To_ICxx.TipChangeReq_OK:= Cell_Services_Prog.Start_All_TCRobots;
	//Out_To_ICxx.Change_Count:= Cell_Services_Prog.Prod_Count_Out;
	Out_To_ICxx.Rxx_ReadyFor_TipChange:= Cell_Services_Prog.Rxx_ReadyAt_TipChangePosition;
Out_To_ICxx.Change_Count.2:= TRUE;
(* ------------------------------------------------------------------------------------- Ancillary Devices --------------------------------------------------------------------------------------------*)
(*Ped Stations*)
	Ped_Stations();

(*Ancillary Equipment such as Stud and Sealant Controllers*)
	Ancillary_Equipment();

(*Servo Motion Devices*)
IF GTAC_CONFIG.Option_SD_Count>0
	THEN
	Servo_Motion();
END_IF;

MAIN.VertiGuard_N01.Q.0:= MAIN.VertiGuard_1.GateClose_CMD;
MAIN.VertiGuard_N01.Q.1:= MAIN.VertiGuard_1.GateOpen_CMD;
(*-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------*)
(*----------------------------------------------------------------------- Invoke and Call Function Blocks -----------------------------------------------------------*)
(*-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------*)

(*----------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke IS FB*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*IPC(IC) Supply Cabinet 01*)
	(*Input Data*)
	IS01.FB_In.Safety_RST:= SAFETY_RESET;
	IS01.FB_In.Enable_Motion:= All_Estops_OK AND All_SafetyGates_OK;
	IS01.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_IC_Count>=1) AND Pulse_CoERead;	(*Global Interval of CoE Reads*)
	IS01.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
	IS01.FB_In.Prev_EcatNode_Present:= NOT ESW02.EP1908_NotPresent; 					(*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	IS01.FB_In.Option_Enable_SplitRelays:= TRUE;									(*Enable Split Relays Option, otherwise only power relays will be expected*)
	IS01.FB_In.Option_Enable_Pbus:= TRUE;											(*Enable EL6731 in PD if a profibus master is present. if not set to false*)
	(*Call FUNCTION*)
	IS01();
	(*Output Data*)
	Out_To_ICxx.IS[1].Discrete_Image:= IS01.Discrete_Image;
	Out_To_ICxx.IS[1].ECAT_Cable_Breaks:= IS01.EcatSlave_Cable_Breaks;
	
		

(*----------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke Large Type Services Stand (Pnuematic I/O)*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*Input Data*)
	SS01.Prev_EcatNode_Present:= NOT IS01.EK1100_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	SS01.Output_Req.0:= All_Estops_OK AND GTAC_CONFIG.Option_Air1; (*air valve 1*)
	SS01.Output_Req.1:= All_Estops_OK AND GTAC_CONFIG.Option_Air1; (*air valve 2*)
	SS01.Output_REQ.2:= RollDoor01.DoorClose_CMD;
	SS01.Output_REQ.3:= RollDoor01.DoorOpen_CMD;
	SS01.Output_REQ.4:= FALSE;
	SS01.Output_REQ.5:= FALSE;
	SS01.Output_REQ.6:= FALSE;
	SS01.Output_REQ.7:= FALSE;
	SS01.FB_In.Option_EP9214_Count:= GTAC_CONFIG.Option_EP9214_Count;
	(*Call Actual Function*)
	SS01();
	(*Output Data*)
	Out_To_ICxx.SS[1].Discrete_Image:= SS01.Discrete_Image;
	Out_To_ICxx.SS[1].ECAT_Cable_Breaks:= SS01.EcatSlave_Cable_Breaks;

	(*Input Data*)
	(*SS02.Prev_EcatNode_Present:= NOT SS01.EP1008_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	SS02.Output_Req.0:= All_Estops_OK AND GTAC_CONFIG.Option_Air2; (*air valve 1*)
	SS02.Output_Req.1:= All_Estops_OK AND GTAC_CONFIG.Option_Air2; (*air valve 2*)
	SS02.Output_REQ.2:= FALSE;
	SS02.Output_REQ.3:= FALSE;
	SS02.Output_REQ.4:= FALSE;
	SS02.Output_REQ.5:= FALSE;
	SS02.Output_REQ.6:= FALSE;
	SS02.Output_REQ.7:= FALSE;
	(*Call Actual Function*)
	SS02();
	(*Output Data*)
	Out_To_ICxx.SS[2].Discrete_Image:= SS02.Discrete_Image;
	Out_To_ICxx.SS[2].ECAT_Cable_Breaks:= SS02.EcatSlave_Cable_Breaks;*)


(*----------------------------------------------------------------------------------------------------------------------------------------*)
(* Invoke Enabling Swtich Plates*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*Input Data*)
	ESW01.Prev_EcatNode_Present:= NOT MAIN.R3.EL6695_PortC_MissingLink; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	(*Call Actual Function*)
	ESW01();
	(*Output Data*)
	Out_To_ICxx.ESW[1].Discrete_Image:= ESW01.Discrete_Image;
	Out_To_ICxx.ESW[1].ECAT_Cable_Breaks:= ESW01.EcatSlave_Cable_Breaks;
	
	(*Input Data*)
	ESW02.Prev_EcatNode_Present:= NOT MAIN.IC03.EK1100_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	(*Call Actual Function*)
	ESW02();
	(*Output Data*)
	Out_To_ICxx.ESW[2].Discrete_Image:= ESW02.Discrete_Image;
	Out_To_ICxx.ESW[2].ECAT_Cable_Breaks:= ESW02.EcatSlave_Cable_Breaks;

	(*Input Data*)
	ESW03.Prev_EcatNode_Present:= NOT MAIN.IC02.EK1100_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	(*Call Actual Function*)
	ESW03();
	(*Output Data*)
	Out_To_ICxx.ESW[3].Discrete_Image:= ESW03.Discrete_Image;
	Out_To_ICxx.ESW[3].ECAT_Cable_Breaks:= ESW03.EcatSlave_Cable_Breaks;

(*----------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke EOAT FBs and Subordinate Fixtures*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*EOATs Action*)
	EOATs();

(*----------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke IC FBs and Subordinate Fixtures*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*ICs Action*)
	ICs();
	
(*----------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke Product Tracking Action*)
(*----------------------------------------------------------------------------------------------------------------------------------------*)
	(*Product Tracking Action*)
	Product_Tracking();

(*-------------------------------------------------------------------------------------------------------------------------------------*)
(*Invoke Robot FBs*)
(*-------------------------------------------------------------------------------------------------------------------------------------*)
	(*Robots Action*)
	Robots();

	
(*-------------------------------------------------------------------------------------------------------------------------------------*)
(*-------------------------------------------------------------------------------------------------------------------------------------*)
(*---------------------------------------------------- End of MAIN---------------------------------------------------------------------*)
(*-------------------------------------------------------------------------------------------------------------------------------------*)
(*-------------------------------------------------------------------------------------------------------------------------------------*)










]]></ST>
    </Implementation>
    <Action Name="EOATs" Id="{74536ccf-3a76-4949-acf9-11e995ae86cc}">
      <Implementation>
        <ST><![CDATA[


	(*R04 - EOAT 04*)
		EOAT04(

			Enable_Motion:= R4.Servos_Are_On,
			Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled,
			Robot_WorkingOK:= ((R4.Task_ID_Ack=PickUP_Fix01) OR (R4.Task_ID_Ack=Work_PED01)) AND R4.Operating,

			(*Set Configuration Data Here*)
			ID:= 4,							(*Set EOAT ID*)
			NodeLayout:= Main.ECAT_Master.EOATNodeLayout[4],	(*Pass in Assembled Node layout for UI*)
			Input_Node_Count:= 5,				(*Set Expected Input Node Count(Current Limit is 9*)
			VB_Node_Count:= 1,				(*Set Expected Input Node Count(Current Limit is 3*)
	
			(*Input Data*)
			(*Use Command All Sensors if your gripper has common part for the entire gripper.*)
			(*Use Command Sensors Group1/Group 2 if your gripper has multiple parts for the entire gripper. EX: LH and RH part*)
			CMD_CheckAllSensors_OFF:= FALSE, 
			CMD_CheckSensorsOFF_Grp1:= R4.EOAT_Req.0, (*129*) (*Sensors 1-2*)
			CMD_CheckSensorsOFF_Grp2:= R4.EOAT_Req.2, (*131*) (*Sensors 3-4*)
			CMD_CheckSensorsOFF_Grp3:= FALSE,
			CMD_CheckSensorsOFF_Grp4:= FALSE,
			CMD_CheckSensorsOFF_Grp5:= FALSE,

			CMD_CheckAllSensors_ON:= FALSE,
			CMD_CheckSensorsON_Grp1:= R4.EOAT_Req.1, (*130*) (*Sensors 1-2*)
			CMD_CheckSensorsON_Grp2:= R4.EOAT_Req.3, (*132*) (*Sensors 3-4*)
			CMD_CheckSensorsON_Grp3:= FALSE,
			CMD_CheckSensorsON_Grp4:= FALSE,
			CMD_CheckSensorsON_Grp5:= FALSE,

			(*Use Command Tool to Work/HOME if your gripper has common part for the entire gripper.*)
			(*Use Clamps Groups if your gripper has a LH/RH part for the gripper.*)
			CMD_Tool_To_WORK:= FALSE,
			CMD_CylToWORK_Grp1:= R4.EOAT_Req.4, (*133*) (*Clamps 1-4*)
			CMD_CylToWORK_Grp2:= R4.EOAT_Req.6, (*135*) (*Clamps 5-8*)
			CMD_CylToWORK_Grp3:= R4.EOAT_Req.8, (*137*) (*Pins 1-2*)
			CMD_CylToWORK_Grp4:= R4.EOAT_Req.10, (*139*) (*Pins 3-4*)
			CMD_CylToWORK_Grp5:= FALSE,

			CMD_Tool_To_HOME:= FALSE,
			CMD_CylToHOME_Grp1:= R4.EOAT_Req.5, (*134*) (*Clamps 1-4*)
			CMD_CylToHOME_Grp2:= R4.EOAT_Req.7, (*136*) (*Clamps 5-8*)
			CMD_CylToHOME_Grp3:= R4.EOAT_Req.9, (*138*) (*Pins 1-2*)
			CMD_CylToHOME_Grp4:= R4.EOAT_Req.11, (*140*) (*Pins 3-4*)
			CMD_CylToHOME_Grp5:= FALSE
			);
		(*Output Data*)
		Out_To_ICxx.EOAT04_Discrete_Image:= EOAT04.Discrete_Image;
		Out_To_ICxx.ProductReport[34]:= EOAT04_1_ProductData_Pers; 	(*Transfer Product Data to UI*)
		Out_To_ICxx.ProductReport[35]:= EOAT04_2_ProductData_Pers; 	(*Transfer Product Data to UI*)

		(*Output Data - Send ACKs bak to Robot*)
		(*Sensor ACKs*)
		R4.FB_In.EOATReq_Ack.0:= EOAT04.EOAT_Part1_Empty;	(*129*) //R4.EOAT_Req.0 AND DEBUG - removed to make more automated. delete if tested good
		R4.FB_In.EOATReq_Ack.1:= EOAT04.Part1_In_EOAT;		(*130*) //R4.EOAT_Req.1 AND DEBUG
		R4.FB_In.EOATReq_Ack.2:= EOAT04.EOAT_Part2_Empty;	(*131*) //R4.EOAT_Req.2 AND DEBUG 
		R4.FB_In.EOATReq_Ack.3:= EOAT04.Part2_In_EOAT;		(*132*) //R4.EOAT_Req.3 AND DEBUG
		
		(*CLAMP ACKs*)
		R4.FB_In.EOATReq_Ack.4:= R4.EOAT_Req.4 AND EOAT04.ACK_CylAtWORK_Grp1;	(*133*)
		R4.FB_In.EOATReq_Ack.5:= R4.EOAT_Req.5 AND EOAT04.ACK_CylAtHOME_Grp1;	(*134*)		
		R4.FB_In.EOATReq_Ack.6:= R4.EOAT_Req.6 AND EOAT04.ACK_CylAtWORK_Grp2;	(*135*)
		R4.FB_In.EOATReq_Ack.7:= R4.EOAT_Req.7 AND EOAT04.ACK_CylAtHOME_Grp2;	(*136*)
		
		(*Pin ACKs*)
		R4.FB_In.EOATReq_Ack.8:= R4.EOAT_Req.8 AND EOAT04.ACK_CylAtWORK_Grp3;	(*137*)
		R4.FB_In.EOATReq_Ack.9:= R4.EOAT_Req.9 AND EOAT04.ACK_CylAtHOME_Grp3;	(*138*)		
		R4.FB_In.EOATReq_Ack.10:= R4.EOAT_Req.10 AND EOAT04.ACK_CylAtWORK_Grp4;	(*139*)
		R4.FB_In.EOATReq_Ack.11:= R4.EOAT_Req.11 AND EOAT04.ACK_CylAtHOME_Grp4;	(*140*)

	(*Additional EOAT can be added here. Up to 30*)
	(*Please update the faults if you add additional EOAT*)



]]></ST>
      </Implementation>
    </Action>
    <Action Name="ICs" Id="{deccbd85-5f42-4b64-8e81-375e56a63756}">
      <Implementation>
        <ST><![CDATA[


	(*Industrial Controller 01*)
	(*Input Data*)
	IC01.FB_In.Safety_RST:=SAFETY_RESET;
	IC01.FB_In.Enable_Motion:= All_Estops_OK AND All_SafetyGates_OK;
	IC01.FB_In.Estops_OK:= All_Estops_OK;
	IC01.FB_In.Safety_Gates_Ok:= All_SafetyGates_OK;
	IC01.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_IC_Count>=1) AND Pulse_CoERead;	(*Global Interval of CoE Reads*)
	IC01.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
	IC01.FB_In.Prev_EcatNode_Present:= TRUE; 												(*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	IC01.FB_In.Output_Req1:= In_From_ICxx.LockSGK1;
	IC01.Turntable_Type:= TRUE;	(*Debug - Set to true if using a turntable. this will change the status light based on table position. set to false if no turntable.*)
	IC01.Op1_At_Operator:= Fix01.TurntableB_At_Robot OR (MAIN.R1.Task_ID_Ack=Sweep_Fix01) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix01) OR (MAIN.R1.Task_ID_Ack=Sweep_Fix02) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix02);
	IC01.Op2_At_Operator:= Fix01.TurntableA_At_Robot OR (MAIN.R1.Task_ID_Ack=Sweep_Fix01) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix01) OR (MAIN.R1.Task_ID_Ack=Sweep_Fix02) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix02);
	IC01.FB_In.OP1_Green_LampReq:= Fix01.Ready_To_Load;
	IC01.FB_In.OP2_Green_LampReq:= Fix03.Ready_To_Load;
	IC01.FB_In.OP1_Yellow_LampReq:= TRUE;
	IC01.FB_In.OP2_Yellow_LampReq:= TRUE;
	IC01.FB_In.OP1_Red_LampReq:= Fix01.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC01.FB_In.OP2_Red_LampReq:= Fix03.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC01.OP1_LC_Clear:= IC01.OP1_HumanVertLC_Clear AND IC01.OP1_HumanHorizLC_Clear AND IC01.OP1_RobotVertLC_Clear AND IC01.OP2_HumanVertLC_Clear AND IC01.OP2_HumanHorizLC_Clear;
	IC01.OP2_LC_Clear:= IC01.OP1_HumanVertLC_Clear AND IC01.OP1_HumanHorizLC_Clear AND IC01.OP1_RobotVertLC_Clear AND IC01.OP2_HumanVertLC_Clear AND IC01.OP2_HumanHorizLC_Clear;
	(*Call FUNCTION*)
	IC01();
	(*Output IC Data to All ICs*)
	Out_To_ICxx.IC[1].Discrete_Image:= IC01.Discrete_Image;
	Out_To_ICxx.IC[1].ECAT_Cable_Breaks:= IC01.ECatSlave_Cable_Breaks;
	Out_To_ICxx.IC01OP1_LCHVR:= IC01.OP1_HumanVertLC_Clear;
	Out_To_ICxx.IC01OP1_LCHHR:= IC01.OP1_HumanHorizLC_Clear;
	Out_To_ICxx.IC01OP1_LCRVR:= IC01.OP1_RobotVertLC_Clear; (*DEBUG - ADD OR REMOVE TO OTHER LIGHT CURTAINS. BYPASSES INDICATOR ON UI*)
	Out_To_ICxx.IC01OP2_LCHVR:= IC01.OP2_HumanVertLC_Clear;
	Out_To_ICxx.IC01OP2_LCHHR:= IC01.OP2_HumanHorizLC_Clear;
	Out_To_ICxx.IC01OP2_LCRVR:= IC01.OP2_RobotVertLC_Clear;
	
		(*OP1*)
			(*Fixture 01*)
			(*Input Data*)
			Fix01.Enable_Motion:= IC01.OP1_Enable_Motion;
			Fix01.Discrete_In:= In_From_ICxx.Fix01_Discrete_In;
			Fix01.Discrete_In.ModelData:= In_From_ICxx.Fix01_Discrete_In.ModelData;
			Fix01.NodeLayout:= Main.ECAT_Master.FixNodeLayout[1];				(*Pass in Assembled Node layout for UI*)
			Fix01.Discrete_In.Input_Node_Count:= 29;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix01.Discrete_In.VB_Node_Count:= 2;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix01.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix01.Discrete_In.Water_Stand_Count:= 0;							(*Overridden for now, later version will map from UI read config sheet*)
			Fix01.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled OR GTAC_CONFIG.Local_DryCycle_Enables.1;
			Fix01.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix01.Flash_Rate:= Pulse_1S;

			(*Call FUNCTION*)
			Fix01();
			(*Output Data*)
			Out_To_ICxx.Fix01_Discrete_Image:= Fix01.Discrete_Image;

		
			(*Fixture 02*)
			(*Input Data*)
			Fix02.Enable_Motion:= IC01.OP2_Enable_Motion;
			Fix02.Discrete_In:= In_From_ICxx.Fix02_Discrete_In;
			Fix02.Discrete_In.ModelData:= In_From_ICxx.Fix02_Discrete_In.ModelData;
			Fix02.NodeLayout:= Main.ECAT_Master.FixNodeLayout[2];				(*Pass in Assembled Node layout for UI*)
			Fix02.Discrete_In.Input_Node_Count:= 29;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix02.Discrete_In.VB_Node_Count:= 2;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix02.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix02.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix02.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled OR GTAC_CONFIG.Local_DryCycle_Enables.2;
			Fix02.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix02.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix02();
			(*Output Data*)
			Out_To_ICxx.Fix02_Discrete_Image:= Fix02.Discrete_Image;

	(*Industrial Controller 02*)
	(*Input Data*)
	IC02.FB_In.Safety_RST:=SAFETY_RESET;
	IC02.FB_In.Enable_Motion:= All_Estops_OK AND All_SafetyGates_OK;
	IC02.FB_In.Estops_OK:= All_Estops_OK;
	IC02.FB_In.Safety_Gates_Ok:= All_SafetyGates_OK;
	IC02.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_IC_Count>=2) AND Pulse_CoERead;	(*Global Interval of CoE Reads*)
	IC02.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
	IC02.FB_In.Prev_EcatNode_Present:= NOT MAIN.MD02.EP2624_PortB_MissingLink ; 						(*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	IC02.FB_In.Output_Req1:= In_From_ICxx.LockSGK1 OR In_From_ICxx.LockSGK2;
	IC02.Turntable_Type:= TRUE;	(*Debug - Set to true if using a turntable. this will change the status light based on table position. set to false if no turntable.*)
	IC02.Op1_At_Operator:= Fix03.TurntableB_At_Robot OR (MAIN.R3.Task_ID_Ack=Sweep_Fix03) OR (MAIN.R4.Task_ID_Ack=Sweep_Fix03) OR (MAIN.R3.Task_ID_Ack=Sweep_Fix04) OR (MAIN.R4.Task_ID_Ack=Sweep_Fix04); (*debug - change robot*)
	IC02.Op2_At_Operator:= Fix03.TurntableA_At_Robot OR (MAIN.R3.Task_ID_Ack=Sweep_Fix03) OR (MAIN.R4.Task_ID_Ack=Sweep_Fix03) OR (MAIN.R3.Task_ID_Ack=Sweep_Fix04) OR (MAIN.R4.Task_ID_Ack=Sweep_Fix04); (*debug - change robot*)
	IC02.FB_In.OP1_Green_LampReq:= Fix03.Ready_To_Load;
	IC02.FB_In.OP2_Green_LampReq:= Fix04.Ready_To_Load;
	IC02.FB_In.OP1_Yellow_LampReq:= TRUE;
	IC02.FB_In.OP2_Yellow_LampReq:= TRUE;
	IC02.FB_In.OP1_Red_LampReq:= Fix03.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC02.FB_In.OP2_Red_LampReq:= Fix04.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC02.OP1_LC_Clear:= IC02.OP1_HumanVertLC_Clear AND IC02.OP1_HumanHorizLC_Clear AND IC02.OP1_RobotVertLC_Clear AND IC02.OP2_HumanVertLC_Clear AND IC02.OP2_HumanHorizLC_Clear;
	IC02.OP2_LC_Clear:= IC02.OP1_HumanVertLC_Clear AND IC02.OP1_HumanHorizLC_Clear AND IC02.OP1_RobotVertLC_Clear AND IC02.OP2_HumanVertLC_Clear AND IC02.OP2_HumanHorizLC_Clear;
	(*Call FUNCTION*)
	IC02();
	(*Output IC Data to all ICs*)
	Out_To_ICxx.IC[2].Discrete_Image:= IC02.Discrete_Image;
	Out_To_ICxx.IC[2].ECAT_Cable_Breaks:= IC02.ECatSlave_Cable_Breaks;
	Out_To_ICxx.IC02OP1_LCHVR:= IC02.OP1_HumanVertLC_Clear;
	Out_To_ICxx.IC02OP1_LCHHR:= IC02.OP1_HumanHorizLC_Clear;
	Out_To_ICxx.IC02OP1_LCRVR:= IC02.OP1_RobotVertLC_Clear;
	Out_To_ICxx.IC02OP2_LCHVR:= IC02.OP2_HumanVertLC_Clear;
	Out_To_ICxx.IC02OP2_LCHHR:= IC02.OP2_HumanHorizLC_Clear;
	Out_To_ICxx.IC02OP2_LCRVR:= IC02.OP2_RobotVertLC_Clear;

		(*OP1*)
			(*Fixture 03*)
			(*Input Data*)
			Fix03.Enable_Motion:= IC02.OP1_Enable_Motion;
			Fix03.Discrete_In:= In_From_ICxx.Fix03_Discrete_In;
			(*Perform Look ahead for Model data depending on line loading*)
			
				(*Valid part For this Fix in EOAT04_1, so use EOAT_1 model*)
				IF ((EOAT04.Part1_In_EOAT AND NOT Fix03.Load_Complete) OR Fix03.Repo_REQS.0) AND Fix03.Part_InEOAT04_1_ReadyforThisFix 
					THEN
					Fix03.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
	
				(*Valid part For this Fix in EOAT04_2, so use EOAT_2 model*)
				ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix03.Load_Complete) OR Fix03.Repo_REQS.0) AND Fix03.Part_InEOAT04_2_ReadyforThisFix
					THEN
					Fix03.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in EOAT04, but valid part in Fix101, so use Fix101 model*)
				ELSIF (((NOT Fix03.Load_Complete OR Fix03.Unload_Complete) AND Fix101.Load_Complete) OR (MAIN.R4.Task_ID_Ack = PickUp_Fix101)) AND 
						NOT Fix03.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix03.Part_InEOAT04_2_ReadyforThisFix AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix03)
					THEN
					Fix03.Discrete_In.ModelData:= Fix101_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101 but valid part in EOAT04_1 for Fix101, so use EOAT04_1 model*)
				ELSIF NOT Fix03.Load_Complete AND NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND Fix101.Part_InEOAT04_1_ReadyforThisFix 
					THEN
					Fix03.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101 but valid part in EOAT04_2 for Fix101, so use EOAT04_1 model*)
				ELSIF NOT Fix03.Load_Complete AND NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND Fix101.Part_InEOAT04_2_ReadyforThisFix 
					THEN
					Fix03.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101, no Valid part in EOAT04 but model in Fix01 / 02 AND Fix03 empty*)
				ELSIF (NOT Fix03.Load_Complete OR Fix03.Unload_Complete) AND NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND 
							NOT Fix101.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix101.Part_InEOAT04_2_ReadyforThisFix AND 
							NOT Fix03.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix03.Part_InEOAT04_2_ReadyforThisFix 
					THEN
					(*Fix01 Faces Weld Robots*)
					IF (Out_To_ICxx.TT01_Location_Index = 1) AND NOT Fix01.All_Sensors_Off AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix03)
						THEN
						Fix03.Discrete_In.ModelData:= Fix01_ProductData_Pers.Product_Model_ID;
					(*Fix02 Faces Weld Robots*)	
					ELSIF (Out_To_ICxx.TT01_Location_Index = 2) AND NOT Fix02.All_Sensors_Off AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix03)
						THEN	
						Fix03.Discrete_In.ModelData:= Fix02_ProductData_Pers.Product_Model_ID;
					ELSIF
						((Out_To_ICxx.TT01_Location_Index = 1) OR (Out_To_ICxx.TT01_Location_Index = 2)) AND Fix01.All_Sensors_Off AND Fix02.All_Sensors_Off
						THEN
						Fix03.Discrete_In.ModelData:= Fix01_ProductData_Pers.Product_Model_ID;
					END_IF;
				END_IF;
(*
				(*FINALLY, if part has been loaded onto this Fix, so use local model data *)
				ELSIF   (Fix03.Load_Complete AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix03)) OR Fix03.Repo_REQS.0
					THEN
						test1:= TRUE;
						Fix03.Discrete_In.ModelData:= Fix03_ProductData_Pers.Product_Model_ID;
				END_IF;  DEBUG - this partially works... not a clue why  - rj*)
				
				(*FINALLY, if part has been loaded onto this Fix, so use local model data *)
				IF   (Fix03.Load_Complete OR Fix03.Repo_REQS.0) AND ((MAIN.R4.Task_ID_Ack <> DropOff_Fix03) OR Fix03.Load_Robots_Complete1)
					 AND NOT Fix03.Unload_Complete
					THEN
						test1:= TRUE;
						Fix03.Discrete_In.ModelData:= Fix03_ProductData_Pers.Product_Model_ID;
				END_IF;
				
			Fix03.NodeLayout:= Main.ECAT_Master.FixNodeLayout[3];				(*Pass in Assembled Node layout for UI*)
			Fix03.Discrete_In.Input_Node_Count:= 21;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix03.Discrete_In.VB_Node_Count:= 1;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix03.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix03.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix03.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled OR GTAC_CONFIG.Local_DryCycle_Enables.3;
			Fix03.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix03.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix03();
			(*Output Data*)
			Out_To_ICxx.Fix03_Discrete_Image:= Fix03.Discrete_Image;


		(*OP2*)
			(*Fixture 04*)
			(*Input Data*)
			Fix04.Enable_Motion:= IC02.OP2_Enable_Motion;
			Fix04.Discrete_In:= In_From_ICxx.Fix04_Discrete_In;
			
				(*Perform Look ahead for Model data depending on line loading*)
			
				(*Valid part For this Fix in EOAT04_1, so use EOAT_1 model*)
				IF ((EOAT04.Part1_In_EOAT AND NOT Fix04.Load_Complete) OR Fix04.Repo_REQS.0) AND Fix04.Part_InEOAT04_1_ReadyforThisFix
					THEN
					Fix04.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
	
				(*Valid part For this Fix in EOAT04_2, so use EOAT_2 model*)
				ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix04.Load_Complete) OR Fix04.Repo_REQS.0) AND Fix04.Part_InEOAT04_2_ReadyforThisFix
					THEN
					Fix04.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in EOAT04, but valid part in Fix101, so use Fix101 model*)
				ELSIF NOT Fix04.Load_Complete AND Fix101.Load_Complete OR (MAIN.R4.Task_ID_Ack = PickUp_Fix101) AND 
						NOT Fix04.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix04.Part_InEOAT04_2_ReadyforThisFix
					THEN
					Fix04.Discrete_In.ModelData:= Fix101_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101 but valid part in EOAT04_1 for Fix101, so use EOAT04_1 model*)
				ELSIF NOT Fix04.Load_Complete AND NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND Fix101.Part_InEOAT04_1_ReadyforThisFix
					THEN
					Fix04.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101 but valid part in EOAT04_2 for Fix101, so use EOAT04_1 model*)
				ELSIF NOT Fix04.Load_Complete AND NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND Fix101.Part_InEOAT04_2_ReadyforThisFix
					THEN
					Fix04.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
	
				(*No valid part in Fix101, no Valid part in EOAT04 but model in Fix01 / 02*)
				ELSIF NOT Fix04.Load_Complete and NOT Fix101.Load_Complete AND (MAIN.R4.Task_ID_Ack <> PickUp_Fix101) AND 
							NOT Fix101.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix101.Part_InEOAT04_2_ReadyforThisFix AND 
							NOT Fix04.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix04.Part_InEOAT04_2_ReadyforThisFix
					THEN
					(*Fix01 Faces Weld Robots*)
					IF (Out_To_ICxx.TT01_Location_Index = 1)
						THEN
						Fix04.Discrete_In.ModelData:= Fix01_ProductData_Pers.Product_Model_ID;
					(*Fix02 Faces Weld Robots*)	
					ELSIF (Out_To_ICxx.TT01_Location_Index = 2)
						THEN	
						Fix04.Discrete_In.ModelData:= Fix02_ProductData_Pers.Product_Model_ID;
					END_IF;
	
				(*FINALLY, if part has been loaded onto this Fix, so use local model data*)
				ELSIF (Fix04.Load_Complete OR Fix04.Repo_REQS.1) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix04)
					THEN
					Fix04.Discrete_In.ModelData:= Fix04_ProductData_Pers.Product_Model_ID;
				END_IF;
				
			Fix04.NodeLayout:= Main.ECAT_Master.FixNodeLayout[4];				(*Pass in Assembled Node layout for UI*)
			Fix04.Discrete_In.Input_Node_Count:= 22;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix04.Discrete_In.VB_Node_Count:= 1;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix04.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix04.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix04.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled OR GTAC_CONFIG.Local_DryCycle_Enables.4;
			Fix04.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix04.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix04();
			(*Output Data*)
			Out_To_ICxx.Fix04_Discrete_Image:= Fix04.Discrete_Image;

	(*Industrial Controller 03*)
	(*Input Data*)
	IC03.FB_In.Safety_RST:=SAFETY_RESET;
	IC03.FB_In.Enable_Motion:= All_Estops_OK AND All_SafetyGates_OK;
	IC03.FB_In.Estops_OK:= All_Estops_OK;
	IC03.FB_In.Safety_Gates_Ok:= All_SafetyGates_OK;
	IC03.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_IC_Count>=3) AND Pulse_CoERead;	(*Global Interval of CoE Reads*)
	IC03.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
	IC03.FB_In.Prev_EcatNode_Present:= NOT MAIN.R11.EL6695_PortC_MissingLink; 						(*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
	IC03.FB_In.Output_Req1:= In_From_ICxx.LockSGK1;
	IC03.Turntable_Type:= FALSE;	(*Debug - Set to true if using a turntable. this will change the status light based on table position. set to false if no turntable.*)
	IC03.Op1_At_Operator:= Fix05.TurntableB_At_Robot OR (MAIN.R1.Task_ID_Ack=Sweep_Fix05) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix05); (*debug - change robot*)
	IC03.Op2_At_Operator:= Fix05.TurntableA_At_Robot OR (MAIN.R1.Task_ID_Ack=Sweep_Fix05) OR (MAIN.R2.Task_ID_Ack=Sweep_Fix05); (*debug - change robot*)
	IC03.FB_In.OP1_Green_LampReq:= Fix05.Ready_To_Load;
	IC03.FB_In.OP2_Green_LampReq:= Fix05.Ready_To_Load;
	IC03.FB_In.OP1_Yellow_LampReq:= TRUE;
	IC03.FB_In.OP2_Yellow_LampReq:= TRUE;
	IC03.FB_In.OP1_Red_LampReq:= Fix05.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC03.FB_In.OP2_Red_LampReq:= Fix06.Red_Lamp_Req OR Faults.System_Major_Fault;
	IC03.OP1_LC_Clear:= IC03.OP1_HumanVertLC_Clear AND IC03.OP1_HumanHorizLC_Clear (*AND IC03.OP1_RobotVertLC_Clear*);
	IC03.OP2_LC_Clear:= IC03.OP1_HumanVertLC_Clear AND IC03.OP1_HumanHorizLC_Clear (*IC03.OP2_HumanVertLC_Clear AND IC03.OP2_HumanHorizLC_Clear AND IC03.OP2_RobotVertLC_Clear*);
	(*Call FUNCTION*)
	IC03();
	(*Output IC Data to all ICs*)
	Out_To_ICxx.IC[3].Discrete_Image:= IC03.Discrete_Image;
	Out_To_ICxx.IC[3].ECAT_Cable_Breaks:= IC03.ECatSlave_Cable_Breaks;
	Out_To_ICxx.IC03OP1_LCHVR:= IC03.OP1_HumanVertLC_Clear;
	Out_To_ICxx.IC03OP1_LCHHR:= IC03.OP1_HumanHorizLC_Clear;
	Out_To_ICxx.IC03OP1_LCRVR:= IC03.OP1_RobotVertLC_Clear;
	Out_To_ICxx.IC03OP2_LCHVR:= IC03.OP2_HumanVertLC_Clear;
	Out_To_ICxx.IC03OP2_LCHHR:= IC03.OP2_HumanHorizLC_Clear;
	Out_To_ICxx.IC03OP2_LCRVR:= IC03.OP2_RobotVertLC_Clear;

		(*OP1*)
			(*Fixture 05*)
			(*Input Data*)
			Fix05.Enable_Motion:= IC03.OP1_Enable_Motion;
			Fix05.Discrete_In:= In_From_ICxx.Fix05_Discrete_In;
			Fix05.Discrete_In.ModelData:= In_From_ICxx.Fix05_Discrete_In.ModelData; (*DEBUG, will have to be finalized once Fix05 redesign is complete, blt*)
			Fix05.NodeLayout:= Main.ECAT_Master.FixNodeLayout[5];				(*Pass in Assembled Node layout for UI*)
			Fix05.Discrete_In.Input_Node_Count:= 4;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix05.Discrete_In.VB_Node_Count:= 1;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix05.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix05.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix05.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled OR GTAC_CONFIG.Local_DryCycle_Enables.5;
			Fix05.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix05.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix05();
			(*Output Data*)
			Out_To_ICxx.Fix05_Discrete_Image:= Fix05.Discrete_Image;


(*Internal Fixtures*)

			(*Fixture 101*)
			(*Input Data*)
			Fix101.Enable_Motion:= Main.Control_Power_ON;								(*ENSURE to bind proper Relay Bank*)
			Fix101.Discrete_In:= In_From_ICxx.Fix101_Discrete_In;
			IF ((EOAT04.Part1_In_EOAT AND NOT Fix101.Load_Complete) OR Fix101.Repo_REQS.0) AND Fix101.Part_InEOAT04_1_ReadyforThisFix
				THEN
				Fix101.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
			ELSIF (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[1] = '') // weld fix101 complete
					AND ((EOAT04.Part2_In_EOAT AND NOT Fix101.Load_Complete) OR Fix101.Repo_REQS.0) AND Fix101.Part_InEOAT04_2_ReadyforThisFix
				THEN
				Fix101.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID; 
			ELSIF (Fix101.Load_Complete OR Fix101.Repo_REQS.1) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix101) AND NOT Fix101.Unload_Complete
				THEN
				Fix101.Discrete_In.ModelData:= Fix101_ProductData_Pers.Product_Model_ID;
			ELSIF (Fix101.Unload_Complete AND Fix101.All_Sensors_Off AND NOT Main.R1.TT_at_Dropoff_Pos)
				THEN
				Fix101.Discrete_In.ModelData:= 1;
			ELSIF Fix101.All_Sensors_Off AND NOT Fix101.Part_InEOAT04_1_ReadyforThisFix AND NOT Fix101.Part_InEOAT04_2_ReadyforThisFix AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix101)
				THEN 
				 IF 	(*Fix01 Faces Weld Robots*)
						Fix01.TurntableA_At_Robot AND (Fix01.Model_ID <> 0)
					THEN
						Fix101.Discrete_In.ModelData:= Fix01_ProductData_Pers.Product_Model_ID;
						(*Fix02 Faces Weld Robots*)	
				ELSIF 	Fix02.TurntableB_At_Robot AND (Fix02.Model_ID <> 0)
					THEN	
						Fix101.Discrete_In.ModelData:= Fix02_ProductData_Pers.Product_Model_ID;
				END_IF
			END_IF;
			Fix101.NodeLayout:= Main.ECAT_Master.FixNodeLayout[101];				(*Pass in Assembled Node layout for UI*)
			Fix101.Discrete_In.Input_Node_Count:= 4;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix101.Discrete_In.VB_Node_Count:= 1;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix101.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix101.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix101.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
			Fix101.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix101.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix101();
			(*Output Data*)
			Out_To_ICxx.Fix101_Discrete_Image:= Fix101.Discrete_Image;
			(*------------------------- Nutweld Based LVDT system -----------------------------------*)
				(*Debug example only, using Fix101 as Nutwelder host*)

				(*Nutweld LVDT1*)
				(*Input Data*).
				MAIN.NutWeld_LVDT[1].Model_ID:= Fix101.Model_ID;
				MAIN.NutWeld_LVDT[1].Option_InScaledValues:= TRUE;		(*Sets if the system is working in scalled or raw values*) 
				MAIN.NutWeld_LVDT[1].Save_LVDT_Conf:= In_From_ICxx.NutWeld_LVDT_Discrete_In[1].Save_LVDT_REQ; 
				MAIN.NutWeld_LVDT[1].Save_Nut_Conf:= In_From_ICxx.NutWeld_LVDT_Discrete_In[1].Save_Nut_REQ; 
				MAIN.NutWeld_LVDT[1].Raw_Transducer:= 0; (*DEBUG,  map analog card Channel here*) 
				MAIN.NutWeld_LVDT[1].Ready_For_Measurement:= MAIN.R1.In_From_ECAT.Robot_OUT[172]; (*DEBUG,  confirm this is the proper output for "Weld ServoGun at Force"*)
				MAIN.NutWeld_LVDT[1].Weld_Complete:= MAIN.R1.WCU1_Weld_Complete; 
				MAIN.NutWeld_LVDT[1].Reset_NutOK:= NOT MAIN.R1.In_AutoExt
												OR Fix101.Reset_All_Completes
												OR (Fix101.In_Manual AND Fix101.Discrete_In.Go_Home); 
				MAIN.NutWeld_LVDT[1].NutInput_UpperLimit[Fix101.Model_ID]:= In_From_ICxx_Pers.Config_NutWeld_LVDT[1].Nut_UpperLimit;
				MAIN.NutWeld_LVDT[1].NutInput_LowerLimit[Fix101.Model_ID]:= In_From_ICxx_Pers.Config_NutWeld_LVDT[1].Nut_LowerLimit;


				(*Call FB Instance*)
				MAIN.NutWeld_LVDT[1]();
				(*Output Data*)
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Saved_ACK:= MAIN.NutWeld_LVDT[1].LVDT_Saved;
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Value_Scaled:= MAIN.NutWeld_LVDT[1].NutPrev_Scaled;
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Value_Raw:= MAIN.NutWeld_LVDT[1].NutPrev_Raw;
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Nut_OK:= MAIN.NutWeld_LVDT[1].NutOK;
				
				(*----------------*)
				(*Outputs to Nutweld LVDT Discrete Image Area from Fix101 Pin13 (See Fix101.Cylinders.Pin13 example)*)
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Pin_RETD:= Fix101.Pin13RETD;
				Out_To_ICxx.NutWeld_LVDT_Discrete_Image[1].LVDT_Pin_ADVD:= Fix101.Pin13ADVD;
	
			(*-------------------------------------------------------------------------*)	
				
				
				
			(*Fixture 102*)
			(*Input Data*)
			Fix102.Enable_Motion:= Main.Control_Power_ON;								(*ENSURE to bind proper Relay Bank*)
			Fix102.Discrete_In:= In_From_ICxx.Fix102_Discrete_In;
			IF ((EOAT04.Part1_In_EOAT AND NOT Fix102.Load_Complete) OR Fix102.Repo_REQS.0) AND Fix102.Part_InEOAT04_1_ReadyforThisFix
				THEN
				Fix102.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
			ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix102.Load_Complete) OR Fix102.Repo_REQS.0) AND Fix102.Part_InEOAT04_2_ReadyforThisFix
				THEN
				Fix102.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
			ELSIF (Fix102.Load_Complete OR Fix102.Repo_REQS.0) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix102) AND NOT Fix102.Unload_Complete
				THEN
				Fix102.Discrete_In.ModelData:= Fix102_ProductData_Pers.Product_Model_ID;
				(*If nothing else is loaded, we need a model number to finish 102 sequance*)
			ELSIF (NOT Fix102.Load_Complete AND (NOT Fix03.Load_Complete OR NOT Fix04.Load_Complete) AND NOT Fix101.Load_Complete AND EOAT04.EOAT_Part1_Empty) 
				THEN
				Fix102.Discrete_In.ModelData:= Fix01_ProductData_Pers.Product_Model_ID;
			END_IF;
 			Fix102.NodeLayout:= Main.ECAT_Master.FixNodeLayout[102];				(*Pass in Assembled Node layout for UI*)
			Fix102.Discrete_In.Input_Node_Count:= 4;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix102.Discrete_In.VB_Node_Count:= 1;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix102.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix102.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix102.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
			Fix102.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix102.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix102();
			(*Output Data*)
			Out_To_ICxx.Fix102_Discrete_Image:= Fix102.Discrete_Image;


			(*Fixture 101*)
			(*Input Data*)
			Fix103.Enable_Motion:= Main.Control_Power_ON;							(*ENSURE to bind proper Relay Bank*)
			Fix103.Discrete_In:= In_From_ICxx.Fix103_Discrete_In;
			IF ((EOAT04.Part1_In_EOAT AND NOT Fix103.Load_Complete) OR Fix103.Repo_REQS.0) AND Fix103.Part_InEOAT04_1_ReadyforThisFix
				THEN
				Fix103.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
			ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix103.Load_Complete) OR Fix103.Repo_REQS.0) AND Fix103.Part_InEOAT04_2_ReadyforThisFix
				THEN
				Fix103.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
			ELSIF (Fix103.Load_Complete OR Fix103.Repo_REQS.1) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix103)
				THEN
				Fix103.Discrete_In.ModelData:= Fix103_ProductData_Pers.Product_Model_ID;
			END_IF;
 			Fix103.NodeLayout:= Main.ECAT_Master.FixNodeLayout[103];				(*Pass in Assembled Node layout for UI*)
			Fix103.Discrete_In.Input_Node_Count:= 2;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix103.Discrete_In.VB_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix103.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix103.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix103.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
			Fix103.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix103.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix103();
			(*Output Data*)
			Out_To_ICxx.Fix103_Discrete_Image:= Fix103.Discrete_Image;


			(*Fixture 101*)
			(*Input Data*)
			Fix104.Enable_Motion:= Main.Control_Power_ON;								(*ENSURE to bind proper Relay Bank*)
			Fix104.Discrete_In:= In_From_ICxx.Fix104_Discrete_In;
			IF ((EOAT04.Part1_In_EOAT AND NOT Fix104.Load_Complete) OR Fix104.Repo_REQS.0) AND Fix104.Part_InEOAT04_1_ReadyforThisFix
				THEN
				Fix104.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
			ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix104.Load_Complete) OR Fix104.Repo_REQS.0) AND Fix104.Part_InEOAT04_2_ReadyforThisFix
				THEN
				Fix104.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
			ELSIF (Fix104.Load_Complete OR Fix104.Repo_REQS.1) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix104)
				THEN
				Fix104.Discrete_In.ModelData:= Fix104_ProductData_Pers[0].Product_Model_ID;
			END_IF;
 			Fix104.NodeLayout:= Main.ECAT_Master.FixNodeLayout[104];				(*Pass in Assembled Node layout for UI*)
			Fix104.Discrete_In.Input_Node_Count:= 2;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix104.Discrete_In.VB_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix104.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix104.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix104.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
			Fix104.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix104.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix104();
			(*Output Data*)
			Out_To_ICxx.Fix104_Discrete_Image:= Fix104.Discrete_Image;


			(*Fixture 105*)
			(*Input Data*)
			Fix105.Enable_Motion:= Main.Control_Power_ON;								(*ENSURE to bind proper Relay Bank*)
			Fix105.Discrete_In:= In_From_ICxx.Fix105_Discrete_In;
			IF ((EOAT04.Part1_In_EOAT AND NOT Fix105.Load_Complete) OR Fix105.Repo_REQS.0) AND Fix105.Part_InEOAT04_1_ReadyforThisFix
				THEN
				Fix105.Discrete_In.ModelData:= EOAT04_1_ProductData_Pers.Product_Model_ID;
			ELSIF ((EOAT04.Part2_In_EOAT AND NOT Fix105.Load_Complete) OR Fix105.Repo_REQS.0) AND Fix105.Part_InEOAT04_2_ReadyforThisFix
				THEN
				Fix105.Discrete_In.ModelData:= EOAT04_2_ProductData_Pers.Product_Model_ID;
			ELSIF (Fix105.Load_Complete OR Fix105.Repo_REQS.1) AND (MAIN.R4.Task_ID_Ack <> DropOff_Fix105)
				THEN
				Fix105.Discrete_In.ModelData:= Fix105_ProductData_Pers.Product_Model_ID;
			END_IF;
			Fix105.NodeLayout:= Main.ECAT_Master.FixNodeLayout[105];				(*Pass in Assembled Node layout for UI*)
			Fix105.Discrete_In.Input_Node_Count:= 2;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix105.Discrete_In.VB_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix105.Discrete_In.Output_Node_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix105.Discrete_In.Water_Stand_Count:= 0;								(*Overridden for now, later version will map from UI read config sheet*)
			Fix105.Dry_Cycle:= GTAC_CONFIG.Dry_Cycle_Enabled;
			Fix105.Cell_In_Services:= Cell_Services_Prog.Service_Call_ForAllRobots OR In_From_ICxx.Cycle_Hold;
			Fix105.Flash_Rate:= Pulse_1S;
			(*Call FUNCTION*)
			Fix105();
			(*Output Data*)
			Out_To_ICxx.Fix105_Discrete_Image:= Fix105.Discrete_Image;]]></ST>
      </Implementation>
    </Action>
    <Action Name="Product_Tracking" Id="{b180e8a1-2952-497b-b976-b2c524bb6089}">
      <Implementation>
        <ST><![CDATA[(*Custom Product Trackng code for this machine (Bumpers Main 2403701), primarily used to transfer model and task status*)




(*------------- Transfer Data from Fix01 or 02 to EOAT04 Upon Pickup ----------------*)
(*Fix01 / 02 are 1st Geo Set fixtures on TT01*)
	(*Picked up with EOAT Side 1*)
	RPulse[1].CLK:= Fix01.Unload_Complete1_Ack;
	RPulse[1]();
	IF RPulse[1].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix01_ProductData_Pers;
			Fix01_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Picked up with EOAT Side 1*)
	RPulse[3].CLK:= Fix02.Unload_Complete1_Ack;
	RPulse[3]();
	IF RPulse[3].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix02_ProductData_Pers;
			Fix02_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
(*--------------------------------------------------------------------------------*)



	
	
(*------------- Transfer Data from EOAT04 to Fix101 Upon Dropoff ----------------*)
(*Fix101 is 1st Finishing Fixture*) 
	(*Placed with EOAT Side 1*)
	RPulse[5].CLK:= Fix101.Load_Complete1_Ack;
	RPulse[5]();
	IF RPulse[5].Q
		THEN
			Fix101_ProductData_Pers:= EOAT04_1_ProductData_Pers;
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	(*Placed with EOAT Side 2*)
	RPulse[6].CLK:= Fix101.Load_Complete2_Ack;
	RPulse[6]();
	IF RPulse[6].Q
		THEN
			Fix101_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
(*------------- Transfer Data from Fix101 to EOAT04 Upon Pickup ----------------*)
	(*Picked up with EOAT Side 2*)
	RPulse[8].CLK:= Fix101.Unload_Complete1_Ack;
	RPulse[8]();
	IF RPulse[8].Q
		THEN
			EOAT04_2_ProductData_Pers:= Fix101_ProductData_Pers;
			Fix101_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	
	(*Blank Data in Fix101 if required by UI*)
	IF (In_From_ICxx.CustomApplication_REQS.17 AND Fix101.Tool_At_Home AND Fix101.All_Sensors_Off AND Fix101.In_Manual) 
		OR Fix101.Reset_All_Completes
		THEN
			Fix101_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)


	
	
	
(*------------- Transfer Data from EOAT04 to Fix03 or Fix04 Upon Dropff ----------------*)
(*Fix03 / 04 are 2nd Geo Set + Finishing fixtures on TT02*)
	(*Placed with EOAT Side 2*)
	RPulse[10].CLK:= Fix03.Load_Robots_Complete1;
	RPulse[10]();
	IF RPulse[10].Q
		THEN
			Fix03_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Placed with EOAT Side 2*)
	RPulse[12].CLK:= Fix04.Load_Complete1_Ack;
	RPulse[12]();
	IF RPulse[12].Q
		THEN
			Fix04_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Blank Data in EOAT04 Side 1*)
	IF In_From_ICxx.CustomApplication_REQS.29 AND MAIN.R4.At_Home AND EOAT04.EOAT_Part1_Empty
		THEN
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Blank Data in EOAT04 Side 2*)
	IF In_From_ICxx.CustomApplication_REQS.30 AND MAIN.R4.At_Home AND EOAT04.EOAT_Part2_Empty
		THEN
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Blank EOAT04 Data in event of a full empty check*)
	RPulse[13].CLK:= EOAT04.CMD_CheckAllSensors_OFF AND EOAT04.EOAT_Part1_Empty AND EOAT04.EOAT_Part2_Empty;
	RPulse[13]();
	IF RPulse[13].Q
		THEN
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	
(*--------------------------------------------------------------------------------*)


(*------------- Transfer Data from Fix03 or 04 to EOAT04 Pickup ----------------*)
	(*Picked up with EOAT Side 1*)
	RPulse[14].CLK:= Fix03.Unload_Complete1_Ack;
	RPulse[14]();
	IF RPulse[14].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix03_ProductData_Pers;
			Fix03_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Picked up with EOAT Side 1*)
	RPulse[16].CLK:= Fix04.Unload_Complete1_Ack;
	RPulse[16]();
	IF RPulse[16].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix04_ProductData_Pers;
			Fix04_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	
   (*Blank Data in Fix03*)
	IF (In_From_ICxx.CustomApplication_REQS.3 AND Fix03.Tool_At_Home AND Fix03.All_Sensors_Off AND Fix03.In_Manual) 
		THEN
			Fix03_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

	(*Blank Data in Fix04*)
	IF (In_From_ICxx.CustomApplication_REQS.4 AND Fix04.Tool_At_Home AND Fix04.All_Sensors_Off AND Fix04.In_Manual) 
		THEN
			Fix04_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)
	
	
	
	
	
(*------------- Transfer Data from EOAT04 to Fix102 Upon Dropoff ----------------*)
(*Fix102 is Insepction Area*)
	(*Placed with EOAT Side 1*)
	RPulse[18].CLK:= Fix102.Load_Complete1_Ack;
	RPulse[18]();
	IF RPulse[18].Q
		THEN
			Fix102_ProductData_Pers:= EOAT04_1_ProductData_Pers;
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	
(*------------- Transfer Data from FIX102 to EOAT04 Upon Pickup ----------------*)
	(*Picked up with EOAT Side 2*)
	RPulse[20].CLK:= Fix102.Unload_Complete1_Ack;
	RPulse[20]();
	IF RPulse[20].Q
		THEN
			EOAT04_2_ProductData_Pers:= Fix102_ProductData_Pers;
			Fix102_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	(*Picked up with EOAT Side 1*)
	RPulse[21].CLK:= Fix102.Unload_Complete2_Ack;
	RPulse[21]();
	IF RPulse[21].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix102_ProductData_Pers;
			Fix102_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
		
	(*Blank Data in Fix102*)
	IF (In_From_ICxx.CustomApplication_REQS.18 AND Fix102.Tool_At_Home AND Fix102.All_Sensors_Off AND Fix102.In_Manual) 
		OR Fix102.Reset_All_Completes
			THEN
			Fix102_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)

	
	
	
	
(*------------- Transfer Data from Fix05 to EOAT04 Upon Pickup ----------------*)
(*Fix05 is Rework Insert only station*)
	(*Picked up with EOAT Side 1*)
	RPulse[22].CLK:= Fix05.Unload_Complete1_Ack;
	RPulse[22]();
	IF RPulse[22].Q
		THEN
			EOAT04_1_ProductData_Pers:= Fix05_ProductData_Pers;
			Fix05_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	(*Picked up with EOAT Side 2*)
	RPulse[23].CLK:= Fix05.Unload_Complete2_Ack;
	RPulse[23]();
	IF RPulse[23].Q
		THEN
			EOAT04_2_ProductData_Pers:= Fix05_ProductData_Pers;
			Fix05_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
(*--------------------------------------------------------------------------------*)
	
	
	

(*------------- Transfer Data from EOAT04 to Fix103 Upon Dropoff ----------------*)
(*Fix103 is QA Request / NOK Offload only station*)
	(*Placed with EOAT Side 1*)
	RPulse[24].CLK:= Fix103.Load_Complete1_Ack;
	RPulse[24]();
	IF RPulse[24].Q
		THEN
			Fix103_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	(*Placed with EOAT Side 2*)
	RPulse[25].CLK:= Fix103.Load_Complete2_Ack;
	RPulse[25]();
	IF RPulse[25].Q
		THEN
			Fix103_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;
	
	(*Blank Data in Fix103*)
	IF (In_From_ICxx.CustomApplication_REQS.19 AND Fix103.Tool_At_Home AND Fix103.All_Sensors_Off AND Fix103.In_Manual) 
		OR Fix103.Reset_All_Completes
			THEN
			Fix103_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)

	
	
	
(*------------- Transfer Data from EOAT04 to Fix104 Upon Dropoff ----------------*)
(*Fix104 is Buffer to load finished parts on if Paint is down*)
	(*Placed with EOAT Side 1*)
	RPulse[26].CLK:= Fix104.Load_Complete1_Ack;
	RPulse[26]();
	IF RPulse[26].Q
		THEN
			IF (Fix104.Fix_ID >=1 AND  Fix104.Fix_ID<=5)
				THEN
					Fix104_ProductData_Pers[Fix104.Fix_ID]:= EOAT04_1_ProductData_Pers;
					EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
				END_IF
	END_IF;	
	(*Placed with EOAT Side 2*)
	RPulse[27].CLK:= Fix104.Load_Complete2_Ack;
	RPulse[27]();
	IF RPulse[27].Q
		THEN
			IF (Fix104.Fix_ID >=1 AND  Fix104.Fix_ID<=5)
				THEN
					Fix104_ProductData_Pers[Fix104.Fix_ID]:= EOAT04_2_ProductData_Pers;
					EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
				END_IF
	END_IF;	
	
	(*Blank Data in Fix104*)
	IF (In_From_ICxx.CustomApplication_REQS.20 AND Fix104.Tool_At_Home AND Fix104.All_Sensors_Off AND Fix104.In_Manual) 
		OR Fix104.Reset_All_Completes
			THEN
			Fix104_ProductData_Pers[0]:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)




	
(*------------- Transfer Data from EOAT04 to Fix105 Upon Dropoff ----------------*)
(*Fix105 is final offload to Paint*)
	(*Placed with EOAT Side 1*)
	RPulse[28].CLK:= Fix105.Load_Complete1_Ack;
	RPulse[28]();
	IF RPulse[28].Q
		THEN
			Fix105_ProductData_Pers:= EOAT04_1_ProductData_Pers;
			EOAT04_1_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;	
	(*Placed with EOAT Side 2*)
	RPulse[29].CLK:= Fix105.Load_Complete2_Ack;
	RPulse[29]();
	IF RPulse[29].Q
		THEN
			Fix105_ProductData_Pers:= EOAT04_2_ProductData_Pers;
			EOAT04_2_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;	
	
	(*Blank Data in Fix105*)
	IF (In_From_ICxx.CustomApplication_REQS.21 AND Fix105.Tool_At_Home AND Fix105.All_Sensors_Off AND Fix105.In_Manual) 
		OR Fix105.Reset_All_Completes
			THEN
			Fix105_ProductData_Pers:= Blank_ProductData_Pers;
	END_IF;

(*--------------------------------------------------------------------------------*)
	
	

	
	
	
	
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Robots" Id="{24524792-0aca-4eae-af81-38966ec4ed01}">
      <Implementation>
        <ST><![CDATA[


(*R1 ------------------------*)
		(*Input Data*)
		R1.FB_In.Robot_Type:=KUKA_KRC4_SAFEOP_TurnTable;
