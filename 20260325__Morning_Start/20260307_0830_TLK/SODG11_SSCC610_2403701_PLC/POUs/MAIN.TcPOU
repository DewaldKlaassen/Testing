		R1.FB_In.OK_ToEnter_EquipInterf6:=R1_Data.OK_ToEnter_EquipInterf6;
		R1.FB_In.OK_ToEnter_EquipInterf7:=R1_Data.OK_ToEnter_EquipInterf7;
