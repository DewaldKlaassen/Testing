			THEN Out_To_ICxx.TT01_Location_Index:= 2;
		ELSE
			Out_To_ICxx.TT01_Location_Index:= 0;
		END_IF*)	//DEBUG - RJ - REMOVE ABOVE AFTER SIM, RESTORE original
		Out_To_ICxx.TT01_Location_Index:= R1.TT_Axis_Location_Index;


(*R2 ------------------------*)
		(*Input Data*)
