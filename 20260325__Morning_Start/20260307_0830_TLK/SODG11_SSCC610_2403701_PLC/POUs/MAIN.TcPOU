		R1.FB_In.SIM_StartWorkAround:= FALSE;  (*Main.SIM_WorkAround_StartRobots*)
		R1.FB_In.CoE_Read_Trigger:= (GTAC_CONFIG.Option_Robot_Count>=1) AND Pulse_CoERead;
		R1.FB_In.Ecat_Master_AmsNetID:= MAIN.ECAT_Master.AmsID;
		R1.FB_In.Prev_EcatNode_Present:= NOT MD01.EP1918_NotPresent; (*Ensure Previous Node Exists to determine Ecat Cable Break of this Devices Input Cable*)
		R1.FB_In.Safety_RST:=SAFETY_RESET;
		R1.FB_In.Enable_Motion:= All_Estops_OK OR GTAC_CONFIG.Under_Construction;
		R1.FB_In.Alarm_RST:=In_From_ICxx.ControlPower1;
		R1.FB_In.Select_Play:=FALSE;
		R1.FB_In.Select_Teach:=FALSE;
		R1.FB_In.Select_Remote:=FALSE;
		R1.FB_In.Start_Scan:=In_From_ICxx.StartRobots;
