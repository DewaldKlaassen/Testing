		R1.FB_In.OK_ToEnter_HumanInterf2:=R1_Data.OK_ToEnter_HumanInterf2;
		R1.FB_In.OK_ToEnter_HumanInterf3:=R1_Data.OK_ToEnter_HumanInterf3;
		R1.FB_In.OK_ToEnter_HumanInterf4:=R1_Data.OK_ToEnter_HumanInterf4;
		R1.FB_In.OK_ToEnter_HumanInterf5:=R1_Data.OK_ToEnter_HumanInterf5;
		R1.FB_In.OK_ToEnter_HumanInterf6:=R1_Data.OK_ToEnter_HumanInterf6;
		R1.FB_In.OK_ToEnter_HumanInterf7:=R1_Data.OK_ToEnter_HumanInterf7;
		R1.FB_In.OK_ToEnter_HumanInterf8:=R1_Data.OK_ToEnter_HumanInterf8;
		R1.FB_In.OK_ToEnter_RobotInterfs:= R1_Data.OK_ToEnter_RobotInterfs;
		R1.FB_In.Fix_ID:= R1_Data.Fix_ID[R1.Location_Index];
		R1.FB_In.Model_ID:= R1_Data.Model_ID[R1.Location_Index];
		R1.FB_In.Task_ID:= R1_Data.Task_ID[R1.Location_Index];
		R1.FB_In.Proceed_From_Pounce:= R1_Data.Proceed_From_Pounce[R1.Location_Index];
		R1.FB_In.Complete_Ack:= R1_Data.Complete_Ack[R1.Location_Index];
		R1.FB_In.PeripheralReq_Ack:= R1_Data.PeripheralReq_Ack[R1.Location_Index];
		R1.FB_In.AuxReq_Ack:= R1_Data.AuxReq_Ack[R1.Location_Index];
		R1.FB_In.User_Inputs.0:= R2.User_Outputs.0 AND R3.User_Outputs.0; (*confirm table position to weld main*)
		R1.FB_In.User_Inputs.1:= NOT R2.User_Outputs.1 AND R3.User_Outputs.1; (*confirm table position to weld subs*)
		R1.FB_In.User_Inputs.2:= R2.User_Outputs.2 AND R3.User_Outputs.2;
		R1.FB_In.User_Inputs.3:= R2.User_Outputs.2 AND R3.User_Outputs.2 AND R2.User_Outputs.3;
		R1.FB_In.User_Inputs.4:= FALSE;
		R1.FB_In.User_Inputs.5:= FALSE;
		R1.FB_In.User_Inputs.6:= FALSE;
		R1.FB_In.User_Inputs.7:= FALSE;
			(*Configure Options Amounts*)
			R1.FB_In.Options.WeldCont_Amount:=0; 					(*Select amount of Spot Type Weld Controllers here (0 min, 4 max)*)
			R1.FB_In.Options.WaterStand_Amount:= 0;				(*Select amount of Water Stands here (0 min, 2 max)*)
			R1.FB_In.Options.MIGCont_Amount:= 1;					(*Select amount of MIG Type Weld Controllers here (0 min, 1 max)*)
			R1.FB_In.Options.Reamer_Amount:= 1;					(*Select amount of Tip Reamers here (0 min, 1 max)*)
			R1.FB_In.Options.EOAT_Amount:= 0;						(*Assign EOAT number to robot (0 min, 10 max)*)
			(*Configure Options Parameters*)
			
			(*R1.Reamer[1](
				(*FB Inputs*)
					Enable_Motion:= All_Estops_OK,
					Fronius_Ream:= TRUE,
                    Binzel_Ream:= FALSE,  (*optional*)
					Ream_REQ:= R1.Peripheral_Req.5 AND (R1.Task_ID_Ack=Tip_Dress),

				(*FB Outputs*)
					Reaming_Complete=> ,(*mapped in cell services*)
					);*)
					
			R1.Reamer[1](
				(*FB Inputs*)
					Enable_Motion:= All_Estops_OK,
					Fronius_Ream:= TRUE,
                    Binzel_Ream:= FALSE,  (*optional*)
					
					Ream_REQ:= R1.Peripheral_Req.1 AND ((R1.Task_ID_Ack=Tip_Dress)OR (R1.In_T1 AND R1.Peripheral_Req.5)),
					Ream_Time:= T#2S,
					Ream_Clamp_Open:= R1.Reamer[1].N01.I.1,
					Spray_REQ:= R1.Peripheral_Req.2 AND ((R1.Task_ID_Ack=Tip_Dress)OR (R1.In_T1 AND R1.Peripheral_Req.5)),
					Spray_Time:= T#2S,
					F_WireCutter_REQ:= R1.Peripheral_Req.4 AND ((R1.Task_ID_Ack=Tip_Dress)OR (R1.In_T1 AND R1.Peripheral_Req.5)),
					F_WireCutter_Time:= T#1S,
					
				(*FB Outputs*)
					Reaming_Complete=> ,(*mapped in cell services*)
					(*The following are for Binzel type reamers only*)
					LifterUp_ACK=> , (*mapped in cell services*)
					Clamp_ACK=>,(*mapped in cell services*)
					Injector_ACK=> ,(*mapped in cell services*)
					WireCutter_ACK=> (*mapped in cell services*)
					);		
		(*Call Actual Object*)
		R1();
		(*Output Data*)
		Out_To_ICxx.Robot[1].Robot_Type:= R1.FB_In.Robot_Type;
		Out_To_ICxx.Robot[1].Status:= R1.Status;
		Out_To_ICxx.Robot[1].Axis_Data[1]:= R1.S_Axis_Pos_Raw; 
		Out_To_ICxx.Robot[1].In_Image:= R1.Input_Image;
		Out_To_ICxx.Robot[1].Out_Image:= R1.Output_Image;
		Out_To_ICxx.Robot[1].Discrete_ImageFSOE:= R1.Discrete_Image_FSoE;
		Out_To_ICxx.Robot[1].Options:= R1.FB_In.Options;
			Out_To_ICxx.Robot[1].WS_Discrete_Image[1]:= R1.WS[1].Discrete_Image;
			Out_To_ICxx.Robot[1].WS_Discrete_Image[2]:= R1.WS[2].Discrete_Image;
 			Out_To_ICxx.Robot[1].ATI_Discrete_Image:= R1.ATI[1].Discrete_Image;
			Out_To_ICxx.Robot[1].Reamer_Discrete_Image:= R1.Reamer[1].Discrete_Image;
			Out_To_ICxx.Robot[1].Fronius_Status:= R1.Fronius_Status;
		Out_To_ICxx.Robot[1].Ped_IO_ToShow[1]:= 0;			(*Set to Ped value if this robots ecat string contains the Ped's IO*)
		Out_To_ICxx.Robot[1].Ped_IO_ToShow[2]:= 0;			(*Set to Ped value if this robots ecat string contains the Ped's IO*)
		Out_To_ICxx.Robot[1].ECAT_Cable_Breaks:= R1.ECatSlave_Cable_Breaks;
		Out_To_ICxx.Robot[1].CT:= R1.CT;
		(*Example of passing Turntable Axis Data*)
