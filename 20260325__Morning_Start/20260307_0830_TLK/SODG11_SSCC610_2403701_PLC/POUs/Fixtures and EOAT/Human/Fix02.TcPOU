    <Action Name="Hardware" Id="{3766533a-c948-4c48-910d-2d1d0c6daeed}">
      <Implementation>
        <ST><![CDATA[
(*Pass Node States into Array  in order on Physical Fixture*)

	NodeState:=NodeLayout.State;

	
(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Sub Fixture Nodes ok*)
	IF 	(Model_ID=1 AND N32.InfoData.State=8 AND N33.InfoData.State=8) (*Model 504 (1) and Model 524(2) uses Nodes 31/32*)
			OR
		(Model_ID=2 AND N32.InfoData.State=8 AND N33.InfoData.State=8)
			OR
		(Model_ID=3 AND N42.InfoData.State=8 AND N43.InfoData.State=8) (*Model 543 (3) uses Nodes 42/43*)
			OR
		(Model_ID=4 AND N40.InfoData.State=8 AND N41.InfoData.State=8) (*Model 526 (4) uses Nodes 40/41*)
			OR
		(Model_ID=5 AND N38.InfoData.State=8 AND N39.InfoData.State=8) (*Model 536 (5) uses Nodes 38/39*)
			OR
		(Model_ID=6 AND N36.InfoData.State=8 AND N37.InfoData.State=8) (*Model 550 (6) uses Nodes 36/37*)
			OR
		(Model_ID=7 AND N34.InfoData.State=8 AND N35.InfoData.State=8) (*Model 571 (7) uses Nodes 34/35*)
		THEN
			SubNode_OK:= TRUE;
	ELSE
			SubNode_OK:= FALSE;
	END_IF;
	
	
	(*Discrete I/O Nodes*)
	IF (*(N00.InfoData.State=8 AND SubNode_OK)*) (*Fix doesn't have an EP1111*)
		(N01.InfoData.State=8 OR (Discrete_In.Input_Node_Count<2))
		AND (N02.InfoData.State=8 OR (Discrete_In.Input_Node_Count<3))
		AND (N03.InfoData.State=8 OR (Discrete_In.Input_Node_Count<4))
		AND (N04.InfoData.State=8 OR (Discrete_In.Input_Node_Count<5))
		AND (N05.InfoData.State=8 OR (Discrete_In.Input_Node_Count<6))
		AND (N06.InfoData.State=8 OR (Discrete_In.Input_Node_Count<7))
		AND (N07.InfoData.State=8 OR (Discrete_In.Input_Node_Count<8))
		AND (N08.InfoData.State=8 OR (Discrete_In.Input_Node_Count<9))
		AND (N09.InfoData.State=8 OR (Discrete_In.Input_Node_Count<10))
		AND (N10.InfoData.State=8 OR (Discrete_In.Input_Node_Count<11))
		AND (N11.InfoData.State=8 OR (Discrete_In.Input_Node_Count<12))
		AND (N12.InfoData.State=8 OR (Discrete_In.Input_Node_Count<13))
		AND (N13.InfoData.State=8 OR (Discrete_In.Input_Node_Count<14))
		AND (N14.InfoData.State=8 OR (Discrete_In.Input_Node_Count<15))
		AND (N15.InfoData.State=8 OR (Discrete_In.Input_Node_Count<16))
		AND (N16.InfoData.State=8 OR (Discrete_In.Input_Node_Count<17))
		AND (N17.InfoData.State=8 OR (Discrete_In.Input_Node_Count<18))
		AND (N18.InfoData.State=8 OR (Discrete_In.Input_Node_Count<19))
		AND (N19.InfoData.State=8 OR (Discrete_In.Input_Node_Count<20))
		AND (N20.InfoData.State=8 OR (Discrete_In.Input_Node_Count<21))
		AND (N21.InfoData.State=8 OR (Discrete_In.Input_Node_Count<22))
		AND (N22.InfoData.State=8 OR (Discrete_In.Input_Node_Count<23))
		AND (N23.InfoData.State=8 OR (Discrete_In.Input_Node_Count<24))
		AND (N24.InfoData.State=8 OR (Discrete_In.Input_Node_Count<25))
		AND (N25.InfoData.State=8 OR (Discrete_In.Input_Node_Count<26))
		AND (N26.InfoData.State=8 OR (Discrete_In.Input_Node_Count<27))
		AND (N27.InfoData.State=8 OR (Discrete_In.Input_Node_Count<28))
		AND (N28.InfoData.State=8 OR (Discrete_In.Input_Node_Count<29))
		AND (N29.InfoData.State=8 OR (Discrete_In.Input_Node_Count<30))
		AND (N30.InfoData.State=8 OR (Discrete_In.Input_Node_Count<31))
		AND (N31.InfoData.State=8 OR (Discrete_In.Input_Node_Count<32))
		AND (N100_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<1))
		AND (N101_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<2))
		AND (N102_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<3))


		THEN
			DiscreteNode_OK:=TRUE;

	ELSE
			DiscreteNode_OK:=FALSE;

	END_IF;


	(*Cable Break Detection*)
	(*Function Returns Flags to warn of possible cable break*)
	ECatSlave_Cable_Breaks:= FUN_GTAC_EcatSlaveConnState_64bit(NodeState);			
	





















(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Production" Id="{429be758-894e-4c54-a61b-bc0e96cdde59}">
      <Implementation>
        <ST><![CDATA[(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Production Information $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Increment Production Counter*)
	Prod_Inc.CLK:= Unload_Complete;
	Prod_Inc();
	IF Prod_Inc.Q
		THEN
		Production_Count:= Production_Count+1;
	END_IF;
	IF Discrete_In.ResetProd
		THEN
		Production_Count:= 0;
	END_IF;
	Prod_Count_Out:= Production_Count;

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Production Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Input Data*)
	Production_Report.Machine_Serial:= GTAC_CONFIG.Machine_Serial;
	Production_Report.Machine_Common_Name:= GTAC_CONFIG.Machine_Common_Name;
	Production_Report.Prod_Inc:= Prod_Inc.Q;
	Production_Report.Scrap_Inc:= In_From_ICxx.QA_Request_RH;
	Production_Report.Scrap_Dec:= In_From_ICxx.QA_Reinsert_RH;
	Production_Report.Reference_TimeDate:= MAIN.Local_Time;
	Production_Report.Reference_Target_Time:= GTAC_CONFIG.ProdConfig_Target_CycleTime; 					(*This is the machine Expected Cycle Time*)
	Production_Report.Config_Day_TOD:= GTAC_CONFIG.ProdConfig_Day;										(*Pass Each Shift Configuration Structure (Start/End Time, Break Times etc*)
	Production_Report.Config_Aft_TOD:= GTAC_CONFIG.ProdConfig_Aft;
	Production_Report.Config_Mid_TOD:= GTAC_CONFIG.ProdConfig_Mid;
	Production_Report.Config_Shift_Enables:= GTAC_CONFIG.ProdConfig_Common.Shift_Enables;					(*Enable Bits for Shifts*)
	Production_Report.Config_Break_Count:= GTAC_CONFIG.ProdConfig_Common.Break_Count;						(*Select Amount of Breaks per shift*)
	Production_Report.Machine_StoppedBy_Fault:= Faults.System_Major_Fault;
	Production_Report.Enable_InShift_Change:= GTAC_CONFIG.ProdConfig_Option_SelectInShiftChange;				(*Allows Operator 5 mins at start and end of shift for clean up*)
	(*Call FB*)
	IF NOT MAIN.Starting_Scan_Pulse
		THEN
		Production_Report();
	END_IF;
	(*Output Data*)
	Out_To_ICxx.ProdReport[2].Curr_Prod_Report:= Production_Report.Shift_Report[0];
	Out_To_ICxx.ProdReport[2].Days_Prod_Report:= Production_Report.Shift_Report[1];
	Out_To_ICxx.ProdReport[2].Aft_Prod_Report:= Production_Report.Shift_Report[2];
	Out_To_ICxx.ProdReport[2].Mid_Prod_Report:= Production_Report.Shift_Report[3];

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Cycle Time Counters ~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Move Previous To Register*)
	Cycle_Time_Pulse.CLK:= Unload_Complete;
	Cycle_Time_Pulse();
	IF Cycle_Time_Pulse.Q
		THEN
		PrevCycle_Time_Out:= Cycle_Time_Out;
	END_IF;
	(*Monitor Current Cycle Time (Full Cycle Time of Process)*)
		Cycle_Time.PT:= T#9999S;
		Cycle_Time.IN:= NOT Cycle_Time_Pulse.Q AND In_Auto;
		Cycle_Time();
		Cycle_Time_Out:= Cycle_Time.ET;

	(*Monitor Load Time*)
		IF In_Auto AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_Weld_Robots  AND NOT Weld_Robots_Clear AND NOT Unload_Complete
			THEN
			Load_Time_Out:= Load_Time.ET;
		END_IF;
		Load_Time.PT:= T#9999S;
		Load_Time.IN:= In_Auto AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_Weld_Robots  AND NOT Weld_Robots_Clear AND NOT Unload_Complete;
		Load_Time();

	(*Monitor Robot Sealing Time*)
		IF NOT Seal_Robots_Clear
			THEN
			Seal_Time_Out:= Seal_Time.ET;
		END_IF;
		Seal_Time.PT:= T#9999S;
		Seal_Time.IN:= NOT Seal_Robots_Clear;
		Seal_Time();

	(*Monitor Robot Stud Time*)
		IF NOT Stud_Robots_Clear
			THEN
			Stud_Time_Out:= Stud_Time.ET;
		END_IF;
		Stud_Time.PT:= T#9999S;
		Stud_Time.IN:= NOT Stud_Robots_Clear;
		Stud_Time();

	(*Monitor Robot Welding Time*)
		IF NOT Weld_Robots_Clear
			THEN
			Weld_Time_Out:= Weld_Time.ET;
		END_IF;
		Weld_Time.PT:= T#9999S;
		Weld_Time.IN:= NOT Weld_Robots_Clear;
		Weld_Time();

	(*Monitor Robot Turntable Time*)
		IF NOT Turntable_Clear
			THEN
			Turn_Time_Out:= Turn_Time.ET;
		END_IF;
		Turn_Time.PT:= T#9999S;
		Turn_Time.IN:= NOT Turntable_Clear;
		Turn_Time();

	(*Monitor Unload Time*)
		IF Welding_Complete
			THEN
			Unload_Time_Out:= Unload_Time.ET;
		END_IF;
		Unload_Time.PT:= T#9999S;
		Unload_Time.IN:= Welding_Complete;
		Unload_Time();



(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Product Data Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
(*Can be used to load and store product specific data (pass fail results, measurements etc) into DB*)
(*Triggers to start actual storage are contained in GTAC_CONFIG.Reports*)

(*Load Data into persistent area*)
	Fix02_ProductData_Pers.Product_Model_ID:= Model_ID;
	Fix02_ProductData_Pers.Machine_Serial:= GTAC_CONFIG.Machine_Serial;
	Fix02_ProductData_Pers.Machine_Common_Name:= GTAC_CONFIG.Machine_Common_Name;
	Fix02_ProductData_Pers.Operator_ID:= 0;					(*for future*)
	Fix02_ProductData_Pers.Product_Serial:= 'NA';
	CASE Model_ID OF
		1:	Fix02_ProductData_Pers.Product_Number:= '504';
		2:	Fix02_ProductData_Pers.Product_Number:= '524';
		3:	Fix02_ProductData_Pers.Product_Number:= '543';
		4:	Fix02_ProductData_Pers.Product_Number:= '526';
		5:	Fix02_ProductData_Pers.Product_Number:= '536';
		6:	Fix02_ProductData_Pers.Product_Number:= '550';
		7:	Fix02_ProductData_Pers.Product_Number:= '571';
	END_CASE;
	Fix02_ProductData_Pers.Product_Common_Name:= 'Volvo Bumper';
		(*Build part specific data arrays, simply leave un-used elements blank (Arrays are [0..31]*)
		(*Pass / Fail Notes - Used to capture overall terms like 'Pass' 'Fail' 'NA' etc.*)	
		IF Weld_Complete_Ack THEN
			Fix02_ProductData_Pers.Generic_PassFail_Notes[1]:= 'Comp';
		END_IF;
		
	(*Transfer Product Data to UI, see MAIN.Product_Data*)		
	Out_To_ICxx.ProductReport[2]:= Fix02_ProductData_Pers; 	
		









]]></ST>
      </Implementation>
    </Action>
