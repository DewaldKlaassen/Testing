										OR (N100.Q.27 AND NOT (Slide1RETD AND Slide2RETD (*AND Slide14RETD AND Slide15RETD*)))
										OR (N100.Q.30 AND NOT (Slide3ADVD AND Slide5ADVD AND Slide9ADVD AND Slide12ADVD AND Slide13ADVD))
										OR (N100.Q.31 AND NOT (Slide3RETD AND Slide5RETD AND Slide9RETD AND Slide12RETD AND Slide13RETD))
										OR (N101.Q.14 AND NOT ((*Slide1ADVD AND Slide2ADVD AND*) Slide14ADVD AND Slide15ADVD))
										OR (N101.Q.15 AND NOT ((*Slide1RETD AND Slide2RETD AND*) Slide14RETD AND Slide15RETD)),
