    <Action Name="Tool_VBSeq_Repos" Id="{8b61678f-f9f6-453d-95ff-a1112adfd73f}">
      <Implementation>
        <ST><![CDATA[(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)


(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Tool Motion Control !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)

(*----------------------------------------- Clamp / Unclamp Steps -------------------------------*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Develop Clamp and Unclamp Interlocks $$$$$$$$$$$$$$$$$$$$$$*)
(* Note: This is one method to create valve bank commands for clamp and unclamp sequencing
you are welcome to use the direct method as well*)

	(*Start Clamp Sequence*)
	
	
	(*First Stage Clamping*) (*V10, V11, V14, V15 ADV, IF Model 543, V19 ADV*)
	Clamp_Step.0:= (Auto_Run AND NOT Welding_Complete AND TurntableA_At_Robot AND Load_Complete1) 
				OR
					(Valve1FB.SideB_Indicator AND Valve2FB.SideB_Indicator AND Valve3FB.SideB_Indicator 
					AND Valve12FB.SideB_Indicator (*AND All_Subs_Complete*) AND TurntableB_At_Robot);

	(*Second Stage Clamping*)	(*V6, V12, V13, V23 ADV, IF Model 543, V20, V21 ADV*)
	IF NOT ((Model_ID=3) OR (Model_ID=10)) AND Load_Complete1 THEN
				Clamp_Step.1:=  Clamp_Step.0 AND 
								(*V10*)
								(Slide4ADVD AND Slide8ADVD AND Slide11ADVD)
								(*V11*)
								AND (Slide6ADVD)
								(*V14*)
								AND (Slide1ADVD AND Slide2ADVD (*AND Slide14ADVD AND Slide15ADVD*))
								(*V15*)
								AND (Pin1ADVD AND Pin4ADVD AND Pin8ADVD)
								(*V24*)
								AND (Slide14ADVD AND Slide15ADVD);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) AND Load_Complete1 THEN
				Clamp_Step.1:=  Clamp_Step.0 AND 
								(*V10*)
								(Slide4ADVD AND Slide8ADVD AND Slide11ADVD)
								(*V11*)
								AND (Slide6ADVD)
								(*V14*)
								AND (Slide1ADVD AND Slide2ADVD (*AND Slide14ADVD AND Slide15ADVD*))
								(*V15*)
								AND (Pin1ADVD AND Pin4ADVD AND Pin8ADVD)
								(*V19*)
								AND (Pin2ADVD AND Pin5ADVD AND Pin7ADVD)
								(*V24*)
								AND (Slide14ADVD AND Slide15ADVD);
		ELSE
			Clamp_Step.1:= FALSE;
	END_IF

	(*Third Stage Clamping*)	(*V1-V7, V23 ADV, IF Model 504, 524, V8 ADV, IF Model 526, 536, 550, 571, V9 ADV, IF Model 543, V18 ADV*)
	IF ((Model_ID=1) OR (Model_ID=8) OR (Model_ID=2) OR (Model_ID=9)) THEN
				Clamp_Step.2:= Clamp_Step.1 AND 
								(*V12*)
								(Slide7ADVD);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) THEN
				Clamp_Step.2:= Clamp_Step.1 AND 
								(*V12*)
								(Slide7ADVD)
								(*V13*)
								AND (Slide10RETD)
								(*V20*)
								AND (Clamp8ADVD AND Clamp24ADVD AND Clamp31ADVD)
								(*V21*)
								AND (Clamp10ADVD AND Clamp27ADVD);
		ELSIF ((Model_ID =4) OR (Model_ID=5) OR (Model_ID=6) OR (Model_ID =7) OR (Model_ID=11) OR (Model_ID=12) OR (Model_ID=13) OR (Model_ID=14)
		   OR (Model_ID=15) OR (Model_ID=16) OR (Model_ID=17) OR (Model_ID=18) OR (Model_ID=19) OR (Model_ID=20) OR (Model_ID=21) OR (Model_ID=22)) THEN
				Clamp_Step.2:= Clamp_Step.1 AND 
								(*V12*)
								(Slide7ADVD)
								(*V13*)
								AND (Slide10ADVD);
		ELSE
			Clamp_Step.2:= FALSE;
	END_IF
														
	(*Forth Stage Clamping*)	(*Fire QAs - V17*)
	IF ((Model_ID=1) OR (Model_ID=8) OR (Model_ID=2) OR (Model_ID=9)) THEN
				Clamp_Step.3:= Clamp_Step.2 AND 
								(*V1*)
								(Clamp1ADVD AND Clamp2ADVD AND Clamp32ADVD AND Clamp37ADVD)
								(*V2*)
								AND (Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD)
								(*V3*)
								AND (Clamp16ADVD AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD)
								(*V4*)
								AND (Clamp3ADVD AND Clamp12ADVD AND Clamp20ADVD AND Clamp28ADVD AND Clamp34ADVD)
								(*V5*)
								AND (Clamp4ADVD AND Clamp11ADVD (*AND Clamp21ADVD*) AND Clamp29ADVD AND Clamp33ADVD)
								(*V6*)
								AND (Clamp6ADVD AND Clamp9ADVD AND Clamp30ADVD AND Clamp36ADVD)
								(*V7*)
								AND (Clamp7ADVD AND Clamp35ADVD)
								(*V8*)
								AND (Clamp22ADVD AND Clamp26ADVD)
								(*V23*)
								AND (Clamp21ADVD);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) THEN
				Clamp_Step.3:= Clamp_Step.2 AND 
								(*V1*)
								(Clamp1ADVD AND Clamp2ADVD AND Clamp32ADVD AND Clamp37ADVD)
								(*V2*)
								AND (Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD)
								(*V3*)
								AND (Clamp16ADVD AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD)
								(*V4*)
								AND (Clamp3ADVD AND Clamp12ADVD AND Clamp20ADVD AND Clamp28ADVD AND Clamp34ADVD)
								(*V5*)
								AND (Clamp4ADVD AND Clamp11ADVD (*AND Clamp21ADVD*) AND Clamp29ADVD AND Clamp33ADVD)
								(*V6*)
								AND (Clamp6ADVD AND Clamp9ADVD AND Clamp30ADVD AND Clamp36ADVD)
								(*V18*)
								AND (Pin3ADVD AND Pin6ADVD)
								(*V23*)
								AND (Clamp21ADVD);
		ELSIF ((Model_ID =4) OR (Model_ID=5) OR (Model_ID=6) OR (Model_ID =7) OR (Model_ID=11) OR (Model_ID=12) OR (Model_ID=13) OR (Model_ID=14)
		   OR (Model_ID=15) OR (Model_ID=16) OR (Model_ID=17) OR (Model_ID=18) OR (Model_ID=19) OR (Model_ID=20) OR (Model_ID=21) OR (Model_ID=22)) THEN
				Clamp_Step.3:= Clamp_Step.2 AND 
								(*V1*)
								(Clamp1ADVD AND Clamp2ADVD AND Clamp32ADVD AND Clamp37ADVD)
								(*V2*)
								AND (Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD)
								(*V3*)
								AND (Clamp16ADVD AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD)
								(*V4*)
								AND (Clamp3ADVD AND Clamp12ADVD AND Clamp20ADVD AND Clamp28ADVD AND Clamp34ADVD)
								(*V5*)
								AND (Clamp4ADVD AND Clamp11ADVD (*AND Clamp21ADVD*) AND Clamp29ADVD AND Clamp33ADVD)
								(*V6*)
								AND (Clamp6ADVD AND Clamp9ADVD AND Clamp30ADVD AND Clamp36ADVD)
								(*V7*)
								AND (Clamp7ADVD AND Clamp35ADVD)
								(*V9*)
								AND (Clamp23ADVD AND Clamp25ADVD)
								(*V23*)
								AND (Clamp21ADVD);
		ELSE
			Clamp_Step.3:= FALSE;

	END_IF
	
	
	(*Fifth Stage Clamping*)	(*V16 ADV*)
	Clamp_Step.4:= Clamp_Step.3 AND
					CheckQA1FB.QAcheck_OK;
	
	
	
	
	(*Start Unclamp Sequence*)
	(*First Stage Unclamping*)	(*V11, V13, V15, V16 RET, IF Model 543, V18, V19 RET*)
	Unclamp_Step.0:= Welding_Complete AND TurntableB_At_Robot;
	
	(*Second Stage Unclamping*)	(*V4, V6, V14, V24 RET, IF Model 504, 524, V8 RET, IF Model 526, 536, 550, 571, V9 RET*)
	IF NOT ((Model_ID=3) OR (Model_ID=10)) THEN
					Unclamp_Step.1:= Unclamp_Step.0 AND 
									(*V11*)
									(Slide6RETD)
									(*V13*)
									AND (Slide10RETD)
									(*V15*)
									AND (Pin1RETD AND Pin4RETD AND Pin8RETD)
									(*V16*)
									AND (Clamp5RETD AND Clamp38RETD AND Slide3RETD AND Slide5RETD AND Slide9RETD AND Slide12RETD AND Slide13RETD);
									
		ELSIF ((Model_ID=3) OR (Model_ID=10)) THEN
					Unclamp_Step.1:= Unclamp_Step.0 AND 
									(*V11*)
									(Slide6RETD)
									(*V13*)
									AND (Slide10RETD)
									(*V15*)
									AND (Pin1RETD AND Pin4RETD AND Pin8RETD)
									(*V16*)
									AND (Clamp5RETD AND Clamp38RETD AND Slide3RETD AND Slide5RETD AND Slide9RETD AND Slide12RETD AND Slide13RETD)
									(*V18*)
									AND (Pin3RETD AND Pin6RETD)
									(*V19*)
									AND (Pin2RETD AND Pin5RETD AND Pin7RETD);
		ELSE
			Unclamp_Step.1:= FALSE;

	END_IF									

									
	(*Third Stage Unclamping*)	(*V5, V10 RET, IF NOT Model 543, V7 RET*)
	IF ((Model_ID=1) OR (Model_ID=8) OR (Model_ID=2) OR (Model_ID=9)) AND Repo_Reqs.0 THEN
					Unclamp_Step.2:= Unclamp_Step.1 AND TurntableB_At_Robot AND 
									(*V4*)
									(Clamp3RETD AND Clamp12RETD AND Clamp20RETD AND Clamp28RETD AND Clamp34RETD)
									(*V6*)
									AND (Clamp6RETD AND Clamp9RETD AND Clamp30RETD AND Clamp36RETD)
									(*V14*)
									AND (Slide1RETD AND Slide2RETD (*AND Slide14RETD AND Slide15RETD*))
									(*V8*)
									AND (Clamp22RETD AND Clamp26RETD)
									(*V24*)
									AND (Slide14RETD AND Slide15RETD);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) AND Repo_Reqs.0 THEN
					Unclamp_Step.2:= Unclamp_Step.1 AND TurntableB_At_Robot AND
									(*V4*)
									(Clamp3RETD AND Clamp12RETD AND Clamp20RETD AND Clamp28RETD AND Clamp34RETD)
									(*V6*)
									AND (Clamp6RETD AND Clamp9RETD AND Clamp30RETD AND Clamp36RETD)
									(*V14*)
									AND (Slide1RETD AND Slide2RETD (*AND Slide14RETD AND Slide15RETD*))
									(*V24*)
									AND (Slide14RETD AND Slide15RETD);
		ELSIF ((Model_ID =4) OR (Model_ID=5) OR (Model_ID=6) OR (Model_ID =7) OR (Model_ID=11) OR (Model_ID=12) OR (Model_ID=13) OR (Model_ID=14)
		   OR (Model_ID=15) OR (Model_ID=16) OR (Model_ID=17) OR (Model_ID=18) OR (Model_ID=19) OR (Model_ID=20) OR (Model_ID=21) OR (Model_ID=22)) AND Repo_Reqs.0 THEN
					Unclamp_Step.2:= Unclamp_Step.1 AND TurntableB_At_Robot AND
									(*V4*)
									(Clamp3RETD AND Clamp12RETD AND Clamp20RETD AND Clamp28RETD AND Clamp34RETD)
									(*V6*)
									AND (Clamp6RETD AND Clamp9RETD AND Clamp30RETD AND Clamp36RETD)
									(*V14*)
									AND (Slide1RETD AND Slide2RETD (*AND Slide14RETD AND Slide15RETD*))
									(*V9*)
									AND (Clamp23RETD AND Clamp25RETD)
									(*V24*)
									AND (Slide14RETD AND Slide15RETD);
		ELSE
			Unclamp_Step.2:= FALSE;
	END_IF				
		
	(*Fourth Stage Unclamping*)	(*V1-V3, V12 RET, IF Model 543, V20, V21 RET*)
	IF NOT ((Model_ID=3) OR (Model_ID=10)) AND (Unload_Complete AND TurntableA_At_Robot) (*AND All_Subs_Complete*) THEN
					Unclamp_Step.3:= (*(NOT Valve1FB.SideB_Indicator OR NOT Valve2FB.SideB_Indicator OR NOT Valve3FB.SideB_Indicator 
									OR NOT Valve12FB.SideB_Indicator) AND NOT Clamp_Step.0*) Unclamp_Step.2 AND 
									(*V5*)
									(Clamp4RETD AND Clamp11RETD (*AND Clamp21RETD*) AND Clamp29RETD AND Clamp33RETD)
									(*V10*)
									AND (Slide4RETD AND Slide8RETD AND Slide11RETD)
									(*V7*)
									AND (Clamp7RETD AND Clamp35RETD)
									(*V23*)
									AND (Clamp21RETD);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) AND (Unload_Complete) THEN
					Unclamp_Step.3:= Unclamp_Step.2 AND 
											(*V5*)
											(Clamp4RETD AND Clamp11RETD AND Clamp21RETD AND Clamp29RETD AND Clamp33RETD)
											(*V10*)
											AND (Slide4RETD AND Slide8RETD AND Slide11RETD);
		ELSE
			Unclamp_Step.3:= FALSE;					
	END_IF	
	

(*------------------------------------------- Repositions --------------------------------------*)

	(*Reposition Request#1*)
	IF (MAIN.R4.Peripheral_Req.0 AND (MAIN.R4.Task_ID_Ack=PickUp_Fix02))
		THEN
			Repo_Reqs.0:= TRUE;
	END_IF;

	(*Reposition Request#2*)
	IF FALSE
		THEN
			Repo_Reqs.1:= TRUE;
	END_IF;

	(*Reposition Request#3*)
	IF FALSE
		THEN
			Repo_Reqs.2:= TRUE;
	END_IF;

	(*Reposition Request#4*)
	IF FALSE
		THEN
			Repo_Reqs.3:= TRUE;
	END_IF;

	(*Reposition Request#5*)
	IF FALSE
		THEN
			Repo_Reqs.4:= TRUE;
	END_IF;

	(*Reposition Request#6*)
	IF FALSE
		THEN
			Repo_Reqs.5:= TRUE;
	END_IF;

	(*Reposition Request#7*)
	IF FALSE
		THEN
			Repo_Reqs.6:= TRUE;
	END_IF;

	(*Reposition Request#8*)
	IF FALSE
		THEN
			Repo_Reqs.7:= TRUE;
	END_IF;

	(*Reset All Reposition Acks At the End Of Cycle*)
	IF Cycle_Complete
		THEN
			Repo_Reqs:= 0;
	END_IF;

(*------------------------- Reposition Acks ---------------------*)
	Repo_Ack.0:= Repo_Reqs.0 AND Tool_At_Unload.1;
	Repo_Ack.1:= Repo_Reqs.1 AND FALSE;
	Repo_Ack.2:= Repo_Reqs.2 AND FALSE;
	Repo_Ack.3:= Repo_Reqs.3 AND FALSE;
	Repo_Ack.4:= Repo_Reqs.4 AND FALSE;
	Repo_Ack.5:= Repo_Reqs.5 AND FALSE;
	Repo_Ack.6:= Repo_Reqs.6 AND FALSE;
	Repo_Ack.7:= Repo_Reqs.7 AND FALSE;























]]></ST>
      </Implementation>
    </Action>
    <Action Name="ValveBank1" Id="{b13ef7c1-7831-408e-807c-0ad47a345825}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

(*+++++++++++VALVE BANK 1 +++++++++++++*)
(*+++++++++++VALVE BANK 1 +++++++++++++*)
(*+++++++++++VALVE BANK 1 +++++++++++++*)


	(*Valve 1, A+B*)
	(*Clamps #1, 2, 32, 37*)
		Valve1FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.1S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.0,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.1 OR Discrete_In.Go_Home),
			SideA_Indicator:= (Clamp1ADVD AND Clamp2ADVD AND Clamp32ADVD AND Clamp37ADVD),
			SideB_Indicator:= (Clamp1RETD AND Clamp2RETD AND Clamp32RETD AND Clamp37RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.0,
			TurnOn_SideB_SOL=> N100.Q.1,
			TurnOn_SideA_Indicator=> Manual_Indicators1.0,
			TurnOn_SideB_Indicator=> Manual_Indicators1.1
			 );
		Valve1FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.3;
		Valve1FB.In_Auto_SideB_Command:= Unclamp_Step.3
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 2, A+B*)
	(*Clamps #13, 14, 15*)
		Valve2FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.2,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.3 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD,
			SideB_Indicator:= (Clamp13RETD AND Clamp14RETD AND Clamp15RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.2,
			TurnOn_SideB_SOL=> N100.Q.3,
			TurnOn_SideA_Indicator=> Manual_Indicators1.2,
			TurnOn_SideB_Indicator=> Manual_Indicators1.3
			 );
		Valve2FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.3;
		Valve2FB.In_Auto_SideB_Command:= Unclamp_Step.3
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 3, A+B*)
	(*Clamps #16-19*)
		Valve3FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.4,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.5 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp16ADVD AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD,
			SideB_Indicator:= (Clamp16RETD AND Clamp17RETD AND Clamp18RETD AND Clamp19RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.4,
			TurnOn_SideB_SOL=> N100.Q.5,
			TurnOn_SideA_Indicator=> Manual_Indicators1.4,
			TurnOn_SideB_Indicator=> Manual_Indicators1.5
			 );
		Valve3FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.3;
		Valve3FB.In_Auto_SideB_Command:= Unclamp_Step.3
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 4, A+B*)
	(*Clamps #3, 12, 20, 28, 34*)
		Valve4FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.6,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.7 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp3ADVD AND Clamp12ADVD AND Clamp20ADVD AND Clamp28ADVD AND Clamp34ADVD,
			SideB_Indicator:= (Clamp3RETD AND Clamp12RETD AND Clamp20RETD AND Clamp28RETD AND Clamp34RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.6,
			TurnOn_SideB_SOL=> N100.Q.7,
			TurnOn_SideA_Indicator=> Manual_Indicators1.6,
			TurnOn_SideB_Indicator=> Manual_Indicators1.7
			 );
		Valve4FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.1;
		Valve4FB.In_Auto_SideB_Command:= Unclamp_Step.1
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 5, A+B*)
	(*Clamps #4, 11, 29, 33*)
		Valve5FB
			(
			Enable_Motion:= Enable_Motion,	
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.8,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.9 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp4ADVD AND Clamp11ADVD AND Clamp29ADVD AND Clamp33ADVD,
			SideB_Indicator:= (Clamp4RETD AND Clamp11RETD AND Clamp29RETD AND Clamp33RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.8,
			TurnOn_SideB_SOL=> N100.Q.9,
			TurnOn_SideA_Indicator=> Manual_Indicators1.8,
			TurnOn_SideB_Indicator=> Manual_Indicators1.9
			 );
		Valve5FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.2;	
		Valve5FB.In_Auto_SideB_Command:= Unclamp_Step.2
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 6, A+B*)
	(*Clamps #6, 9, 30, 36*)
		Valve6FB
			(
			Enable_Motion:= Enable_Motion,
			Enable_Latch:= FALSE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.10,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.11 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp6ADVD AND Clamp9ADVD AND Clamp30ADVD AND Clamp36ADVD,
			SideB_Indicator:= (Clamp6RETD AND Clamp9RETD AND Clamp30RETD AND Clamp36RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.10,
			TurnOn_SideB_SOL=> N100.Q.11,
			TurnOn_SideA_Indicator=> Manual_Indicators1.10,
			TurnOn_SideB_Indicator=> Manual_Indicators1.11
			 );
		Valve6FB.In_Auto_SideA_Command:= Clamp_Step.1 AND NOT Unclamp_Step.1;
		Valve6FB.In_Auto_SideB_Command:= Unclamp_Step.1
										OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);


	(*Valve 7, ALL BUT 543*)
	(*Clamps #7, 35*)
		Valve7FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.12,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.13 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp7ADVD AND Clamp35ADVD,
			SideB_Indicator:= (Clamp7RETD AND Clamp35RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.12,
			TurnOn_SideB_SOL=> N100.Q.13,
			TurnOn_SideA_Indicator=> Manual_Indicators1.12,
			TurnOn_SideB_Indicator=> Manual_Indicators1.13
			 );
			 
	IF NOT ((Model_ID=3) OR (Model_ID=10)) THEN		 
				Valve7FB.In_Auto_SideA_Command:= Clamp_Step.2 AND NOT Unclamp_Step.2;
				Valve7FB.In_Auto_SideB_Command:= Unclamp_Step.2
												OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);
		ELSIF ((Model_ID=3) OR (Model_ID=10)) THEN
				Valve7FB.In_Auto_SideA_Command:= FALSE;
				Valve7FB.In_Auto_SideB_Command:= TRUE;
	END_IF
												
												

	(*Valve 8, ONLY 504, 524*)
	(*Clamps #22, 26*)
		Valve8FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.14,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.15 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp22ADVD AND Clamp26ADVD,
			SideB_Indicator:= (Clamp22RETD AND Clamp26RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.14,
			TurnOn_SideB_SOL=> N100.Q.15,
			TurnOn_SideA_Indicator=> Manual_Indicators1.14,
			TurnOn_SideB_Indicator=> Manual_Indicators1.15
			 );
			 
	IF (*(Model_ID<3)*) (Model_ID=1) OR (Model_ID=2) OR (Model_ID=8) OR (Model_ID=9) THEN		 
				Valve8FB.In_Auto_SideA_Command:= (Clamp_Step.2 AND NOT Unclamp_Step.1);
				Valve8FB.In_Auto_SideB_Command:= Unclamp_Step.1
												OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);
		ELSE
				Valve8FB.In_Auto_SideA_Command:= FALSE;
				Valve8FB.In_Auto_SideB_Command:= TRUE;
		END_IF

	(*Valve 9, ONLY 526, 536, 550, 571*)
	(*Clamp #23, 25*)
		Valve9FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= Discrete_In.ManReqs.16,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.17 OR Discrete_In.Go_Home),
			SideA_Indicator:= Clamp23ADVD AND Clamp25ADVD,
			SideB_Indicator:= (Clamp23RETD AND Clamp25RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.16,
			TurnOn_SideB_SOL=> N100.Q.17,
			TurnOn_SideA_Indicator=> Manual_Indicators1.16,
			TurnOn_SideB_Indicator=> Manual_Indicators1.17
			 );
			 
	IF (*(Model_ID>3)*)    (Model_ID=4) OR (Model_ID=5) OR (Model_ID=6) OR (Model_ID=7)
						OR (Model_ID=11) OR (Model_ID=12) OR (Model_ID=13) OR (Model_ID=14)
						OR (Model_ID=15) OR (Model_ID=16) OR (Model_ID=17) OR (Model_ID=18)
						OR (Model_ID=19) OR (Model_ID=20) OR (Model_ID=21) OR (Model_ID=22) THEN		 
				Valve9FB.In_Auto_SideA_Command:= (Clamp_Step.2 AND NOT Unclamp_Step.1);
				Valve9FB.In_Auto_SideB_Command:= Unclamp_Step.1
												OR ((TurntableB_At_Robot OR Turntable_Bypassed) AND All_Sensors_Off AND Weld_Robots_Clear);
		ELSE
				Valve9FB.In_Auto_SideA_Command:= FALSE;
				Valve9FB.In_Auto_SideB_Command:= TRUE;
		END_IF

