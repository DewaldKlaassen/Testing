						AND Part_Present23 AND Part_Present24 AND NOT Part_Present25 
						AND NOT Part_Present29 AND NOT Part_Present30 AND NOT Part_Present31 
						AND Part_Present34 AND Part_Present35 AND Part_Present36 
						AND Part_Present37 AND Part_Present38 AND NOT Part_Present39 
						AND NOT Part_Present40 AND NOT Part_Present41 AND NOT Part_Present42
						AND Part_Present46 AND Part_Present47 AND Part_Present48 
						AND Part_Present49 AND Part_Present50 AND Part_Present51 
						AND NOT Part_Present52 AND NOT Part_Present53 AND NOT Part_Present54 
						AND NOT Part_Present55 AND NOT Part_Present56 AND Part_Present65 
						AND Part_Present66 AND Part_Present67)

				(*571*)
					OR ((Model_ID=7)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6
						AND Part_Present7 AND NOT Part_Present8 AND NOT Part_Present9
						AND NOT Part_Present10 AND NOT Part_Present11 AND NOT Part_Present12
						AND NOT Part_Present13 AND Part_Present15 AND NOT Part_Present16 
						AND NOT Part_Present17 AND NOT Part_Present18 AND NOT Part_Present19 
						AND NOT Part_Present20 AND NOT Part_Present21 AND Part_Present22 
						AND Part_Present23 AND Part_Present24 AND NOT Part_Present25 
						AND NOT Part_Present29 
						AND NOT Part_Present30 AND NOT Part_Present31 AND NOT Part_Present32 
						AND Part_Present33 AND Part_Present34 AND Part_Present35 
						AND Part_Present36 AND Part_Present37 AND Part_Present38 
						AND NOT Part_Present39 AND NOT Part_Present40 AND NOT Part_Present41 
						AND NOT Part_Present42 AND NOT Part_Present43 AND Part_Present45
						AND Part_Present46 AND Part_Present47 AND Part_Present48
						AND Part_Present49 AND Part_Present50 AND Part_Present51
						AND NOT Part_Present52 AND NOT Part_Present53 AND NOT Part_Present54
						AND NOT Part_Present55 AND NOT Part_Present56 AND NOT Part_Present57
						AND Part_Present62 AND Part_Present63 AND Part_Present64)
					) OR (All_Sensors_Off AND Dry_Cycle);

	(*Sensors Required for Resetting Subs*)
	(*SUB 1 - Common Sensor(s) For All Models*)
	All_Sensors_On.9:=(Part_Present7 )OR (All_Sensors_Off AND Dry_Cycle);

	(*SUB 2 - Common Sensor(s) For All Models*)
	All_Sensors_On.10:=(Part_Present51) OR (All_Sensors_Off AND Dry_Cycle);

	(*SUB 3 - Common Sensor(s) For All Models*)
	All_Sensors_On.11:=(Model_ID >= 4) AND (Part_Present21) OR (All_Sensors_Off AND Dry_Cycle);

	(*SUB 4 - Common Sensor(s) For All Models*)
	All_Sensors_On.12:=(Model_ID >= 4) AND (Part_Present36 AND Part_Present37) OR (All_Sensors_Off AND Dry_Cycle);
	
	(*SUB 5 - Common Sensor(s) For All Models*)
	All_Sensors_On.13:=(Model_ID = 3) AND (Part_Present73 AND Part_Present74) OR (All_Sensors_Off AND Dry_Cycle);

*)




(*end*)]]></ST>
      </Implementation>
    </Action>
    <Method Name="Blank_NodeLayout" Id="{ce0ef940-40ba-48ee-9b1b-d7db98ac8eb8}">
      <Declaration><![CDATA[METHOD PRIVATE Blank_NodeLayout : BOOL
VAR_INPUT
	Start_Array_Member: UINT;
END_VAR

VAR
	Index: UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF Start_Array_Member >=34 AND Start_Array_Member < 45 THEN
	FOR Index:= Start_Array_Member TO 45 BY 1 DO
		Discrete_Image.NodeLayout.NodeName[index]:='';
		Discrete_Image.NodeLayout.NodeType[index]:='';
		Discrete_Image.NodeState[index]:= 0;
	END_FOR

END_IF
 ]]></ST>
      </Implementation>
    </Method>
