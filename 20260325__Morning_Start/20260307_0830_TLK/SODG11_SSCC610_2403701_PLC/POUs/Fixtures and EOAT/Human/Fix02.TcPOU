    <Action Name="Xfer_To_UI" Id="{65323377-a699-453d-b085-d19054ece2f8}">
      <Implementation>
        <ST><![CDATA[(*Transfer General Status of Fixture and I/O Images for Display On HMI*)
	Discrete_Image.Status:= Status;
	Discrete_Image.CLFaults1:= CLFaults1;
	Discrete_Image.CLFaults2:= CLFaults2;
	Discrete_Image.CLFaults3:= CLFaults3;
	Discrete_Image.CLFaults4:= CLFaults4;
	Discrete_Image.CLFaulted:= CLFaulted;
	Discrete_Image.PPFaults:= PPFaults;
	Discrete_Image.PPFaults1:= PPFaults1;
	Discrete_Image.PPFaults2:= PPFaults2;
	Discrete_Image.PPFaulted:= PPFaulted;
	Discrete_Image.Model_Data:= Model_ID;
	Discrete_Image.ToolID:= Fix_ID;
	Discrete_Image.ProdCount:= Prod_Count_Out ;
	Discrete_Image.CycleTime:= Cycle_Time_Out;
	Discrete_Image.PrevCycleTime:= PrevCycle_Time_Out;
	Discrete_Image.LoadTime:= Load_Time_Out;
	Discrete_Image.WeldTime:= Weld_Time_Out;
	Discrete_Image.UnloadTime:= Unload_Time_Out;

	Discrete_Image.InAuto:= In_Auto_Mode;
	Discrete_Image.InManual:= In_Manual_Mode;
	Discrete_Image.ManInds:= Manual_Indicators1;
	Discrete_Image.ManInds2:= Manual_Indicators2;
	Discrete_Image.ManInds3:= Manual_Indicators3;
	Discrete_Image.At_Home:= Tool_At_Home;
	Discrete_Image.Enable_Motion:= Enable_Motion;
	Discrete_Image.All_Sensors_Off:= All_Sensors_Off;
	Discrete_Image.Bypass_ACKS:= Discrete_In.Bypass_REQS;
	Discrete_Image.CustomApplication_ACKS:= Discrete_In.CustomApplication_REQS;
	Discrete_Image.Fixture_Allow_Model_Change:= Fixture_Allow_Model_Change;


	(*See Below for Overiding code as well*)
	Discrete_Image.NodeLayout:=NodeLayout;
	Discrete_Image.NodeState:=NodeState;
	(*
	Overiding code!!!!
	All Nodes after Valve Banks are in Hot connect groups and are for sub fixtures which are interchangable
	Therefore we must decide which node types will be built into the NodeLayout based on model selection
	We must also move the selected Node states as well
	Once everything is moved, then we wll blank out the areas afterward
	*)
	IF Model_ID = 1 OR Model_ID = 2	THEN
		(*Model 504 (1) and Model 524(2) uses Nodes 31/32, whihc are at [34]/[35]*)
		(*Selected Nodes are already at proper array section, blank the rest*)
		Blank_NodeLayout(36);

	ELSIF Model_ID = 3 THEN
		(*Model 543 (3) uses Nodes 42/43, which are at [44]/[45]*)
		Discrete_Image.NodeLayout.NodeName[34]:= NodeLayout.NodeName[44];
		Discrete_Image.NodeLayout.NodeName[35]:= NodeLayout.NodeName[45];
		Discrete_Image.NodeLayout.NodeType[34]:= NodeLayout.NodeType[44];
		Discrete_Image.NodeLayout.NodeType[35]:= NodeLayout.NodeType[45];
		Discrete_Image.NodeState[34]:= NodeLayout.State[44];
		Discrete_Image.NodeState[35]:= NodeLayout.State[45];
		(*Selected Nodes moved to proper array section, blank the rest*)
		Blank_NodeLayout(36);

	ELSIF Model_ID = 4 THEN
		(*Model 526 (4) uses Nodes 40/41, which are at [42]/[43]*)
		Discrete_Image.NodeLayout.NodeName[34]:= NodeLayout.NodeName[42];
		Discrete_Image.NodeLayout.NodeName[35]:= NodeLayout.NodeName[43];
		Discrete_Image.NodeLayout.NodeType[34]:= NodeLayout.NodeType[42];
		Discrete_Image.NodeLayout.NodeType[35]:= NodeLayout.NodeType[43];
		Discrete_Image.NodeState[34]:= NodeLayout.State[42];
		Discrete_Image.NodeState[35]:= NodeLayout.State[43];
		(*Selected Nodes moved to proper array section, blank the rest*)
		Blank_NodeLayout(36);
		
	ELSIF Model_ID = 5 THEN
		(*Model 536 (5) uses Nodes 38/39, which are at [40]/[41]*)
		Discrete_Image.NodeLayout.NodeName[34]:= NodeLayout.NodeName[40];
		Discrete_Image.NodeLayout.NodeName[35]:= NodeLayout.NodeName[41];
		Discrete_Image.NodeLayout.NodeType[34]:= NodeLayout.NodeType[40];
		Discrete_Image.NodeLayout.NodeType[35]:= NodeLayout.NodeType[41];
		Discrete_Image.NodeState[34]:= NodeLayout.State[40];
		Discrete_Image.NodeState[35]:= NodeLayout.State[41];
		(*Selected Nodes moved to proper array section, blank the rest*)
		Blank_NodeLayout(36);

	ELSIF Model_ID = 6 THEN
		(*Model 550 (6) uses Nodes 36/37, which are at [38]/[39]*)
		Discrete_Image.NodeLayout.NodeName[34]:= NodeLayout.NodeName[38];
		Discrete_Image.NodeLayout.NodeName[35]:= NodeLayout.NodeName[39];
		Discrete_Image.NodeLayout.NodeType[34]:= NodeLayout.NodeType[38];
		Discrete_Image.NodeLayout.NodeType[35]:= NodeLayout.NodeType[39];
		Discrete_Image.NodeState[34]:= NodeLayout.State[38];
		Discrete_Image.NodeState[35]:= NodeLayout.State[39];
		(*Selected Nodes moved to proper array section, blank the rest*)
		Blank_NodeLayout(36);

	ELSIF Model_ID = 7 THEN
		(*Model 571 (7) uses Nodes 34/35, which are at [36]/[37]*)
		Discrete_Image.NodeLayout.NodeName[34]:= NodeLayout.NodeName[36];
		Discrete_Image.NodeLayout.NodeName[35]:= NodeLayout.NodeName[37];
		Discrete_Image.NodeLayout.NodeType[34]:= NodeLayout.NodeType[36];
		Discrete_Image.NodeLayout.NodeType[35]:= NodeLayout.NodeType[37];
		Discrete_Image.NodeState[34]:= NodeLayout.State[36];
		Discrete_Image.NodeState[35]:= NodeLayout.State[37];
		(*Selected Nodes moved to proper array section, blank the rest*)
		Blank_NodeLayout(36);
		
	ELSE
		(*No Model means no nodes selected, blank 'em all!*)
		Blank_NodeLayout(34);
	
	END_IF;
	
	Discrete_Image.Input_Node_Count:= Discrete_In.Input_Node_Count;
	Discrete_Image.VB_Node_Count:= Discrete_In.VB_Node_Count;
	Discrete_Image.Water_Stand_Count:= Discrete_In.Water_Stand_Count;

	IF  (Discrete_Image.Input_Node_Count < 4)
		THEN Discrete_Image.VB_Screen_Position:= 1;
	ELSIF  (Discrete_Image.Input_Node_Count < 7)
		THEN Discrete_Image.VB_Screen_Position:= 2;
	ELSIF  (Discrete_Image.Input_Node_Count < 10)
		THEN Discrete_Image.VB_Screen_Position:= 3;
	ELSIF  (Discrete_Image.Input_Node_Count < 13)
		THEN Discrete_Image.VB_Screen_Position:= 4;
	ELSIF  (Discrete_Image.Input_Node_Count < 16)
		THEN Discrete_Image.VB_Screen_Position:= 5;
	ELSIF  (Discrete_Image.Input_Node_Count < 19)
		THEN Discrete_Image.VB_Screen_Position:= 6;
	ELSIF  (Discrete_Image.Input_Node_Count < 22)
		THEN Discrete_Image.VB_Screen_Position:= 7;
	ELSIF  (Discrete_Image.Input_Node_Count < 26)
		THEN Discrete_Image.VB_Screen_Position:= 8;
	ELSE
			Discrete_Image.VB_Screen_Position:= 9;
	END_IF;

	Discrete_Image.N00:= N00;
	Discrete_Image.N01:= N01;
	Discrete_Image.N02:= N02;
	Discrete_Image.N03:= N03;
	Discrete_Image.N04:= N04;
	Discrete_Image.N05:= N05;
	Discrete_Image.N06:= N06;
	Discrete_Image.N07:= N07;
	Discrete_Image.N08:= N08;
	Discrete_Image.N09:= N09;
	Discrete_Image.N10:= N10;
	Discrete_Image.N11:= N11;
	Discrete_Image.N12:= N12;
	Discrete_Image.N13:= N13;
	Discrete_Image.N14:= N14;
	Discrete_Image.N15:= N15;
	Discrete_Image.N16:= N16;
	Discrete_Image.N17:= N17;
	Discrete_Image.N18:= N18;
	Discrete_Image.N19:= N19;
	Discrete_Image.N20:= N20;
	Discrete_Image.N21:= N21;
	Discrete_Image.N22:= N22;
	Discrete_Image.N23:= N23;
	Discrete_Image.N24:= N24;
	Discrete_Image.N25:= N25;
	Discrete_Image.N26:= N26;
	Discrete_Image.N27:= N27;
	Discrete_Image.N28:= N28;
	Discrete_Image.N29:= N29;
	Discrete_Image.N30:= N30;
	Discrete_Image.N31:= N31;
	Discrete_Image.N32:= N32;
	Discrete_Image.N33:= N33;
	Discrete_Image.N34:= N34;
	Discrete_Image.N35:= N35;
	Discrete_Image.N36:= N36;
	Discrete_Image.N37:= N37;
	Discrete_Image.N38:= N38;
	Discrete_Image.N39:= N39;
	Discrete_Image.N40:= N40;
	Discrete_Image.N41:= N41;
	Discrete_Image.N42:= N42;
	Discrete_Image.N43:= N43;
	Discrete_Image.N100:= N100;
	Discrete_Image.N100_STAT:= N100_STAT;
	Discrete_Image.N101:= N101;
	Discrete_Image.N101_STAT:= N101_STAT;
	Discrete_Image.N102:= N102;
	Discrete_Image.N102_STAT:= N102_STAT;

	Discrete_Image.ECatSlave_Cable_Breaks:= ECatSlave_Cable_Breaks;

	Discrete_Image.Operator_Performance_Pen:= Production_Report.Shift_Report[0].Prod_Performance;








]]></ST>
      </Implementation>
    </Action>
