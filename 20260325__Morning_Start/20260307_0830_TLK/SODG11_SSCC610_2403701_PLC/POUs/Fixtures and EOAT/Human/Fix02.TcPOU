			Enable_Manual_Commands:= In_Manual AND (All_Robots_Clear OR TurntableA_At_Robot),  (*TLK ADDED OR*)
			In_Manual_SideA_Command:= (Discrete_In.ManReqs2.10 OR Discrete_In.Go_Home)
										OR (N100.Q.18 AND NOT (Slide4ADVD AND Slide8ADVD AND Slide11ADVD))
										OR (N100.Q.19 AND NOT (Slide4RETD AND Slide8RETD AND Slide11RETD))
