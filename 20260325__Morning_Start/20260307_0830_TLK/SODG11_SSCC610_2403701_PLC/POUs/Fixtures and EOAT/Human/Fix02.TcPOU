END_VAR

	(*data that needs to be retained in the event of a power cycle*)
	VAR PERSISTENT

		Load_Complete1: BOOL;
		Load_Complete2: BOOL;
		Load_Complete: BOOL;
		Stud_Complete: BOOL;
		Welding_Complete: BOOL;
		Sealing_Complete: BOOL;
		Unload_Complete: BOOL;
		TurnA_Complete: BOOL;
		TurnB_Complete: BOOL;
		Cycle_Complete: BOOL;
		Eject_Complete: BOOL;
		VacCheck_Complete: BOOL;
		Date_Stamp_Complete: BOOL;
		Load_Seq01: FB_GTAC_Load_Seq_20230302;
		Production_Count:INT;
		Repo_REQS: UINT;
		(*Allow_Load_PreCall: BOOL;
		Allow_Weld_PreCall: BOOL;
		Allow_Unload_PreCall: BOOL;*)
		(*All_SubPP_Off: BOOL;*)
		Production_Report: FB_Production_Report_20221007;
		Sub1_Weld_Complete: BOOL;
		Sub1_Reset: BOOL;
		Sub2_Weld_Complete: BOOL;
		Sub2_Reset: BOOL;
		Sub3_Weld_Complete: BOOL;
		Sub3_Reset: BOOL;
		Sub4_Weld_Complete: BOOL;
		Sub4_Reset: BOOL;
		Sub5_Weld_Complete: BOOL;
		Sub5_Reset: BOOL;
		All_Subs_Complete: BOOL;
		All_Subs_Reset: BOOL;

	END_VAR

	VAR_OUTPUT

		Prog_Ok: BOOL;
		Discrete_Image: udt_FixXX_Output_Image_20250721_CUSTOM;
		In_Auto_Mode: BOOL;
		In_Manual_Mode: BOOL;
		Manual_Indicators1: DINT;
		Manual_Indicators2: DINT;
		Manual_Indicators3: DINT;
		At_Home: BOOL;
		Ready_To_Load: BOOL;
		Red_Lamp_Req: BOOL;
		Status: UINT;
		CLFaults1:UDINT;
		CLFaults2:UDINT;
		CLFaults3:UDINT;
		CLFaults4:UDINT;
		PPFaults: UDINT;
		PPFaults1: UDINT;
		PPFaults2: UDINT;
		Prod_Count_Out: INT;
		Cycle_Time_Out: TIME;
		PrevCycle_Time_Out: TIME;
		Load_Time_Out: TIME;
		Weld_Time_Out: TIME;
		Seal_Time_Out: TIME;
		Stud_Time_Out: TIME;
		Turn_Time_Out: TIME;
		Unload_Time_Out: TIME;
		Model_ID: UINT;
		TurntableA_At_Robot: BOOL;
		TurntableB_At_Robot: BOOL;
		Tool_Call_ForLoadRobots1: BOOL;
		Tool_Call_ForLoadRobots2: BOOL;
		Tool_Call_ForSealRobots: BOOL;
		Tool_Call_ForStudRobots: BOOL;
		Tool_Call_ForWeldRobots: BOOL;
		Tool_Call_ForSweepA: BOOL;
		Tool_Call_ForSweepB: BOOL;
		Tool_Call_ForUnloadRobots1: BOOL;
		Tool_Call_ForUnloadRobots2: BOOL;
		Robots_Clear_ToProceed: BOOL;
		Task_ID: UINT;
		Fix_ID: UINT;
		Load_Complete1_Ack: BOOL;
		Load_Complete2_Ack: BOOL;
		Seal_Complete_Ack: BOOL;
		Stud_Complete_Ack: BOOL;
		Weld_Complete_Ack: BOOL;
		TurnA_Complete_Ack: BOOL;
		TurnB_Complete_Ack: BOOL;
		Unload_Complete1_Ack: BOOL;
		Unload_Complete2_Ack: BOOL;
		Repo_Ack: UINT;
		Door_Close_Req: BOOL;
		Door_Open_Req: BOOL;
	END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[	(*Set FB_OK to True*)
	Prog_OK:= TRUE;

	(*
						 MODEL ID MAP
					 -------------------
				Model ID :  Part ID  :   Tooling ID
					1  	 : 	 504     :     42
					2	 :   524     :	   42
					3	 :   543     :	   47
					4	 :   526     :	   46
					5	 :   536     :	   45
					6	 :   550     :	   44
					7	 :   571     :	   43
	
*)
	(*Set conditions to allow model change*)
	Fixture_Allow_Model_Change:= (In_Manual AND Tool_At_Home AND All_Sensors_Off AND All_Robots_Clear)
							OR (Model_ID=0);


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Fixture Bypasses $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	Turntable_Bypassed:= ((TurntableB_At_Robot AND Tool_At_Home AND All_Sensors_OFF)
					OR (Turntable_Bypassed AND NOT TurntableA_At_Robot))
					OR Discrete_In.Bypass_REQS.3;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Check on Status of Hardware*)
	Hardware();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Standard Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*Clamp/Cylinder Inputs*)
	Cylinders();

(*Part Present Inputs*)
	Proxies();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Qaulity Checking Routines $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*QA Checks*)
		(*CheckQA1FB(
			Start_QAcheck:= Auto_Run AND Enable_Motion AND Clamp_Step.3,
			QAcheck_Reset:= Cycle_Complete OR (In_Manual AND Discrete_In.Go_Home AND All_Sensors_Off),
			QAcheck_Retry:= In_From_ICxx.QA_Reset.0,
			QAcheck_Release:= In_From_ICxx.QA_Reset.1,
			QAcheck_Adv_In:= QACheck1ADVD AND QACheck2ADVD AND QACheck3ADVD AND QACheck4ADVD AND QACheck5ADVD AND QACheck6ADVD,
			QAcheck_Ret_In:= QACheck1RETD AND QACheck2RETD AND QACheck3RETD AND QACheck4RETD AND QACheck5RETD AND QACheck6RETD,
			User_Dry_Cycle:= Dry_Cycle,
			QAcheck_OK_Delay:= T#0.75s,
			QAcheck_Fault_Delay:= T#3.0s,
			QAcheck_OK=> All_QAChecks_OK,
			QAcheck_Failed=> QAChecks_Failed);*) (*TLK TEMP REMOVED UNTILL PART QA 100%*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Auto / Manual Mode Code*)
	IF Discrete_In.Mode_Select.0 AND NOT Discrete_In.Mode_Select.1
		THEN
			In_Auto:= TRUE;
			In_Auto_Mode:= TRUE;
	END_IF;
	IF NOT Discrete_In.Mode_Select.0 AND Discrete_In.Mode_Select.1
		THEN
			In_Auto:= FALSE;
			In_Auto_Mode:= FALSE;
	END_IF;
	In_Manual:= NOT In_Auto;
	In_Manual_Mode:= In_Manual;

(*--------------------------------------------------------------------------------Tool Positions---------------------------------------------------------------*)
	Tool_States();

(*----------------------------------------------------Part Present Sensor Input Patterns----------------------------------------------------------------*)
	All_Sensors();


(*>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Auto Run Cycle >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
	(*Control of Auto_Run*)
	Auto_Run:= Enable_Motion AND In_Auto AND ((Model_ID<>0) OR Turntable_Bypassed) AND NOT Cycle_Complete;

	(*Auto Run Enables All Other Auto Cycle Code*)
	IF Auto_Run
		THEN

            IF  NOT TurnA_Complete AND Welding_Complete AND Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Weld_Robots_Clear  AND Unload_Robots_Clear
				AND (NOT TurntableA_At_Robot OR TurnTable_WorkingOK) 
			    AND (MAIN.MD01.Door_Closed )
				THEN
					(*Start Turntable SweepA (Fix02 to the Operator)*)
					Start_TurntableA:= TRUE;
					
			ELSIF All_Sensors_Off AND NOT TurnA_Complete AND Weld_Robots_Clear AND Load_Robots_Clear AND Unload_Robots_Clear
				AND (NOT TurntableA_At_Robot OR TurnTable_WorkingOK)AND Turntable_Bypassed AND (Tool_At_Rotate.0 OR Tool_At_Rotate.1)
				AND (MAIN.MD01.Door_Closed )
				THEN
					Start_TurntableA:= All_Sensors_Off;
			ELSE
					Start_TurntableA:= FALSE;
			END_IF;


			IF NOT TurnB_Complete AND (Load_Complete OR TurnTable_WorkingOK) AND NOT Welding_Complete AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND  Weld_Robots_Clear AND Unload_Robots_Clear
				AND (NOT TurntableB_At_Robot OR TurnTable_WorkingOK) AND NOT Turntable_Bypassed (*AND NOT All_Subs_Reset*)
				AND (MAIN.MD01.Door_Closed )
				THEN
					(*Start Turntable SweepB (Fix02 to the Robot)*)
					Start_TurntableB:= (Tool_At_Rotate.0 AND All_Sensors_On.3 AND Load_Complete)
									OR TurnTable_WorkingOK;
									
            ELSIF All_Sensors_Off AND Discrete_In.Bypass_REQS.3 AND NOT TurnB_Complete AND Weld_Robots_Clear AND Load_Robots_Clear AND Unload_Robots_Clear
				AND (NOT TurntableB_At_Robot OR TurnTable_WorkingOK) AND Turntable_Bypassed AND Tool_At_Rotate.1 
				AND (MAIN.MD01.Door_Closed )
			THEN
					Start_TurntableB:= TRUE;
            ELSE
					Start_TurntableB:= FALSE;
            END_IF;


			IF Load_Complete AND NOT Welding_Complete AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableB_At_Robot AND Mig_Robots_Ready 
				THEN
					(*Start Weld Robots*)
					Start_Weld_Robots:=((Tool_At_Weld.0 AND NOT Repo_Reqs.3 AND NOT Repo_Reqs.4 AND NOT Repo_Reqs.5 AND All_Sensors_On.3)
										OR (Tool_At_Weld.1 AND Repo_Reqs.3 AND All_Sensors_On.3)
										OR (Tool_At_Weld.2 AND Repo_Reqs.4 AND All_Sensors_On.4)
										OR (Tool_At_Weld.3 AND Repo_Reqs.5 AND All_Sensors_On.5)
										OR (Tool_At_Unload.0 AND Weld_Robots_UnclampEarly))
										OR Weld_Robots_WorkingOK;
					(*Allow Weld Robots To Proceed*)
					Weld_Robots_Proceed:= Load_Complete AND Tool_At_Weld.0 AND All_Sensors_On.3;
			ELSE
					Start_Weld_Robots:= FALSE;
					Weld_Robots_Proceed:= FALSE;
			END_IF;
			
			IF Welding_Complete AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear2
				AND TurnTableB_At_Robot AND Weld_Robots_Clear
				THEN
					(*Start Unload Robots*)
					Start_Unload_Robots1:=((Tool_At_Unload.0 AND NOT Repo_Reqs.0 AND All_Sensors_On.8) AND (Unload_Robots_EOATEmpty1)
										OR (Tool_At_Unload.1 AND Repo_Reqs.0 AND All_Sensors_On.4)
										OR (NOT Unload_Robots_Clear1 AND NOT Unload_Robots_EOATEmpty1))
										OR Unload_Robots_WorkingOK1;
					(*Allow Unload Robots To Proceed*)
					Unload_Robots_Proceed1:= Welding_Complete AND Tool_At_Unload.0 AND All_Sensors_On.8 AND Unload_Robots_EOATEmpty1;
			ELSE
					Start_Unload_Robots1:= FALSE;
					Unload_Robots_Proceed1:= FALSE;
			END_IF;




	ELSE
		Start_Load_Robots1:= FALSE;
		Start_Load_Robots2:= FALSE;
		Start_Seal_Robots:= FALSE;
		Start_Stud_Robots:= FALSE;
		Start_TurntableA:= FALSE;
		Start_TurntableB:= FALSE;
		Start_Weld_Robots:= FALSE;
		Start_Unload_Robots1:= FALSE;
		Start_Unload_Robots2:= FALSE;
		Load_Robots_Proceed1:=FALSE;
		Load_Robots_Proceed2:=FALSE;
		Seal_Robots_Proceed:=FALSE;
		Weld_Robots_Proceed:=FALSE;
		Unload_Robots_Proceed1:=FALSE;
		Unload_Robots_Proceed2:=FALSE;
	END_IF;



(*---------------------------------------------------------------Completes----------------------------------------------------*)
	(*1st Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete1:=  All_Sensors_On.2;
	ELSIF Dry_Cycle
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete1:= TRUE;
		END_IF;
	END_IF;
	(*2nd Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete2:=  All_Sensors_On.3;
	ELSIF Dry_Cycle
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete2:= TRUE;
		END_IF;
	END_IF;
	(*All Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete:= ((All_Sensors_On.3 AND Tool_At_Weld.0)
					OR (Repo_Reqs.0 AND All_Sensors_On.4)
					OR (Repo_Reqs.1 AND All_Sensors_On.5)
					OR (Repo_Reqs.2 AND All_Sensors_On.6))
					OR Weld_Robots_WorkingOK OR Welding_Complete;
	ELSIF Dry_Cycle
		THEN
		IF Load_Complete1 AND Load_Complete2 AND All_Sensors_Off
			THEN
			Load_Complete:= TRUE;
		END_IF;
	END_IF;

	(*Welding Complete*)
	IF Weld_Robots_Complete
		THEN
		Welding_Complete:= TRUE;
	END_IF;

	(*Turntable Complete*)
	TurnA_Complete:= Fix01.TurnA_Complete;
	TurnB_Complete:= Fix01.TurnB_Complete;

	(*Unload Complete*)
	IF NOT Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	ELSIF Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	END_IF;
(*	
	(*SUB 1 Complete/RESET*)
	IF All_Sensors_On.9 AND Welding_Complete AND NOT Unload_Complete
		THEN 
		Sub1_Weld_Complete:= TRUE;
	ELSIF TurntableA_At_Robot AND Sub1_Weld_Complete AND All_Sensors_Off1
		THEN
		Sub1_Weld_Complete:= FALSE;
		Sub1_Reset:= TRUE;
	END_IF
	
	(*SUB 2 Complete/RESET*)
	IF All_Sensors_On.10 AND Welding_Complete AND NOT Unload_Complete
		THEN 
		Sub2_Weld_Complete:= TRUE;
	ELSIF TurntableA_At_Robot AND Sub2_Weld_Complete AND All_Sensors_Off2
		THEN
		Sub2_Weld_Complete:= FALSE;
		Sub2_Reset:= TRUE;
	END_IF
	
	(*SUB 3 Complete/RESET*)
	IF All_Sensors_On.11 AND Welding_Complete AND NOT Unload_Complete 
		THEN 
		Sub3_Weld_Complete:= TRUE;
	ELSIF TurntableA_At_Robot AND Sub3_Weld_Complete AND All_Sensors_Off3
		THEN
		Sub3_Weld_Complete:= FALSE;
		Sub3_Reset:= TRUE;
	END_IF
	
	(*SUB 4 Complete/RESET*)
	IF All_Sensors_On.12 AND Welding_Complete AND NOT Unload_Complete 
		THEN 
		Sub4_Weld_Complete:= TRUE;
	ELSIF TurntableA_At_Robot AND Sub4_Weld_Complete AND All_Sensors_Off4
		THEN
		Sub4_Weld_Complete:= FALSE;
		Sub4_Reset:= TRUE;
	END_IF
	
	(*SUB 5 Complete/RESET*)
	IF All_Sensors_On.13 AND Welding_Complete AND NOT Unload_Complete 
		THEN 
		Sub5_Weld_Complete:= TRUE;
	ELSIF TurntableA_At_Robot AND Sub5_Weld_Complete AND All_Sensors_Off5
		THEN
		Sub5_Weld_Complete:= FALSE;
		Sub5_Reset:= TRUE;
	END_IF
	
	IF (((Model_ID<=2)AND Sub1_Weld_Complete AND Sub2_Weld_Complete) 
		OR ((Model_ID=3)AND Sub1_Weld_Complete AND Sub2_Weld_Complete AND Sub5_Weld_Complete) 
		OR ((Model_ID>=4)AND Sub1_Weld_Complete AND Sub2_Weld_Complete AND Sub3_Weld_Complete AND Sub4_Weld_Complete) )
		THEN
	All_Subs_Complete:= TRUE;
	END_IF
	
	IF (Model_ID<=2) AND Sub1_Reset AND Sub2_Reset
		THEN 
		All_Subs_Reset:= TRUE;
		Sub1_Reset:= FALSE;
		Sub2_Reset:= FALSE;
	ELSIF (Model_ID=3) AND Sub1_Reset AND Sub2_Reset AND Sub5_Reset
		THEN 
		All_Subs_Reset:= TRUE;
		Sub1_Reset:= FALSE;
		Sub2_Reset:= FALSE;
		Sub5_Reset:= FALSE;
	ELSIF (Model_ID>=4) AND Sub1_Reset AND Sub2_Reset AND Sub3_Reset AND Sub4_Reset
		THEN 
		All_Subs_Reset:= TRUE;
		Sub1_Reset:= FALSE;
		Sub2_Reset:= FALSE;
		Sub3_Reset:= FALSE;
		Sub4_Reset:= FALSE;
	END_IF
*)	
(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Cycle Complete !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
	(*Set Cycle Complete*)
	IF Load_Complete AND Welding_Complete AND Unload_Complete AND All_Robots_Clear (*AND All_Subs_Reset*) AND TurntableA_At_Robot
		THEN Cycle_Complete:= TRUE;
	END_IF;
	(*Reset All Completes*)
	IF Load_Robots_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear AND NOT Unload_Robots_Complete1 AND NOT Unload_Robots_Complete2
		THEN
			IF In_Manual AND Discrete_In.Go_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF NOT Dry_Cycle AND Cycle_Complete AND NOT Enable_Motion AND Tool_At_Home
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF Dry_Cycle AND Cycle_Complete AND Tool_At_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:=TRUE;
			ELSE
					Reset_All_Completes:= FALSE;
			END_IF;
	END_IF;
	(*Perform Actual Reset*)
		IF Reset_All_Completes
			THEN
				Cycle_Complete:= FALSE;
				Load_Complete1:= FALSE;
				Load_Complete2:= FALSE;
				Load_Complete:= FALSE;
				Sealing_Complete:= FALSE;
				Stud_Complete:= FALSE;
				Welding_Complete:= FALSE;
				Date_Stamp_Complete:= FALSE;
				VacCheck_Complete:= FALSE;
				Unload_Complete:=FALSE;
				Eject_Complete:= FALSE;
				Load_Robots_UnclampEarly1:= FALSE;
				Load_Robots_UnclampEarly2:= FALSE;
				Seal_Robots_UnclampEarly:= FALSE;
				Stud_Robots_UnclampEarly:= FALSE;
				Weld_Robots_UnclampEarly:= FALSE;
				Repo_Reqs:= 0;
				Reset_All_Completes:= FALSE;
				All_Subs_Reset:= FALSE;
				All_Subs_Complete:= FALSE;

		END_IF;

(*---------------------------------------------------------------------------- Call Various Actions ----------------------------------------------------------------------------------------------------*)
	(*Poduction Counters and Report*)
	Production();

	(*Register Robot(s) to Fixture*)
	Robot_Registration();

	(*Setup Fix ID and Model Data*)
	Task_Fix_Model_IDs();

	(*Generate Status Banner and Fault Flags*)
	Status_and_Faults();

	(*Tool Clamp / Unclamp Sequencing and Reposition Handling*)
	Tool_VBSeq_Repos();
	
	(*Transfer Object Image Data to UI Section*)
	Xfer_To_UI();


(*-----------------------------------------------------------------------------------------Transfer Valve Outputs --------------------------------------------------------------------------------*)
	(*Move "Manual_Home_Prompt" as required for home prompting*)
		Manual_Ind_HomePrompt:= Flash_Rate AND In_Manual AND Discrete_In.Go_Home AND NOT Tool_At_Home;

	(*Call each valve bank*)
	ValveBank1();
	ValveBank2();
	(*ValveBank3(); *)

	(*Door Close Request*)
		Door_Close_Req:= NOT Weld_Curtain_Bypass AND (In_Auto AND TurntableA_At_Robot AND Enable_Motion
					AND NOT CLFaulted.0 AND NOT PPFaulted.0 AND NOT QAChecks_Failed
					AND ((Load_Complete AND NOT Welding_Complete) OR (Enable_Motion AND TurnTable_Bypassed) OR Dry_Cycle))
					OR (In_Manual AND MAIN.IC01.OP1_LC_Clear AND Discrete_In.CustomApplication_REQS.7);

	(*Door Open Request*)
		Door_Open_Req:= Weld_Curtain_Bypass OR (NOT Dry_Cycle AND TurntableA_At_Robot AND In_Auto AND All_Robots_Clear
					AND ((Welding_Complete AND NOT Dry_Cycle)
					OR (NOT Welding_Complete AND (CLFaulted.0 OR PPFaulted.0 OR QAChecks_Failed))
					OR (Tool_At_Home AND All_Sensors_Off AND NOT Turntable_Bypassed)))
					OR (In_Manual AND  (Discrete_In.CustomApplication_REQS.6 OR (TurntableA_At_Robot AND Discrete_In.Go_Home)));

	(*Reset N90*)
		N90_Reset_Rtrig(CLK := Enable_Motion AND MAIN.SS01.Air_PressureOK);
		IF N90_Reset_Rtrig.Q AND NOT N90_Reset_Complete
			THEN
				N90_Reset_Trigger:=TRUE;
		ELSIF N90_Reset_Complete
			THEN
					N90_Reset_Trigger:=FALSE;	
		END_IF
						
	(*Logic added for Reset*)
		N90_CMD.Device.Global_Reset := N90_Reset_Trigger OR ((In_From_ICxx.ControlPower1 OR MAIN.IC01.OP1_Cycle_Start OR MAIN.IC01.OP2_Cycle_Start) AND NOT N90_Reset_Complete);(*Power_Reset.Q;*)
		N98.Q.0 := TRUE;
		N98.Q.1 := TRUE;
		N98.Q.2 := TRUE;
		N98.Q.3 := TRUE;

		IF N90_Reset_Rtrig.Q AND N90_CMD.Device.Global_Reset AND Enable_Motion
			THEN 
				N90_Reset_Complete:=TRUE;
		ELSE 
				N90_Reset_Complete:=FALSE;
		END_IF
]]></ST>
    </Implementation>
