		Stud_Complete_Ack: BOOL;
		Weld_Complete_Ack: BOOL;
		TurnA_Complete_Ack: BOOL;
		TurnB_Complete_Ack: BOOL;
		Unload_Complete1_Ack: BOOL;
		Unload_Complete2_Ack: BOOL;
		Repo_Ack: UINT;
	END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[	(*Set FB_OK to True*)
	Prog_OK:= TRUE;


	(*Set conditions to allow model change*)
	Fixture_Allow_Model_Change:= (In_Manual AND Tool_At_Home AND All_Sensors_Off AND All_Robots_Clear)
							OR (Model_ID=0);



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Fixture Bypasses $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	Weld_Curtain_Bypass:= Discrete_In.Bypass_REQS.0;
	Vacuum_Bypass:= Discrete_In.Bypass_REQS.1;
	Stud_Bypass:= Discrete_In.Bypass_REQS.2;
	Sealer_Bypass:= MAIN.SL01.Disp1_Bypass;


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Check on Status of Hardware*)
	Hardware();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Standard Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*Clamp/Cylinder Inputs*)
	Cylinders();

(*Part Present Inputs*)
	Proxies();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Qaulity Checking Routines $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*QA Checks*)
		CheckQA1FB(
			Start_QAcheck:= Auto_Run AND Enable_Motion AND Tool_At_Load.3,
			QAcheck_Reset:= Cycle_Complete OR (In_Manual AND Discrete_In.Go_Home AND All_Sensors_Off),
			QAcheck_Retry:= In_From_ICxx.QA_Reset.0,
			QAcheck_Release:= In_From_ICxx.QA_Reset.1,
			QAcheck_Adv_In:= QACheck1ADVD AND QACheck2ADVD,
			QAcheck_Ret_In:= QACheck1RETD AND QACheck2RETD,
			User_Dry_Cycle:= Dry_Cycle,
			QAcheck_OK_Delay:= T#0.75s,
			QAcheck_Fault_Delay:= T#3.0s,
			QAcheck_OK=> All_QAChecks_OK,
			QAcheck_Failed=> QAChecks_Failed);



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Auto / Manual Mode Code*)
	IF Discrete_In.Mode_Select.0 AND NOT Discrete_In.Mode_Select.1
		THEN
			In_Auto:= TRUE;
			In_Auto_Mode:= TRUE;
	END_IF;
	IF NOT Discrete_In.Mode_Select.0 AND Discrete_In.Mode_Select.1
		THEN
			In_Auto:= FALSE;
			In_Auto_Mode:= FALSE;
	END_IF;
	In_Manual:= NOT In_Auto;
	In_Manual_Mode:= In_Manual;

(*--------------------------------------------------------------------------------Tool Positions---------------------------------------------------------------*)
	Tool_States();

(*----------------------------------------------------Part Present Sensor Input Patterns----------------------------------------------------------------*)
	All_Sensors();


(*>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Auto Run Cycle >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
	(*Control of Auto_Run*)
	Auto_Run:= Enable_Motion AND In_Auto AND Model_ID<>0 AND NOT Cycle_Complete;

	(*Auto Run Enables All Other Auto Cycle Code*)
	IF Auto_Run
		THEN

			IF (NOT Load_Complete1 OR (Load_Robots_UnclampEarly1 AND All_Sensors_On.1))
				AND Load_Robots_Clear2 AND Stud_Robots_Clear AND Seal_Robots_Clear
				AND Weld_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableA_At_Robot
				THEN
					(*Start 1st Load Robots*)
					Start_Load_Robots1:= ((Tool_At_Load.0 AND All_Sensors_Off AND NOT Repo_Reqs.0 AND Load_Robots_PartInEOAT1)
									OR (Tool_At_Load.1 AND All_Sensors_On.4 AND Repo_Reqs.0))
									OR Load_Robots_WorkingOK1;
					(*Allow 1st Load Robots To Proceed*)
					Load_Robots_Proceed1:= Tool_At_Load.0 AND All_Sensors_Off AND Load_Robots_PartInEOAT1;
			ELSE
					Start_Load_Robots1:= FALSE;
					Load_Robots_Proceed1:= FALSE;
			END_IF;


			IF (NOT Load_Complete2 OR (Load_Robots_UnclampEarly2 AND All_Sensors_On.2))
				AND Load_Robots_Clear1 AND Stud_Robots_Clear AND Seal_Robots_Clear
				AND Weld_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableA_At_Robot
				THEN
					(*Start 2nd Load Robots*)
					Start_Load_Robots2:= ((Tool_At_Load.1 AND All_Sensors_Off AND NOT Repo_Reqs.0 AND Load_Robots_PartInEOAT2)
									OR (Tool_At_Load.1 AND All_Sensors_On.4 AND Repo_Reqs.0))
									OR Load_Robots_WorkingOK2;
					(*Allow 2nd Load Robots To Proceed*)
					Load_Robots_Proceed2:= Tool_At_Load.1 AND All_Sensors_Off AND Load_Robots_PartInEOAT2;
			ELSE
					Start_Load_Robots2:= FALSE;
					Load_Robots_Proceed2:= FALSE;
			END_IF;


			IF NOT Sealer_Bypass AND Load_Complete AND NOT Sealing_Complete
				AND Load_Robots_Clear AND Stud_Robots_Clear AND  Weld_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableA_At_Robot
				THEN
					(*Start Seal Robots*)
					Start_Seal_Robots:= ((Tool_At_Seal.0 AND All_Sensors_On.3 AND NOT Repo_Reqs.1 AND NOT MAIN.SL01.Disp1_Faulted AND MAIN.SL01.Disp1_Ready)
									OR (Tool_At_Seal.1 AND All_Sensors_On.4 AND Repo_Reqs.1))
									OR Seal_Robots_WorkingOK;
					(*Allow Seal Robots To Proceed*)
					Seal_Robots_Proceed:= Tool_At_Seal.0 AND All_Sensors_On.3;
			ELSE
					Start_Seal_Robots:= FALSE;
					Seal_Robots_Proceed:= FALSE;
			END_IF;


			IF NOT Stud_Bypass AND Load_Complete AND NOT Stud_Complete AND NOT Welding_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND  Weld_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableA_At_Robot
				THEN
					(*Start Stud Robots*)
					Start_Stud_Robots:= ((Tool_At_Stud.0 AND All_Sensors_On.3 AND NOT Repo_Reqs.2)
									OR (Tool_At_Stud.1 AND All_Sensors_On.4 AND Repo_Reqs.2))
									OR Stud_Robots_WorkingOK;
					(*Allow Stud Robots To Proceed*)
					Stud_Robots_Proceed:= Tool_At_Stud.0 AND All_Sensors_On.3;
			ELSE
					Start_Stud_Robots:= FALSE;
					Stud_Robots_Proceed:= FALSE;
			END_IF;


                             IF  NOT TurnA_Complete AND Load_Complete AND NOT Welding_Complete AND NOT Unload_Complete
				 AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND  Weld_Robots_Clear AND Unload_Robots_Clear
				AND (NOT TurntableA_At_Robot OR TurnTable_WorkingOK)
				THEN
					(*Start Turntable SweepA (Fix01 to the Robot)*)
					Start_TurntableA:= ((Tool_At_Rotate.0 AND All_Sensors_On.3)
									OR (All_Sensors_Off AND Tool_At_Home))
									OR TurnTable_WorkingOK;
			ELSE
					Start_TurntableA:= FALSE;
			END_IF;


			IF NOT TurnB_Complete AND Welding_Complete AND NOT Unload_Complete AND (Sealing_Complete OR Sealer_Bypass) AND (Stud_Complete OR Stud_Bypass)
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Weld_Robots_Clear  AND Unload_Robots_Clear
				AND (NOT TurntableB_At_Robot OR TurnTable_WorkingOK)
				THEN
					(*Start Turntable SweepB (Fix01 to the Operator)*)
					Start_TurntableB:= TRUE;
                             ELSIF All_Sensors_Off AND NOT TurnB_Complete AND Weld_Robots_Clear AND Load_Robots_Clear AND Unload_Robots_Clear
				AND (NOT TurntableB_At_Robot OR TurnTable_WorkingOK)
			THEN
					Start_TurntableB:= All_Sensors_Off;
                             ELSE
					Start_TurntableB:= FALSE;
                             END_IF;


			IF Load_Complete AND NOT Welding_Complete AND (Sealing_Complete OR Sealer_Bypass) AND (Stud_Complete OR Stud_Bypass) AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear
				AND TurnTableA_At_Robot AND Mig_Robots_Ready 
				THEN
					(*Start Weld Robots*)
					Start_Weld_Robots:=((Tool_At_Weld.0 AND NOT Repo_Reqs.3 AND NOT Repo_Reqs.4 AND NOT Repo_Reqs.5 AND All_Sensors_On.3)
										OR (Tool_At_Weld.1 AND Repo_Reqs.3 AND All_Sensors_On.3)
										OR (Tool_At_Weld.2 AND Repo_Reqs.4 AND All_Sensors_On.4)
										OR (Tool_At_Weld.3 AND Repo_Reqs.5 AND All_Sensors_On.5)
										OR (Tool_At_Unload.0 AND Weld_Robots_UnclampEarly))
										OR Weld_Robots_WorkingOK;
					(*Allow Weld Robots To Proceed*)
					Weld_Robots_Proceed:= Load_Complete AND Tool_At_Weld.0 AND All_Sensors_On.3;
			ELSE
					Start_Weld_Robots:= FALSE;
					Weld_Robots_Proceed:= FALSE;
			END_IF;


			IF Welding_Complete  AND (Sealing_Complete OR Sealer_Bypass) AND (Stud_Complete OR Stud_Bypass) AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear2
				AND TurnTableA_At_Robot
				THEN
					(*Start Unload Robots*)
					Start_Unload_Robots1:=((((Tool_At_Unload.0 AND NOT Repo_Reqs.6 AND NOT Repo_Reqs.7 AND All_Sensors_On.8)
										OR (Tool_At_Unload.1 AND Repo_Reqs.6)
										OR (Tool_At_Unload.2 AND Repo_Reqs.7))
										AND (All_Sensors_On.8 AND Unload_Robots_EOATEmpty1))
										OR (NOT Unload_Robots_Clear1 AND NOT Unload_Robots_EOATEmpty1))
										OR Unload_Robots_WorkingOK1;
					(*Allow Unload Robots To Proceed*)
					Unload_Robots_Proceed1:= Welding_Complete AND Tool_At_Unload.0 AND All_Sensors_On.8 AND Unload_Robots_EOATEmpty1;
			ELSE
					Start_Unload_Robots1:= FALSE;
					Unload_Robots_Proceed1:= FALSE;
			END_IF;


			IF Welding_Complete  AND (Sealing_Complete OR Sealer_Bypass) AND (Stud_Complete OR Stud_Bypass) AND NOT Unload_Complete
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND TurnTable_Clear AND Unload_Robots_Clear1
				AND TurnTableA_At_Robot
				THEN
					(*Start Unload Robots*)
					Start_Unload_Robots2:=((((Tool_At_Unload.0 AND NOT Repo_Reqs.6 AND NOT Repo_Reqs.7 AND All_Sensors_On.8)
										OR (Tool_At_Unload.1 AND Repo_Reqs.6)
										OR (Tool_At_Unload.2 AND Repo_Reqs.7))
										AND (All_Sensors_On.8 AND Unload_Robots_EOATEmpty2))
										OR (NOT Unload_Robots_Clear2 AND NOT Unload_Robots_EOATEmpty2))
										OR Unload_Robots_WorkingOK2;
					(*Allow Unload Robots To Proceed*)
					Unload_Robots_Proceed2:= Welding_Complete AND Tool_At_Unload.0 AND All_Sensors_On.8 AND Unload_Robots_EOATEmpty2;
			ELSE
					Start_Unload_Robots2:= FALSE;
					Unload_Robots_Proceed2:= FALSE;
			END_IF;


	ELSE
		Start_Load_Robots1:= FALSE;
		Start_Load_Robots2:= FALSE;
		Start_Seal_Robots:= FALSE;
		Start_Stud_Robots:= FALSE;
		Start_TurntableA:= FALSE;
		Start_TurntableB:= FALSE;
		Start_Weld_Robots:= FALSE;
		Start_Unload_Robots1:= FALSE;
		Start_Unload_Robots2:= FALSE;
		Load_Robots_Proceed1:=FALSE;
		Load_Robots_Proceed2:=FALSE;
		Seal_Robots_Proceed:=FALSE;
		Weld_Robots_Proceed:=FALSE;
		Unload_Robots_Proceed1:=FALSE;
		Unload_Robots_Proceed2:=FALSE;
	END_IF;




(*---------------------------------------------------------------Completes----------------------------------------------------*)
	(*1st Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete1:=  All_Sensors_On.1;
	ELSIF Dry_Cycle
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete1:= TRUE;
		END_IF;
	END_IF;
	(*2nd Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete2:=  All_Sensors_On.2;
	ELSIF Dry_Cycle
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete2:= TRUE;
		END_IF;
	END_IF;
	(*All Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete:= (All_Sensors_On.2
					OR (All_Sensors_On.3 AND Tool_At_Weld.0)
					OR (Repo_Reqs.0 AND All_Sensors_On.4)
					OR (Repo_Reqs.1 AND All_Sensors_On.5)
					OR (Repo_Reqs.2 AND All_Sensors_On.6))
					OR Weld_Robots_WorkingOK OR Welding_Complete;
	ELSIF Dry_Cycle
		THEN
		IF Load_Complete1 AND Load_Complete2 AND All_Sensors_Off
			THEN
			Load_Complete:= TRUE;
		END_IF;
	END_IF;

	(*Welding Complete*)
	IF Weld_Robots_Complete
		THEN
		Welding_Complete:= TRUE;
	END_IF;

	(*Unload Complete*)
	IF NOT Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	ELSIF Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	END_IF;
(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Cycle Complete !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
	(*Set Cycle Complete*)
	IF Auto_Run AND Load_Complete AND Welding_Complete AND Unload_Complete AND All_Robots_Clear
		THEN Cycle_Complete:= TRUE;
	END_IF;
	(*Reset All Completes*)
	IF Load_Robots_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear AND NOT Unload_Robots_Complete1 AND NOT Unload_Robots_Complete2
		THEN
			IF In_Manual AND Discrete_In.Go_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF NOT Dry_Cycle AND Cycle_Complete AND NOT Enable_Motion AND Tool_At_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF Dry_Cycle AND Cycle_Complete AND Tool_At_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:=TRUE;
			ELSE
					Reset_All_Completes:= FALSE;
			END_IF;
	END_IF;
	(*Perform Actual Reset*)
		IF Reset_All_Completes
			THEN
				Cycle_Complete:= FALSE;
				Load_Complete1:= FALSE;
				Load_Complete2:= FALSE;
				Load_Complete:= FALSE;
				Sealing_Complete:= FALSE;
				Stud_Complete:= FALSE;
				Welding_Complete:= FALSE;
				Date_Stamp_Complete:= FALSE;
				VacCheck_Complete:= FALSE;
				Unload_Complete:=FALSE;
				Eject_Complete:= FALSE;
				Load_Robots_UnclampEarly1:= FALSE;
				Load_Robots_UnclampEarly2:= FALSE;
				Seal_Robots_UnclampEarly:= FALSE;
				Stud_Robots_UnclampEarly:= FALSE;
				Weld_Robots_UnclampEarly:= FALSE;
				Repo_Reqs:= 0;
				Reset_All_Completes:= FALSE;

		END_IF;

(*---------------------------------------------------------------------------- Call Various Actions ----------------------------------------------------------------------------------------------------*)
	(*Poduction Counters and Report*)
	Production();

	(*Register Robot(s) to Fixture*)
	Robot_Registration();

	(*Setup Fix ID and Model Data*)
	Task_Fix_Model_IDs();

	(*Generate Status Banner and Fault Flags*)
	Status_and_Faults();

	(*Tool Clamp / Unclamp Sequencing and Reposition Handling*)
	Tool_VBSeq_Repos();

	(*Transfer Object Image Data to UI Section*)
	Xfer_To_UI();


(*-----------------------------------------------------------------------------------------Transfer Valve Outputs --------------------------------------------------------------------------------*)
	(*Move "Manual_Home_Prompt" as required for home prompting*)
		Manual_Ind_HomePrompt:= Flash_Rate AND In_Manual AND Discrete_In.Go_Home AND NOT Tool_At_Home;

	(*Call each valve bank*)
	ValveBank1();
	(*ValveBank2();
	ValveBank3(); *)






















]]></ST>
    </Implementation>
    <Action Name="All_Sensors" Id="{7c1d020f-659c-4abc-962f-66a9e7f96303}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)



(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)

	(*All Sensors Required Off*)
	All_Sensors_Off:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
			AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6
			AND NOT Part_Present7 AND NOT Part_Present8 AND NOT Part_Present9
			AND NOT Part_Present10 AND NOT Part_Present11 AND NOT Part_Present12
			AND NOT Part_Present13 AND NOT Part_Present14 AND NOT Part_Present15
			AND NOT Part_Present16 AND NOT Part_Present17 AND NOT Part_Present18
			AND NOT Part_Present19 AND NOT Part_Present20 AND NOT Part_Present21
			AND NOT Part_Present22 AND NOT Part_Present23 AND NOT Part_Present24
			AND NOT Part_Present25 AND NOT Part_Present26 AND NOT Part_Present27
			AND NOT Part_Present28 AND NOT Part_Present29 AND NOT Part_Present30
			AND NOT Part_Present31 AND NOT Part_Present32 AND NOT Part_Present33
			AND NOT Part_Present34 AND NOT Part_Present35 AND NOT Part_Present36
			AND NOT Part_Present37 AND NOT Part_Present38 AND NOT Part_Present39
			AND NOT Part_Present40;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off1:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
			AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6
			AND NOT Part_Present7 AND NOT Part_Present8 AND NOT Part_Present9
			AND NOT Part_Present10 AND NOT Part_Present11 AND NOT Part_Present12
			AND NOT Part_Present13 AND NOT Part_Present14 AND NOT Part_Present15
			AND NOT Part_Present16 AND NOT Part_Present17 AND NOT Part_Present18
			AND NOT Part_Present19 AND NOT Part_Present20 AND NOT Part_Present21
			AND NOT Part_Present22 AND NOT Part_Present23 AND NOT Part_Present24
			AND NOT Part_Present25 AND NOT Part_Present26 AND NOT Part_Present27
			AND NOT Part_Present28 AND NOT Part_Present29 AND NOT Part_Present30
			AND NOT Part_Present31 AND NOT Part_Present32 AND NOT Part_Present33
			AND NOT Part_Present34 AND NOT Part_Present35 AND NOT Part_Present36
			AND NOT Part_Present37 AND NOT Part_Present38 AND NOT Part_Present39
			AND NOT Part_Present40;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off2:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
			AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6
			AND NOT Part_Present7 AND NOT Part_Present8 AND NOT Part_Present9
			AND NOT Part_Present10 AND NOT Part_Present11 AND NOT Part_Present12
			AND NOT Part_Present13 AND NOT Part_Present14 AND NOT Part_Present15
			AND NOT Part_Present16 AND NOT Part_Present17 AND NOT Part_Present18
			AND NOT Part_Present19 AND NOT Part_Present20 AND NOT Part_Present21
			AND NOT Part_Present22 AND NOT Part_Present23 AND NOT Part_Present24
			AND NOT Part_Present25 AND NOT Part_Present26 AND NOT Part_Present27
			AND NOT Part_Present28 AND NOT Part_Present29 AND NOT Part_Present30
			AND NOT Part_Present31 AND NOT Part_Present32 AND NOT Part_Present33
			AND NOT Part_Present34 AND NOT Part_Present35 AND NOT Part_Present36
			AND NOT Part_Present37 AND NOT Part_Present38 AND NOT Part_Present39
			AND NOT Part_Present40;



(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)


	(*Sensors Required for Start Of 1st Robot Load*)
	All_Sensors_On.0:= FALSE OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required for Start of 2nd Robot Load*)
	All_Sensors_On.1:= FALSE OR  (Dry_Cycle AND All_Sensors_Off);

	(*Sensors After Load Complete*)
	All_Sensors_On.2:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6
						AND Part_Present7 AND Part_Present8 AND Part_Present9
						AND Part_Present10 AND Part_Present11 AND Part_Present12
						AND Part_Present13 AND Part_Present14 AND Part_Present15
						AND Part_Present16 AND Part_Present17 AND Part_Present18
						AND Part_Present19 AND Part_Present20 AND Part_Present21
						AND Part_Present22 AND Part_Present23 AND Part_Present24
						AND Part_Present25 AND Part_Present26 AND Part_Present27
						AND Part_Present28 AND Part_Present29 AND Part_Present30
						AND Part_Present31 AND Part_Present32 AND Part_Present33
						AND Part_Present34 AND Part_Present35 AND Part_Present36
						AND Part_Present37 AND Part_Present38 AND Part_Present39
						AND Part_Present40)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6
						AND Part_Present7 AND Part_Present8 AND Part_Present9
						AND Part_Present10 AND Part_Present11 AND Part_Present12
						AND Part_Present13 AND Part_Present14 AND Part_Present15
						AND Part_Present16 AND Part_Present17 AND Part_Present18
						AND Part_Present19 AND Part_Present20 AND Part_Present21
						AND Part_Present22 AND Part_Present23 AND Part_Present24
						AND Part_Present25 AND Part_Present26 AND Part_Present27
						AND Part_Present28 AND Part_Present29 AND Part_Present30
						AND Part_Present31 AND Part_Present32 AND Part_Present33
						AND Part_Present34 AND Part_Present35 AND Part_Present36
						AND Part_Present37 AND Part_Present38 AND Part_Present39
						AND Part_Present40)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6
						AND Part_Present7 AND Part_Present8 AND Part_Present9
						AND Part_Present10 AND Part_Present11 AND Part_Present12
						AND Part_Present13 AND Part_Present14 AND Part_Present15
						AND Part_Present16 AND Part_Present17 AND Part_Present18
						AND Part_Present19 AND Part_Present20 AND Part_Present21
						AND Part_Present22 AND Part_Present23 AND Part_Present24
						AND Part_Present25 AND Part_Present26 AND Part_Present27
						AND Part_Present28 AND Part_Present29 AND Part_Present30
						AND Part_Present31 AND Part_Present32 AND Part_Present33
						AND Part_Present34 AND Part_Present35 AND Part_Present36
						AND Part_Present37 AND Part_Present38 AND Part_Present39
						AND Part_Present40)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6
						AND Part_Present7 AND Part_Present8 AND Part_Present9
						AND Part_Present10 AND Part_Present11 AND Part_Present12
						AND Part_Present13 AND Part_Present14 AND Part_Present15
						AND Part_Present16 AND Part_Present17 AND Part_Present18
						AND Part_Present19 AND Part_Present20 AND Part_Present21
