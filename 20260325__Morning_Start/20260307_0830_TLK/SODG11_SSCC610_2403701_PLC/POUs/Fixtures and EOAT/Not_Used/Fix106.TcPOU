	Tool_At_Weld.4:= FALSE;


	Tool_At_Unload.0:=Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Clamp13RETD AND Clamp14RETD AND Clamp15RETD AND Clamp16RETD
				AND Clamp17RETD AND Clamp18RETD AND Clamp19RETD AND Clamp20RETD
				AND Clamp21RETD AND Clamp22RETD AND Clamp23RETD AND Clamp24RETD
