    <Action Name="Robot_Registration" Id="{8d8cf2bd-4fc9-4065-abc9-fc36d490f73f}">
      <Implementation>
        <ST><![CDATA[

(*#################################### Register Robots to Tool ##################################*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*NOTE: See Example code in Fix 15 / 16*)
(*NOTE: See Example code in Fix 15 / 16*)

	(*Data From Load Robot(s)*)
	Load_Robots_Clear1:= TRUE;
	Load_Robots_Clear2:= TRUE;
	Load_Robots_Clear:=Load_Robots_Clear1 AND Load_Robots_Clear2;
	Load_Robots_WorkingOK1:= FALSE;
	Load_Robots_WorkingOK2:= FALSE;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly1:= TRUE;
	END_IF;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly2:= TRUE;
	END_IF;
	Load_Robots_Complete1:= FALSE;
	Load_Robots_Complete2:= FALSE;
	Load_Robots_PartInEOAT1:= FALSE;
	Load_Robots_PartInEOAT2:= FALSE;


	(*Data From Turntable*)
	TurntableA_Clear:= TRUE;
	TurntableB_Clear:= TRUE;
	Turntable_Clear:= TurntableA_Clear AND TurntableB_Clear AND NOT MAIN.R1.In_Teach;
	TurntableA_At_Robot:= FALSE;
	TurntableB_At_Robot:= FALSE;
	Turntable_WorkingOK:= FALSE;
	TurntableA_Complete:= FALSE;
	TurntableB_Complete:= FALSE;


	(*Data From Seal Robot(s)*)
	Seal_Robots_Clear:= TRUE;
	Seal_Robots_WorkingOK:= FALSE;
	IF FALSE
		THEN
		Seal_Robots_UnclampEarly:= TRUE;
	END_IF;
	Seal_Robots_Complete:= FALSE;


	(*Data From Stud Robot(s)*)
	Stud_Robots_Clear:= TRUE;
	Stud_Robots_WorkingOK:= FALSE;
	IF FALSE
		THEN
		Stud_Robots_UnclampEarly:= TRUE;
	END_IF;
	Stud_Robots_Complete:= FALSE;


	(*Data From Weld Robot(s)*)
	Weld_Robots_Clear:= TRUE;
	Weld_Robots_WorkingOK:= FALSE;
	IF FALSE
		THEN
		Weld_Robots_UnclampEarly:= TRUE;
	END_IF;
	Weld_Robots_Complete:= FALSE;

	(*Change Robots for Current Fixture functionality*) (*If no MIG robots Set to True.  Example code is in Fix15/16*) 
	Mig_Robots_Ready:=	TRUE;	

	(*Data From Unload Robot(s)*)
	Unload_Robots_Clear1:= TRUE;
	Unload_Robots_Clear2:= TRUE;
	Unload_Robots_Clear:= Unload_Robots_Clear1 AND Unload_Robots_Clear2;
	Unload_Robots_WorkingOK1:= FALSE;
	Unload_Robots_WorkingOK2:= FALSE;
	Unload_Robots_Complete1:= FALSE;
	Unload_Robots_Complete2:= FALSE;
	Unload_Robots_EOATEmpty1:=FALSE;
	Unload_Robots_EOATEmpty2:= FALSE;



	(*Amalgumate All Robots Clear of Tool*)
	All_Robots_Clear:= Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear;

	(*Data To All Robots*)
	(*Task ID*)
	R1_Data.Task_ID[1]:=Task_ID;

	(*Fix ID*)
	R1_Data.Fix_ID[1]:=Fix_ID;

	(*Model ID*)
	R1_Data.Model_ID[1]:=Model_ID;

	(*Proceed from Pounce*)
	R1_Data.Proceed_From_Pounce[1]:= Robots_Clear_ToProceed;

	(*Complete Acks*)
	R1_Data.Complete_Ack[1]:=(Weld_Complete_Ack AND Weld_Robots_WorkingOK);

	(*Repo Acks*)
	R1_Data.PeripheralReq_Ack[1]:= Repo_Ack;

(*%%%%%%%%%%%%%% Call Robots to Tool and Give Them, Task ID, Fixture ID and Model ID %%%%%%%%%%%%%%%%%*)
	(* Perform Call To Tool*)
	Tool_Call_ForLoadRobots1:= Enable_Motion AND (NOT Cell_In_Services OR NOT Load_Robots_Clear1)
						AND Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForLoadRobots2:= Enable_Motion AND (NOT Cell_In_Services OR NOT Load_Robots_Clear2)
						AND NOT Start_Load_Robots1 AND Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForSealRobots:=Enable_Motion AND (NOT Cell_In_Services OR NOT Seal_Robots_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForStudRobots:=Enable_Motion AND (NOT Cell_In_Services OR NOT Stud_Robots_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForSweepA:= Enable_Motion AND (NOT Cell_In_Services OR NOT TurntableA_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForSweepB:= Enable_Motion AND (NOT Cell_In_Services OR NOT TurntableB_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND Start_TurntableB;
	Tool_Call_ForWeldRobots:= Enable_Motion AND (NOT Cell_In_Services OR NOT Weld_Robots_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForUnloadRobots1:= Enable_Motion AND (NOT Cell_In_Services OR NOT Unload_Robots_Clear1)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForUnloadRobots2:= Enable_Motion AND (NOT Cell_In_Services OR NOT Unload_Robots_Clear2)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;



	(*Allow Robots to Proceed Into Tool*)
	(*!!!!!This is the final OK to allow Robots Into the Tool Area, So it Better Be Ready!!!!!!!*)
	IF Enable_Motion
		THEN
			IF Load_Robots_Proceed1 AND Load_Robots_WorkingOK1 AND Load_Robots_Clear2 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Load_Robots_Proceed2 AND Load_Robots_WorkingOK2 AND Load_Robots_Clear1 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Seal_Robots_Proceed AND Seal_Robots_WorkingOK AND Load_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Stud_Robots_Proceed AND Stud_Robots_WorkingOK AND Load_Robots_Clear AND Seal_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Weld_Robots_Proceed AND Weld_Robots_WorkingOK AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Unload_Robots_Proceed1 AND Unload_Robots_WorkingOK1 AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear2
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Unload_Robots_Proceed2 AND Unload_Robots_WorkingOK2 AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear1
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSE Robots_Clear_ToProceed:= FALSE;
			END_IF;
		ELSE Robots_Clear_ToProceed:= FALSE;
	END_IF;

(*+++++++++++++++++++++++++++++++++++++++++++++++ Task Complete Acks ++++++++++++++++++++++++++*)
	(*1st Load Complete Ack*)
	Load_Complete1_Ack:= Load_Robots_Complete1 AND Load_Complete1;

	(*2nd Load Complete Ack*)
	Load_Complete2_Ack:= Load_Robots_Complete2 AND Load_Complete2;

	(*Seal Complete Ack*)
	Seal_Complete_Ack:= Seal_Robots_Complete AND Sealing_Complete;

	(*Stud Complete Ack*)
	Stud_Complete_Ack:= Stud_Robots_Complete AND Stud_Complete;

	(*Sweep Complete ACK*)
	TurnA_Complete_Ack := TurntableA_Complete AND TurntableA_At_Robot;
	TurnB_Complete_Ack := TurntableB_Complete AND TurntableB_At_Robot;

	(*Weld Complete Ack*)
	Weld_Complete_Ack:= Weld_Robots_Complete AND Welding_Complete;

	(*Unload Complete Ack*)
	Unload_Complete1_Ack:= Unload_Robots_Complete1 AND Unload_Complete;

	(*Unload Complete Ack*)
	Unload_Complete2_Ack:= Unload_Robots_Complete2 AND Unload_Complete;




(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Status_and_Faults" Id="{73de8309-e8da-4095-9aa0-c5799c791ef0}">
      <Implementation>
        <ST><![CDATA[


(*^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ General Visualization ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^*)
	(*For Ready to Load Indicators*)
		(*Flash when tool should be loaded but load is not complete*)
		IF In_Auto AND Tool_At_Home AND NOT Welding_Complete AND All_Robots_Clear AND NOT All_Sensors_On.2
			THEN
				Ready_To_Load:= Pulse_500mS;
				(*Go solid when tool has been loaded properly*)
				(*Go solid when tool is ready to be unloaded*)
		ELSIF In_Auto AND All_Robots_Clear  AND ((Tool_At_Home AND NOT Welding_Complete AND All_Sensors_On.2 AND NOT Enable_Motion)
			OR (Tool_At_Unload.0 AND Welding_Complete AND (Sealing_Complete OR Sealer_Bypass) AND (Stud_Complete OR Stud_Bypass) AND TurntableA_At_Robot AND NOT All_Sensors_Off))
			THEN
				Ready_To_Load:= TRUE;
		ELSE
				Ready_To_Load:= FALSE;
		END_IF;
	(*For Red Stack Light Indicators*)
		Red_Lamp_Req:= PPFaults<>0 OR CLFaulted.0 OR CLFaulted.4 OR (NOT Sealer_Bypass AND MAIN.SL01.Disp1_Volume_NotOK AND (MAIN.R1.Task_ID_Ack=Seal_Fix16)) OR Load_Seq01.Faulted;


	(*Status Banners*)
		(*1 - Check Parts On Sub Check*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.0
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.0
					THEN Status:= 1;
				ELSIF Dry_Cycle AND NOT Load_Complete1
					THEN Status:=1;
				END_IF;
		END_IF;
		(*2 - Sub Check OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.1
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.1
					THEN Status:= 2;
				ELSIF Dry_Cycle AND NOT Load_Complete2
					THEN Status:=2;
				END_IF;
		END_IF;
		(*3 - Load Main Part*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Home
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.2
					THEN Status:= 3;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=3;
				END_IF;
		END_IF;
		(*10 - Load Parts Onto Tool*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.0
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.2
					THEN Status:= 10;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=10;
				END_IF;
		END_IF;
		(*11 - Robot(s) Loading*)
		IF ((Start_Load_Robots1 OR  Load_Robots_WorkingOK1) OR (Start_Load_Robots2 OR  Load_Robots_WorkingOK2)) AND In_Auto AND NOT In_Manual
			AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 11;
		END_IF;
		(*12 - Parts Loaded OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF (All_Sensors_On.2 AND Tool_At_Load.0) AND NOT Dry_Cycle
					THEN Status:= 12;
				ELSIF Load_Complete
					THEN Status:= 12;
				END_IF;
		END_IF;
		(*19 - Robot(s) Stud*)
		IF (Start_Stud_Robots OR Stud_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 19;
		END_IF;
		(*20 - Robot(s) Sealing*)
		IF (Start_Seal_Robots OR Seal_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 20;
		END_IF;
		(*21 - Robot(s) Welding*)
		IF (Start_Weld_Robots OR Weld_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 21;
		END_IF;
		(*22 - Welding Complete / Ready for Unload*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Welding_Complete
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 22;
		END_IF;
		(*26 - Ready for Rotate*)
		IF (Start_TurntableA OR Start_TurntableB) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
			AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status := 26;
		END_IF;
		(*31 - Robot(s) Unloading*)
		IF (Start_Unload_Robots1 OR Unload_Robots_WorkingOK1 OR Start_Unload_Robots2 OR Unload_Robots_WorkingOK2) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots
			THEN Status:= 31;
		END_IF;
		(*32 - Unload Complete*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Unload_Complete
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 32;
		END_IF;
		(*42 - Cycle Complete*)
		IF In_Auto AND NOT In_Manual AND Cycle_Complete AND All_Sensors_Off
			THEN Status:= 42;
		END_IF;
		(*50 - In Manual*)
		IF In_Manual
			THEN Status:= 50;
		END_IF;
		(*51 - Clamp Fault*)
		IF (CLFaults1>0 OR CLFaults2>0 OR CLFaults3>0 OR CLFaults4>0) AND In_Auto AND NOT In_Manual
			THEN Status:= 51;
		END_IF;
		(*52 - Part Present Sensor Fault*)
		IF PPFaults>0 AND In_Auto AND NOT In_Manual
			THEN Status:= 52;
		END_IF;
		(*53 - Nut Checks Failed Call QA*)
		IF QAChecks_Failed AND In_Auto AND NOT In_Manual
			THEN Status:= 53;
		END_IF;
		(*54 - Sealer Failed Call QA*)
		IF NOT Sealer_Bypass AND (MAIN.SL01.Disp1_Volume_NotOK AND (MAIN.R1.Task_ID_Ack=Seal_Fix16)) AND In_Auto AND NOT In_Manual
			THEN Status:= 54;
		END_IF;
		(*55 - Load Sequence Fault Call QA*)
		IF Load_Seq01.Faulted AND In_Auto AND NOT In_Manual
			THEN Status:= 55;
		END_IF;



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Faults $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Clamp/Cylider Faults Group 1*)
		IF CLFaults1>0
			THEN CLFaulted.1:=TRUE;
		ELSE
			CLFaulted.1:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 2*)
		IF CLFaults2>0
			THEN CLFaulted.2:=TRUE;
		ELSE
			CLFaulted.2:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 3*)
		IF CLFaults3>0
			THEN CLFaulted.3:=TRUE;
		ELSE
			CLFaulted.3:=FALSE;
		END_IF;
	(*Clamp/Cylinder Faults Group 4 - Reserved Flag for QA Check Motion Faults*)
		IF CLFaults4>0
			THEN CLFaulted.4:=TRUE;
		ELSE
			CLFaulted.4:=FALSE;
		END_IF;
	(*Bit 0 is designated as ANY Clamp Group Faulted*)
	IF CLFaulted.1 OR CLFaulted.2 OR CLFaulted.3
		THEN CLFaulted.0:= TRUE;
	ELSE CLFaulted.0 := FALSE;
	END_IF;

	(*Part Present Sensor Faults*)
		IF (PPFaults>0) OR (PPFaults1>0) OR (PPFaults2>0)
			THEN PPFaulted.0:=TRUE;
		ELSE
			PPFaulted.0:=FALSE;
		END_IF;
























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Task_Fix_Model_IDs" Id="{0f59bfee-ce8c-4053-8be5-428a232432be}">
      <Implementation>
        <ST><![CDATA[

	(*Develop Task IDs - See Global Variable, "TaskID_Record"*)

	IF (Start_Load_Robots1 OR Start_Load_Robots2) AND Enable_Motion
		THEN Task_ID:= Dropoff_Fix106;
	ELSIF Start_Seal_Robots AND Enable_Motion
		THEN Task_ID:= Seal_Fix106;
	ELSIF Start_Stud_Robots AND Enable_Motion
		THEN Task_ID:= Stud_Fix106;
	ELSIF Start_Weld_Robots AND Enable_Motion
		THEN Task_ID:= Weld_Fix106;
	ELSIF Start_TurnTableA AND Enable_Motion
		THEN Task_ID:= Sweep_Fix106;
	ELSIF (Start_Unload_Robots1 OR Start_Unload_Robots2) AND Enable_Motion
		THEN Task_ID:= Pickup_Fix106;
	ELSE Task_ID:= 0;
	END_IF;

	(*Develop Fixture ID*)
	Fix_ID:= N00.ID;					(*In Future Map Beckhoff Dip Switch Data From IP67 Block to Here*)

	(*Develop Model ID*)
	Model_ID:= Discrete_In.ModelData;

















]]></ST>
      </Implementation>
    </Action>
    <Action Name="Tool_States" Id="{f6a5398e-fb8f-4945-9dd9-fbac9e44339f}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

	Tool_At_HOME:= Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Clamp13RETD AND Clamp14RETD AND Clamp15RETD AND Clamp16RETD
				AND Clamp17RETD AND Clamp18RETD AND Clamp19RETD AND Clamp20RETD
				AND Clamp21RETD AND Clamp22RETD AND Clamp23RETD AND Clamp24RETD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD AND Pin7ADVD
				AND Pin8ADVD AND Pin9ADVD AND Pin10ADVD AND Pin11ADVD AND Pin12ADVD AND Pin13ADVD AND Pin14ADVD
				AND Slide1RETD AND Slide2RETD AND Slide3RETD AND Slide4RETD AND Slide5RETD AND Slide6RETD
				AND Swing1ADVD AND Swing2ADVD AND Swing3ADVD AND Swing4ADVD AND Swing5ADVD AND Swing6ADVD;


	Tool_At_Load.0:=Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Clamp13RETD AND Clamp14RETD AND Clamp15RETD AND Clamp16RETD
				AND Clamp17RETD AND Clamp18RETD AND Clamp19RETD AND Clamp20RETD
				AND Clamp21RETD AND Clamp22RETD AND Clamp23RETD AND Clamp24RETD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD AND Pin7ADVD
				AND Pin8ADVD AND Pin9ADVD AND Pin10ADVD AND Pin11ADVD AND Pin12ADVD AND Pin13ADVD AND Pin14ADVD
				AND Slide1RETD AND Slide2RETD AND Slide3RETD AND Slide4RETD AND Slide5RETD AND Slide6RETD
				AND Swing1ADVD AND Swing2ADVD AND Swing3ADVD AND Swing4ADVD AND Swing5ADVD AND Swing6ADVD;
	Tool_At_Load.1:=FALSE;
	Tool_At_Load.2:= FALSE;
	Tool_At_Load.3:= FALSE;
	Tool_At_Load.4:= FALSE;


	Tool_At_Seal.0:= Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Clamp5ADVD AND Clamp6ADVD AND Clamp7ADVD AND Clamp8ADVD
				AND Clamp9ADVD AND Clamp10ADVD AND Clamp11ADVD AND Clamp12ADVD
				AND Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD AND Clamp16ADVD
				AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD AND Clamp20ADVD
				AND Clamp21ADVD AND Clamp22ADVD AND Clamp23ADVD AND Clamp24ADVD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD AND Pin7ADVD
				AND Pin8ADVD AND Pin9ADVD AND Pin10ADVD AND Pin11ADVD AND Pin12ADVD AND Pin13ADVD AND Pin14ADVD
				AND Slide1RETD AND Slide2RETD AND Slide3RETD AND Slide4RETD AND Slide5RETD AND Slide6RETD
				AND Swing1ADVD AND Swing2ADVD AND Swing3ADVD AND Swing4ADVD AND Swing5ADVD AND Swing6ADVD;
	Tool_At_Seal.1:= FALSE;
	Tool_At_Seal.2:= FALSE;
	Tool_At_Seal.3:= FALSE;
	Tool_At_Seal.4:= FALSE;


	Tool_At_Stud.0:= Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Clamp5ADVD AND Clamp6ADVD AND Clamp7ADVD AND Clamp8ADVD
				AND Clamp9ADVD AND Clamp10ADVD AND Clamp11ADVD AND Clamp12ADVD
				AND Clamp13ADVD AND Clamp14ADVD AND Clamp15ADVD AND Clamp16ADVD
				AND Clamp17ADVD AND Clamp18ADVD AND Clamp19ADVD AND Clamp20ADVD
				AND Clamp21ADVD AND Clamp22ADVD AND Clamp23ADVD AND Clamp24ADVD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD AND Pin7ADVD
				AND Pin8ADVD AND Pin9ADVD AND Pin10ADVD AND Pin11ADVD AND Pin12ADVD AND Pin13ADVD AND Pin14ADVD
				AND Slide1RETD AND Slide2RETD AND Slide3RETD AND Slide4RETD AND Slide5RETD AND Slide6RETD
				AND Swing1ADVD AND Swing2ADVD AND Swing3ADVD AND Swing4ADVD AND Swing5ADVD AND Swing6ADVD;
	Tool_At_Stud.1:= FALSE;
	Tool_At_Stud.2:= FALSE;
