    <Implementation>
      <ST><![CDATA[	(*Set FB_OK to True*)
	FB_OK:= TRUE;


(*---------------------------------------------------- Gather Hardwear ------------------------------------------------------*)
	Hardware();


(*---------------------------------------------------- Gather Clamp Sensor Inputs --------------------------------------*)
	Cylinders();


(*---------------------------------------------------- Gather Part Present Sensor Inputs ------------------------------*)
	Proxies();


(*---------------------------------------------------- Group Clamp Sensors -----------------------------------------------*)
	Tool_States();


(*---------------------------------------------------- Group Part Present Sensors ---------------------------------------*)
	All_Sensors();



(*---------------------------------------------------- Status and Faults--------------------------------------------------------*)
	Status_and_Faults();


(*---------------------------------------------------- Transfer to UI -------------------------------------------------------------*)
	Xfer_To_UI();


(*------------------------------------------------------Transfer Valve Outputs ----------------------------------------------*)
	ValveBank1();


(*---------------------------------------------------- Gather Robot Registration-------------------------------------------*)









(*end*)]]></ST>
    </Implementation>
    <Action Name="All_Sensors" Id="{b56dda2f-70da-4ab5-ad3d-49335d196d12}">
      <Implementation>
        <ST><![CDATA[

(*	Note - In the event there is a left part and a right part, grouping the sensors allows only portions of the sensors to be monitored at a time.
		If this is not advantageous to the design, there is still the option to group all the sensors as one group instead.
		In this example, there are all 5 groups set up. 
		Change this section to suit the specific design you have, where .0 is all, .1 is group one, .2 is group two, etc*)


	(*All Sensors Off*)
	All_Sensors_Off.0:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
					AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6
					AND NOT Part_Present7 AND NOT Part_Present8;

	(*All Sensors Off - Group 1*)
	All_Sensors_Off.1:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
					AND NOT Part_Present4 AND NOT Part_Present5;

	(*All Sensors Off - Group 2*)
	All_Sensors_Off.2:= NOT Part_Present6 AND NOT Part_Present7 AND NOT Part_Present8;

	(*All Sensors Off - Group 3*)
	All_Sensors_Off.3:= FALSE;

	(*All Sensors Off - Group 4*)
	All_Sensors_Off.4:= FALSE;

	(*All Sensors Off - Group 5*)
	All_Sensors_Off.5:= FALSE;



	(*All Sensors On*)
	All_Sensors_On.0:= (Part_Present1 AND Part_Present2 AND Part_Present3
					AND Part_Present4 AND Part_Present5 AND Part_Present6
					AND Part_Present7 AND Part_Present8)
					OR (All_Sensors_Off.0 AND Dry_Cycle);

	(*All Sensors On - Group 1*)
	All_Sensors_On.1:= (Part_Present1 AND Part_Present2 AND Part_Present3 AND Part_Present4 AND Part_Present5)
					OR (All_Sensors_Off.0 AND Dry_Cycle);

	(*All Sensors On - Group 2*)
	All_Sensors_On.2:= (Part_Present6 AND Part_Present7 AND Part_Present8)
					OR (All_Sensors_Off.0 AND Dry_Cycle);

	(*All Sensors On - Group 3*)
	All_Sensors_On.3:= (FALSE)
					OR (All_Sensors_Off.0 AND Dry_Cycle);

	(*All Sensors On - Group 4*)
	All_Sensors_On.4:= (FALSE)
					OR (All_Sensors_Off.0 AND Dry_Cycle);

	(*All Sensors On - Group 5*)
	All_Sensors_On.5:= (FALSE)
					OR (All_Sensors_Off.0 AND Dry_Cycle);




	(*Group all Sensors*)
	IF CMD_CheckAllSensors_OFF AND All_Sensors_Off.0
		THEN
			EOAT_All_Empty:= TRUE;
			EOAT_Full:= FALSE;

	ELSIF CMD_CheckAllSensors_ON AND All_Sensors_On.0
		THEN
			EOAT_All_Empty:= FALSE;
			EOAT_Full:= TRUE;

	END_IF

	IF CMD_CheckSensorsOFF_Grp1 AND All_Sensors_Off.1
		THEN
			EOAT_Part1_Empty:= TRUE;
			Part1_In_EOAT:= FALSE;

	ELSIF CMD_CheckSensorsON_Grp1 AND All_Sensors_On.1
		THEN
			EOAT_Part1_Empty:= FALSE;
			Part1_In_EOAT:= TRUE;

	END_IF

	IF CMD_CheckSensorsOFF_Grp2 AND All_Sensors_Off.2
		THEN
			EOAT_Part2_Empty:= TRUE;
			Part2_In_EOAT:= FALSE;

	ELSIF CMD_CheckSensorsON_Grp2 AND All_Sensors_On.2
		THEN
			EOAT_Part2_Empty:= FALSE;
			Part2_In_EOAT:= TRUE;

	END_IF

	IF CMD_CheckSensorsOFF_Grp3 AND All_Sensors_Off.3
		THEN
			EOAT_Part3_Empty:= TRUE;
			Part3_In_EOAT:= FALSE;

	ELSIF CMD_CheckSensorsON_Grp3 AND All_Sensors_On.3
		THEN
			EOAT_Part3_Empty:= FALSE;
			Part3_In_EOAT:= TRUE;

	ELSIF CMD_CheckSensorsON_Grp3 AND All_Sensors_On.3
		THEN
			EOAT_Part3_Empty:= FALSE;
			Part3_In_EOAT:= TRUE;

	END_IF

	IF CMD_CheckSensorsOFF_Grp4 AND All_Sensors_Off.4
		THEN
			EOAT_Part4_Empty:= TRUE;
			Part4_In_EOAT:= FALSE;
	ELSIF CMD_CheckSensorsON_Grp4 AND All_Sensors_On.4
		THEN
			EOAT_Part4_Empty:= FALSE;
			Part4_In_EOAT:= TRUE;

	END_IF

	IF CMD_CheckSensorsOFF_Grp5 AND All_Sensors_Off.5
		THEN
			EOAT_Part5_Empty:= TRUE;
			Part5_In_EOAT:= FALSE;
	ELSIF CMD_CheckSensorsON_Grp5 AND All_Sensors_On.5
		THEN
			EOAT_Part5_Empty:= FALSE;
			Part5_In_EOAT:= TRUE;

	END_IF












(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Cylinders" Id="{f1175e42-32ad-4210-b03c-120a4fbe2a22}">
      <Implementation>
        <ST><![CDATA[(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)

		(*Clamp1*)
		Clamp1FB(
