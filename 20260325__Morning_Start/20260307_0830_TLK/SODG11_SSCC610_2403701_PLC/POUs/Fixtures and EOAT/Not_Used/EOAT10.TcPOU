			Sensor_Input:=N01.I.3,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp1,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp1,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present4,
			Faulted=>  PPFaults.4);

	(*Part 5 Present*)
		Part_Present5FB(
			Sensor_Input:= N01.I.4,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp1,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp1,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present5,
			Faulted=>  PPFaults.5);

	(*Part 6 Present*)
		Part_Present6FB(
			Sensor_Input:= N01.I.5,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp2,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp2,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present6,
			Faulted=>  PPFaults.6);

	(*Part 7 Present*)
		Part_Present7FB(
			Sensor_Input:= N01.I.7,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp2,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp2,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present7,
			Faulted=>  PPFaults.7);

	(*Part 8 Present*)
		Part_Present8FB(
			Sensor_Input:= N09.I.0,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp2,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp2,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
