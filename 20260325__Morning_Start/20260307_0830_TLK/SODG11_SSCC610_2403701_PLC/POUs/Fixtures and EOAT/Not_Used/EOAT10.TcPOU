		(*Pin5*)
		Pin5FB(
			Retracted_Sensor:=  N04.I.0,
			Advanced_Sensor:=  N04.I.1,
			Retract_Solenoid:=  N100.Q.13,
			Advance_Solenoid:=  N100.Q.12,
			Adv_Delay:=  T#0.1S,
			Ret_Delay:=  T#0.1S,
			Fault_Delay:=  T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Pin5RETD,
			In_Advanced_Position=> Pin5ADVD,
			Faulted=> CLFaults1.9);

		(*Pin6*)
		Pin6FB(
			Retracted_Sensor:=  N04.I.2,
			Advanced_Sensor:=  N04.I.3,
			Retract_Solenoid:=  N100.Q.13,
			Advance_Solenoid:=  N100.Q.12,
			Adv_Delay:=  T#0.1S,
			Ret_Delay:=  T#0.1S,
			Fault_Delay:=  T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Pin6RETD,
			In_Advanced_Position=> Pin6ADVD,
			Faulted=> CLFaults1.10 );

































(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Hardware" Id="{69c076d1-112b-4b1c-b5e8-7ef5a6ce351e}">
      <Implementation>
        <ST><![CDATA[(*Pass Node States into Array  in order on Physical Fixture*)

	NodeState:=NodeLayout.State;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Discrete I/O Nodes*)

	IF (N01.InfoData.State=8)
		AND (N01.InfoData.State=8 OR (Input_Node_Count<2))
		AND (N02.InfoData.State=8 OR (Input_Node_Count<3))
		AND (N03.InfoData.State=8 OR (Input_Node_Count<4))
		AND (N04.InfoData.State=8 OR (Input_Node_Count<5))
		AND (N05.InfoData.State=8 OR (Input_Node_Count<6))
		AND (N06.InfoData.State=8 OR (Input_Node_Count<7))
		AND (N07.InfoData.State=8 OR (Input_Node_Count<8))
		AND (N08.InfoData.State=8 OR (Input_Node_Count<9))
		AND (N09.InfoData.State=8 OR (Input_Node_Count<10))
		AND (N100_STAT.InfoData.State=8)

		THEN
			DiscreteNode_OK:=TRUE;

	ELSE
			DiscreteNode_OK:=FALSE;

	END_IF;

	(*Cable Break Detection*)
		ECatSlave_Cable_Breaks:= FUN_GTAC_EcatSlaveConnState_64bit(NodeState);		(*Function Returns Flags to warn of possible cable break*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Proxies" Id="{acb67698-2840-4194-af02-4c2dcb07f611}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

(*Note - On_Trigger and Off_Trigger need to be changed based on which group in All_Sensors_On the sensor is placed.*)


	(*Part 1 Present*)
		Part_Present1FB(
			Sensor_Input:= N01.I.0,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp1 OR EOAT_Full OR Part1_In_EOAT,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp1 OR EOAT_All_Empty OR EOAT_Part1_Empty,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present1,
			Faulted=>  PPFaults.1);

	(*Part 2 Present*)
		Part_Present2FB(
			Sensor_Input:= N01.I.1,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp1,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR CMD_CheckSensorsOFF_Grp1,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR Robot_WorkingOK,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present2,
			Faulted=>  PPFaults.2);

	(*Part 3 Present*)
		Part_Present3FB(
			Sensor_Input:= N01.I.2,
			On_Trigger1:= CMD_CheckAllSensors_ON OR CMD_CheckSensorsON_Grp1,
