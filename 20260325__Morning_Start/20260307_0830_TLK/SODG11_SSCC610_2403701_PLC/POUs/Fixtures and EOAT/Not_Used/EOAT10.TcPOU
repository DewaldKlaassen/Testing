    </Action>
    <Action Name="Status_and_Faults" Id="{1c060ab7-bc37-415f-ba71-82466251528d}">
      <Implementation>
        <ST><![CDATA[	(*Clamp/Cylinder Faults*)
		IF CLFaults1>0
			THEN CLFaulted.1:=TRUE;
		ELSE
			CLFaulted.1:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults2>0
			THEN CLFaulted.2:=TRUE;
		ELSE
			CLFaulted.2:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults3>0
			THEN CLFaulted.3:=TRUE;
		ELSE
			CLFaulted.3:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults4>0
			THEN CLFaulted.4:=TRUE;
		ELSE
			CLFaulted.4:=FALSE;
		END_IF;
	(*Bit 0 is designated as ANY Clamp Fault Word Faulted*)
		IF CLFaulted.1 OR CLFaulted.2 OR CLFaulted.3
			THEN CLFaulted.0:= TRUE;
		ELSE
			CLFaulted.0 := FALSE;
		END_IF;

	(*Part Present Sensor Faults*)
		IF PPFaults>0
			THEN PPFaulted.0:=TRUE;
		ELSE
			PPFaulted.0:=FALSE;
		END_IF;

		EOAT_FLT:= (CLFaulted>0) OR (PPFaulted>0);















(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Tool_States" Id="{9955e7a8-e3b7-4b12-9d5b-fd7cbea14d9f}">
      <Implementation>
        <ST><![CDATA[(*	Note - In the event there is a left part and a right part, grouping the cylinders allows only portions of the cylinders to be controlled at a time.
		If this is not advantageous to the design, there is still the option to group all the cylinders as one group instead.
		In this example, there are all 5 groups set up. 
		Change this section to suit the specific design you have, where .0 is all, .1 is group one, .2 is group two, etc*)


	(*Tool All Home - All Cylinders Home*)
	Tool_At_Home.0:=Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD;

	(*Tool All Home - Cylinders Home Group 1*)
	Tool_At_Home.1:=Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD;

	(*Tool All Home - Cylinders Home Group 2*)
	Tool_At_Home.2:=Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Clamp5RETD AND Clamp6RETD AND Clamp7RETD AND Clamp8RETD
				AND Clamp9RETD AND Clamp10RETD AND Clamp11RETD AND Clamp12RETD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD;

	(*Tool All Home - Cylinders Home Group 3*)
	Tool_At_Home.3:= FALSE;

	(*Tool All Home - Cylinders Home Group 4*)
	Tool_At_Home.4:= FALSE;

	(*Tool All Home - Cylinders Home Group 5*)
	Tool_At_Home.5:= FALSE;




	(*Tool at Work - All Cylinders Work*)
	Tool_At_Work.0:= Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Clamp5ADVD AND Clamp6ADVD AND Clamp7ADVD AND Clamp8ADVD
				AND Clamp9ADVD AND Clamp10ADVD AND Clamp11ADVD AND Clamp12ADVD
				AND Pin1ADVD AND Pin2ADVD AND Pin3ADVD AND Pin4ADVD AND Pin5ADVD AND Pin6ADVD;

	(*Tool at Work - Cylinders Work Group 1*)
	Tool_At_Work.1:= Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Clamp5ADVD AND Clamp6ADVD AND Clamp7ADVD AND Clamp8ADVD;

	(*Tool at Work - Cylinders Work Group 2*)
	Tool_At_Work.2:= Clamp9ADVD AND Clamp10ADVD AND Clamp11ADVD AND Clamp12ADVD
				AND Pin1RETD AND Pin2RETD AND Pin3RETD AND Pin4RETD AND Pin5RETD AND Pin6RETD;

	(*Tool at Work - Cylinders Work Group 3*)
	Tool_At_Work.3:= FALSE;

	(*Tool at Work - Cylinders Work Group 4*)
	Tool_At_Work.4:= FALSE;

	(*Tool at Work - Cylinders Work Group 5*)
	Tool_At_Work.5:= FALSE;




	(*Group all Tool States*)
	ACK_Tool_At_WORK:= CMD_Tool_To_WORK AND Tool_At_WORK.0;
	ACK_Tool_At_HOME:= CMD_Tool_To_HOME AND Tool_At_HOME.0;

	ACK_CylAtWORK_Grp1:= CMD_CylToWORK_Grp1 AND Tool_At_WORK.1;
	ACK_CylAtHOME_Grp1:= CMD_CylToHOME_Grp1 AND Tool_At_HOME.1;
	ACK_CylAtWORK_Grp2:= CMD_CylToWORK_Grp2 AND Tool_At_WORK.2;
	ACK_CylAtHOME_Grp2:= CMD_CylToHOME_Grp2 AND Tool_At_HOME.2;
	ACK_CylAtWORK_Grp3:= CMD_CylToWORK_Grp3 AND Tool_At_WORK.3;
	ACK_CylAtHOME_Grp3:= CMD_CylToHOME_Grp3 AND Tool_At_HOME.3;
	ACK_CylAtWORK_Grp4:= CMD_CylToWORK_Grp4 AND Tool_At_WORK.4;
	ACK_CylAtHOME_Grp4:= CMD_CylToHOME_Grp4 AND Tool_At_HOME.4;
	ACK_CylAtWORK_Grp5:= CMD_CylToWORK_Grp5 AND Tool_At_WORK.5;
	ACK_CylAtHOME_Grp5:= CMD_CylToHOME_Grp5 AND Tool_At_HOME.5;














(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="ValveBank1" Id="{d13482b5-e7f5-4053-89d2-60155df1d5d7}">
      <Implementation>
        <ST><![CDATA[(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

