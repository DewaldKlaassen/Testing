		(*Allow_Load_PreCall: BOOL;
		Allow_Weld_PreCall: BOOL;
		Allow_Unload_PreCall: BOOL;*)
		(*All_SubPP_Off: BOOL;*)
		Production_Report: FB_Production_Report_20221007;
		
		
		Current_Time: DT;
		Current_Time_Str : STRING;
		Current_Time_Len : INT;
	
		(*QA data*)
		Part_Failed_Record : STRING;
        Current_Nok_Data : ARRAY [0..5] OF udt_Generic_Nok_Data_Grid_20251208;
		History_Nok_Data : ARRAY [0..5] OF udt_Generic_Nok_Data_Grid_20251208;
		

	END_VAR

	VAR_OUTPUT

		Prog_Ok: BOOL;
		Discrete_Image: udt_FixXX_Output_Image_20220715;
		In_Auto_Mode: BOOL;
		In_Manual_Mode: BOOL;
		Manual_Indicators1: DINT;
		Manual_Indicators2: DINT;
		Manual_Indicators3: DINT;
		At_Home: BOOL;
		Ready_To_Load: BOOL;
		Red_Lamp_Req: BOOL;
		Status: UINT;
		CLFaults1:UDINT;
		CLFaults2:UDINT;
		CLFaults3:UDINT;
		CLFaults4:UDINT;
		PPFaults: UDINT;
		PPFaults1: UDINT;
		PPFaults2: UDINT;
		Prod_Count_Out: INT;
		Cycle_Time_Out: TIME;
		PrevCycle_Time_Out: TIME;
		Load_Time_Out: TIME;
		Weld_Time_Out: TIME;
		Seal_Time_Out: TIME;
		Stud_Time_Out: TIME;
		Turn_Time_Out: TIME;
		Unload_Time_Out: TIME;
		Model_ID: UINT;
		TurntableA_At_Robot: BOOL;
		TurntableB_At_Robot: BOOL;
		Tool_Call_ForLoadRobots1: BOOL;
		Tool_Call_ForLoadRobots2: BOOL;
		Tool_Call_ForSealRobots: BOOL;
		Tool_Call_ForStudRobots: BOOL;
		Tool_Call_ForWeldRobots: BOOL;
		Tool_Call_ForSweepA: BOOL;
		Tool_Call_ForSweepB: BOOL;
		Tool_Call_ForUnloadRobots1: BOOL;
		Tool_Call_ForUnloadRobots2: BOOL;
		Robots_Clear_ToProceed: BOOL;
		Task_ID: UINT;
		Fix_ID: UINT;
		Load_Complete1_Ack: BOOL;
		Load_Complete2_Ack: BOOL;
		Seal_Complete_Ack: BOOL;
		Stud_Complete_Ack: BOOL;
		Weld_Complete_Ack: BOOL;
		TurnA_Complete_Ack: BOOL;
		TurnB_Complete_Ack: BOOL;
		Unload_Complete1_Ack: BOOL;
		Unload_Complete2_Ack: BOOL;
		Repo_Ack: UINT;
	END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[	(*Set FB_OK to True*)
	Prog_OK:= TRUE;

	(*Conveyor*)
	Conveyor();
	
	
	(*Set conditions to allow model change*)
	Fixture_Allow_Model_Change:= (In_Manual AND Tool_At_Home AND All_Sensors_Off AND All_Robots_Clear)
							OR (Model_ID=0);


	(*Set conditions for interlock Part direction once in EOAT04*)
	(*Welded by all upstream and Failed by Fix102*)
	(*Side 1 of EOAT*)
	Part_InEOAT04_1_ReadyForThisFix:= (EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[1] = 'Comp' 		//Fix01 Weld Comp
									OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[2] = 'Comp')		//Fix02 Weld Comp
									AND EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[11] = 'Comp'		//Fix101 Weld Comp
									AND (EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[3] = 'Comp'		//Fix03 Weld Comp
									OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[4] = 'Comp')		//Fix04 Weld Comp
									AND (EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[12] = '1' 
											OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[12] = '2' 
											OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[12] = '3'
											OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[12] = 'Fail');  
	//Fix102 Failed : IV3 failed = 1, Smart Ray failed = 2, IV3 & Smart Ray failed = 3
	
	(*Side 2 of EOAT*)
	Part_InEOAT04_2_ReadyForThisFix:= (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[1] = 'Comp' 		//Fix01 Weld Comp
									OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[2] = 'Comp')		//Fix02 Weld Comp
									AND EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[11] = 'Comp'		//Fix101 Weld Comp
									AND (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[3] = 'Comp'		//Fix03 Weld Comp
									OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[4] = 'Comp')		//Fix04 Weld Comp
									AND (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[12] = '1'
											OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[12] = '2' 
											OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[12] = '3'
											OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[12] = 'Fail');  
	//Fix102 Failed : IV3 failed = 1, Smart Ray failed = 2, IV3 & Smart Ray failed = 3

	(*QA_Data*)
     IF   EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[18] = '1' OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[18] = '1'
          THEN
		  Part_Failed_Record := 'IV3 Failed';
	ELSIF EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[18] = '2' OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[18] = '2' 	
		  THEN
		  Part_Failed_Record := 'Smart Ray Failed';
	ELSIF EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[18] = '3' OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[18] = '3' 	
		  THEN
		  Part_Failed_Record := 'IV3 & Smart Ray Failed';	  
     //ELSE   
    END_IF						
		
  			
(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Fixture Bypasses $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	Weld_Curtain_Bypass:= Discrete_In.Bypass_REQS.0;
	Vacuum_Bypass:= Discrete_In.Bypass_REQS.1;
	Stud_Bypass:= Discrete_In.Bypass_REQS.2;
	Sealer_Bypass:= MAIN.SL01.Disp1_Bypass;


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Check on Status of Hardware*)
	Hardware();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Standard Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*Clamp/Cylinder Inputs*)
	Cylinders();

(*Part Present Inputs*)
	Proxies();


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Auto / Manual Mode Code*)
	IF Discrete_In.Mode_Select.0 AND NOT Discrete_In.Mode_Select.1
		THEN
			In_Auto:= TRUE;
			In_Auto_Mode:= TRUE;
	END_IF;
	IF NOT Discrete_In.Mode_Select.0 AND Discrete_In.Mode_Select.1
		THEN
			In_Auto:= FALSE;
			In_Auto_Mode:= FALSE;
	END_IF;
	In_Manual:= NOT In_Auto;
	In_Manual_Mode:= In_Manual;

(*--------------------------------------------------------------------------------Tool Positions---------------------------------------------------------------*)
	Tool_States();

(*----------------------------------------------------Part Present Sensor Input Patterns----------------------------------------------------------------*)
	All_Sensors();


(*>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Auto Run Cycle >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
	(*Control of Auto_Run*)
	Auto_Run:= Enable_Motion AND In_Auto AND Model_ID<>0 AND NOT Cycle_Complete;

	(*Auto Run Enables All Other Auto Cycle Code*)
	IF Auto_Run
		THEN

			IF  NOT Load_Complete AND NOT Load_Complete1 AND NOT Automatic_Index_CV_Trigger_SR.Q1 AND NOT Manual_Index_CV_Trigger_SR.Q1
                AND (Part_InEOAT04_1_ReadyForThisFix OR Part_InEOAT04_2_ReadyForThisFix)
				THEN
					(*Start 1st Load Robots*)
					Start_Load_Robots1:= (All_Sensors_Off1 AND (Load_Robots_PartInEOAT1 OR Load_Robots_PartInEOAT2) AND NOT Repo_Reqs.0)
									OR (Repo_Reqs.0 AND All_Sensors_On.0)
									OR Load_Robots_WorkingOK1;
					(*Allow 1st Load Robots To Proceed*)
					Load_Robots_Proceed1:= All_Sensors_Off1 AND (Load_Robots_PartInEOAT1 OR Load_Robots_PartInEOAT2);
			ELSE
					Start_Load_Robots1:= FALSE;
					Load_Robots_Proceed1:= FALSE;
			END_IF;
	

	ELSE
		Start_Load_Robots1:= FALSE;
		Load_Robots_Proceed1:=FALSE;
	END_IF;




(*---------------------------------------------------------------Completes----------------------------------------------------*)
	(*1st Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete1:=  All_Sensors_On.0;
	ELSIF Dry_Cycle AND FALSE
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete1:= TRUE;
		END_IF;
	END_IF;

	(*All Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete:= Load_Complete1 AND Load_Robots_Complete1;
	ELSIF Dry_Cycle AND FALSE
		THEN
		IF Load_Complete1 AND Load_Complete2 AND All_Sensors_Off
			THEN
			Load_Complete:= TRUE;
		END_IF;
	END_IF;
	
	(*Unload Complete*)
	Unload_Part_Ready := (Part_Present5 AND Part_Present6);
	IF (Unload_Part_Ready AND NOT Part_Present5 AND NOT Part_Present6 )
		THEN
		Unload_Complete := TRUE;
		Unload_Part_Ready := FALSE;
	END_IF
	// need feed back to reset the unload complete on conveyor from icxx 
(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Cycle Complete !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
	(*Set Cycle Complete*)
	IF Auto_Run AND Load_Complete AND All_Robots_Clear
		THEN Cycle_Complete:= TRUE;
	END_IF;
	(*Reset All Completes*)
	IF Load_Robots_Clear
		THEN
			IF In_Manual AND Manual_Index_CV_Start (*this need to be linked into the var of tchmi*) AND All_Sensors_Off1 (*Manual reset => Manual conveyor *)
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF NOT Dry_Cycle AND Cycle_Complete AND All_Sensors_Off1 AND NOT Automatic_Index_CV_Start
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF Dry_Cycle AND Cycle_Complete AND Tool_At_Home AND All_Sensors_Off AND FALSE
				THEN
					Reset_All_Completes:=TRUE;
			ELSE
					Reset_All_Completes:= FALSE;
			END_IF;
	END_IF;
	(*Perform Actual Reset*)
		IF Reset_All_Completes
			THEN
				Cycle_Complete:= FALSE;
				Load_Complete1:= FALSE;
				Load_Complete:= FALSE;
				Load_Robots_UnclampEarly1:= FALSE;
				Load_Robots_UnclampEarly2:= FALSE;
				Repo_Reqs:= 0;
				Reset_All_Completes:= FALSE;
				Part_Failed_Record := '';

		END_IF;

(*---------------------------------------------------------------------------- Call Various Actions ----------------------------------------------------------------------------------------------------*)
	(*Poduction Counters and Report*)
	Production();

	(*Register Robot(s) to Fixture*)
	Robot_Registration();

	(*Setup Fix ID and Model Data*)
	Task_Fix_Model_IDs();

	(*Generate Status Banner and Fault Flags*)
	Status_and_Faults();

	(*Tool Clamp / Unclamp Sequencing and Reposition Handling*)
	Tool_VBSeq_Repos();

	(*Transfer Object Image Data to UI Section*)
	Xfer_To_UI();


(*-----------------------------------------------------------------------------------------Transfer Valve Outputs --------------------------------------------------------------------------------*)
	(*Move "Manual_Home_Prompt" as required for home prompting*)
		Manual_Ind_HomePrompt:= Flash_Rate AND In_Manual AND Discrete_In.Go_Home AND NOT Tool_At_Home;

	(*Call each valve bank*)
	ValveBank1();
	(*ValveBank2();
	ValveBank3(); *)
	

]]></ST>
    </Implementation>
    <Action Name="All_Sensors" Id="{1fd39326-e197-449b-ba78-47a755700a31}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)



(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)

	(*All Sensors Required Off*)
	All_Sensors_Off:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
			AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off1:= NOT Part_Present1 AND NOT Part_Present2;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off2:= NOT Part_Present3 AND NOT Part_Present4;



(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)


	(*Sensors Required for Start Of 1st Robot Load*)
	All_Sensors_On.0:= Part_Present1 AND Part_Present2;
	(*Sensors Required for Start of 2nd Robot Load*)
	All_Sensors_On.1:= Part_Present3 AND Part_Present4;

	(*Sensors After Load Complete*)
	All_Sensors_On.2:=( Part_Present1 AND Part_Present2 AND Part_Present3
					AND Part_Present4 AND Part_Present5 AND Part_Present6);


	(*Sensors Require for Start Of Welding*)
	All_Sensors_On.3:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)
					) OR (All_Sensors_Off AND Dry_Cycle);


	(*Sensors Required After Repo_Reqs.0*)
	All_Sensors_On.4:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.1*)
	All_Sensors_On.5:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.2*)
	All_Sensors_On.6:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.3*)
	All_Sensors_On.7:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);


	(*Sensors Required for Start Of Unload1*)
	All_Sensors_On.8:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)
					) OR (All_Sensors_Off AND Dry_Cycle);

	(*Sensors Required for Start Of Unload2*)
	All_Sensors_On.9:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2 AND Part_Present3
						AND Part_Present4 AND Part_Present5 AND Part_Present6)
					) OR (All_Sensors_Off AND Dry_Cycle);


























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Conveyor" Id="{4c0f935f-faf3-4e1c-9d5c-7e1ee17eb646}">
      <Implementation>
        <ST><![CDATA[
	(*Auto / Manual mode*)		
IF In_Auto AND In_Auto_Mode AND NOT CV_In_Manual
    THEN
    CV_In_Auto   := TRUE;
ELSE 
	CV_In_Auto   := FALSE;
END_IF
IF In_Manual AND In_Manual_Mode AND NOT CV_In_Auto
	THEN
	CV_In_Manual := TRUE;
ELSE
	CV_In_Manual := FALSE;
END_IF	

(*Flags and Watchdog*)
First_Flag      := Part_Present1 AND Part_Present2 AND Load_Robots_Complete1;
Flag_Watchdog   := Part_Present3 AND Part_Present4 AND NOT Part_Present1 AND NOT Part_Present2;
Automatic_Index_CV_Trigger_SR.SET1 := First_Flag; 
Automatic_Index_CV_Trigger_SR.RESET := Flag_Watchdog;
Automatic_Index_CV_Trigger_SR();
Operation_Clear := NOT (Part_Present5 AND Part_Present6);

(*Auto Start*) 
IF CV_In_Auto AND Load_Robots_Clear AND Automatic_Index_CV_Trigger_SR.Q1 AND NOT Automatic_Index_CV_Stop
	THEN
	Automatic_Index_CV_Start := TRUE;
ELSE
	Automatic_Index_CV_Start := FALSE;
END_IF
(*Auto Stop*)
Automatic_Stop_Timer.IN := Flag_Watchdog OR NOT Operation_Clear;
Automatic_Stop_Timer.PT := T#4S;
Automatic_Stop_Timer();
IF Automatic_Stop_Timer.Q 
	THEN
	Automatic_Index_CV_Stop := TRUE;
ELSE
	Automatic_Index_CV_Stop := FALSE;
END_IF

(*Manual Control*)
Manual_Index_CV_Trigger_SR.SET1  := Discrete_In.Manual_Conveyor_Start;
Manual_Index_CV_Trigger_SR.RESET := Manual_Index_CV_Stop OR Discrete_In.Go_Home;
Manual_Index_CV_Trigger_SR();

(*Manual Start*)
IF CV_In_Manual AND Load_Robots_Clear AND Manual_Index_CV_Trigger_SR.Q1 AND NOT Manual_Index_CV_Stop
	THEN
	Manual_Index_CV_Start := TRUE; (*stays high untill the part is located on the last sets of proxies*)
ELSE 
	Manual_Index_CV_Start := FALSE;
END_IF
(*Manual Stop*) 
// Manual stop is used when the operator manually drives the part to the last conveyor sensors
Manual_Stop_Timer.IN := NOT Operation_Clear;
Manual_Stop_Timer.PT := T#2S;
Manual_Stop_Timer();
IF Manual_Stop_Timer.Q
	THEN
    Manual_Index_CV_Stop := TRUE;
ELSE
	Manual_Index_CV_Stop := FALSE;
END_IF


Conveyor_Full:= (Part_Present1 AND Part_Present2 AND Part_Present3 AND Part_Present4 AND Part_Present5 AND Part_Present6);

// Current time 
Current_Time:= SYSTEMTIME_TO_DT(main.Local_Time);
Current_Time_Str := DT_TO_STRING(Current_Time);
Current_Time_Len := LEN(Current_Time_Str);

	
	HMI_QA_DataGrid(
	In_Auto:= CV_In_Auto, 
	In_Manual:= CV_In_Manual,
 
	(*Datagrid parameter*)
	In_TimeStamp:= RIGHT(Current_Time_Str, Current_Time_Len - 3), 
	In_Model_ID:= UDINT_TO_STRING(Model_ID), 
	In_NOK_Faulted:= Part_Failed_Record, 
	
	(*DataGrid Current/History Update*)
	In_Load_complete_From_Rxx:= Load_Robots_Complete1, 
	In_Unload_complete_From_Plc:= Unload_Complete, 
	In_Manual_PartReset_From_ICxx:= Manual_PartReset_From_ICxx, //Tchmi button 
	Force_Unload_Complete_From_ICxx := Force_Unload_Complete_From_ICxx, //Tchmi button number
	
	(*Error reset ACK*)
	In_User_Error_Ack_From_ICxx:= User_Error_Ack_From_ICxx, //Tchmi button
	
	(*Reset*)
	In_Current_Nok_Data_Reset:= Current_Nok_Data_Reset_From_ICxx, //Tchmi button 
	In_History_Nok_Data_Reset:= History_Nok_Data_Reset_From_ICxx, //Tchmi button 
	In_Current_History_Reset:= Current_History_Reset_From_ICxx, //Tchmi button 
	
	(*Output*)
	Out_Current_Nok_Data=> Current_Nok_Data, 
	Out_History_Nok_Data=> History_Nok_Data, 
	
	(*Flag to ICxx*)
	Force_Unload_Part_In_Process_To_ICxx=> Force_Unload_Part_In_Process_To_ICxx , 
	
	(*Error Flags To ICxx *)
	Current_Nok_Data_Error=> Current_Nok_Data_Error_To_ICxx, 
	History_Nok_Data_Error=> History_Nok_Data_Error_To_ICxx, 
	Force_Unload_Part_Error=> Force_Unload_Part_Error_To_ICxx);


]]></ST>
      </Implementation>
    </Action>
    <Action Name="Cylinders" Id="{958c796a-26a3-4706-912f-36f2d264de22}">
      <Implementation>
        <ST><![CDATA[
(* -----------------------------------------------------------------------------------*)
(*Below are Examples only, each will have to be customized for your application
	Notes:
	- Use SODGxx-SSCC61x-xxxxxxx_Fix IO and Seq.xlsx document to capture Clamp / Cylinder I/O Layout
	- CLFaults1 thru 4 can be used to group cylinder type faults (All Clamps on CLFaults1, all Pins on CLFaults2)
		OR
	- CLFaults 1 thru 4 can be used to group cylinder UI screens 
		(All items on Cylinder_1.content screen are on CLFaults1, all items on Cylinder_2.content screen are on CLFaults2 as example)
*)
(* -----------------------------------------------------------------------------------*)



(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)
(*
		(*Clamp1*)
		Clamp1FB(
			Retracted_Sensor:= N02.I.0 ,
			Advanced_Sensor:= N02.I.1 ,
			Retract_Solenoid:= N100.Q.1,
			Advance_Solenoid:= N100.Q.0 ,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Clamp1RETD,
			In_Advanced_Position=> Clamp1ADVD,
			Faulted=> CLFaults1.1 );


(*Pins*)(*Pins*)(*Pins*)
(*Pins*)(*Pins*)(*Pins*)
(*Pins*)(*Pins*)(*Pins*)

		(*Pin1*)
		Pin1FB(
			Retracted_Sensor:= N03.I.0,
			Advanced_Sensor:= N03.I.1,
			Retract_Solenoid:= N101.Q.1,
			Advance_Solenoid:= N101.Q.0,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Pin1RETD,
			In_Advanced_Position=> Pin1ADVD,
			Faulted=> CLFaults2.1 );


(*Slides*)(*Slides*)(*Slides*)
(*Slides*)(*Slides*)(*Slides*)
(*Slides*)(*Slides*)(*Slides*)

		(*Slide1*)
		Slide1FB(
			Retracted_Sensor:= N07.I.0,
			Advanced_Sensor:= N07.I.1,
			Retract_Solenoid:= N100.Q.11,
			Advance_Solenoid:= N100.Q.10,
			Adv_Delay:= T#0.2S,
			Ret_Delay:= T#0.2S,
			Fault_Delay:= T#4.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Slide1RETD,
			In_Advanced_Position=> Slide1ADVD,
			Faulted=> CLFaults3.1 );

(*Swings*)(*Swings*)(*Swings*)
(*Swings*)(*Swings*)(*Swings*)
(*Swings*)(*Swings*)(*Swings*)

		(*Swing1*)
		Swing1FB(
			Retracted_Sensor:= N09.I.0,
			Advanced_Sensor:= N09.I.1,
			Retract_Solenoid:= N101.Q.1,
			Advance_Solenoid:= N101.Q.0,
			Adv_Delay:= T#0.2S,
			Ret_Delay:= T#0.2S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Swing1RETD,
			In_Advanced_Position=> Swing1ADVD,
			Faulted=> CLFaults4.1 );



(*Triple*)(*Triple*)(*Triple*)
(*Triple*)(*Triple*)(*Triple*)
(*Triple*)(*Triple*)(*Triple*)

		(*Cyl1, Triple Position*)
		Cyl1FB(
			Retracted_Sensor:= N01.I.0,
			Advanced_Sensor:= N01.I.1,
			Mid_Sensor:= N01.I.2,
			Retract_Solenoid:= N100.Q.1,
			Advance_Solenoid:= N100.Q.0,
			Mid_Solenoid:= N100.Q.2,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Mid_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Cyl1RETD,
			In_Advanced_Position=> Cyl1ADVD,
			In_Mid_Position=> Cyl1MID,
			Faulted=> CLFaults4.11 );


(*QA*)(*QA*)(*QA*)
(*QA*)(*QA*)(*QA*)
(*QA*)(*QA*)(*QA*)

		(*QA Check1*)
		QACheck1FB(
			Retracted_Sensor:= N04.I.0,
			Advanced_Sensor:= N04.I.1,
			Retract_Solenoid:= N100.Q.5,
			Advance_Solenoid:= N100.Q.4,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> QACheck1RETD,
			In_Advanced_Position=> QACheck1ADVD,
			Faulted=> CLFaults4.1 );


*)
(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Hardware" Id="{092a6163-a1c2-42de-a3a7-dc69dd27be2c}">
      <Implementation>
        <ST><![CDATA[
(*Pass Node States into Array  in order on Physical Fixture*)

		NodeState:=NodeLayout.State;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Discrete I/O Nodes*)
	IF (*N00.InfoData.State=8*) (*Fix doesn't have an EP1111*) 
		(N01.InfoData.State=8 OR (Discrete_In.Input_Node_Count<2))
		AND (N02.InfoData.State=8 OR (Discrete_In.Input_Node_Count<3))

		THEN
			DiscreteNode_OK:=TRUE;

	ELSE
			DiscreteNode_OK:=FALSE;

	END_IF;



	(*Cable Break Detection*)
	(*Function Returns Flags to warn of possible cable break*)
	ECatSlave_Cable_Breaks:= FUN_GTAC_EcatSlaveConnState_64bit(NodeState);	























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Production" Id="{c843cb03-c3b8-4612-bbf8-208fb052e4ad}">
      <Implementation>
        <ST><![CDATA[(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Production Information $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Increment Production Counter*)
	Prod_Inc.CLK:= Load_Complete;
	Prod_Inc();
	IF Prod_Inc.Q
		THEN
		Production_Count:= Production_Count+1;
	END_IF;
	IF Discrete_In.ResetProd
		THEN
		Production_Count:= 0;
	END_IF;
	Prod_Count_Out:= Production_Count;

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Production Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Input Data*)
	Production_Report.Machine_Serial:= GTAC_CONFIG.Machine_Serial;
	Production_Report.Machine_Common_Name:= GTAC_CONFIG.Machine_Common_Name;
	Production_Report.Prod_Inc:= Prod_Inc.Q;
	Production_Report.Scrap_Inc:= In_From_ICxx.QA_Request_RH;
	Production_Report.Scrap_Dec:= In_From_ICxx.QA_Reinsert_RH;
	Production_Report.Reference_TimeDate:= MAIN.Local_Time;
	Production_Report.Reference_Target_Time:= GTAC_CONFIG.ProdConfig_Target_CycleTime; 					(*This is the machine Expected Cycle Time*)
	Production_Report.Config_Day_TOD:= GTAC_CONFIG.ProdConfig_Day;										(*Pass Each Shift Configuration Structure (Start/End Time, Break Times etc*)
	Production_Report.Config_Aft_TOD:= GTAC_CONFIG.ProdConfig_Aft;
	Production_Report.Config_Mid_TOD:= GTAC_CONFIG.ProdConfig_Mid;
	Production_Report.Config_Shift_Enables:= GTAC_CONFIG.ProdConfig_Common.Shift_Enables;					(*Enable Bits for Shifts*)
	Production_Report.Config_Break_Count:= GTAC_CONFIG.ProdConfig_Common.Break_Count;						(*Select Amount of Breaks per shift*)
	Production_Report.Machine_StoppedBy_Fault:= Faults.System_Major_Fault;
	Production_Report.Enable_InShift_Change:= GTAC_CONFIG.ProdConfig_Option_SelectInShiftChange;				(*Allows Operator 5 mins at start and end of shift for clean up*)
	(*Call FB*)
	IF NOT MAIN.Starting_Scan_Pulse
		THEN
		Production_Report();
	END_IF;

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Cycle Time Counters ~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Move Previous To Register*)
	Cycle_Time_Pulse.CLK:= Load_Complete;
	Cycle_Time_Pulse();
	IF Cycle_Time_Pulse.Q
		THEN
		PrevCycle_Time_Out:= Cycle_Time_Out;
	END_IF;
	(*Monitor Current Cycle Time (Full Cycle Time of Process)*)
		Cycle_Time.PT:= T#9999S;
		Cycle_Time.IN:= NOT Cycle_Time_Pulse.Q AND In_Auto;
		Cycle_Time();
		Cycle_Time_Out:= Cycle_Time.ET;

	(*Monitor Load Time*)
		IF In_Auto AND NOT Load_Robots_Clear 
			THEN
			Load_Time_Out:= Load_Time.ET;
		END_IF;
		Load_Time.PT:= T#9999S;
		Load_Time.IN:= In_Auto AND NOT Load_Robots_Clear;
		Load_Time();



	(*Monitor Unload Time*)
		IF Welding_Complete
			THEN
			Unload_Time_Out:= Unload_Time.ET;
		END_IF;
		Unload_Time.PT:= T#9999S;
		Unload_Time.IN:= Welding_Complete;
		Unload_Time();







(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Product Data Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
(*Can be used to load and store product specific data (pass fail results, measurements etc) into DB*)
(*Triggers to start actual storage are contained in GTAC_CONFIG.Reports*)

(*Load Data into area*)
	(*Capture Load Complete*)
	IF Load_Complete1_Ack THEN
		Out_To_ICxx.ProductReport[13].Generic_PassFail_Notes[13]:= 'Comp';
	END_IF;
		Out_To_ICxx.ProductReport[19]:= Fix103_ProductData_Pers; 	(*Transfer Product Data to UI, see MAIN.Product_Data*)








]]></ST>
      </Implementation>
    </Action>
    <Action Name="Proxies" Id="{96049cd0-3367-4f00-b868-23ab83f785fb}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)



	(*Part 1 Present*)
		Part_Present1FB(
			Sensor_Input:= N01.I.0,
			On_Trigger1:= Enable_Motion AND In_Auto AND NOT Unload_Complete AND Repo_Reqs.0,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Dry_Cycle OR (Cycle_Complete AND NOT Enable_Motion),
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR MAIN.Conveyor01.Conveyor_On_CMD,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present1,
			Faulted=>  PPFaults.1);

	(*Part 2 Present*)
		Part_Present2FB(
			Sensor_Input:= N01.I.1,
			On_Trigger1:= Enable_Motion AND In_Auto AND NOT Unload_Complete AND Repo_Reqs.0,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Dry_Cycle OR (Cycle_Complete AND NOT Enable_Motion),
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR MAIN.Conveyor01.Conveyor_On_CMD,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present2,
			Faulted=>  PPFaults.2);

	(*Part 3 Present*)
		Part_Present3FB(
			Sensor_Input:= N01.I.2,
			On_Trigger1:= Enable_Motion AND In_Auto AND MAIN.Conveyor01.Conveyor_On_CMD,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Cycle_Complete OR Conveyor_Full,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle AND MAIN.Conveyor01.Conveyor_On_CMD,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present3,
			Faulted=>  PPFaults.3);

	(*Part 4 Present*)
		Part_Present4FB(
			Sensor_Input:=N01.I.3,
			On_Trigger1:= Enable_Motion AND In_Auto AND MAIN.Conveyor01.Conveyor_On_CMD,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Cycle_Complete OR Conveyor_Full,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle AND MAIN.Conveyor01.Conveyor_On_CMD,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present4,
			Faulted=>  PPFaults.4);

	(*Part 5 Present*)
		Part_Present5FB(
			Sensor_Input:= N01.I.4,
			On_Trigger1:= Enable_Motion AND In_Auto AND Repo_Reqs.0,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Cycle_Complete OR Conveyor_Full,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR MAIN.Conveyor01.Conveyor_On_CMD OR TRUE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present5,
			Faulted=>  PPFaults.5);

	(*Part 6 Present*)
		Part_Present6FB(
			Sensor_Input:= N01.I.5,
			On_Trigger1:= Enable_Motion AND In_Auto AND Repo_Reqs.0,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Cycle_Complete OR Conveyor_Full,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Dry_Cycle OR MAIN.Conveyor01.Conveyor_On_CMD OR TRUE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present6,
			Faulted=>  PPFaults.6);


(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Robot_Registration" Id="{bfe877c3-2258-435d-9a73-44db7e685230}">
      <Implementation>
        <ST><![CDATA[

(*#################################### Register Robots to Tool ##################################*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*NOTE: See Example code in Fix 15 / 16*)
(*NOTE: See Example code in Fix 15 / 16*)

	(*Data From Load Robot(s)*)
	Load_Robots_Clear1:= (MAIN.R4.Clear_Of_EquipInterf5 AND NOT (MAIN.R4.Task_ID_Ack=Dropoff_Fix103)) OR MAIN.R4.At_Home;
	Load_Robots_Clear2:= TRUE;
	Load_Robots_Clear:=Load_Robots_Clear1 AND Load_Robots_Clear2;
	Load_Robots_WorkingOK1:= (MAIN.R4.Task_ID_Ack=Dropoff_Fix103) AND MAIN.R4.Operating;
	Load_Robots_WorkingOK2:= FALSE;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly1:= TRUE;
	END_IF;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly2:= TRUE;
	END_IF;
	Load_Robots_Complete1:= MAIN.R4.At_EquipInterf5 AND (MAIN.R4.Task_ID_Ack=Dropoff_Fix103) AND MAIN.R4.Task_Completed;
	Load_Robots_Complete2:= FALSE;
	Load_Robots_PartInEOAT1:= EOAT04.EOAT_Part1_Empty;
	Load_Robots_PartInEOAT2:= EOAT04.EOAT_Part2_Empty;



	(*Change Robots for Current Fixture functionality*) (*If no MIG robots Set to True.  Example code is in Fix15/16*) 
	Mig_Robots_Ready:=	TRUE;	


	(*Amalgumate All Robots Clear of Tool*)
	All_Robots_Clear:= Load_Robots_Clear;

	(*Data To All Robots*)
	(*Task ID*)
	R4_Data.Task_ID[13]:=Task_ID;

	(*Fix ID*)
	R4_Data.Fix_ID[13]:=103;

	(*Model ID*)
	R4_Data.Model_ID[13]:=Model_ID;

	(*Proceed from Pounce*)
	R4_Data.Proceed_From_Pounce[13]:= Robots_Clear_ToProceed;

	(*Complete Acks*)
	R4_Data.Complete_Ack[13]:=(Load_Complete1_Ack AND Load_Robots_WorkingOK1);

	(*Repo Acks*)
	R4_Data.PeripheralReq_Ack[13]:= Repo_Ack;

(*%%%%%%%%%%%%%% Call Robots to Tool and Give Them, Task ID, Fixture ID and Model ID %%%%%%%%%%%%%%%%%*)
	(* Perform Call To Tool*)
	Tool_Call_ForLoadRobots1:= Enable_Motion AND (NOT Cell_In_Services OR NOT Load_Robots_Clear1)
						AND Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForLoadRobots2:= Enable_Motion AND (NOT Cell_In_Services OR NOT Load_Robots_Clear2)
						AND NOT Start_Load_Robots1 AND Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;


	(*Allow Robots to Proceed Into Tool*)
	(*!!!!!This is the final OK to allow Robots Into the Tool Area, So it Better Be Ready!!!!!!!*)
	IF Enable_Motion
		THEN
			IF Load_Robots_Proceed1 AND Load_Robots_WorkingOK1 AND Load_Robots_Clear2
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Load_Robots_Proceed2 AND Load_Robots_WorkingOK2 AND Load_Robots_Clear1
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSE Robots_Clear_ToProceed:= FALSE;
			END_IF;
		ELSE Robots_Clear_ToProceed:= FALSE;
	END_IF;

(*+++++++++++++++++++++++++++++++++++++++++++++++ Task Complete Acks ++++++++++++++++++++++++++*)
	(*1st Load Complete Ack*)
	Load_Complete1_Ack:= Load_Robots_Complete1 AND Load_Complete1;

	(*2nd Load Complete Ack*)
	Load_Complete2_Ack:= Load_Robots_Complete2 AND Load_Complete2;





(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Status_and_Faults" Id="{42c17350-f462-41ff-8431-a035a1ae35b0}">
      <Implementation>
        <ST><![CDATA[


(*^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ General Visualization ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^*)
	(*For Ready to Load Indicators*)
		(*Flash when tool should be loaded but load is not complete*)
		IF In_Auto AND All_Robots_Clear AND NOT All_Sensors_On.0
			THEN
				Ready_To_Load:= Pulse_500mS;
				(*Go solid when tool has been loaded properly*)
				(*Go solid when tool is ready to be unloaded*)
		ELSIF In_Auto AND All_Robots_Clear  AND All_Sensors_On.0
			THEN
				Ready_To_Load:= TRUE;
		ELSE
				Ready_To_Load:= FALSE;
		END_IF;
	(*For Red Stack Light Indicators*)
		Red_Lamp_Req:= PPFaulted.0 OR Load_Seq01.Faulted;


	(*Status Banners*)
	
	(*Unused statuses are commented out: 11172025 W*)
	(*
		(*1 - Check Parts On Sub Check*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.0
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.0
					THEN Status:= 1;
				ELSIF Dry_Cycle AND NOT Load_Complete1
					THEN Status:=1;
				END_IF;
		END_IF;
		(*2 - Sub Check OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.1
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.1
					THEN Status:= 2;
				ELSIF Dry_Cycle AND NOT Load_Complete2
					THEN Status:=2;
				END_IF;
		END_IF;
		(*3 - Load Main Part*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Home
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.2
					THEN Status:= 3;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=3;
				END_IF;
		END_IF;
		(*10 - Load Parts Onto Tool*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete
			THEN
				IF NOT Dry_Cycle AND All_Sensors_On.0
					THEN Status:= 10;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=10;
				END_IF;
		END_IF;*)
		(*11 - Robot(s) Loading*)
		IF ((Start_Load_Robots1 OR  Load_Robots_WorkingOK1) OR (Start_Load_Robots2 OR  Load_Robots_WorkingOK2)) AND In_Auto AND NOT In_Manual
			THEN Status:= 11;
		END_IF;
		(*12 - Parts Loaded OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete
			THEN
				IF (All_Sensors_On.0 AND Load_Robots_Clear) AND NOT Dry_Cycle
					THEN Status:= 12;
				ELSIF Load_Complete
					THEN Status:= 12;
				END_IF;
		END_IF;
		(*(*19 - Robot(s) Stud*)
		IF (Start_Stud_Robots OR Stud_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 19;
		END_IF;
		(*20 - Robot(s) Sealing*)
		IF (Start_Seal_Robots OR Seal_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 20;
		END_IF;
		(*21 - Robot(s) Welding*)
		IF (Start_Weld_Robots OR Weld_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 21;
		END_IF;
		(*22 - Welding Complete / Ready for Unload*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Welding_Complete
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 22;
		END_IF;
		(*26 - Ready for Rotate*)
		IF (Start_TurntableA OR Start_TurntableB) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
			AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status := 26;
		END_IF;
		(*31 - Robot(s) Unloading*)
		IF (Start_Unload_Robots1 OR Unload_Robots_WorkingOK1 OR Start_Unload_Robots2 OR Unload_Robots_WorkingOK2) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots
			THEN Status:= 31;
		END_IF;
		(*32 - Unload Complete*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Unload_Complete
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 32;
		END_IF;*)
		(*42 - Cycle Complete*)
		IF In_Auto AND NOT In_Manual AND Cycle_Complete AND All_Sensors_Off
			THEN Status:= 42;
		END_IF;
		(*50 - In Manual*)
		IF In_Manual  
			THEN Status:= 50;
		END_IF;
		(*(*51 - Clamp Fault*)
		IF (CLFaults1>0 OR CLFaults2>0 OR CLFaults3>0 OR CLFaults4>0) AND In_Auto AND NOT In_Manual
			THEN Status:= 51;
		END_IF;*)
		(*52 - Part Present Sensor Fault*)
		IF PPFaults>0 AND In_Auto AND NOT In_Manual
			THEN Status:= 52;
		END_IF;
		(*53 - Nut Checks Failed Call QA*)
		IF (Current_Nok_Data_Error_To_ICxx OR History_Nok_Data_Error_To_ICxx OR Force_Unload_Part_Error_To_ICxx) 
            AND In_Auto AND NOT In_Manual
			 THEN Status:= 53;
		END_IF;
		(*
		(*54 - Sealer Failed Call QA*)
		IF NOT Sealer_Bypass AND (MAIN.SL01.Disp1_Volume_NotOK AND (MAIN.R1.Task_ID_Ack=Seal_Fix16)) AND In_Auto AND NOT In_Manual
			THEN Status:= 54;
		END_IF;
		(*55 - Load Sequence Fault Call QA*)
		IF Load_Seq01.Faulted AND In_Auto AND NOT In_Manual
			THEN Status:= 55;
		END_IF;*)
		(*70 - Auto Conveyor Indexing*)
		IF Automatic_Index_CV_Start AND In_Auto (*AND Load_Robots_Clear*)
			THEN Status := 70;
		END_IF
		(*71 - Manual Conveyor Indexing*)
		IF Manual_Index_CV_Start AND In_Manual (*AND Load_Robots_Clear*)
			THEN Status := 71;
		END_IF
		(*72 - Conveyor Faults*)
		IF MAIN.VFD01.Faulted AND NOT Automatic_Index_CV_Start AND NOT Manual_Index_CV_Start
			THEN Status := 72;
		END_IF



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Faults $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Clamp/Cylider Faults Group 1*)
		IF CLFaults1>0
			THEN CLFaulted.1:=TRUE;
		ELSE
			CLFaulted.1:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 2*)
		IF CLFaults2>0
			THEN CLFaulted.2:=TRUE;
		ELSE
			CLFaulted.2:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 3*)
		IF CLFaults3>0
			THEN CLFaulted.3:=TRUE;
		ELSE
			CLFaulted.3:=FALSE;
		END_IF;
	(*Faults Group 4 - Reserved Flag for QA Check Motion Faults*)
		IF Current_Nok_Data_Error_To_ICxx OR History_Nok_Data_Error_To_ICxx OR Force_Unload_Part_Error_To_ICxx
			THEN CLFaulted.4:=TRUE;
		ELSE
			CLFaulted.4:=FALSE;
		END_IF;
	(*Bit 0 is designated as ANY Clamp Group Faulted*)
	IF CLFaulted.1 OR CLFaulted.2 OR CLFaulted.3
		THEN CLFaulted.0:= TRUE;
	ELSE CLFaulted.0 := FALSE;
	END_IF;

	(*Part Present Sensor Faults*)
		IF (PPFaults>0) OR (PPFaults1>0) OR (PPFaults2>0)
			THEN PPFaulted.0:=TRUE;
		ELSE
			PPFaulted.0:=FALSE;
		END_IF;
























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Task_Fix_Model_IDs" Id="{2947a763-4c7b-4016-8ff9-161ae0165401}">
      <Implementation>
        <ST><![CDATA[

	(*Develop Task IDs - See Global Variable, "TaskID_Record"*)

	IF (Start_Load_Robots1 OR Start_Load_Robots2) AND Enable_Motion
		THEN Task_ID:= Dropoff_Fix103;
	ELSIF Start_Seal_Robots AND Enable_Motion
		THEN Task_ID:= Seal_Fix103;
	ELSIF Start_Stud_Robots AND Enable_Motion
		THEN Task_ID:= Stud_Fix103;
	ELSIF Start_Weld_Robots AND Enable_Motion
		THEN Task_ID:= Weld_Fix103;
	ELSIF Start_TurnTableA AND Enable_Motion
		THEN Task_ID:= Sweep_Fix103;
	ELSIF (Start_Unload_Robots1 OR Start_Unload_Robots2) AND Enable_Motion
		THEN Task_ID:= Pickup_Fix103;
	ELSE Task_ID:= 0;
	END_IF;

	(*Develop Fixture ID*)
	Fix_ID:= N00.ID;					(*In Future Map Beckhoff Dip Switch Data From IP67 Block to Here*)

	(*Develop Model ID*)
	Model_ID:= Discrete_In.ModelData;

















]]></ST>
      </Implementation>
    </Action>
