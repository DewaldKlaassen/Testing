		Production_Report: FB_Production_Report_20221007;
		Keyence_NutCheck_StatusBits_0: UDINT;
		Keyence_NutCheck_StatusBits_1: UDINT;
		Keyence_NutCheck_StatusBits_2: UDINT;
		Keyence_Camera_Complete1: BOOL;
		Keyence_Camera_Complete2: BOOL;
		Keyence_Camera_Passed1: BOOL;
		Keyence_Camera_Passed2: BOOL;
		SmartRay_Complete: BOOL;
		SmartRay_Passed: BOOL;
		
		

	END_VAR

	VAR_OUTPUT

		Prog_Ok: BOOL;
		Discrete_Image: udt_FixXX_Output_Image_20220715;
		In_Auto_Mode: BOOL;
		In_Manual_Mode: BOOL;
		Manual_Indicators1: DINT;
		Manual_Indicators2: DINT;
		Manual_Indicators3: DINT;
		At_Home: BOOL;
		Ready_To_Load: BOOL;
		Red_Lamp_Req: BOOL;
		Status: UINT;
		CLFaults1:UDINT;
		CLFaults2:UDINT;
		CLFaults3:UDINT;
		CLFaults4:UDINT;
		PPFaults: UDINT;
		PPFaults1: UDINT;
		PPFaults2: UDINT;
		Prod_Count_Out: INT;
		Cycle_Time_Out: TIME;
		PrevCycle_Time_Out: TIME;
		Load_Time_Out: TIME;
		Weld_Time_Out: TIME;
		Seal_Time_Out: TIME;
		Stud_Time_Out: TIME;
		Turn_Time_Out: TIME;
		Unload_Time_Out: TIME;
		Model_ID: UINT;
		TurntableA_At_Robot: BOOL;
		TurntableB_At_Robot: BOOL;
		Tool_Call_ForLoadRobots1: BOOL;
		Tool_Call_ForLoadRobots2: BOOL;
		Tool_Call_ForSealRobots: BOOL;
		Tool_Call_ForStudRobots: BOOL;
		Tool_Call_ForWeldRobots: BOOL;
		Tool_Call_ForSweepA: BOOL;
		Tool_Call_ForSweepB: BOOL;
		Tool_Call_ForUnloadRobots1: BOOL;
		Tool_Call_ForUnloadRobots2: BOOL;
		Robots_Clear_ToProceed: BOOL;
		Task_ID: UINT;
		Fix_ID: UINT;
		Load_Complete1_Ack: BOOL;
		Load_Complete2_Ack: BOOL;
		Seal_Complete_Ack: BOOL;
		Stud_Complete_Ack: BOOL;
		Weld_Complete_Ack: BOOL;
		TurnA_Complete_Ack: BOOL;
		TurnB_Complete_Ack: BOOL;
		Unload_Complete1_Ack: BOOL;
		Unload_Complete2_Ack: BOOL;
		Repo_Ack: UINT;
		
		Guard_Close_Req: BOOL;
		Guard_Open_Req: BOOL;
		
	END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[	(*Set FB_OK to True*)
	Prog_OK:= TRUE;


	(*Set conditions to allow model change*)
	Fixture_Allow_Model_Change:= (In_Manual AND Tool_At_Home AND All_Sensors_Off AND All_Robots_Clear)
							OR (Model_ID=0);


(*Set conditions for interlock Part direction once in EOAT04*)
	(*Welded at Fix01 or Fix02 and Welded by Fix101 and Welded by Fix03 or Fix04 but not yet Inspected by Fix102*)
	(*Side 1 of EOAT*)
	Part_InEOAT04_1_ReadyForThisFix:= (EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[1] = 'Comp' 		//Fix01 Weld Comp
									OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[2] = 'Comp')		//Fix02 Weld Comp
									AND EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[11] = 'Comp'		//Fix101 Weld Comp
									AND (EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[3] = 'Comp'		//Fix03 Weld Comp
									OR EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[4] = 'Comp')		//Fix04 Weld Comp
									AND EOAT04_1_ProductData_Pers.Generic_PassFail_Notes[12] = '';			//Fix102 Passed/Failed
	(*Side 2 of EOAT*)
	Part_InEOAT04_2_ReadyForThisFix:= (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[1] = 'Comp' 		//Fix01 Weld Comp
									OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[2] = 'Comp')		//Fix02 Weld Comp
									AND EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[11] = 'Comp'		//Fix101 Weld Comp
									AND (EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[3] = 'Comp'		//Fix03 Weld Comp
									OR EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[4] = 'Comp')		//Fix04 Weld Comp
									AND EOAT04_2_ProductData_Pers.Generic_PassFail_Notes[12] = '';			//Fix102 Passed/Failed

(*Verti Guard Door Close Request*)
		Guard_Close_Req:= (((In_Auto AND (Start_Load_Robots1 OR Start_Unload_Robots1) AND All_Robots_Clear AND MAIN.All_Estops_OK AND MAIN.All_SafetyGates_OK
						 AND MAIN.VertiGuard_1.Gate_Opened AND NOT Dry_Cycle AND (Load_Robots_Complete1 OR Unload_Robots_Complete1))
						 AND In_Auto AND NOT CLFaulted.0 AND NOT PPFaulted.0 AND NOT QAChecks_Failed AND NOT Welding_Complete)

						OR (In_Manual AND All_Robots_Clear AND (MAIN.VertiGuard_1.Gate_Opened OR MAIN.VertiGuard_1.GateOpened_Switches) AND Discrete_In.CustomApplication_REQS.7));


(*Verti Guard Door Open Request*)
		Guard_Open_Req:= (((In_Auto AND (Start_Load_Robots1 OR Start_Unload_Robots1) AND All_Robots_Clear AND MAIN.All_Estops_OK AND MAIN.All_SafetyGates_OK
						 AND MAIN.VertiGuard_1.Gate_Closed AND NOT Dry_Cycle)
						 AND In_Auto AND NOT CLFaulted.0 AND NOT PPFaulted.0 AND NOT QAChecks_Failed AND NOT Welding_Complete)

						OR (In_Manual AND All_Robots_Clear AND (MAIN.VertiGuard_1.Gate_Closed OR MAIN.VertiGuard_1.GateClosed_Switches) AND Discrete_In.CustomApplication_REQS.6));


	
(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Fixture Bypasses $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	Weld_Curtain_Bypass:= Discrete_In.Bypass_REQS.0;
	Vacuum_Bypass:= Discrete_In.Bypass_REQS.1;
	Stud_Bypass:= Discrete_In.Bypass_REQS.2;
	Sealer_Bypass:= MAIN.SL01.Disp1_Bypass;
(*debug - WG - May need to add an inspection bypass here, understanding they want to be able to run without inspection if the unit goes down*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Check on Status of Hardware*)
	Hardware();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Standard Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*Clamp/Cylinder Inputs*)
	Cylinders();

(*Part Present Inputs*)
	Proxies();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Qaulity Checking Routines $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Call QA Camera Action*)
			QA_Cameras();
	(*Call QA Smart Ray Action*)
	        QA_SmartRay();
	
(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Auto / Manual Mode Code*)
	IF Discrete_In.Mode_Select.0 AND NOT Discrete_In.Mode_Select.1
		THEN
			In_Auto:= TRUE;
			In_Auto_Mode:= TRUE;
	END_IF;
	IF NOT Discrete_In.Mode_Select.0 AND Discrete_In.Mode_Select.1
		THEN
			In_Auto:= FALSE;
			In_Auto_Mode:= FALSE;
	END_IF;
	In_Manual:= NOT In_Auto;
	In_Manual_Mode:= In_Manual;

(*--------------------------------------------------------------------------------Tool Positions---------------------------------------------------------------*)
	Tool_States();

(*----------------------------------------------------Part Present Sensor Input Patterns----------------------------------------------------------------*)
	All_Sensors();


(*>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> Auto Run Cycle >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
	(*Control of Auto_Run*)
	Auto_Run:= Enable_Motion AND In_Auto AND Model_ID<>0 AND NOT Cycle_Complete;

	(*Auto Run Enables All Other Auto Cycle Code*)
	IF Auto_Run
		THEN
		
	      (*Seq: 
                1. Turntable job(= for R4 DROP OFF) 
                2. Drop off 
                3. Inspection(=weld job) 
                4. Pick up*)
				
           	IF ((Welding_Complete AND Unload_Complete) OR (Part_InEOAT04_1_ReadyForThisFix AND Tool_At_Home AND All_Sensors_Off))
				AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				AND NOT Main.R1.TT_at_DropOff_Pos
				THEN
					(*Start Trunnion Turn (Table Zero)*)
					Start_TurntableA:= ((Tool_At_Home AND All_Sensors_Off))
									OR TurnTable_WorkingOK;
			ELSE
					Start_TurntableA:= FALSE;
			END_IF;

			IF NOT Load_Complete AND NOT Welding_Complete AND NOT Unload_Complete
			   AND Weld_Robots_Clear AND TurntableB_At_Robot AND (Load_Robots_PartInEOAT1 AND NOT Load_Robots_PartInEOAT2)
				THEN
					(*Start 1st Load Robots*)
					Start_Load_Robots1:= ((Tool_At_Home AND All_Sensors_Off AND Load_Robots_PartInEOAT1 AND Part_InEOAT04_1_ReadyForThisFix)
									OR ((Tool_At_Home OR Tool_At_Load.0) AND Repo_Reqs.0))
									OR Load_Robots_WorkingOK1;
					(*Allow 1st Load Robots To Proceed*)
					Load_Robots_Proceed1:= Tool_At_Home AND All_Sensors_Off AND Load_Robots_PartInEOAT1  AND Part_InEOAT04_1_ReadyForThisFix AND Weld_Robots_Clear AND TurntableB_At_Robot AND MAIN.VertiGuard_1.Gate_Opened; (*Weld robot clear: making sure r10&11 in home pos*)
			ELSE
					Start_Load_Robots1:= FALSE;
					Load_Robots_Proceed1:= FALSE;
			END_IF;

			(*QA Inspection job*)
			IF TurntableB_At_Robot AND Load_Complete AND NOT Welding_Complete AND NOT Unload_Complete
			   AND Unload_Robots_Clear AND Load_Robots_Clear AND PLC_Ready_for_Inspection[0] AND PLC_Ready_for_Inspection[1] // coming from SR
				THEN
					(*Start Weld Robots*)
					(*QA Inspection job*)
					Start_Weld_Robots:= (Tool_At_Weld.0 AND All_Sensors_On.0)
										OR Weld_Robots_WorkingOK;
					(*Allow Weld Robots To Proceed*)
					(*QA Inspection job*)
					Weld_Robots_Proceed:= Tool_At_Weld.0 AND All_Sensors_On.0 AND NOT Load_Robots_WorkingOK1 AND NOT Unload_Robots_WorkingOK1; (*R4 clear: making sure R4 is not in the weld area*)
			ELSE
					Start_Weld_Robots:= FALSE;
					Weld_Robots_Proceed:= FALSE;
			END_IF;
			
			IF Load_Complete AND Welding_Complete AND NOT Unload_Complete
			   AND Weld_Robots_Clear AND TurntableA_At_Robot
				THEN
					(*Start Unload Robots*)
					Start_Unload_Robots1:=(Tool_At_Unload.0 AND All_Sensors_On.0 AND EOAT04.EOAT_Part1_Empty AND EOAT04.EOAT_Part2_Empty)
										OR ((Tool_At_Unload.0 OR Tool_At_Unload.1) AND Repo_Reqs.2)
										OR Unload_Robots_WorkingOK1;
					(*Allow Unload Robots To Proceed*)
					Unload_Robots_Proceed1:= Tool_At_Unload.0 AND All_Sensors_On.0 AND EOAT04.EOAT_Part1_Empty AND EOAT04.EOAT_Part2_Empty AND Weld_Robots_Clear AND TurntableA_At_Robot AND MAIN.VertiGuard_1.Gate_Opened;
			ELSE
					Start_Unload_Robots1:= FALSE;
					Unload_Robots_Proceed1:= FALSE;
			END_IF;

	ELSE
		Start_Load_Robots1:= FALSE;
		Start_TurntableA:= FALSE;
		Start_Weld_Robots:= FALSE;
		Start_Unload_Robots1:= FALSE;
		Load_Robots_Proceed1:=FALSE;
		Weld_Robots_Proceed:=FALSE;
		Unload_Robots_Proceed1:=FALSE;
	END_IF;




(*---------------------------------------------------------------Completes----------------------------------------------------*)

	(*Turntable Complete*)
	IF TurntableA_Complete
		THEN
			TurnA_Complete:= TRUE;
	END_IF;
	
	(*1st Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete1:=  All_Sensors_On.0;
	ELSIF Dry_Cycle AND FALSE
		THEN
		IF Tool_At_Home AND Enable_Motion AND All_Sensors_Off
			THEN
			Load_Complete1:= TRUE;
		END_IF;
	END_IF;

	(*All Load Complete*)
	IF NOT Dry_Cycle
		THEN
		Load_Complete:= All_Sensors_On.0;
	ELSIF Dry_Cycle AND FALSE
		THEN
		IF Load_Complete1 AND Load_Complete2 AND All_Sensors_Off
			THEN
			Load_Complete:= TRUE;
		END_IF;
	END_IF;

	(*Welding Complete*)
	IF Weld_Robots_Complete AND SR_Complete[0] AND SR_Complete[1] //coming from SR
		THEN
		Welding_Complete:= TRUE;
	END_IF;
	
	(*Unload Complete*)
	IF NOT Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	ELSIF Dry_Cycle
		THEN
			IF (Unload_Robots_Complete1 OR Unload_Robots_Complete2 OR (All_Sensors_Off AND Unload_Robots_Clear)) AND Welding_Complete
				THEN
				Unload_Complete:= TRUE;
			END_IF;
	END_IF;
(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Cycle Complete !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)
	(*Set Cycle Complete*)
	IF Auto_Run AND Main.R10.TT_at_DropOff_Pos AND Welding_Complete AND Unload_Complete 
		THEN Cycle_Complete:= TRUE;
	END_IF;
	(*Reset All Completes*)
	IF Load_Robots_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear AND NOT Unload_Robots_Complete1 AND NOT Unload_Robots_Complete2
		THEN
			IF In_Manual AND Discrete_In.Go_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF NOT Dry_Cycle AND Cycle_Complete AND Tool_At_Home AND All_Sensors_Off
				THEN
					Reset_All_Completes:= TRUE;
			ELSIF Dry_Cycle AND Cycle_Complete AND Tool_At_Home AND All_Sensors_Off AND FALSE
				THEN
					Reset_All_Completes:=TRUE;
			ELSE
					Reset_All_Completes:= FALSE;
			END_IF;
	END_IF;
	(*Perform Actual Reset*)
		IF Reset_All_Completes
			THEN
				Cycle_Complete:= FALSE;
				TurnA_Complete:= FALSE;
				Load_Complete1:= FALSE;
				Load_Complete:= FALSE;
				Welding_Complete:= FALSE;
				Unload_Complete:=FALSE;
				Load_Robots_UnclampEarly1:= FALSE;
				Weld_Robots_UnclampEarly:= FALSE;
				Repo_Reqs:= 0;
				(*Custom Additions*)
				Keyence_NutCheck_StatusBits_0:= 0; (*Blank Keyence Nut Check Data Area 0*)
				Keyence_NutCheck_StatusBits_1:= 0; (*Blank Keyence Nut Check Data Area 1*)
				Keyence_NutCheck_StatusBits_2:= 0; (*Blank Keyence Nut Check Data Area 2*)
				Keyence_Camera_Passed1:= FALSE;
				Keyence_Camera_Passed2:= FALSE;
				SmartRay_Passed:= FALSE;

				Reset_All_Completes:= FALSE;

		END_IF;

(*---------------------------------------------------------------------------- Call Various Actions ----------------------------------------------------------------------------------------------------*)
	(*Poduction Counters and Report*)
	Production();

	(*Register Robot(s) to Fixture*)
	Robot_Registration();

	(*Setup Fix ID and Model Data*)
	Task_Fix_Model_IDs();

	(*Generate Status Banner and Fault Flags*)
	Status_and_Faults();

	(*Tool Clamp / Unclamp Sequencing and Reposition Handling*)
	Tool_VBSeq_Repos();

	(*Transfer Object Image Data to UI Section*)
	Xfer_To_UI();


(*-----------------------------------------------------------------------------------------Transfer Valve Outputs --------------------------------------------------------------------------------*)
	(*Move "Manual_Home_Prompt" as required for home prompting*)
		Manual_Ind_HomePrompt:= Flash_Rate AND In_Manual AND Discrete_In.Go_Home AND NOT Tool_At_Home;

	(*Call each valve bank*)
	ValveBank1();























]]></ST>
    </Implementation>
    <Action Name="All_Sensors" Id="{1dd64550-39d7-4aa3-9c6f-f2c637b543af}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)



(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)
(**************************************************************************All Sensors Off******************************************************************************)

	(*All Sensors Required Off*)
	All_Sensors_Off:= NOT Part_Present1 AND NOT Part_Present2;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off1:= NOT Part_Present1 AND NOT Part_Present2;

	(*All Sensors Required Off - Used for sub fixtures where the part has to move from one stage to the next*)
	All_Sensors_Off2:= NOT Part_Present1 AND NOT Part_Present2;



(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)
(**************************************************************************All Sensors On******************************************************************************)


	(*Sensors Required for Start Of 1st Robot Load*)
	All_Sensors_On.0:= Part_Present1 AND Part_Present2;
	(*Sensors Required for Start of 2nd Robot Load*)
	All_Sensors_On.1:= FALSE OR  (Dry_Cycle AND All_Sensors_Off);

	(*Sensors After Load Complete*)
	All_Sensors_On.2:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2)
					) OR (All_Sensors_Off AND Dry_Cycle);


	(*Sensors Require for Start Of Welding*)
	All_Sensors_On.3:=(Part_Present1 AND Part_Present2)
					 OR (All_Sensors_Off AND Dry_Cycle);


	(*Sensors Required After Repo_Reqs.0*)
	All_Sensors_On.4:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.1*)
	All_Sensors_On.5:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.2*)
	All_Sensors_On.6:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);
	(*Sensors Required After Repo_Reqs.3*)
	All_Sensors_On.7:= (FALSE) OR (Dry_Cycle AND All_Sensors_Off);


	(*Sensors Required for Start Of Unload1*)
	All_Sensors_On.8:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2)
					) OR (All_Sensors_Off AND Dry_Cycle);

	(*Sensors Required for Start Of Unload2*)
	All_Sensors_On.9:=(
					((Model_ID=1)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=2)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=3)
						AND Part_Present1 AND Part_Present2)

					OR ((Model_ID=4)
						AND Part_Present1 AND Part_Present2)
					) OR (All_Sensors_Off AND Dry_Cycle);


























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Cylinders" Id="{b99fc6e9-0ed4-4e3b-9989-987f41a5dbc8}">
      <Implementation>
        <ST><![CDATA[
(* -----------------------------------------------------------------------------------*)
(*Below are Examples only, each will have to be customized for your application
	Notes:
	- Use SODGxx-SSCC61x-xxxxxxx_Fix IO and Seq.xlsx document to capture Clamp / Cylinder I/O Layout
	- CLFaults1 thru 4 can be used to group cylinder type faults (All Clamps on CLFaults1, all Pins on CLFaults2)
		OR
	- CLFaults 1 thru 4 can be used to group cylinder UI screens 
		(All items on Cylinder_1.content screen are on CLFaults1, all items on Cylinder_2.content screen are on CLFaults2 as example)
*)
(* -----------------------------------------------------------------------------------*)



(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)
(*Clamps*)(*Clamps*)(*Clamps*)

		(*Clamp1*)
		Clamp1FB(
			Retracted_Sensor:= N01.I.0 ,
			Advanced_Sensor:= N01.I.1 ,
			Retract_Solenoid:= N100.Q.3,
			Advance_Solenoid:= N100.Q.2,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Clamp1RETD,
			In_Advanced_Position=> Clamp1ADVD,
			Faulted=> CLFaults1.1 );

		(*Clamp2*)
		Clamp2FB(
			Retracted_Sensor:= N01.I.2 ,
			Advanced_Sensor:= N01.I.3 ,
			Retract_Solenoid:= N100.Q.3,
			Advance_Solenoid:= N100.Q.2,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Clamp2RETD,
			In_Advanced_Position=> Clamp2ADVD,
			Faulted=> CLFaults1.2 );

		(*Clamp3*)
		Clamp3FB(
			Retracted_Sensor:= N01.I.4,
			Advanced_Sensor:= N01.I.5,
			Retract_Solenoid:= N100.Q.3,
			Advance_Solenoid:= N100.Q.2,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Clamp3RETD,
			In_Advanced_Position=> Clamp3ADVD,
			Faulted=> CLFaults1.3 );

		(*Clamp4*)
		Clamp4FB(
			Retracted_Sensor:= N01.I.6,
			Advanced_Sensor:= N01.I.7,
			Retract_Solenoid:= N100.Q.3,
			Advance_Solenoid:= N100.Q.2,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Clamp4RETD,
			In_Advanced_Position=> Clamp4ADVD,
			Faulted=> CLFaults1.4 );

(*Pins*)(*Pins*)(*Pins*)
(*Pins*)(*Pins*)(*Pins*)
(*Pins*)(*Pins*)(*Pins*)

		(*Pin1*)
		Pin1FB(
			Retracted_Sensor:= N02.I.0,
			Advanced_Sensor:= N02.I.1,
			Retract_Solenoid:= N100.Q.1,
			Advance_Solenoid:= N100.Q.0,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Pin1RETD,
			In_Advanced_Position=> Pin1ADVD,
			Faulted=> CLFaults2.1 );

		(*Pin2*)
		Pin2FB(
			Retracted_Sensor:= N02.I.2,
			Advanced_Sensor:= N02.I.3,
			Retract_Solenoid:= N100.Q.1,
			Advance_Solenoid:= N100.Q.0,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> Pin2RETD,
			In_Advanced_Position=> Pin2ADVD,
			Faulted=> CLFaults2.2 );

(*QA*)(*QA*)(*QA*)
(*QA*)(*QA*)(*QA*)
(*QA*)(*QA*)(*QA*)
(*
		(*QA Check1*)
		QACheck1FB(
			Retracted_Sensor:= N04.I.0,
			Advanced_Sensor:= N04.I.1,
			Retract_Solenoid:= N100.Q.5,
			Advance_Solenoid:= N100.Q.4,
			Ret_Delay:= T#0.1S,
			Adv_Delay:= T#0.1S,
			Fault_Delay:= T#3.0S,
			Disable_Fault:= FALSE,
			In_Retracted_Position=> QACheck1RETD,
			In_Advanced_Position=> QACheck1ADVD,
			Faulted=> CLFaults4.1 );

*)
(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Hardware" Id="{88e6caba-d36e-403d-b9d8-38365fe5d4d7}">
      <Implementation>
        <ST><![CDATA[
(*Pass Node States into Array  in order on Physical Fixture*)

		NodeState:=NodeLayout.State;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Discrete I/O Nodes*)
	IF (*N00.InfoData.State=8*) (*Fix doesn't have an EP1111*) 
		(N01.InfoData.State=8 OR (Discrete_In.Input_Node_Count<2))
		AND (N02.InfoData.State=8 OR (Discrete_In.Input_Node_Count<3))
		AND (N03.InfoData.State=8 OR (Discrete_In.Input_Node_Count<4))
		AND (N04.InfoData.State=8 OR (Discrete_In.Input_Node_Count<5))
		AND (N05.InfoData.State=8 OR (Discrete_In.Input_Node_Count<6))
		AND (N06.InfoData.State=8 OR (Discrete_In.Input_Node_Count<7))
		AND (N07.InfoData.State=8 OR (Discrete_In.Input_Node_Count<8))
		AND (N08.InfoData.State=8 OR (Discrete_In.Input_Node_Count<9))
		AND (N09.InfoData.State=8 OR (Discrete_In.Input_Node_Count<10))
		AND (N10.InfoData.State=8 OR (Discrete_In.Input_Node_Count<11))
		AND (N11.InfoData.State=8 OR (Discrete_In.Input_Node_Count<12))
		AND (N12.InfoData.State=8 OR (Discrete_In.Input_Node_Count<13))
		AND (N13.InfoData.State=8 OR (Discrete_In.Input_Node_Count<14))
		AND (N14.InfoData.State=8 OR (Discrete_In.Input_Node_Count<15))
		AND (N15.InfoData.State=8 OR (Discrete_In.Input_Node_Count<16))
		AND (N16.InfoData.State=8 OR (Discrete_In.Input_Node_Count<17))
		AND (N17.InfoData.State=8 OR (Discrete_In.Input_Node_Count<18))
		AND (N18.InfoData.State=8 OR (Discrete_In.Input_Node_Count<19))
		AND (N19.InfoData.State=8 OR (Discrete_In.Input_Node_Count<20))
		AND (N20.InfoData.State=8 OR (Discrete_In.Input_Node_Count<21))
		AND (N21.InfoData.State=8 OR (Discrete_In.Input_Node_Count<22))
		AND (N22.InfoData.State=8 OR (Discrete_In.Input_Node_Count<23))
		AND (N100_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<1))
		AND (N101_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<2))
		AND (N102_STAT.InfoData.State=8 OR (Discrete_In.VB_Node_Count<3))

		THEN
			DiscreteNode_OK:=TRUE;

	ELSE
			DiscreteNode_OK:=FALSE;

	END_IF;



	(*Cable Break Detection*)
	(*Function Returns Flags to warn of possible cable break*)
	ECatSlave_Cable_Breaks:= FUN_GTAC_EcatSlaveConnState_64bit(NodeState);	























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Production" Id="{78cbfb38-3cae-4b34-97ba-66bae534f489}">
      <Implementation>
        <ST><![CDATA[(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Production Information $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Increment Production Counter*)
	Prod_Inc.CLK:= Unload_Complete;
	Prod_Inc();
	IF Prod_Inc.Q
		THEN
		Production_Count:= Production_Count+1;
	END_IF;
	IF Discrete_In.ResetProd
		THEN
		Production_Count:= 0;
	END_IF;
	Prod_Count_Out:= Production_Count;

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Production Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Input Data*)
	Production_Report.Machine_Serial:= GTAC_CONFIG.Machine_Serial;
	Production_Report.Machine_Common_Name:= GTAC_CONFIG.Machine_Common_Name;
	Production_Report.Prod_Inc:= Prod_Inc.Q;
	Production_Report.Scrap_Inc:= In_From_ICxx.QA_Request_RH;
	Production_Report.Scrap_Dec:= In_From_ICxx.QA_Reinsert_RH;
	Production_Report.Reference_TimeDate:= MAIN.Local_Time;
	Production_Report.Reference_Target_Time:= GTAC_CONFIG.ProdConfig_Target_CycleTime; 					(*This is the machine Expected Cycle Time*)
	Production_Report.Config_Day_TOD:= GTAC_CONFIG.ProdConfig_Day;										(*Pass Each Shift Configuration Structure (Start/End Time, Break Times etc*)
	Production_Report.Config_Aft_TOD:= GTAC_CONFIG.ProdConfig_Aft;
	Production_Report.Config_Mid_TOD:= GTAC_CONFIG.ProdConfig_Mid;
	Production_Report.Config_Shift_Enables:= GTAC_CONFIG.ProdConfig_Common.Shift_Enables;					(*Enable Bits for Shifts*)
	Production_Report.Config_Break_Count:= GTAC_CONFIG.ProdConfig_Common.Break_Count;						(*Select Amount of Breaks per shift*)
	Production_Report.Machine_StoppedBy_Fault:= Faults.System_Major_Fault;
	Production_Report.Enable_InShift_Change:= GTAC_CONFIG.ProdConfig_Option_SelectInShiftChange;				(*Allows Operator 5 mins at start and end of shift for clean up*)
	(*Call FB*)
	IF NOT MAIN.Starting_Scan_Pulse
		THEN
		Production_Report();
	END_IF;

(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Cycle Time Counters ~~~~~~~~~~~~~~~~~~~~~~~~~*)
	(*Move Previous To Register*)
	Cycle_Time_Pulse.CLK:= Unload_Complete;
	Cycle_Time_Pulse();
	IF Cycle_Time_Pulse.Q
		THEN
		PrevCycle_Time_Out:= Cycle_Time_Out;
	END_IF;
	(*Monitor Current Cycle Time (Full Cycle Time of Process)*)
		Cycle_Time.PT:= T#9999S;
		Cycle_Time.IN:= NOT Cycle_Time_Pulse.Q AND In_Auto;
		Cycle_Time();
		Cycle_Time_Out:= Cycle_Time.ET;

	(*Monitor Load Time*)
		IF In_Auto AND NOT Load_Robots_Clear
			THEN
			Load_Time_Out:= Load_Time.ET;
		END_IF;
		Load_Time.PT:= T#9999S;
		Load_Time.IN:= In_Auto AND NOT Load_Robots_Clear;
		Load_Time();

	(*Monitor Robot Welding Time: MIG Inspection Job*)
		IF In_Auto AND NOT Weld_Robots_Clear
			THEN
			Weld_Time_Out:= Weld_Time.ET;
		END_IF;
		Weld_Time.PT:= T#9999S;
		Weld_Time.IN:= In_Auto AND NOT Weld_Robots_Clear;
		Weld_Time();

	(*Monitor Unload Time*)
		IF In_Auto AND NOT Unload_Robots_Clear
			THEN
			Unload_Time_Out:= Unload_Time.ET;
		END_IF;
		Unload_Time.PT:= T#9999S;
		Unload_Time.IN:= In_Auto AND NOT Unload_Robots_Clear;
		Unload_Time();
		
		

(*~~~~~~~~~~~~~~~ DEBUG Temporary Area to start roughing in Keyence Nut Check Status captures, blt ~~~~~~~~~~~~*)

(*Capture Keyence IV3 Camera1 Results*)
QA_IV3_Pulse[1].CLK:= Keyence_Camera_Complete1;
QA_IV3_Pulse[1]();
 
IF QA_IV3_Pulse[1].Q
	THEN
	(*DEBUG, testing manual setting of bits*)
	Keyence_NutCheck_StatusBits_0:= 0;
	Keyence_NutCheck_StatusBits_0.0:= TRUE;
	Keyence_NutCheck_StatusBits_0.6:= TRUE;
	Keyence_NutCheck_StatusBits_0.22:= TRUE;
	
	(*Capture results into Persistant Data tracking area*)
	Fix102_ProductData_Pers.Generic_Measurements[0]:= UDINT_TO_REAL(Keyence_NutCheck_StatusBits_0);
	
	(*Evaluate Pass reslts to detrmein ovr-all pass*)
	IF Keyence_NutCheck_StatusBits_0.0 AND Keyence_NutCheck_StatusBits_0.1 AND Keyence_NutCheck_StatusBits_0.2
		AND Keyence_NutCheck_StatusBits_0.4 AND Keyence_NutCheck_StatusBits_0.5 AND Keyence_NutCheck_StatusBits_0.6
		AND Keyence_NutCheck_StatusBits_0.7 AND Keyence_NutCheck_StatusBits_0.8 AND Keyence_NutCheck_StatusBits_0.9
		(*DEBUG Add in how ever many bits are required, blt*)
		THEN
		Keyence_Camera_Passed1:= TRUE;
	END_IF
END_IF;	



(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~Product Data Report~~~~~~~~~~~~~~~~~~~~~~~~~*)
(*Can be used to load and store product specific data (pass fail results, measurements etc) into DB*)
(*Triggers to start actual storage are contained in GTAC_CONFIG.Reports*)

(*Load Data into area*)
	(*DEBUG, needs finalizing, blt*)
	IF Weld_Complete_Ack THEN
		IF Keyence_Camera_Passed1 AND Keyence_Camera_Passed2 AND SmartRay_Passed (*Add in more pass requirements here if required*)
			THEN
			Fix102_ProductData_Pers.Generic_PassFail_Notes[12]:= 'Pass';
		ELSE
			Fix102_ProductData_Pers.Generic_PassFail_Notes[12]:= 'Fail'; //DEBUG DEBUG - This needs to be Fail - Changed for testing - RJ
		END_IF;
	END_IF;
	
	Out_To_ICxx.ProductReport[18]:= Fix102_ProductData_Pers; 	(*Transfer Product Data to UI, see MAIN.Product_Data*)
	


(*Pass / Fail Notes - Used to capture overall terms like 'Pass' 'Fail' 'NA' etc.*)
// 20260113: code added due to fix103 QA
    IF    Unload_Robots_Complete1 AND QA_IV3_OK[1] AND QA_IV3_OK[2] AND Smart_Ray_OK
          THEN
          Fix102_ProductData_Pers.Generic_PassFail_Notes[18] := 'Comp';
    ELSIF Unload_Robots_Complete1 AND (QA_IV3_NOK[1] OR QA_IV3_NOK[2]) AND Smart_Ray_OK
		  THEN
		  Fix102_ProductData_Pers.Generic_PassFail_Notes[18] := '1'; // Keyence Failed
    ELSIF Unload_Robots_Complete1 AND Smart_Ray_NOK AND QA_IV3_OK[1] AND QA_IV3_OK[2]
		  THEN
		  Fix102_ProductData_Pers.Generic_PassFail_Notes[18] := '2'; // Smart Ray Failed
	ELSIF Unload_Robots_Complete1 AND (QA_IV3_NOK[1] OR QA_IV3_NOK[2]) AND Smart_Ray_NOK 
          THEN
          Fix102_ProductData_Pers.Generic_PassFail_Notes[18] := '3';	 // Keyence & Smart Ray Failed
	END_IF
	







]]></ST>
      </Implementation>
    </Action>
    <Action Name="Proxies" Id="{ad686894-056b-467f-91f1-ca5f83266a11}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

Repo1_Step.0 := (MAIN.R4.Peripheral_Req.0 AND (MAIN.R4.Task_ID_Ack=Dropoff_Fix05));

	(*Part 1 Present*)
		Part_Present1FB(
			Sensor_Input:= N02.I.4,
			On_Trigger1:= Enable_Motion AND In_Auto AND Repo_Reqs.0 AND NOT Repo_Reqs.2,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Dry_Cycle OR (Cycle_Complete AND NOT Enable_Motion) OR Repo_Reqs.2,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Load_Robots_WorkingOK1 AND NOT Repo1_Step.0,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present1,
			Faulted=>  PPFaults.1);

	(*Part 2 Present*)
		Part_Present2FB(
			Sensor_Input:= N02.I.6,
			On_Trigger1:= Enable_Motion AND In_Auto AND Repo_Reqs.0 AND NOT Repo_Reqs.2,
			On_Trigger2:= TRUE,
			Off_Trigger1:= Dry_Cycle OR (Cycle_Complete  AND NOT Enable_Motion) OR Repo_Reqs.2,
			Off_Trigger2:= TRUE,
			Disable_Faults:= Load_Robots_WorkingOK1 AND NOT Repo1_Step.0,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present2,
			Faulted=>  PPFaults.2);



(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="QA_Cameras" Id="{fa1025a7-962c-4409-aa83-3c2a08a63ead}">
      <Implementation>
        <ST><![CDATA[	
    (*Fix102 Cam QA*)
	Fix102_QA_Trigger:= Load_Complete;(*OR (main.r4.Aux_Req.0 AND MAIN.R4.Task_ID_Ack=Dropoff_Fix102)   <- This condition for the case when the cycle time is a problem*)
	
    Camera_Trigger_Request(CLK:= Fix102_QA_Trigger, Q=> );
	
	
	(*Ped04 Camera 1 - Keyence IV3 Sealer Inspection*)
	QA_IV3[1](
	Discrete_In:=In_From_ICxx.IVx_Discrete_In[1],
	TriggerRequest:= Camera_Trigger_Request.Q, 
	WarningClear:= In_From_ICxx.ControlPower1 , 
	ProgramRequest:= CAM_Request_prog[1] , 
	BufferClear:= , (*DEBUG= Boolean to Clear Buffer, used to clear the I/O status from IV2 System*)
	Reset_Sequence:= (Welding_Complete AND QA_IV3_OK[1])                           (*OK situation*)  
                      OR (QA_IV3[1].Discrete_In.IVx_Release)                       (*NOK: release situation*)
                      OR (Unload_Complete),                                        (*Reset*)
	In_Auto:= MAIN.Control_Power_ON, 
	IV_Check_OK=> QA_IV3_OK[1], 
	IV_Check_NOK=> QA_IV3_NOK[1], 
	Camera_Faulted=> QA_IV3_Faulted[1], 
	Camera_Complete=> QA_IV3_Complete[1], 
	CurrentPrg_Out=>CAM_PROG[1] , 
	IV_Busy_Out=> (*Wait for IV camera to be busy Processing the Image*),);
	
	Out_To_ICxx.IVx[1].Discrete_Image:= QA_IV3[1].Discrete_Image;
	
	(*Ped04 Camera 2 - Keyence IV3 Sealer Inspection*)
	QA_IV3[2](
	Discrete_In:=In_From_ICxx.IVx_Discrete_In[2],
	TriggerRequest:= Camera_Trigger_Request.Q, 
	WarningClear:= In_From_ICxx.ControlPower1 , 
	ProgramRequest:= CAM_Request_prog[2] , 
	BufferClear:= , (*DEBUG= Boolean to Clear Buffer, used to clear the I/O status from IV2 System*) 
	Reset_Sequence:= (Welding_Complete AND QA_IV3_OK[2])                           (*OK situation*)  
                      OR (QA_IV3[2].Discrete_In.IVx_Release)                       (*NOK: release situation*)
                      OR (Unload_Complete),                                        (*Reset*)
	In_Auto:= MAIN.Control_Power_ON, 
	IV_Check_OK=> QA_IV3_OK[2], 
	IV_Check_NOK=> QA_IV3_NOK[2], 
	Camera_Faulted=> QA_IV3_Faulted[2], 
	Camera_Complete=> QA_IV3_Complete[2], 
	CurrentPrg_Out=>CAM_PROG[2] , 
	IV_Busy_Out=> (*Wait for IV camera to be busy Processing the Image*),);
	
	Out_To_ICxx.IVx[2].Discrete_Image:= QA_IV3[2].Discrete_Image;]]></ST>
      </Implementation>
    </Action>
    <Action Name="QA_SmartRay" Id="{e02ce1c7-9fb4-44d0-8802-624f9eb4cc67}">
      <Implementation>
        <ST><![CDATA[(*Flag for Part tracking*)	
Smart_Ray_OK:= SR_Smart_Ray_OK[0] AND SR_Smart_Ray_OK[1];
Smart_Ray_NOK:= SR_Smart_Ray_NOK[0] AND SR_Smart_Ray_NOK[1];	

(*R10*)
(*-----------------------------------------------------------------------------*)
QA_SR[0].In_Robot_From_SR.Alive_Out := MAIN.R10.In_Rxx_From_SmartRay.Alive_Out;
QA_SR[0].In_Robot_From_SR.FailureGlobal_Out := MAIN.R10.In_Rxx_From_SmartRay.FailureGlobal_Out;
QA_SR[0].Out_Robot_To_SR.InspectionCompleted_In := MAIN.R10.Out_Rxx_To_SmartRay.InspectionCompleted_In;

QA_SR[0](
	Discrete_In := In_From_ICxx.SRx_Discrete_In[0],
	Previous_Job_Complete:= Load_Complete, //Robot Drop off and PLC start sending a signals to SR 
	Robot_Inspection_Start:= Start_Weld_Robots, // Robot Inspection Start
	PartType:= UINT_TO_BYTE(Model_ID), 
	PartID:= SR_PartID, 
	All_Reset:= Reset_All_Completes, 
	Profinode_OK => SR_Profinode_OK[0],
	Robot_Start_Ready=> PLC_Ready_for_Inspection[0], // a couple of signals need before the robot call the jobs on SR
	Error=>SR_Error[0] ,
	Comm_Error=>SR_Comm_Error[0], 
	FB_Error=> SR_PLC_FB_Error[0], 	
	Smart_Ray_OK=> SR_Smart_Ray_OK[0], 
	Smart_Ray_NOK=> SR_Smart_Ray_NOK[0], 
	PLC_Inspection_Complete=>SR_Complete[0]);

(*Discrete image to UI*)
Out_To_ICxx.SRx[0].DiscreteImage := QA_SR[0].Discrete_Image;
(*-----------------------------------------------------------------------------*)	
	
(*R11*)
(*-----------------------------------------------------------------------------*)
QA_SR[1].In_Robot_From_SR.Alive_Out := MAIN.R11.In_Rxx_From_SmartRay.Alive_Out;
QA_SR[1].In_Robot_From_SR.FailureGlobal_Out := MAIN.R11.In_Rxx_From_SmartRay.FailureGlobal_Out;
QA_SR[1].Out_Robot_To_SR.InspectionCompleted_In := MAIN.R11.Out_Rxx_To_SmartRay.InspectionCompleted_In;


QA_SR[1](
	Discrete_In := In_From_ICxx.SRx_Discrete_In[1],
	Previous_Job_Complete:= Load_Complete, //Robot Drop off and PLC start sending a signals to SR 
	Robot_Inspection_Start:= Start_Weld_Robots, // Robot Inspection Start
	PartType:= UINT_TO_BYTE(Model_ID), 
	PartID:= SR_PartID, 
	All_Reset:= Reset_All_Completes,
    Profinode_OK => SR_Profinode_OK[1], 
	Robot_Start_Ready=> PLC_Ready_for_Inspection[1], // a couple of signals need before the robot call the jobs on SR
	Error=>SR_Error[1],
	Comm_Error=>SR_Comm_Error[1], 
	FB_Error=> SR_PLC_FB_Error[1], 	
	Smart_Ray_OK=> SR_Smart_Ray_OK[1], 
	Smart_Ray_NOK=> SR_Smart_Ray_NOK[1], 
	PLC_Inspection_Complete=>SR_Complete[1]);
	
(*Discrete image to UI*)
Out_To_ICxx.SRx[1].DiscreteImage := QA_SR[1].Discrete_Image;	
(*-----------------------------------------------------------------------------*)

	]]></ST>
      </Implementation>
    </Action>
    <Action Name="Robot_Registration" Id="{8df122bf-f69a-4031-a7b8-f1500f0abe76}">
      <Implementation>
        <ST><![CDATA[

(*#################################### Register Robots to Tool ##################################*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*NOTE: See Example code in Fix 15 / 16*)
(*NOTE: See Example code in Fix 15 / 16*)

	(*Data From Load Robot(s)*)
	Load_Robots_Clear1:= (MAIN.R4.Clear_Of_EquipInterf4 AND NOT (MAIN.R4.Task_ID_Ack=Dropoff_Fix102)) OR MAIN.R4.At_Home;
	Load_Robots_Clear2:= TRUE;
	Load_Robots_Clear:=Load_Robots_Clear1 AND Load_Robots_Clear2;
	Load_Robots_WorkingOK1:= (MAIN.R4.Task_ID_Ack=Dropoff_Fix102) AND MAIN.R4.Operating;
	Load_Robots_WorkingOK2:= FALSE;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly1:= TRUE;
	END_IF;
	IF FALSE
		THEN
		Load_Robots_UnclampEarly2:= TRUE;
	END_IF;
	Load_Robots_Complete1:= MAIN.R4.At_EquipInterf4 AND (MAIN.R4.Task_ID_Ack=Dropoff_Fix102) AND MAIN.R4.Task_Completed;
	Load_Robots_Complete2:= FALSE;
	Load_Robots_PartInEOAT1:= EOAT04.Part1_In_EOAT;
	Load_Robots_PartInEOAT2:= EOAT04.Part2_In_EOAT;


	(*Data From Turntable*)
	TurntableA_Clear:= (MAIN.R10.Clear_Of_EquipInterf2 AND (MAIN.R10.Task_ID_Ack<>Sweep_Fix102)) 
                        OR (MAIN.R10.At_Home AND MAIN.R11.At_Home);
	TurntableB_Clear:= TRUE;
	Turntable_Clear:= TurntableA_Clear AND TurntableB_Clear AND NOT MAIN.R10.In_Teach;
	TurntableA_At_Robot:= (MAIN.R10.T03.I.0 AND MAIN.R10.T03.I.1);
	TurntableB_At_Robot:= (MAIN.R10.T03.I.2 AND MAIN.R10.T03.I.3);
	Turntable_WorkingOK:= (MAIN.R10.Task_ID_Ack=Sweep_Fix102) AND MAIN.R10.Operating;
	TurntableA_Complete:= MAIN.R10.Clear_Of_EquipInterf2 AND (MAIN.R10.Task_ID_Ack=Sweep_Fix102) AND MAIN.R10.Task_Completed;
	TurntableB_Complete:= FALSE;
	
	(*Data From Seal Robot(s)*)
	Seal_Robots_Clear:= TRUE;
	Seal_Robots_WorkingOK:= FALSE;
	IF FALSE
		THEN
		Seal_Robots_UnclampEarly:= TRUE;
	END_IF;
	Seal_Robots_Complete:= FALSE;


	(*Data From Stud Robot(s)*)
	Stud_Robots_Clear:= TRUE;
	Stud_Robots_WorkingOK:= FALSE;
	IF FALSE
		THEN
		Stud_Robots_UnclampEarly:= TRUE;
	END_IF;
	Stud_Robots_Complete:= FALSE;


	(*Data From Weld Robot(s)*)
	Weld_Robots_Clear:= (MAIN.R10.Clear_Of_EquipInterf1 AND NOT (MAIN.R10.Task_ID_Ack=Weld_Fix102) AND MAIN.R11.Clear_Of_EquipInterf1 AND NOT (MAIN.R11.Task_ID_Ack=Weld_Fix102)) 
                        OR (MAIN.R10.At_Home AND MAIN.R11.At_Home);
	Weld_Robots_WorkingOK:= (MAIN.R10.Task_ID_Ack=Weld_Fix102) AND MAIN.R10.Operating AND (MAIN.R11.Task_ID_Ack=Weld_Fix102) AND MAIN.R11.Operating;
	IF FALSE
		THEN
		Weld_Robots_UnclampEarly:= TRUE;
	END_IF;
	Weld_Robots_Complete:= (MAIN.R10.At_EquipInterf1 AND (MAIN.R10.Task_ID_Ack=Weld_Fix102) AND MAIN.R10.Task_Completed) AND
                           (MAIN.R11.At_EquipInterf1 AND (MAIN.R11.Task_ID_Ack=Weld_Fix102) AND MAIN.R11.Task_Completed);

	(*Change Robots for Current Fixture functionality*) (*If no MIG robots Set to True.  Example code is in Fix15/16*) 
	Mig_Robots_Ready:=	TRUE;

	(*Data From Unload Robot(s)*)
	Unload_Robots_Clear1:= (MAIN.R4.Clear_Of_EquipInterf4 AND NOT (MAIN.R4.Task_ID_Ack=Pickup_Fix102)) OR MAIN.R4.At_Home;
	Unload_Robots_Clear2:= TRUE;
	Unload_Robots_Clear:= Unload_Robots_Clear1 AND Unload_Robots_Clear2;
	Unload_Robots_WorkingOK1:= (MAIN.R4.Task_ID_Ack=Pickup_Fix102) AND MAIN.R4.Operating;
	Unload_Robots_WorkingOK2:= FALSE;
	Unload_Robots_Complete1:= MAIN.R4.At_EquipInterf4 AND (MAIN.R4.Task_ID_Ack=Pickup_Fix102) AND MAIN.R4.Task_Completed;
	Unload_Robots_Complete2:= FALSE;
	Unload_Robots_EOATEmpty1:= EOAT04.EOAT_Part1_Empty;
	Unload_Robots_EOATEmpty2:= EOAT04.EOAT_Part2_Empty;



	(*Amalgumate All Robots Clear of Tool*)
	All_Robots_Clear:= Load_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear;

	(*Data To All Robots*)
	(*Task ID*)
	R4_Data.Task_ID[12]:=Task_ID;
	
	R10_Data.Task_ID[9]:=Task_ID; (*EquipInterf1*)
	R11_Data.Task_ID[9]:=Task_ID; (*EquipInterf1*)
	
	R10_Data.Task_ID[10]:=Task_ID; (*EquipInterf2*)
	R11_Data.Task_ID[10]:=Task_ID; (*EquipInterf2*)

	(*Fix ID*)
	R4_Data.Fix_ID[12]:=Fix_ID;
	
	R10_Data.Fix_ID[9]:=Fix_ID; (*EquipInterf1*)
	R11_Data.Fix_ID[9]:=Fix_ID; (*EquipInterf1*)
	
	R10_Data.Fix_ID[10]:=Fix_ID; (*EquipInterf2*)
	R11_Data.Fix_ID[10]:=Fix_ID; (*EquipInterf2*)
	
	(*Model ID*)
	R4_Data.Model_ID[12]:=Model_ID;

	R10_Data.Model_ID[9]:=Model_ID; (*EquipInterf1*)
	R11_Data.Model_ID[9]:=Model_ID; (*EquipInterf1*)
	
	R10_Data.Model_ID[10]:=Model_ID; (*EquipInterf2*)
	R11_Data.Model_ID[10]:=Model_ID; (*EquipInterf2*)
	
	(*Proceed from Pounce*)
	R4_Data.Proceed_From_Pounce[12]:= Robots_Clear_ToProceed;
	
	R10_Data.Proceed_From_Pounce[9]:=Robots_Clear_ToProceed; (*EquipInterf1*)
	R11_Data.Proceed_From_Pounce[9]:=Robots_Clear_ToProceed; (*EquipInterf1*)
	
	(*Complete Acks*)
	R4_Data.Complete_Ack[12]:=(Load_Complete1_Ack AND Load_Robots_WorkingOK1) OR (Unload_Complete1_Ack AND Unload_Robots_WorkingOK1);;
	
	R10_Data.Complete_Ack[11]:=(TurnA_Complete_Ack AND Turntable_WorkingOK); (*EquipInterf1*)
	
    R10_Data.Complete_Ack[9]:=(Weld_Complete_Ack AND Weld_Robots_WorkingOK); (*EquipInterf2*)
	R11_Data.Complete_Ack[9]:=(Weld_Complete_Ack AND Weld_Robots_WorkingOK); (*EquipInterf2*)

	
	(*Repo Acks*)
	R4_Data.PeripheralReq_Ack[12]:= Repo_Ack;
	
	R10_Data.PeripheralReq_Ack[9]:= Repo_Ack; (*EquipInterf1*)
	R11_Data.PeripheralReq_Ack[9]:= Repo_Ack; (*EquipInterf1*)
	
	R10_Data.PeripheralReq_Ack[10]:= Repo_Ack; (*EquipInterf2*)
	R11_Data.PeripheralReq_Ack[10]:= Repo_Ack; (*EquipInterf2*)
	

(*%%%%%%%%%%%%%% Call Robots to Tool and Give Them, Task ID, Fixture ID and Model ID %%%%%%%%%%%%%%%%%*)
	(* Perform Call To Tool*)
	Tool_Call_ForLoadRobots1:= Enable_Motion AND (NOT Cell_In_Services OR NOT Load_Robots_Clear1)
						AND Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForSweepA:= Enable_Motion AND (NOT Cell_In_Services OR NOT TurntableA_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForWeldRobots:= Enable_Motion AND (NOT Cell_In_Services OR NOT Weld_Robots_Clear)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;
	Tool_Call_ForUnloadRobots1:= Enable_Motion AND (NOT Cell_In_Services OR NOT Unload_Robots_Clear1)
						AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots
						AND Start_Unload_Robots1 AND NOT Start_Unload_Robots2 AND NOT Start_TurntableA AND NOT Start_TurntableB;



	(*Allow Robots to Proceed Into Tool*)
	(*!!!!!This is the final OK to allow Robots Into the Tool Area, So it Better Be Ready!!!!!!!*)
	IF Enable_Motion
		THEN
			IF Load_Robots_Proceed1 AND Load_Robots_WorkingOK1 AND Load_Robots_Clear2 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Load_Robots_Proceed2 AND Load_Robots_WorkingOK2 AND Load_Robots_Clear1 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Weld_Robots_Proceed AND Weld_Robots_WorkingOK AND Load_Robots_Clear AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Unload_Robots_Clear
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Unload_Robots_Proceed1 AND Unload_Robots_WorkingOK1 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear2
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSIF Unload_Robots_Proceed2 AND Unload_Robots_WorkingOK2 AND Seal_Robots_Clear AND Stud_Robots_Clear AND Turntable_Clear AND Weld_Robots_Clear AND Unload_Robots_Clear1
				THEN Robots_Clear_ToProceed:=TRUE;
			ELSE Robots_Clear_ToProceed:= FALSE;
			END_IF;
		ELSE Robots_Clear_ToProceed:= FALSE;
	END_IF;

(*+++++++++++++++++++++++++++++++++++++++++++++++ Task Complete Acks ++++++++++++++++++++++++++*)
	(*1st Load Complete Ack*)
	Load_Complete1_Ack:= Load_Robots_Complete1 AND Load_Complete1;

	(*Sweep Complete ACK*)
	TurnA_Complete_Ack := TurntableA_Complete;
	TurnB_Complete_Ack := TurntableB_Complete AND TurntableB_At_Robot;

	(*Weld Complete Ack*)
	Weld_Complete_Ack:= Weld_Robots_Complete AND Welding_Complete;

	(*Unload Complete Ack*)
	Unload_Complete1_Ack:= Unload_Robots_Complete1 AND Unload_Complete;
	
	(*Sweep Complete ACK*)
	TurnA_Complete_Ack := (TurntableA_Complete AND TurntableA_At_Robot);


(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Status_and_Faults" Id="{ced8a584-4488-4e15-93c3-17427f983f2e}">
      <Implementation>
        <ST><![CDATA[


(*^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ General Visualization ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^*)
	(*For Ready to Load Indicators*)
		(*Flash when tool should be loaded but load is not complete*)
		IF In_Auto AND All_Robots_Clear AND Tool_At_Home AND TurnA_Complete AND NOT All_Sensors_On.0
			THEN
				Ready_To_Load:= Pulse_500mS;
				(*Go solid when tool has been loaded properly*)
				(*Go solid when tool is ready to be unloaded*)
		ELSIF In_Auto AND All_Robots_Clear AND TurnA_Complete AND NOT Load_Complete  AND ((Tool_At_Home OR Tool_At_Load.0) AND All_Sensors_On.0)
			THEN
				Ready_To_Load:= TRUE;
		ELSE
				Ready_To_Load:= FALSE;
		END_IF;
	(*For Red Stack Light Indicators*)
		Red_Lamp_Req:= PPFaulted.0 OR CLFaulted.0 OR CLFaulted.4(*.4= QA fault*);


	(*Status Banners*)
	
		(*Unused statuses are commented out: 10242025 W*)
		(*Table rotation: Seq1 > Robot loading: Seq2 > Robots Inspection: Seq3 > Robot Unloading: Last Seq*)
	
		(*1 - Check Parts On Sub Check*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.0
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.0
					THEN Status:= 1;
				ELSIF Dry_Cycle AND NOT Load_Complete1
					THEN Status:=1;
				END_IF;
		END_IF;
		(*2 - Sub Check OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.1
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.1
					THEN Status:= 2;
				ELSIF Dry_Cycle AND NOT Load_Complete2
					THEN Status:=2;
				END_IF;
		END_IF;
		(*3 - Load Main Part*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Home
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.2
					THEN Status:= 3;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=3;
				END_IF;
		END_IF;
		(*10 - Load Parts Onto Tool*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Tool_At_Load.0
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Seal_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			AND NOT Start_TurntableB AND NOT Start_Weld_Robots AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN
				IF NOT Dry_Cycle AND NOT All_Sensors_On.2
					THEN Status:= 10;
				ELSIF Dry_Cycle AND NOT Load_Complete
					THEN Status:=10;
				END_IF;
		END_IF;
		
		(*11 - Robot(s) Loading*)
		(*Second Seq*)
		IF ((Start_Load_Robots1 OR  Load_Robots_WorkingOK1) OR (Start_Load_Robots2 OR  Load_Robots_WorkingOK2)) AND In_Auto AND NOT In_Manual
			THEN Status:= 11;
		END_IF;
		
		(*12 - Parts Loaded OK*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete
			THEN
				IF (All_Sensors_On.0 AND Tool_At_Load.1) AND NOT Dry_Cycle
					THEN Status:= 12;
				ELSIF Load_Complete
					THEN Status:= 12;
				END_IF;
		END_IF;
		
		(*19 - Robot(s) Stud*)
		IF (Start_Stud_Robots OR Stud_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Seal_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 19;
		END_IF;
		(*20 - Robot(s) Sealing*)
		IF (Start_Seal_Robots OR Seal_Robots_WorkingOK) AND In_Auto AND NOT In_Manual
			AND NOT Start_Load_Robots1 AND NOT Start_Load_Robots2 AND NOT Start_Weld_Robots AND NOT Start_Stud_Robots AND NOT Start_TurntableA
			 AND NOT Start_TurntableB AND NOT Start_Unload_Robots1 AND NOT Start_Unload_Robots2
			THEN Status:= 20;
		END_IF;
		
		(*121 - Robot(s) Welding: Robot QA Inspection*)
		(*Third Seq*)
		IF ((Start_Weld_Robots OR Weld_Robots_WorkingOK) AND In_Auto AND NOT In_Manual) OR test_1
			THEN Status:= 121;
		END_IF;
		(*122 - Welding Complete / Ready for Unload *)
		IF (In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Welding_Complete) OR test_2
			THEN Status:= 122;
		END_IF;
		
		(*26 - Ready for Rotate*)
		(*First seq*)
		IF In_Auto AND NOT In_Manual AND All_Robots_Clear AND Tool_At_Home AND All_Sensors_Off AND Start_TurntableA OR Start_TurntableB
			THEN Status := 26;
		END_IF;
		
		(*31 - Robot(s) Unloading*)
		(*Last Seq*)
		IF (Start_Unload_Robots1 OR Unload_Robots_WorkingOK1 OR Start_Unload_Robots2 OR Unload_Robots_WorkingOK2) AND In_Auto AND NOT In_Manual
			THEN Status:= 31;
		END_IF;
		(*32 - Unload Complete*)
		IF In_Auto AND NOT In_Manual AND NOT Cycle_Complete AND Unload_Complete
			THEN Status:= 32;
		END_IF;
		
		
		(*42 - Cycle Complete*)
		IF In_Auto AND NOT In_Manual AND Cycle_Complete AND All_Sensors_Off
			THEN Status:= 42;
		END_IF;
		(*50 - In Manual*)
		IF In_Manual AND NOT test_1 AND NOT test_2 AND NOT test_3
			THEN Status:= 50;
		END_IF;
		(*51 - Clamp Fault*)
		IF (CLFaults1>0 OR CLFaults2>0 OR CLFaults3>0) AND In_Auto AND NOT In_Manual
			THEN Status:= 51;
		END_IF;
		(*52 - Part Present Sensor Fault*)
		IF ((PPFaults>0) OR (PPFaults1>0) OR (PPFaults2>0)) AND In_Auto AND NOT In_Manual
			THEN Status:= 52;
		END_IF;
		(*53 - Nut Checks Failed Call QA*)
		IF ((QA_IV3_NOK[1] OR QA_IV3_NOK[2]) AND In_Auto AND NOT In_Manual) or test_3
			THEN Status:= 53;
		END_IF;
		
		(*54 - Sealer Failed Call QA*)
		IF NOT Sealer_Bypass AND (MAIN.SL01.Disp1_Volume_NotOK AND (MAIN.R1.Task_ID_Ack=Seal_Fix16)) AND In_Auto AND NOT In_Manual
			THEN Status:= 54;
		END_IF;
		(*55 - Load Sequence Fault Call QA*)
		IF Load_Seq01.Faulted AND In_Auto AND NOT In_Manual
			THEN Status:= 55;
		END_IF;
		
       (*153 - Smart Ray Error*)
		IF (SR_Error[0] OR SR_Error[1]) OR (SR_Comm_Error[0] OR SR_Comm_Error[1]) OR (SR_PLC_FB_Error[0] OR SR_PLC_FB_Error[1])
            AND In_Auto AND NOT In_Manual
			THEN Status:= 153;
		END_IF		
	

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Faults $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Clamp/Cylider Faults Group 1*)
		IF CLFaults1>0
			THEN CLFaulted.1:=TRUE;
		ELSE
			CLFaulted.1:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 2*)
		IF CLFaults2>0
			THEN CLFaulted.2:=TRUE;
		ELSE
			CLFaulted.2:=FALSE;
		END_IF;
	(*Clamp/Cylider Faults Group 3*)
		IF CLFaults3>0
			THEN CLFaulted.3:=TRUE;
		ELSE
			CLFaulted.3:=FALSE;
		END_IF;
	(*Clamp/Cylinder Faults Group 4 - Reserved Flag for QA Check Motion Faults*)
		IF (QA_IV3_NOK[1] OR QA_IV3_NOK[2]) OR TRUE
			THEN CLFaulted.4:=TRUE;
		ELSE
			CLFaulted.4:=FALSE;
		END_IF;
	(*Bit 0 is designated as ANY Clamp Group Faulted*)
	IF CLFaulted.1 OR CLFaulted.2 OR CLFaulted.3
		THEN CLFaulted.0:= TRUE;
	ELSE CLFaulted.0 := FALSE;
	END_IF;

	(*Part Present Sensor Faults*)
		IF (PPFaults>0) OR (PPFaults1>0) OR (PPFaults2>0)
			THEN PPFaulted.0:=TRUE;
		ELSE
			PPFaulted.0:=FALSE;
		END_IF;
























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Task_Fix_Model_IDs" Id="{47b2941d-eca2-463c-bef6-853cfb8de182}">
      <Implementation>
        <ST><![CDATA[

	(*Develop Task IDs - See Global Variable, "TaskID_Record"*)

	IF (Start_Load_Robots1 OR Start_Load_Robots2) AND Enable_Motion
		THEN Task_ID:= Dropoff_Fix102;
	ELSIF Start_Weld_Robots AND Enable_Motion
		THEN Task_ID:= Weld_Fix102;
	ELSIF Start_TurnTableA AND Enable_Motion
		THEN Task_ID:= Sweep_Fix102;
	ELSIF (Start_Unload_Robots1 OR Start_Unload_Robots2) AND Enable_Motion
		THEN Task_ID:= Pickup_Fix102;
	ELSE Task_ID:= 0;
	END_IF;

	(*Develop Fixture ID*)
	Fix_ID:= 102;					(*In Future Map Beckhoff Dip Switch Data From IP67 Block to Here*)

	(*Develop Model ID*)
	Model_ID:= Discrete_In.ModelData;

















]]></ST>
      </Implementation>
    </Action>
    <Action Name="Tool_States" Id="{7a5c644c-a765-4f25-b233-066f80444699}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

	Tool_At_HOME:= Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Pin1ADVD AND Pin2ADVD;


	Tool_At_Load.0:=Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Pin1ADVD AND Pin2ADVD;
	Tool_At_Load.1:= FALSE;
	Tool_At_Load.2:= FALSE;
	Tool_At_Load.3:= FALSE;
	Tool_At_Load.4:= FALSE;

	
	Tool_At_Rotate.0:= Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Pin1ADVD AND Pin2ADVD;
	Tool_At_Rotate.1:= FALSE;
	Tool_At_Rotate.2:= FALSE;
	Tool_At_Rotate.3:= FALSE;
	Tool_At_Rotate.4:= FALSE;

	
	Tool_At_Weld.0:= Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Pin1ADVD AND Pin2ADVD;
	Tool_At_Weld.1:= FALSE;
	Tool_At_Weld.2:= FALSE;
	Tool_At_Weld.3:= FALSE;
	Tool_At_Weld.4:= FALSE;


	Tool_At_Unload.0:=Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD
				AND Pin1RETD AND Pin2RETD;
	Tool_At_Unload.1:= Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD
				AND Pin1RETD AND Pin2RETD;
	Tool_At_Unload.2:= FALSE;
	Tool_At_Unload.3:= FALSE;
	Tool_At_Unload.4:= FALSE;






(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Tool_VBSeq_Repos" Id="{001f0ebd-c11b-4841-ba9e-34723c2c8e0f}">
      <Implementation>
        <ST><![CDATA[(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)


(*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! Tool Motion Control !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*)

(*----------------------------------------- Camp / Unclamp Steps -------------------------------*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Develop Clamp and Unclamp Interlocks $$$$$$$$$$$$$$$$$$$$$$*)
(* Note: This is one method to create valve bank commands for clamp and unclamp sequencing
you are welcome to use the direct method as well*)

	(*First Stage Clamping*)
	(*Drop Off*)(*Signal for adv clamps: V2 (="Tool_At_Load.0")*)
	Clamp_Step.0:= (NOT Welding_Complete) OR Unload_Complete;
	
	(*Second Stage Clamping*)
	Clamp_Step.1:= ((Repo_Reqs.0 AND All_Sensors_On.3) OR Load_Complete) AND NOT Weld_Robots_Complete AND
                   (Pin1ADVD AND Pin2ADVD); 

	(*Third Stage Clamping*)		
	Clamp_Step.2:= FALSE; 
	
	(*Forth Stage Clamping*)
	Clamp_Step.3:= FALSE;
 

	(*Start Unlcamp Sequence*)
	(*First Stage Unclamping - RETD Pins*)
	Unclamp_Step.0:= Welding_Complete AND NOT Unload_Complete; 
	
	(*Second Stage Unclamping - RETD Clamps*)
	Unclamp_Step.1:= Unclamp_Step.0 AND Repo_Reqs.2 AND 
                   (Pin1RETD AND Pin2RETD)
				OR 
					(NOT Welding_Complete AND NOT Repo_Reqs.0 AND NOT Load_Complete);



(*------------------------------------------- Repositions --------------------------------------*)

	(*Reposition Request#1*)
	(*Drop Off repo*)
	IF (MAIN.R4.Peripheral_Req.0 AND (MAIN.R4.Task_ID_Ack=Dropoff_Fix102))
		THEN
			Repo_Reqs.0:= TRUE;
	END_IF;

	(*Reposition Request#2*)
	(*Inspection repo*)
	IF (MAIN.R4.Peripheral_Req.1 AND (MAIN.R4.Task_ID_Ack=weld_Fix102))
		THEN
			Repo_Reqs.1:= TRUE;
	END_IF;

	(*Reposition Request#3*)
	(*Pick Up repo*)
	IF (MAIN.R4.Peripheral_Req.2 AND (MAIN.R4.Task_ID_Ack=Pickup_Fix102))
		THEN
			Repo_Reqs.2:= TRUE;
	END_IF;

	(*Reposition Request#4*)
	IF FALSE
		THEN
			Repo_Reqs.3:= TRUE;
	END_IF;

	(*Reposition Request#5*)
	IF FALSE
		THEN
			Repo_Reqs.4:= TRUE;
	END_IF;

	(*Reposition Request#6*)
	IF FALSE
		THEN
			Repo_Reqs.5:= TRUE;
	END_IF;

	(*Reposition Request#7*)
	IF FALSE
		THEN
			Repo_Reqs.6:= TRUE;
	END_IF;

	(*Reposition Request#8*)
	IF FALSE
		THEN
			Repo_Reqs.7:= TRUE;
	END_IF;

	(*Reset All Reposition Acks At the End Of Cycle*)
	IF Cycle_Complete
		THEN
			Repo_Reqs:= 0;
	END_IF;

(*------------------------- Reposition Acks ---------------------*)
	Repo_Ack.0:= Repo_Reqs.0 AND Tool_At_Load.0;   (*Drop Off*)
	Repo_Ack.1:= Repo_Reqs.1 AND FALSE;            (*Inspection*)
	Repo_Ack.2:= Repo_Reqs.2 AND Tool_At_Unload.1; (*Pick Up*)
	Repo_Ack.3:= Repo_Reqs.3 AND FALSE;
	Repo_Ack.4:= Repo_Reqs.4 AND FALSE;
	Repo_Ack.5:= Repo_Reqs.5 AND FALSE;
	Repo_Ack.6:= Repo_Reqs.6 AND FALSE;
	Repo_Ack.7:= Repo_Reqs.7 AND FALSE;























]]></ST>
      </Implementation>
    </Action>
    <Action Name="ValveBank1" Id="{b5935c8f-89fa-410e-971f-0f3b43e0d7b8}">
      <Implementation>
        <ST><![CDATA[

(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)
(*+++++++++++THIS AREA IS CUSTOM PER INSTALLATION AND WILL HAVE TO BE MODIFIED PER +++++++++++++*)

(*+++++++++++VALVE BANK 1 +++++++++++++*)
(*+++++++++++VALVE BANK 1 +++++++++++++*)
(*+++++++++++VALVE BANK 1 +++++++++++++*)


	(*Valve 1, A+B*)
	// NOW Pin 1,2 Piped and Labled From Supplier (*TLK*)
		Valve1FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.1S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND All_Robots_Clear,
			In_Manual_SideA_Command:= Discrete_In.ManReqs.0,
			In_Manual_SideB_Command:= (Discrete_In.ManReqs.1 OR Discrete_In.Go_Home),
			SideA_Indicator:= (Pin1ADVD AND Pin2ADVD) OR Manual_Ind_HomePrompt,
			SideB_Indicator:= (Pin1RETD AND Pin2RETD),
			TurnOn_SideA_SOL=> N100.Q.0,
			TurnOn_SideB_SOL=> N100.Q.1,
			TurnOn_SideA_Indicator=> Manual_Indicators1.0,
			TurnOn_SideB_Indicator=> Manual_Indicators1.1
			 );
		Valve1FB.In_Auto_SideA_Command:= (*Clamp_Step.1 AND NOT Unclamp_Step.1;*) Clamp_Step.0 AND NOT Unclamp_Step.0;
		Valve1FB.In_Auto_SideB_Command:= (*NOT Clamp_Step.1 AND Unclamp_Step.1;*) NOT Clamp_Step.0 AND Unclamp_Step.0;


	(*Valve 2, A+B*)
	// NOW Clamp 1,2,3,4 Piped and Labled From Supplier (*TLK*)
		Valve2FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= TRUE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.10S,
			Enable_Auto_Commands:= In_Auto,
			Enable_Manual_Commands:= In_Manual AND All_Robots_Clear,
			In_Manual_SideA_Command:= (Discrete_In.ManReqs.2 OR Discrete_In.Go_Home),
			In_Manual_SideB_Command:= Discrete_In.ManReqs.3,		
			SideA_Indicator:= (Clamp1ADVD AND Clamp2ADVD AND Clamp3ADVD AND Clamp4ADVD),
			SideB_Indicator:= (Clamp1RETD AND Clamp2RETD AND Clamp3RETD AND Clamp4RETD) OR Manual_Ind_HomePrompt,
			TurnOn_SideA_SOL=> N100.Q.2,
			TurnOn_SideB_SOL=> N100.Q.3,
			TurnOn_SideA_Indicator=> Manual_Indicators1.2,
			TurnOn_SideB_Indicator=> Manual_Indicators1.3
			 );
		Valve2FB.In_Auto_SideA_Command:= (*Clamp_Step.0 AND NOT Unclamp_Step.0;*) Clamp_Step.1 AND NOT Unclamp_Step.1;
		Valve2FB.In_Auto_SideB_Command:= (*NOT Clamp_Step.0 AND Unclamp_Step.0;*) NOT Clamp_Step.1 AND Unclamp_Step.1;


		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
	(*Valve 3, A+B*)
