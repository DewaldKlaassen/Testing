		Purge_CompleteTrigger1: TON;

		DiscreteNode_OK: BOOL;
		Profinode_OK: BOOL;

		Faulted: BOOL;

		(*Status Information regarding Graco System*)




	END_VAR

	VAR_OUTPUT
		(*Output Data to External*)
		FB_OK: BOOL;

		Dispense_Amount: UINT;
		Disp1_Bypass: BOOL;
		Disp1_Faulted: BOOL;
		Disp1_Ready: BOOL;
		Disp1_Volume_NotOK: BOOL;
		Disp1_Bypass_Ack: BOOL;


		(*Pump - Ouputs*)
		Pump1_Sys_Data_Exchange_CMD: UINT;

		Pump1_Sys_Enable: BOOL;
		Pump1_Sys_Disable_REQ: BOOL;
		Pump1_Lockout: BOOL;
		Pump1_Style_Enable: BOOL;
		Pump1_Go: BOOL;
		Pump1_Disp_Complete: BOOL;
		Pump1_Tandem_Cross_REQ: BOOL;
		Pump2_Prime_Inactive_Pump_REQ: BOOL;

		Pump1_Valve_Depressurization_REQ: BOOL;
		Pump1_Platen_Depressurization_REQ: BOOL;
		Pump1_Auto_Depressurization_Cancel_REQ: BOOL;
		Pump_Acknowledge_Clear_Errors: BOOL; (*both pumps*)
		(*Reserved Bit 1*)
		(*Reserved Bit 2*)
		(*Reserved Bit 3*)
		(*Reserved Bit 4*)

		Pump1_Desired_Style_Numb: UINT;
		Pump1_Style_PreCharge_REQ: UINT;	(*xxx.x bars*)
		Pump1_FlowRate_REQ: UINT;			(*xxxx cc/min*)
		Pump1_ShotSize_REQ: UINT;			(*xxx.xx cc*)
		Pump2_PrimePressure_Target: UINT;	(*xxx.x bars*)
		Pump2_PrimeFlow_Target: UINT;			(*xxxx cc/min*)

		Heat1_HeatEnabled_REQ: BOOL;
		Heat1_HeatDissabled_REQ: BOOL;
		Heat1_PLC_Lockout: BOOL;
		Heat1_Heat_ON_REQ: BOOL;
		Heat1_Heat_OFF_REQ: BOOL;
		Heat1_Setback_REQ: BOOL;
		Heat1_Acknowledge_Clear_Errors: BOOL;
		(*Reserved Bit 1*)

		(*Reserved Bit 2*)
		(*Reserved Bit 3*)
		(*Reserved Bit 4*)
		(*Reserved Bit 5*)
		(*Reserved Bit 6*)
		(*Reserved Bit 7*)
		(*Reserved Bit 8*)

		Heat1_Data_Exchange_CMD: UINT;
		Heat1_Data_Exchange_CMD_Value: UDINT;

		Heat2_HeatEnabled_REQ: BOOL;
		Heat2_HeatDissabled_REQ: BOOL;
		Heat2_PLC_Lockout: BOOL;
		Heat2_Heat_ON_REQ: BOOL;
		Heat2_Heat_OFF_REQ: BOOL;
		Heat2_Setback_REQ: BOOL;
		Heat2_Acknowledge_Clear_Errors: BOOL;
		(*Reserved Bit 1*)

		(*Reserved Bit 2*)
		(*Reserved Bit 3*)
		(*Reserved Bit 4*)
		(*Reserved Bit 5*)
		(*Reserved Bit 6*)
		(*Reserved Bit 7*)
		(*Reserved Bit 8*)

		Heat2_Data_Exchange_CMD: UINT;
		Heat2_Data_Exchange_CMD_Value: UDINT;



