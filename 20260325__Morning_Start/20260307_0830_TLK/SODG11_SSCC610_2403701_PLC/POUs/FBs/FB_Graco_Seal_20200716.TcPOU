    <Declaration><![CDATA[(*Function block created for Graco Sealer*)
(*July 31 2014*)
(*Rev1 - JVD initial creation*)
(*
------------------------------------------------------------------------------------------
	REVISION NOTES:
	Version 20141017:
	- Added Error_Reset and Dry_Cycle FB Inputs to remove dependancies on external variable, b.lekx-toniolo
	Version 20141127:
	- Added ability to map Internal or External EL6731 Proibus Master, b.lekx-toniolo
	Version 20141209
	- General Structure Clean-up, b.lekx-toniolo
	Version 20160302
	- Added purge function, JVD
	- Added Enable_Motion, JVD
	-Added All_SafetiesOK, JVD
	-Added Faulted to the reset bit, JVD
	Version 20160405
	- added Disp1_No_Error to Faulted, JVD
	-added ProfiNode_OK to Fault, JVD
	Version 20160412
	- re-mapped purge to style select 15 at request of Graco for better table updates, blt
	Version 20161202
	-develop code for up to 4 dispense heads, j.vandongen
	-added capture for sealant/volume Ok, j.vandongen
	Version 20170227
	-fixed copy/paste typos, jvandongen
	Version 20171201
	- fixed option gun count comparissons in the code, j.vandongen
	Version 20200716
	- changed from PCF to iQ controls (new GSD map), j.vandongen

------------------------------------------------------------------------------------------
*)
FUNCTION_BLOCK FB_Graco_Seal_20200716

	VAR_INPUT
		External_Terminal_Enable: BOOL; (* Set Bit Low if you will be using the Internal Profibus Master Terminal Instance, set High to Pass Profibus Master Data from External*)
