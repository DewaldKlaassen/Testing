]]></Declaration>
    <Implementation>
      <ST><![CDATA[


	(*Set FB_OK to True*)
	FB_OK:= TRUE;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	IF NOT External_Terminal_Enable
		THEN (*Internally mapped Profimaster is selected*)
			(*Discrete I/O Node (EL6731 Internal MASTER)*)
			IF Txx_Internal_ProfiMaster.InfoData.State=8
				THEN
				DiscreteNode_OK:=TRUE;
			ELSE
				DiscreteNode_OK:=FALSE;
			END_IF
	END_IF

	IF External_Terminal_Enable
		THEN (*Externally mapped ProfiMaster is selected*)
			(*Discrete I/O Node (EL6731 Internal MASTER)*)
			IF Txx_External_ProfiMaster.InfoData.State=8
				THEN
					DiscreteNode_OK:=TRUE;
			ELSE
					DiscreteNode_OK:=FALSE;
			END_IF
	END_IF

	(*Profibus Node*)
	IF GracoSealer_Inputs.Inputs.DpState=0
		THEN
			ProfiNode_OK:=TRUE;
	ELSE
			ProfiNode_OK:=FALSE;
	END_IF


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Safety Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather Inputs  $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

(*Graco Sealer Input Bits*)
	Inputs();



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)





(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Transfer Standard Outputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Output for Dispense Head Amount*)
	Dispense_Amount:= 1;

	(*Bypass Acks*)
	Disp1_Bypass_Ack:= Disp1_Bypass;

	Outputs();























(*end*)]]></ST>
    </Implementation>
