<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_GTAC_Kuka_CUSTOM" Id="{5d8e71c6-1a66-4e71-8c6b-7b83bf2e77b5}" SpecialFunc="None">
    <Declaration><![CDATA[///FB for use with KUKA, KRC4 Series Robot Controller Using Ethercat I/O Interface and SafeOperation:
///	Original Author(s): Brent Lekx-Toniolo of Sodecia GTAC; 
///------------------------------------------------------------------------------------------
///REVISION NOTES:
///	Date: July 2013
///	- Fix Service Job Status Banner to Include >250 TaskIDAcks: b.lekx-toniolo
///	Date: July 2014:
///	- Add Kuka Mig Type Robot: Rob Remillard
///	Version 20141016:
///	- Small updates for Weld Contoller Fault Abstraction and map Robot S-Axis Position: b.lekx-toniolo, JVD
///	Version 20141202:
///	- added turn table type robots for Weld controller Mapping: JVD
/// 	- added turn table type robot to the Kuka type declation: JVD
///	Version 20141209:
///	- added turntable position index code, b.lekx-toniolo
///	- corrected Robot to Robot Inerfs based on bug found by JVD, b.lekx-toniolo
///	Version 20141216:
///	- added HOME and HOME5: JVD
///	- changed mapping for in Auto/T1/T2 and Homes: JVD
///	- Increased Task ID Area from 8 bits to 16 bits, b.lekx-toniolo JVD
///	Version 20150103:
///	- changed servos on for krc4_safeop_turntable type robots. RR/JVD
///	-changed instance of udt call. RR/JVD
///	Version 20150109:
///	- changed Turntable indexed positions, removed Home4, Home5 RR/JVD
///	 -Error in code for task_id for WCU#1 and WCU#2  for tip change. was 255, changed to 355 and added task_id_ack = 354 JVD
///	Version 20150120:
///	- Added "previous ecat node ok" input for more accurate display of cable breaks, b.lekx-toniolo
///	Version 20150128:
///	- Added code for "teach Interlock" status message, b.lekx-toniolo
///	Version 20150203:
///	- Added ATI FB
///	- Added user, direct access inputs
///	- Added Peri Req requests off to Proceed, r.remillard
///	Version 20150227:
///	- Added Steppers Approaching max to WCU inputs, JVD
///	- Changed Out_To_ECAT.Robot_IN[16] to use NOT FB_In.Under_Construction, JVD
///	Version 20150318:
///	- Added FB_Inputs to allow force brake and master test reqs, blt
///	Version 20150512:
///	- changed Out_To_ECAT.Robot_IN[88] to FB_In.Under_Construction, JVD
///	Version 20150616
///	-added cycle time counter, JVD
///	Version 20150622
///	-wrapped up CTs into a udt for easier data handling, blt
///	Version 20150928:
///	- Added CoE reads to gather EL6900 temperatue data, b.lekx-toniolo
///	Version 20151029:
///	- Changes for Kuka KRC4 FSoE safety interface, this FB will be for FSoE only, b.lekx-toniolo
///	Version 20151215:
///	- Re did "Servos Not on" messages and added "waiting for Task Complete Ack" message, b.lekx-toniolo
///	Version 20160127
///	- Internalized Water Stand FB and code to commonize functionality with EOAT and ATI concepts, b.lekx-toniolo
///	- Added Configuration Variables for optional addins, b.lekx-toniolo
///	- Changed code for TQM vs Collision Detect, b.lekx-toniolo
///	Version 20160601
///	-Added KUKA_KRC4c_SafeOP_Agilus Type, b.lekx-toniolo
///	Version20160808
///	- Finalized TQM code, b.lekx-toniolo, r.remillard, j. vandongen
///	Version20160921
///	- Added In_Welding, b.lekx-toniolo, r.remillard, j. vandongen
///	Version20161027
///	- Added not At_Home interlock to Pounce Proceed, b.lekx-toniolo
///	Version20161122
///	- Changed the Proceed from Pounce for the cell services, j.bysma
///	Version 20161202
///	-added IN[161-168] and OUT[161-168] as additional Aux Request bits, j.vandongen 
///	-changed Under_Contrustion to Weld_Inhibit to bypass water faults. j.vandongen
///	Version 20170306
///	- added WCU#3 and WCU#4 mapping, moved Fronius mapping. r.remillard
///	- added cycle time totals for robot, j.vandongen
///	Version 20170412
///	- fixed problem with servos on request due to new safe space setup. r.remillard
///	Version 20170525
///	- corrected issue with general Weld FLT bit being masked by fronius welder error status, b.lekx-toniolo
///	Version 20170531
///	- added mig count to options, b.lekx-toniolo
///	- changed fronius status to udt type def, b.lekx-toniolo
///	- Changes for switch from Fronius CMT to TPSi, b.lekx-toniolo 
///	Version 20170620
///	- added User outs, j.vandongen
///	- changed EOAT req to 16 bits, j.vandongen
///	Version 20170704
///	- changed EOAT calls, j.vandongen
///	Version 20170801
///	- changed WS declaration to use new water stand FB, j.vandongen
///	- added option to dissable water faults instead of under_construction, j.vandongen
///	Version 20171025
///	- changed mapping of TQM, j,vandongen
///	- added mapping for Program Number selection from robot, j.vandongen         
///	Version 20171113
///	 - changed cooling out to WTC to prevent robot running without water, j.vandongen
///	Version 20180405
///	- changed mapping of reamer FB, j.vandongen
///	Version 20180417
///	- moved under_construction mapping from IN[88[ to IN[14], j.vandongen
///	- removed IN[98] and IN[99], part in EOAT bits, handled external from robot, j.vandongen
///	Version 20181004
///	- WCU#2 missing contact saver input. , j.vandongen
///	Version 20910903
///	- changed water stand instance, j.vandongen
///	- added clear to unclamp to In[97], j.vandongen
///	- added Inputs and Outputs actions, j.vandongen
///	Version 20190923
///	- added EOAT_FLT status, j.vandongen
///	Version 20200109
///	- changed WTC NO_Fault bit due to issue inside WoV signal mapping, j.vandongen
///	Version 20200512
///	- added Clear_To_Unclamp to status 36, j.vandongen
///	Version 20200710
///	- changed WS to new type, j.vandongen
///	Version 20210510
///	-Readded Mig Welding code that had been missed in previous revisions. - C.drees
///		-Added Fronius Status Bits and mapping to Robot Outputs
///		-Corrected code for Weld Controller Faults
/// Version 20210517
///		-Consdensed WCU Tip Change Requests
///		-Condensed WCU Stepper Reset
/// Version 20220623
///		- Updated WS instances, b.lekx-toniolo
/// Version 20240208 (R&D project 90034, Sim Integration)
///		- Added OPC attributes as required for OPC server interface development, b.lekx-toniolo
///		- Updated FB_In to pass In_Sim_Mode and SIM_StartWorkAround for use in this FB, b.lekx-toniolo
///		- Correct some minor typos etc to do with Disable water fault (FB Input), b.lekx-toniolo
/// Version 20240620 (TraccTCP Addition)
///		- Added TraccTCP developed and tested by Wes Griffiths on project 2302901, b.lekx-toniolo
///		- Blank EOAT ID fault when 0 EOATs selected (nuisance fault in SIM), w.griffiths
///------------------------------------------------------------------------------------------
{attribute 'contains_implicit_enum'}
FUNCTION_BLOCK FB_GTAC_Kuka_CUSTOM
VAR_INPUT
	Enable_FB: BOOL;
	///Inputs to FB
	FB_In: udt_Generic_Robot_FBIN_CUSTOM;
END_VAR
VAR
	
	///Ecat Bus Coupler
	T01 AT %I*: udt_EK1100;
	///EL Safety CPU
	T02_STAT AT %I*: udt_EL6900_STAT_20160426;
	T02_CMD AT %Q*: udt_EL6900_CMD_20121204;
	///EL Safety Inputs
	T03 AT %I*: udt_EL1904_v2;
	///EK Junction Terminal
	T04 AT %I*: udt_EK1122;
	///reserved spot for second EK1100 in Robot controller
	RT01: udt_EK1100;
	///Ecat Bridge, specific to Kuka KRC4 FSoE
	RT02 AT %I*: udt_EL6695_20151028;
	///Develop EtherCAT Interface
	In_From_HW AT %I*: udt_GenericRobot_AnyFieldbus_InputBytes_20220421;
	{attribute 'OPC.UA.DA':='1'}
	In_From_ECAT: udt_EtherCAT_Kuka_InputBits_20121204;
	Out_To_HW AT %Q*: udt_GenericRobot_AnyFieldbus_OutputBytes_20220421;
	{attribute 'OPC.UA.DA':='1'}
	Out_To_ECAT: udt_EtherCAT_Kuka_OutputBits_20121204;

	/// Nodes/Interface States
	DiscreteNode_OK: BOOL;
	EtherCATNode_OK: BOOL;
	EtherCATConn_OK: BOOL;
	///Cable Break Warning Flags
	ECatSlave_Cable_Breaks: UDINT;
	///Coupler is Not Present on Bus when expected
	EK1100_NotPresent: BOOL;
	///Port C of EK1100 is OUT
	EK1100_PortC_MissingLink: BOOL;
	///Port D of EK1122 is X1
	EK1122_PortD_MissingLink: BOOL;
	///Port B of EK1122 is X2
	EK1122_PortB_MissingLink: BOOL;
	///Bridge Terminal is not on Bus when expected
	EL6695_NotPresent: BOOL;
	///Port C of EL6695 is OUT
	EL6695_PortC_MissingLink: BOOL;
	///FB to retrieve Data from terminals via CoE
	CoE_ReadFB_1: FB_EcCoESdoReadEx;
	///Variable, 8 bytes, for receiving data
	CoE_ReadBuffer_1: ARRAY[0..7] OF BYTE;
	///CoE Read Error Flag
	CoE_ReadErr_1: BOOL;
	///CoE Read Error Identification
	CoE_ReadErrID_1: UDINT;
	///Flag for result of CoE Read
	EL6900_Overtemperature: BOOL;
	///FB for control of MIG Tip Reamer
	Reamer: ARRAY[1..2] OF (*FB_GTAC_Reamer_20180405*) FB_GTAC_Reamer_20230328;
	///FB for Control of ATI Tool Changer attached to the robot
	ATI: ARRAY[1..2] OF FB_ATI_Changer_20151105;
	///FB for Robot Water Temperature and Flow
	WS: ARRAY[1..2] OF FB_GTAC_WaterStand_20220622;
	///Robot Teach Pendant Estop Button OK, See Rxx Print Package, Page P03
	PendEstop_Ok: BOOL;
	///Robot Controller Estop Estop Button OK, See Rxx Print Package, Page P03
	ContEstop_Ok: BOOL;
	///Robot Peripherals are Read
	Safety_PeriReady: BOOL;
	///SafeOperation Configuration is Active
	SafeOP_Active: BOOL;
	///Robot Estop Relays Are On, See Rxx Print Package, Page P05 and P08 
	Estop_Relays_On: BOOL;
	///Robot Estop Relays Are Off
	Estop_Relays_Off: BOOL;
	///Robot Safety Gate Relays Are On, See Rxx Print Package, Page P05 and P08
	SafetyGate_Relays_On: BOOL;
	///Robot Safety Gate Relays Are Off
	SafetyGate_Relays_Off: BOOL;
	///Robot EOAT Relays Are On, See Rxx Print Package, Page P05 and P09
	EOAT_Relays_On: BOOL;
	///Robot EOAT Relays Are Off
	EOAT_Relays_Off: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#1
	Zone1_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#1
	Zone1_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#2
	Zone2_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#2
	Zone2_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#3
	Zone3_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#3
	Zone3_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#4
	Zone4_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#4
	Zone4_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#5
	Zone5_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#5
	Zone5_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#6
	Zone6_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#6
	Zone6_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#7
	Zone7_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#7
	Zone7_Detected_NotClear: BOOL;
	///Hardware Detects that Robot is Clear of Human Interf#8
	Zone8_Detected_Clear: BOOL;
	///Hardware Detects that Robot is In Human Interf#8
	Zone8_Detected_NotClear: BOOL;
	///Standard Internals
	///System Inputs From Robot System Outputs
	Operating: BOOL;
	Servos_Are_On: BOOL;
	Faulted: BOOL;
	Battery_Alarm: BOOL;
	In_AutoExt: BOOL;
	In_Auto: BOOL;
	In_T1: BOOL;
	In_T2: BOOL;
	In_Teach: BOOL;
	In_Home: BOOL;
	In_Home1: BOOL;
	In_Home2: BOOL;
	In_Home3: BOOL;
	In_Home4: BOOL;
	In_Home5: BOOL;
	Collision_Detect_Valid: BOOL;
	TQM_Valid: BOOL;
	Holding: BOOL;
	Ream_Reqd: BOOL;
	TraccTCP_Reqd: BOOL;
	Master_Test_Reqd: BOOL;
	Brake_Test_Reqd: BOOL;
	Brake_Test_Reqd_Internal_Robot: BOOL;
	///Tip Dresser Variables
	Tip_DressOn_Req: BOOL;
	Tip_DressReq_ToSafety AT %Q*: BOOL;
	Tip_DressOn_Ack: BOOL;
	Tip_Dress_Reqd: BOOL;
	///Standard Inputs From Robot Standard Outputs
	Clear_Of_EquipInterf1: BOOL;
	Clear_Of_EquipInterf2: BOOL;
	Clear_Of_EquipInterf3: BOOL;
	Clear_Of_EquipInterf4: BOOL;
	Clear_Of_EquipInterf5: BOOL;
	Clear_Of_EquipInterf6: BOOL;
	Clear_Of_EquipInterf7: BOOL;
	Clear_Of_EquipInterf8: BOOL;
	Clear_Of_EquipInterf9: BOOL;
	Clear_Of_HumanInterf1: BOOL;
	Clear_Of_HumanInterf2: BOOL;
	Clear_Of_HumanInterf3: BOOL;
	Clear_Of_HumanInterf4: BOOL;
	Clear_Of_HumanInterf5: BOOL;
	Clear_Of_HumanInterf6: BOOL;
	Clear_Of_HumanInterf7: BOOL;
	Clear_Of_HumanInterf8: BOOL;
	S_Axis_Pos_Raw: INT;
	S_Axis_Pos_Indexed: UINT;
	External_Axis_Pos_Raw: INT;
	
	///Turntable Position Index
	TT_Axis_Location_Index: UINT;
	TT_SideA_AtRobot: BOOL;
	TT_SideB_AtRobot: BOOL;
	EOAT_ID_Ack: UINT;
	Fix_ID_Ack: UINT;
	Model_ID_Ack: UINT;
	User_Outputs: UINT;
	Task_ID_Ack: UINT;
	Peripheral_Req: UINT;
	Aux_Req: UINT;
	Program_No_Req: UINT;
	At_Pounce: BOOL;
	///LHPart_In_EOAT: BOOL; de bug
	///		RHPart_In_EOAT: BOOL;
	///		Part_In_EOAT: BOOL;
	Clear_To_Unclamp: BOOL;
	Task_Completed: BOOL;
	Clear_Of_RobotInterfs: UINT;
	EOAT_Req: UINT;
	///WCU#1 Inputs
	WCU1_NoFaults: BOOL;
	WCU1_SteppersAreReset: BOOL;
	WCU1_SteppersApprMax: BOOL;
	WCU1_TipChgReqd_1: BOOL;
	WCU1_StepperAtMax_1: BOOL;
	WCU1_TipChgReqd_2: BOOL;
	WCU1_StepperAtMax_2: BOOL;
	WCU1_DressReqd_1: BOOL;
	WCU1_DressReqd_2: BOOL;
	WCU1_Weld_Init: BOOL;
	WCU1_Weld_InProgress: BOOL;
	WCU1_Weld_Complete: BOOL;
	WCU1_AnyTipChangeRqst:BOOL;
	///WCU#2 Inputs
	WCU2_NoFaults: BOOL;
	WCU2_SteppersAreReset: BOOL;
	WCU2_SteppersApprMax: BOOL;
	WCU2_TipChgReqd_1: BOOL;
	WCU2_StepperAtMax_1: BOOL;
	WCU2_TipChgReqd_2: BOOL;
	WCU2_StepperAtMax_2: BOOL;
	WCU2_DressReqd_1: BOOL;
	WCU2_DressReqd_2: BOOL;
	WCU2_Weld_Init: BOOL;
	WCU2_Weld_InProgress: BOOL;
	WCU2_Weld_Complete: BOOL;
	WCU2_AnyTipChangeRqst:BOOL;
	///WCU#3 Inputs
	WCU3_NoFaults: BOOL;
	WCU3_SteppersAreReset: BOOL;
	WCU3_SteppersApprMax: BOOL;
	WCU3_TipChgReqd_1: BOOL;
	WCU3_StepperAtMax_1: BOOL;
	WCU3_TipChgReqd_2: BOOL;
	WCU3_StepperAtMax_2: BOOL;
	WCU3_DressReqd_1: BOOL;
	WCU3_DressReqd_2: BOOL;
	WCU3_Weld_Init: BOOL;
	WCU3_Weld_InProgress: BOOL;
	WCU3_Weld_Complete: BOOL;
	WCU3_AnyTipChangeRqst:BOOL;
	///WCU#4 Inputs
	WCU4_NoFaults: BOOL;
	WCU4_SteppersAreReset: BOOL;
	WCU4_SteppersApprMax: BOOL;
	WCU4_TipChgReqd_1: BOOL;
	WCU4_StepperAtMax_1: BOOL;
	WCU4_TipChgReqd_2: BOOL;
	WCU4_StepperAtMax_2: BOOL;
	WCU4_DressReqd_1: BOOL;
	WCU4_DressReqd_2: BOOL;
	WCU4_Weld_Init: BOOL;
	WCU4_Weld_InProgress: BOOL;
	WCU4_Weld_Complete: BOOL;
	WCU4_AnyTipChangeRqst:BOOL;
	All_WCUSteppers_Reset :BOOL;
	Any_WCU_TipChng_Rqst:BOOL;
	///Fronius Mig Weld Controller
	Fronius_ErrorImage: UINT;
	Fronius_ProcessActive: BOOL;
	Fronius_Mig_HotKey: BOOL;
	Fronius_TorchCollision: BOOL;
	Fronius_PowerSourceReady: BOOL;
	Fronius_IgnitionError: BOOL;
	///Weld Controller Common
	In_Welding: BOOL;
	///The So Called Location Index is used to index Information To and From the Robot Based on its Working Location
	Location_Index: UINT;
	///Robot is At one of it's designated home position
	At_Home: BOOL;
	At_EquipInterf1: BOOL;
	At_EquipInterf2: BOOL;
	At_EquipInterf3: BOOL;
	At_EquipInterf4: BOOL;
	At_EquipInterf5: BOOL;
	At_EquipInterf6: BOOL;
	At_EquipInterf7: BOOL;
	At_EquipInterf8: BOOL;
	At_EquipInterf9: BOOL;
	At_HumanInterf1: BOOL;
	At_HumanInterf2: BOOL;
	At_HumanInterf3: BOOL;
	At_HumanInterf4: BOOL;
	At_HumanInterf5: BOOL;
	At_HumanInterf6: BOOL;
	At_HumanInterf7: BOOL;
	At_HumanInterf8: BOOL;
	///InterfsOK
	OK_At_EquipInterf1: BOOL;
	OK_At_EquipInterf2: BOOL;
	OK_At_EquipInterf3: BOOL;
	OK_At_EquipInterf4: BOOL;
	OK_At_EquipInterf5: BOOL;
	OK_At_EquipInterf6: BOOL;
	OK_At_EquipInterf7: BOOL;
	OK_At_EquipInterf8: BOOL;
	OK_At_EquipInterf9: BOOL;
	OK_At_EquipInterfALL: BOOL;
	OK_At_HumanInterf1: BOOL;
	OK_At_HumanInterf2: BOOL;
	OK_At_HumanInterf3: BOOL;
	OK_At_HumanInterf4: BOOL;
	OK_At_HumanInterf5: BOOL;
	OK_At_HumanInterf6: BOOL;
	OK_At_HumanInterf7: BOOL;
	OK_At_HumanInterf8: BOOL;
	OK_At_HumanInterfALL: BOOL;
	OK_At_RobotInterfs: UINT;
	OK_At_RobotInterfsALL: BOOL;
	/// Robot is Ready
	Ready: BOOL;
	///Robot has Ack'd proper Fix, EOAT, Model and Task ID
	ID_Acks_OK: BOOL;
	///All Interferences with Human and Equipment Zones OK
	All_Interfs_Ok: BOOL;
	///Request to Turn On Servos
	Servos_Req: BOOL;
	///Delay Servos On Request
	Servos_Req_Delay: TON;
	///Request to Turn Servos OFF
	Servos_Off_Req: BOOL;
	///Start Robot
	Start_Robot_Scan: BOOL;
	///Hold Robot
	Hold_Robot: BOOL;
	EOAT_ID: UINT;
	///Fault Flags
	Fix_ID_FLT: BOOL;
	Eoat_ID_FLT: BOOL;
	Model_ID_FLT: BOOL;
	Task_ID_FLT: BOOL;
	Ack_ID_FLT: BOOL;
	Ack_ID_TMR: TON;
	Comp_Ack_TMR: TON;
	TQM_NotValid_FLT: BOOL;
	Estop_RelayFLT: BOOL;
	SafetyGate_RelayFLT: BOOL;
	EOAT_RelayFLT: BOOL;
	WaterStand_FLT: BOOL;
	Weld_Controller_FLT: BOOL;
	EOAT_FLT: BOOL;
	ToolChanger_FLT: BOOL;
	///Local Always Off
	Stay_Off: BOOL := FALSE;
	{attribute 'implicit_enum_type' := ''}
		Kuka_Types:					(*Enumeration of Robot Types*)
		(
			KUKA_KRC2:= 51,
			KUKA_KRC4:=60,
			KUKA_KRC4_SafeOP:=61,
			KUKA_KRC4_SafeOP_Small:=62,
			KUKA_KRC4_SafeOP_ATI:=63,
			KUKA_KRC4c_SafeOP_Agilus:=64,
			KUKA_KRC4_SafeOP_TurnTable:=69
		);
	///Robot Is Auto Restart Type, for Internal Robots etc
	Robot_Is_AutoRestart: BOOL;
	///Generic Pulse Generator
	Pulse_2s_FB: FB_Pulse_Generator;
	Pulse_2s: BOOL;
	///Used for Robot Cycle time
	Cycle_TimeEquip1: TON;
	Cycle_Time_PulseEquip1: R_TRIG;
	Cycle_TimeEquip2: TON;
	Cycle_Time_PulseEquip2: R_TRIG;
	Cycle_TimeEquip3: TON;
	Cycle_Time_PulseEquip3: R_TRIG;
	Cycle_TimeEquip4: TON;
