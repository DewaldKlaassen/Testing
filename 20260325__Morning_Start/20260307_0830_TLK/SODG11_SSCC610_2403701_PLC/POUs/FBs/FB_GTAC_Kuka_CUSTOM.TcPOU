	(*IN_PLC : Smart Ray <-> Robot*)
	In_Rxx_From_SmartRay : udt_SmartRay_Out_To_Robot_IN_20260119;
	Out_Rxx_To_SmartRay: udt_Robot_Out_To_SmartRay_IN_20260119;	
	
	Temp1: BOOL;
	Temp2: BOOL;
	Temp3: BOOL;
	Temp4: BOOL;
	Temp5: BOOL;
	Temp6: BOOL;
	Temp7: BOOL;
	Temp8: BOOL;
	clear_To: BOOL;
END_VAR
VAR_OUTPUT
	FB_Ok: BOOL;
	Status: INT;
	Fronius_Status: udt_Fronius_Status_20170531;
	Fronius_Ready: BOOL;
	Input_Image: udt_GenericRobot_AnyFieldbus_InputBytes_20220421;
	Output_Image: udt_GenericRobot_AnyFieldbus_OutputBytes_20220421;
	Discrete_Image: udt_RobotDiscreteNode_ImageSSCCv46wSAFEOP_20131903;
	Discrete_Image_FSoE: udt_RobotDiscreteNode_ImageFSoE_20151028;
	CT: udt_GenericRobot_CycleTimes_20170304;
