	TT_at_DropOff_Pos: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(*Generic 2s Pulse generator*)
Pulse_2s_FB(On_Time:= T#2s, Off_Time:= T#2s, Wave=> Pulse_2s );



	(*Check Robot Type and Weld Controller count and set FB_OK to True if range is ok*)
	IF FB_In.Robot_Type>50 AND FB_In.Robot_Type<100 AND
		FB_In.Options.WeldCont_Amount >=0 AND FB_In.Options.WeldCont_Amount <=4 AND
		FB_In.Options.MIGCont_Amount >=0 AND FB_In.Options.MIGCont_Amount <=1 AND
		FB_In.Options.Reamer_Amount>=0 AND FB_In.Options.Reamer_Amount<=1 AND
		FB_In.Options.WaterStand_Amount>=0 AND FB_In.Options.WaterStand_Amount<=2 AND
		FB_In.Options.EOAT_Amount>=0 AND FB_In.Options.EOAT_Amount<=4
		THEN
		FB_OK:= TRUE;
	ELSE
		FB_OK:= FALSE;
	END_IF;

(*----------------- First Gather an Input Image in Generic Byte Type and convert TO Kuka Specific Type*)

IF FB_In.In_Sim_Mode (*Added during project 90034*)
	THEN
	(*If in Sim Mode, Robot INs[x] (In_From_ECAT) will be provided by Sim environment, therefore reflect back to In_From_HW for proper display on UI*)
	In_From_HW:= FUN_GTAC_GenericRobotInputImage_From_KUKAKRC4(In_From_ECAT);
ELSE
	(*Otherwise keep stock signal flow (In_From_HW -> In_From_ECAT) *)
	In_From_ECAT:= FUN_GTAC_GenericRobotInputImage_TO_KUKAKRC4(In_From_HW);

END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather Status Of Hardware $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*General Robot Node Status*)
(*FSoE Type*)
		(*Discrete I/O Node, FSoE Type*)
		IF T01.InfoData.State=8 AND T02_Stat.InfoData.State=8 AND T03.InfoData.State=8 AND T04.InfoData.State=8
			(*AND RT01.InfoData.State=8*) AND RT02.InfoData.State=8 (*Check of RT01 will depend on if we can pass state from Robot controller via EtherCAT*)
			THEN DiscreteNode_OK:=TRUE;
		ELSE DiscreteNode_OK:=FALSE;
		END_IF;

(*Develop Port Connection Warning Flags*)
	IF T01.InfoData.State=257 (*State Machine for Slave Not Present*)
		THEN EK1100_NotPresent:= TRUE;
	ELSE EK1100_NotPresent := FALSE;
	END_IF;

	IF T01.InfoData.State=17416 (*State Machine for Link Missing at Port C*)
		THEN EK1100_PortC_MissingLink:= TRUE; (*PortC is OUT Port*)
	ELSE EK1100_PortC_MissingLink := FALSE;
	END_IF;

	IF (T04.InfoData.State=-31736) (*State Machine for Link Missing at Port D (0xA8408)*)
		OR (T04.InfoData.State=-23544) (*State Machine for Link Missing at Port D and Port B (0xA408)*)
		THEN EK1122_PortD_MissingLink:= TRUE; (*Port D is X1 Port*)
	ELSE EK1122_PortD_MissingLink := FALSE;
	END_IF;

	IF (T04.InfoData.State= 9224) (*State Machine for Link Missing at Port B (0x2408)*)
		OR (T04.InfoData.State=-23544) (*State Machine for Link Missing at Port D and Port B (0xA408)*)
		THEN EK1122_PortB_MissingLink:= TRUE; (*Port B is X2 Port*)
	ELSE EK1122_PortB_MissingLink := FALSE;
	END_IF;

	IF RT02.InfoData.State= 257 (*State Machine for Slave Not Present*)
		THEN EL6695_NotPresent:= TRUE;
	ELSE EL6695_NotPresent := FALSE;
	END_IF;

	IF RT02.InfoData.State= 9224 (*State Machine for Link Missing at Port C*)
		THEN EL6695_PortC_MissingLink:= TRUE; (*PortC is OUT Port*)
	ELSE EL6695_PortC_MissingLink := FALSE;
	END_IF;

(*EtherCAT Bridge Terminal*)
		IF RT01.InfoData.State= 8 AND RT02.InfoData.State= 8					(*Slave in OP and External Device (Primary Master, KRC4) is Connected*)
			THEN EtherCATNode_OK:=TRUE;
		ELSE EtherCATNode_OK:=FALSE;
		END_IF;

		(*EtherCAT Connection From EK1100 to SYS- X-44*)
		IF RT01.InfoData.State= 8											(*External Device (Primary Master, KRC4) is Connected*)
			THEN EtherCATConn_OK:=TRUE;
		ELSE EtherCATConn_OK:=FALSE;
		END_IF;

	(*Wrap up break Flags to Variable for shipment to UI*)
	ECatSlave_Cable_Breaks.0:= EK1100_NotPresent AND FB_In.Prev_EcatNode_Present;
	ECatSlave_Cable_Breaks.1:= EK1100_PortC_MissingLink;
	ECatSlave_Cable_Breaks.16:=EK1122_PortD_MissingLink;
	ECatSlave_Cable_Breaks.17:=EK1122_PortB_MissingLink;
	ECatSlave_Cable_Breaks.18:= EL6695_NotPresent AND NOT EK1100_NotPresent;
	ECatSlave_Cable_Breaks.19:= EL6695_PortC_MissingLink;
	ECatSlave_Cable_Breaks.20:= NOT EtherCATConn_OK;

	(*------------ CoE Reads ------------*)

	(*Read EL6900 Primaray Temperature Data*)

	(*FB Inputs*)
	CoE_ReadFB_1.bExecute:= FB_In.CoE_Read_Trigger
							AND (T02_Stat.InfoData.State=8);						(*Execute Upon Trigger*)
	CoE_ReadFB_1.sNetId:= FB_In.Ecat_Master_AmsNetID;
	CoE_ReadFB_1.nSlaveAddr:= T02_STAT.InfoData.AdsAddr.port;						(*Address of Ecat Slave being Read*)
	CoE_ReadFB_1.nIndex:= 16#FA80;												(*CANopen SDO Index of Object (FA80 = Hardware Diag Object)*)
	CoE_ReadFB_1.nSubIndex:= 16#01;												(*CANopen SDO SubIndex (Location from Index) of Object (1 = Primary Temperature)*)
	CoE_ReadFB_1.cbBufLen:= 8;													(*Limit on Receive Length (bytes)*)
	CoE_ReadFB_1.pDstBuf:= ADR(CoE_ReadBuffer_1);								(*Pointer to Receive Buffer*)
	CoE_ReadFB_1.tTimeout:= T#2s;												(*TImeout for Read*)
	CoE_ReadFB_1.bCompleteAccess:= TRUE;										(*Allow Complete Access to Full SDO Object*)

	(*Execute FB*)
	CoE_ReadFB_1();

	(*FB Outputs*)
	CoE_ReadErr_1:= CoE_ReadFB_1.bError;										(*Error Flag of Read*)
	CoE_ReadErrID_1:= CoE_ReadFB_1.nErrId;										(*Error ID of Read (See ADS Return Codes)*)

	(*Tranfer Data to Image*)
	IF (T02_Stat.InfoData.State=8) AND NOT CoE_ReadErr_1
		THEN
		T02_STAT.CoE_Temperature_1:= FUN_GTAC_BYTEStoINT(CoE_ReadBuffer_1[0],CoE_ReadBuffer_1[1]);	(*Grab bytes 0 and 1 of read buffer, this is Primary Temperature*)
		T02_STAT.CoE_Temperature_2:= FUN_GTAC_BYTEStoINT(CoE_ReadBuffer_1[2],CoE_ReadBuffer_1[3]);	(*Grab bytes 2 and 3 of read buffer, this is Secondary Temperature*)
	ELSE
		(*If Read Error, then blank data*)
		T02_STAT.CoE_Temperature_1:=0;
		T02_STAT.CoE_Temperature_2:=0;
	END_IF;

	(*Finally Evaluate Temperature Vs Upper Limit Restrictions*)
	IF (T02_STAT.CoE_Temperature_1>=90) OR (T02_STAT.CoE_Temperature_2>=90)
		THEN
		EL6900_Overtemperature:= TRUE;
	ELSE
		EL6900_Overtemperature:= FALSE;
	END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Gather All Safety I/O $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

		(*Get Status of Estops*)
		PendEstop_OK:= RT02.FSOE_Inputs_Data_0.0;
		ContEstop_OK:= TRUE;

		(*Get Status of Safety Peripheral Ready Signal*)
		Safety_PeriReady:= RT02.FSOE_Inputs_Data_0.4;
		(*Get Status of SafeOP Active*)
		SafeOP_Active:= RT02.FSOE_Inputs_Data_1.0;

		Estop_Relays_On:= RT02.FSOE_Outputs_Data_0.1 AND RT02.FSOE_Outputs_Data_0.1;
		Estop_Relays_Off:= NOT Estop_Relays_On;
		SafetyGate_Relays_On:= RT02.FSOE_Outputs_Data_0.2;
		SafetyGate_Relays_Off:= NOT SafetyGate_Relays_On;
		EOAT_Relays_On:= FALSE;
		EOAT_Relays_Off:= FALSE;
		Tip_DressOn_Ack:= T03.I.3;

			(*Safety Zone Detected Clear Signals, Either done with Base Limit Switchs or SafeOP Alarm Space Notification*)
			Zone1_Detected_Clear:= RT02.FSOE_Inputs_Data_2.0;
			Zone1_Detected_NotClear:= NOT Zone1_Detected_Clear;
			Zone2_Detected_Clear:= RT02.FSOE_Inputs_Data_2.1;
			Zone2_Detected_NotClear:= NOT Zone2_Detected_Clear;
			Zone3_Detected_Clear:= RT02.FSOE_Inputs_Data_2.2;
			Zone3_Detected_NotClear:= NOT Zone3_Detected_Clear;
			Zone4_Detected_Clear:= RT02.FSOE_Inputs_Data_2.3;
			Zone4_Detected_NotClear:= NOT Zone4_Detected_Clear;
			Zone5_Detected_Clear:= RT02.FSOE_Inputs_Data_2.4;
			Zone5_Detected_NotClear:= NOT Zone5_Detected_Clear;
			Zone6_Detected_Clear:= RT02.FSOE_Inputs_Data_2.5;
			Zone6_Detected_NotClear:= NOT Zone6_Detected_Clear;
			Zone7_Detected_Clear:= RT02.FSOE_Inputs_Data_2.6;
			Zone7_Detected_NotClear:= NOT Zone7_Detected_Clear;
			Zone8_Detected_Clear:= RT02.FSOE_Inputs_Data_2.7;
			Zone8_Detected_NotClear:= NOT Zone8_Detected_Clear;

			IF (FB_In.Robot_Type = KUKA_KRC4_SafeOP_TurnTable)
				THEN
				(*TurnTable Indexed Postion (Turntable may or may not be used)*)
				TT_SideA_AtRobot:= T03.I.0 AND T03.I.1 AND NOT T03.I.2 AND NOT T03.I.3;
				TT_SideB_AtRobot:= NOT T03.I.0 AND NOT T03.I.1 AND T03.I.2 AND T03.I.3;
				TT_Axis_Location_Index.0:= TT_SideA_AtRobot AND NOT TT_SideB_AtRobot; (*Pos1*)		
				TT_Axis_Location_Index.1:=NOT TT_SideA_AtRobot AND TT_SideB_AtRobot; (*Pos2*)
			ELSE
				(*No turntable type, blank positional data*)
				TT_SideA_AtRobot:= FALSE;
				TT_SideB_AtRobot:= FALSE;
				TT_Axis_Location_Index.0:= TT_SideA_AtRobot AND NOT TT_SideB_AtRobot; (*Pos1*)		
				TT_Axis_Location_Index.1:=NOT TT_SideA_AtRobot AND TT_SideB_AtRobot; (*Pos2*)
			END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$Gather All Standard and System Inputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	Inputs();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Internal Code $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)

	(*Ensuring WCU Steppers are reset*)
	CASE Fb_in.Options.WeldCont_Amount OF
		0:	All_WCUSteppers_Reset:=TRUE;
		1:	All_WCUSteppers_Reset:=WCU1_SteppersAreReset;
		2:	All_WCUSteppers_Reset:=WCU1_SteppersAreReset AND WCU2_SteppersAreReset;
		3:	All_WCUSteppers_Reset:=WCU1_SteppersAreReset AND WCU2_SteppersAreReset AND WCU3_SteppersAreReset;
		4:	All_WCUSteppers_Reset:=WCU1_SteppersAreReset AND WCU2_SteppersAreReset AND WCU3_SteppersAreReset AND WCU4_SteppersAreReset;
	END_CASE

	(*Tip Change Logic*)
		WCU1_AnyTipChangeRqst := WCU1_SteppersApprMax OR WCU1_TipChgReqd_1 OR WCU1_TipChgReqd_2 OR WCU1_StepperAtMax_1  OR WCU1_StepperAtMax_2;
		WCU2_AnyTipChangeRqst := WCU2_SteppersApprMax OR WCU2_TipChgReqd_1 OR WCU2_TipChgReqd_2 OR WCU2_StepperAtMax_1  OR WCU2_StepperAtMax_2;
		WCU3_AnyTipChangeRqst := WCU3_SteppersApprMax OR WCU3_TipChgReqd_1 OR WCU3_TipChgReqd_2 OR WCU3_StepperAtMax_1  OR WCU3_StepperAtMax_2;
		WCU4_AnyTipChangeRqst := WCU4_SteppersApprMax OR WCU4_TipChgReqd_1 OR WCU4_TipChgReqd_2 OR WCU4_StepperAtMax_1  OR WCU4_StepperAtMax_2;

	CASE Fb_in.Options.WeldCont_Amount OF
		1:	Any_WCU_TipChng_Rqst:=WCU1_AnyTipChangeRqst;
		2:	Any_WCU_TipChng_Rqst:=WCU1_AnyTipChangeRqst OR WCU2_AnyTipChangeRqst;
		3:	Any_WCU_TipChng_Rqst:=WCU1_AnyTipChangeRqst OR WCU2_AnyTipChangeRqst OR WCU3_AnyTipChangeRqst;
		4:	Any_WCU_TipChng_Rqst:=WCU1_AnyTipChangeRqst OR WCU2_AnyTipChangeRqst OR WCU3_AnyTipChangeRqst OR WCU4_AnyTipChangeRqst;
	END_CASE
	
		

	(*Develop Location Index Number Based On Which Interference Location to Robot Is Working In*)
	IF FALSE
		THEN Location_Index:=0;
	ELSIF At_HumanInterf1
		THEN Location_Index:=1;
	ELSIF At_HumanInterf2
		THEN Location_Index:=2;
	ELSIF At_HumanInterf3
		THEN Location_Index:=3;
	ELSIF At_HumanInterf4
		THEN Location_Index:=4;
	ELSIF At_HumanInterf5
		THEN Location_Index:=5;
	ELSIF At_HumanInterf6
		THEN Location_Index:=6;
	ELSIF At_HumanInterf7
		THEN Location_Index:=7;
	ELSIF At_HumanInterf8
		THEN Location_Index:=8;
	ELSIF At_EquipInterf1
		THEN Location_Index:=9;
	ELSIF At_EquipInterf2
		THEN Location_Index:=10;
	ELSIF At_EquipInterf3
		THEN Location_Index:=11;
	ELSIF At_EquipInterf4
		THEN Location_Index:=12;
	ELSIF At_EquipInterf5
		THEN Location_Index:=13;
	ELSIF At_EquipInterf6
		THEN Location_Index:=14;
	ELSIF At_EquipInterf7
		THEN Location_Index:=15;
	ELSIF At_EquipInterf8
		THEN Location_Index:=16;
	ELSIF At_EquipInterf9
		THEN Location_Index:=17;
	ELSE
		Location_Index:=0;
	END_IF;

	(*Place Limits on Location Index as it will be used to access Arrays (Prevent Out of Bounds)*)
	IF Location_Index>16
		THEN Location_Index:=16;
	ELSIF Location_Index<0
		THEN Location_Index:=0;
	END_IF;


(*Robot At Home (Work Home or Intermediate Home)*)
	 At_Home := In_Home OR In_Home1 OR In_Home2 OR In_Home3 OR In_Home4 OR In_Home5;


	(*At Equipment Interference Zones*)
	At_EquipInterf1:= NOT Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf2:= Clear_Of_EquipInterf1 AND NOT Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf3:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND NOT Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf4:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND NOT Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf5:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND NOT Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf6:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND NOT Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf7:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND NOT Clear_Of_EquipInterf7 AND Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf8:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND NOT Clear_Of_EquipInterf8
					AND Clear_Of_EquipInterf9;
	At_EquipInterf9:= Clear_Of_EquipInterf1 AND Clear_Of_EquipInterf2 AND Clear_Of_EquipInterf3 AND Clear_Of_EquipInterf4
					AND Clear_Of_EquipInterf5 AND Clear_Of_EquipInterf6 AND Clear_Of_EquipInterf7 AND NOT Clear_Of_EquipInterf8
					AND NOT Clear_Of_EquipInterf9;

	(*At Human Interference Zones*)
	At_HumanInterf1:= NOT Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf2:= Clear_Of_HumanInterf1 AND NOT Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf3:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND NOT  Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf4:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND NOT Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf5:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND NOT Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf6:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND NOT Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf7:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND NOT Clear_Of_HumanInterf7 AND Clear_Of_HumanInterf8;
	At_HumanInterf8:= Clear_Of_HumanInterf1 AND Clear_Of_HumanInterf2 AND Clear_Of_HumanInterf3 AND Clear_Of_HumanInterf4
					AND Clear_Of_HumanInterf5 AND Clear_Of_HumanInterf6 AND Clear_Of_HumanInterf7 AND NOT Clear_Of_HumanInterf8;

	(*Check Interference Zones*)
	OK_At_EquipInterf1:= FB_In.OK_ToEnter_EquipInterf1 OR Clear_Of_EquipInterf1;
	OK_At_EquipInterf2:= FB_In.OK_ToEnter_EquipInterf2 OR Clear_Of_EquipInterf2;
	OK_At_EquipInterf3:= FB_In.OK_ToEnter_EquipInterf3 OR Clear_Of_EquipInterf3;
	OK_At_EquipInterf4:= FB_In.OK_ToEnter_EquipInterf4 OR Clear_Of_EquipInterf4;
	OK_At_EquipInterf5:= FB_In.OK_ToEnter_EquipInterf5 OR Clear_Of_EquipInterf5;
	OK_At_EquipInterf6:= FB_In.OK_ToEnter_EquipInterf6 OR Clear_Of_EquipInterf6;
	OK_At_EquipInterf7:= FB_In.OK_ToEnter_EquipInterf7 OR Clear_Of_EquipInterf7;
	OK_At_EquipInterf8:= FB_In.OK_ToEnter_EquipInterf8 OR Clear_Of_EquipInterf8;
	OK_At_EquipInterf9:= FB_In.OK_ToEnter_EquipInterf9 OR Clear_Of_EquipInterf9; //NEW
	OK_At_EquipInterfALL:= OK_At_EquipInterf1 AND OK_At_EquipInterf2 AND OK_At_EquipInterf3 AND OK_At_EquipInterf4
						 AND OK_At_EquipInterf5 AND OK_At_EquipInterf6 AND OK_At_EquipInterf7 AND OK_At_EquipInterf8 AND OK_At_EquipInterf9;

	OK_At_HumanInterf1:= FB_In.OK_ToEnter_HumanInterf1 OR Clear_Of_HumanInterf1;
	OK_At_HumanInterf2:= FB_In.OK_ToEnter_HumanInterf2 OR Clear_Of_HumanInterf2;
	OK_At_HumanInterf3:= FB_In.OK_ToEnter_HumanInterf3 OR Clear_Of_HumanInterf3;
	OK_At_HumanInterf4:= FB_In.OK_ToEnter_HumanInterf4 OR Clear_Of_HumanInterf4;
	OK_At_HumanInterf5:= FB_In.OK_ToEnter_HumanInterf5 OR Clear_Of_HumanInterf5;
	OK_At_HumanInterf6:= FB_In.OK_ToEnter_HumanInterf6 OR Clear_Of_HumanInterf6;
	OK_At_HumanInterf7:= FB_In.OK_ToEnter_HumanInterf7 OR Clear_Of_HumanInterf7;
	OK_At_HumanInterf8:= FB_In.OK_ToEnter_HumanInterf8 OR Clear_Of_HumanInterf8;
	OK_At_HumanInterfALL:= OK_At_HumanInterf1 AND OK_At_HumanInterf2 AND OK_At_HumanInterf3 AND OK_At_HumanInterf4
							AND OK_At_HumanInterf5 AND OK_At_HumanInterf6 AND OK_At_HumanInterf7 AND OK_At_HumanInterf8;

	OK_At_RobotInterfs.0:= FB_In.OK_ToEnter_RobotInterfs.0 OR Clear_Of_RobotInterfs.0;
	OK_At_RobotInterfs.1:= FB_In.OK_ToEnter_RobotInterfs.1 OR Clear_Of_RobotInterfs.1;
	OK_At_RobotInterfs.2:= FB_In.OK_ToEnter_RobotInterfs.2 OR Clear_Of_RobotInterfs.2;
	OK_At_RobotInterfs.3:= FB_In.OK_ToEnter_RobotInterfs.3 OR Clear_Of_RobotInterfs.3;
	OK_At_RobotInterfs.4:= FB_In.OK_ToEnter_RobotInterfs.4 OR Clear_Of_RobotInterfs.4;
	OK_At_RobotInterfs.5:= FB_In.OK_ToEnter_RobotInterfs.5 OR Clear_Of_RobotInterfs.5;
	OK_At_RobotInterfs.6:= FB_In.OK_ToEnter_RobotInterfs.6 OR Clear_Of_RobotInterfs.6;
	OK_At_RobotInterfs.7:= FB_In.OK_ToEnter_RobotInterfs.7 OR Clear_Of_RobotInterfs.7;
	OK_At_RobotInterfsALL:= (Ok_At_RobotInterfs = 255);

	(*All Interference Zones OK*)
	All_Interfs_OK:= At_Home OR (OK_At_EquipInterfALL AND OK_At_HumanInterfALL AND OK_At_RobotInterfsAll);


	(*Robot Acks Proper, FIX, EOAT, Model, and Task IDs *)
	Ack_ID_TMR.PT:=T#1.5S;
	Ack_ID_TMR();

	Fix_ID_Flt:= NOT At_Home AND Fix_ID_Ack<>FB_In.Fix_ID;
	EOAT_ID_Flt:= NOT At_Home AND FB_In.Options.EOAT_Amount <>0 AND (((FB_In.Robot_Type=Kuka_KRC4_SafeOP_ATI) AND EOAT_ID_Ack<>ATI[1].Tool_ID)
								OR ((FB_In.Robot_Type<>Kuka_KRC4_SafeOP_ATI)AND EOAT_ID_Ack<>1));
	Model_ID_FLT:= NOT At_Home AND Model_ID_Ack <> FB_In.Model_ID;
	Task_ID_Flt:= NOT At_Home AND Task_ID_Ack<350 AND (Task_ID_Ack<>FB_In.Task_ID OR Task_ID_Ack=0);

	(*If Fault Timer hasn't been triggered, ID Acks Are OK*)
	Ack_ID_TMR.IN:= Fix_ID_FLT OR EOAT_ID_FLT OR Model_ID_FLT OR Task_ID_FLT ;
	ID_Acks_OK:= NOT Ack_ID_TMR.Q;

	(*Robot Ready*)
	Ready:=Servos_Are_On AND In_AutoExt;

	(*Turn On Servo Motors*)
	Servos_Req_Delay.PT:=T#1.0s;
	Servos_Req_Delay();
	Servos_Req_Delay.IN:= Estop_Relays_On AND SafetyGate_Relays_On AND In_AutoExt AND NOT Servos_Are_On;
	Servos_Req:= Servos_Req_Delay.Q AND Pulse_2s;

	(*Turn Servo Motors Off*)
	IF NOT Estop_Relays_On
		THEN Servos_Off_Req:= TRUE;
	ELSE Servos_Off_Req:= FALSE;
	END_IF;

	(*Start Robot Scan*)
	IF (FB_In.Start_Scan OR Robot_Is_AutoRestart)
		AND NOT FB_In.Stop_Scan2
		AND (Estop_Relays_On AND SafetyGate_Relays_On AND All_Interfs_OK)
		AND (At_Home OR ID_Acks_OK AND Ready )
		THEN
			Start_Robot_Scan:=FB_In.Start_Scan;
	ELSE
			Start_Robot_Scan:=FALSE;
	END_IF;

	(*Hold Robot*)
	IF (Estop_Relays_On AND FB_IN.Enable_Motion AND FB_In.Teach_Interlock AND NOT FB_In.Stop_Scan AND NOT FB_In.Stop_Scan2)
		AND (In_Teach OR ((At_Home OR (Task_ID_Ack<>0 AND (Fix_ID_Ack<>0 OR Task_ID_Ack>350) AND ID_Acks_OK AND All_Interfs_OK))
		AND SafetyGate_Relays_On
		AND NOT WaterStand_FLT
		AND NOT FB_In.Major_Faults))
		THEN
			Hold_Robot:= FALSE;
	ELSE
			Hold_Robot:= TRUE;
	END_IF;

	(*Troubleshooting Code*)
	IF NOT Estop_Relays_On
		THEN Temp1:= TRUE;
	END_IF;
	IF NOT FB_In.Enable_Motion
		THEN Temp2:= TRUE;
	END_IF;
	IF FB_In.Stop_Scan
		THEN Temp3:= TRUE;
	END_IF;
	IF NOT At_Home
		THEN Temp4:= TRUE;
	END_IF;
	IF NOT ID_Acks_OK
		THEN Temp5:= TRUE;
	END_IF;
	IF NOT All_Interfs_OK
		THEN Temp6:= TRUE;
	END_IF;
	IF NOT SafetyGate_Relays_On
		THEN Temp7:= TRUE;
	END_IF;

	IF FB_In.Safety_RST
		THEN
			Temp1:= FALSE;
			Temp2:= FALSE;
			Temp3:= FALSE;
			Temp4:= FALSE;
			Temp5:= FALSE;
			Temp6:= FALSE;
			Temp7:= FALSE;
			Temp8:= FALSE;
	END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Status Banner $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Mesages 1 through 9 are reserved for legacy code*)
	(*Spare*)
	IF FALSE
		THEN Status:= 1;
	(*Spare*)
	ELSIF FALSE
		THEN Status:= 2;
	(*Spare*)
	ELSIF FALSE
		THEN Status:= 3;
	(*Spare*)
	ELSIF FALSE
		THEN Status:= 4;
	(*Robot Home and Ready*)
	ELSIF At_Home AND Operating AND NOT Faulted AND NOT Ack_ID_Flt AND Task_ID_Ack=0
		THEN Status:= 10;
	(*Robot Waiting For Start*)
	ELSIF  Ready AND NOT Operating AND NOT Faulted AND ID_Acks_OK
		THEN Status:= 11;
	(*Robot Servos Not On*)
	ELSIF NOT Ready AND NOT Servos_Are_On AND In_AutoExt
		THEN Status:= 14;
	(*Robot Not In Auto External*)
	ELSIF NOT Ready AND In_AutoExt AND NOT In_Auto AND ID_Acks_OK
		THEN Status:= 15;
	(*Robot In Auto*)
	ELSIF  NOT Ready AND In_Auto AND ID_Acks_OK
		THEN Status:= 16;
	(*Robot In T1*)
	ELSIF  NOT Ready AND In_T1  AND ID_Acks_OK
		THEN Status:= 17;
	(*Robot In T2*)
	ELSIF  NOT Ready AND In_T2  AND ID_Acks_OK
		THEN Status:= 18;
	(*Robot Held by Teach Interlock*)
	ELSIF NOT FB_In.Teach_Interlock
		THEN Status:= 30;
	(*Robot Faulted*)
	ELSIF Faulted
		THEN Status:= 31;
	(*Robot Fix ID Ack Fault*)
	ELSIF NOT ID_Acks_OK AND Fix_ID_Flt AND Servos_Are_On
		THEN Status:= 32;
	(*Robot EOAT ID Ack Fault*)
	ELSIF NOT ID_Acks_OK AND EOAT_ID_Flt AND Servos_Are_On
		THEN Status:= 33;
	(*Robot Task ID Ack Fault*)
	ELSIF NOT ID_Acks_OK AND Task_ID_Flt AND Servos_Are_On
		THEN Status:= 34;
	(*Robot Model ID Ack Fault*)
	ELSIF NOT ID_Acks_OK AND Model_ID_Flt AND Servos_Are_On
		THEN Status:= 35;
	(*Robot Peri Req Fault*)
	ELSIF At_Pounce AND ((Peripheral_Req<>0) OR (Aux_Req<>0) OR Clear_To_Unclamp)
		THEN Status:= 36;
	(*Robot Held by Water Fault*)
	ELSIF WaterStand_FLT
		THEN Status:= 37;
	(*External EOAT Fault*)
	ELSIF FB_In.EOAT_FLT
		THEN Status:= 38;
		
	(*Waiting on Task Complete Ack*)
	ELSIF At_Home AND Task_Completed AND FB_In.Complete_Ack
		THEN Status:= 40;

	(*Robot Custom Messages (See Global Variables, Task ID Record) *)
	ELSIF (NOT At_Home OR Task_ID_Ack>350) AND Task_Id_Ack<>0 AND Ready AND Operating AND NOT Faulted AND ID_Acks_OK
		THEN Status:= Task_ID_Ack+100;

	(*FB Configuration Issue*)
	ELSIF NOT FB_Ok
		THEN Status:= 499;

	(*Produce "Invalid Data" If None of The Above Hold True To Blank Status Banner, but only if not at Home*)
	ELSE
		IF NOT At_Home
		 THEN
			Status:=0;
		END_IF;
	END_IF;

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Faults $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*FSoE Type, blank old Relay fault flags*)
		Estop_RelayFLT:= FALSE;
		SafetyGate_RelayFLT:= FALSE;
		EOAT_RelayFLT:=  FALSE;

(*Water Stand Faults*)
		WaterStand_FLT:= NOT FB_In.Option_Disable_WaterFLT AND NOT FB_In.Weld_Inhibit AND
							(((FB_In.Options.WaterStand_Amount>0) AND NOT WS[1].WaterTempFlow_OK)
							OR ((FB_In.Options.WaterStand_Amount>1) AND NOT WS[2].WaterTempFlow_OK));
(*ToolChanger Faults*)
		ToolChanger_FLT:= (FB_In.Robot_Type=Kuka_KRC4_SafeOP_ATI) AND
							ATI[1].Unsafe_Unlock OR ATI[1].Sensor_Fault OR ATI[1].COMM_Error;

(*TQM Not Valid When Required Fault*)
		TQM_NotValid_FLT:=  NOT FB_In.Under_Construction
							AND At_Pounce AND NOT TQM_Valid
							AND (Task_ID_Ack<>352);

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Execute Optional Item FBs attached to Robot System $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
(*Water Stand#1*)
			WS[1].Valve1:= Safety_PeriReady; 										(*Interlock to Turn on Water*)
(*Water Stand#2*)
			WS[2].Valve1:= Safety_PeriReady; 										(*Interlock to Turn on Water*)

(*ATI Tool Changer01*)
	IF FB_In.Robot_Type=Kuka_KRC4_SafeOP_ATI
		THEN
			ATI[1](
				ATI_Lock_Requested:= In_From_ECat.Robot_OUT[441],
				ATI_Unlock_Requested:= In_From_ECat.Robot_OUT[442],
				Fault_Reset:=  FB_In.Safety_RST,
				ATI_Locked=> Out_To_ECat.Robot_IN[441],
				ATI_Unlocked=> Out_To_ECat.Robot_IN[442],
				ATI_Unlock_Enabled=> Out_To_ECat.Robot_IN[443],
				ATI_Sensors_On=> Out_To_ECat.Robot_IN[444],
				Unsafe_Unlock=> Out_To_ECat.Robot_IN[445],
				Sensor_Fault=> Out_To_ECat.Robot_IN[446],
				COMM_Error=> Out_To_ECat.Robot_IN[447],
				Tool_ID_Out0=> Out_To_ECat.Robot_IN[449],
				Tool_ID_Out1=> Out_To_ECat.Robot_IN[450],
				Tool_ID_Out2=> Out_To_ECat.Robot_IN[451],
				Tool_ID_Out3=> Out_To_ECat.Robot_IN[452],
				Tool_ID_Out4=> Out_To_ECat.Robot_IN[453],
				Tool_ID_Out5=> Out_To_ECat.Robot_IN[454],
				Tool_ID_Out6=> Out_To_ECat.Robot_IN[455],
				Tool_ID_Out7=> Out_To_ECat.Robot_IN[456]
				 );
	END_IF;
		(*If Robot is Tool Change Type then Tool_ID comes fromTool Changer, otherwise Lock EOAT_ID to 1*)
	IF FB_In.Robot_Type=Kuka_KRC4_SafeOP_ATI
		THEN
			EOAT_ID.0:= ATI[1].Tool_ID.0;							(*EOAT ID 1*)
			EOAT_ID.1:= ATI[1].Tool_ID.1;							(*EOAT ID 2*)
			EOAT_ID.2:= ATI[1].Tool_ID.2;							(*EOAT ID 4*)
			EOAT_ID.3:= ATI[1].Tool_ID.3;							(*EOAT ID 8*)
			EOAT_ID.4:= ATI[1].Tool_ID.4;							(*EOAT ID 16*)
			EOAT_ID.5:= ATI[1].Tool_ID.5;							(*EOAT ID 32*)
			EOAT_ID.6:= ATI[1].Tool_ID.6;							(*EOAT ID 64*)
			EOAT_ID.7:= ATI[1].Tool_ID.7;							(*EOAT ID 128*)
		ELSE
			EOAT_ID.0:= TRUE;									(*EOAT ID 1*)
			EOAT_ID.1:= FALSE;									(*EOAT ID 2*)
			EOAT_ID.2:= FALSE;									(*EOAT ID 4*)
			EOAT_ID.3:= FALSE;									(*EOAT ID 8*)
			EOAT_ID.4:= FALSE;									(*EOAT ID 16*)
			EOAT_ID.5:= FALSE;									(*EOAT ID 32*)
			EOAT_ID.6:= FALSE;									(*EOAT ID 64*)
			EOAT_ID.7:= FALSE;									(*EOAT ID 128*)
	END_IF;

(*Cycle Time*)
	CycleTime();

(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Transfer Standard Outputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Transfer I/O Images for Display On UI (User Interface)*)
	Input_Image:=In_From_HW;
	Output_Image:=Out_To_HW;

	(*Non FSoE Type*)
	Discrete_Image.T01:=T01;
	Discrete_Image.T02_STAT:=T02_STAT;
	Discrete_Image.T03:=T03;

	(*FSoE Type*)
	Discrete_Image_FSoE.T01:= T01;
	Discrete_Image_FSoE.T02_STAT:= T02_STAT;
	Discrete_Image_FSoE.T03:= T03;
	Discrete_Image_FSOE.T04:=T04;
	Discrete_Image_FSoE.RT01:=RT01;
	Discrete_Image_FSoE.RT02:=RT02;


	(*Outputs*)
	Outputs();

(*----------------- Gather KUKA Type Data and convert to Generic Robot Type for Transfer to Output Image*)

Out_To_HW:= FUN_GTAC_KUKAKRC4_To_GenericRobotOutputImage(Out_To_ECAT);


(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Transfer Safety Outputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Set All Safety Groups to Run*)
		T02_CMD.SGs_RUNSTOP:= TRUE;
	(*Reset Of Safety Group Errors*)
		T02_CMD.SGs_ERRAck:= FB_In.Safety_RST;
	(*Reset Only Used FBs With In Safety Group*)
		(*Reset of Estop, Safety Gate and Misc FBs*)
		T02_CMD.FBs_ControlPowerPB:= FB_In.Safety_RST;
	(*Request to turn on Tip Dresser Contactor*)
		Tip_DressReq_ToSafety:= Tip_DressOn_Req;













(*end*)]]></ST>
    </Implementation>
    <Action Name="CycleTime" Id="{92b511ab-6b5e-4515-a569-2720588a54b7}">
      <Implementation>
        <ST><![CDATA[(*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Cycle Time Counters ~~~~~~~~~~~~~~~~~~~~~~~~~*)


(*///////////////////////////////// Equipment Interferences ////////////////////////////////////*)

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip1.CLK:= NOT AT_EquipInterf1;
	Cycle_Time_PulseEquip1();
	IF Cycle_Time_PulseEquip1.Q
		THEN
		CT.PrevCycle_Time_OutEquip1:= CT.Cycle_Time_OutEquip1;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip1.PT:= T#9999S;
		Cycle_TimeEquip1.IN:= AT_EquipInterf1;
		Cycle_TimeEquip1();
		CT.Cycle_Time_OutEquip1:= Cycle_TimeEquip1.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip2.CLK:= NOT At_EquipInterf2;
	Cycle_Time_PulseEquip2();
	IF Cycle_Time_PulseEquip2.Q
		THEN
		CT.PrevCycle_Time_OutEquip2:= CT.Cycle_Time_OutEquip2;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip2.PT:= T#9999S;
		Cycle_TimeEquip2.IN:= AT_EquipInterf2;
		Cycle_TimeEquip2();
		CT.Cycle_Time_OutEquip2:= Cycle_TimeEquip2.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip3.CLK:= NOT At_EquipInterf3;
	Cycle_Time_PulseEquip3();
	IF Cycle_Time_PulseEquip3.Q
		THEN
		CT.PrevCycle_Time_OutEquip3:= CT.Cycle_Time_OutEquip3;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip3.PT:= T#9999S;
		Cycle_TimeEquip3.IN:= AT_EquipInterf3;
		Cycle_TimeEquip3();
		CT.Cycle_Time_OutEquip3:= Cycle_TimeEquip3.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip4.CLK:= NOT At_EquipInterf4;
	Cycle_Time_PulseEquip4();
	IF Cycle_Time_PulseEquip4.Q
		THEN
		CT.PrevCycle_Time_OutEquip4:= CT.Cycle_Time_OutEquip4;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip4.PT:= T#9999S;
		Cycle_TimeEquip4.IN:= AT_EquipInterf4;
		Cycle_TimeEquip4();
		CT.Cycle_Time_OutEquip4:= Cycle_TimeEquip4.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip5.CLK:= NOT At_EquipInterf5;
	Cycle_Time_PulseEquip5();
	IF Cycle_Time_PulseEquip5.Q
		THEN
		CT.PrevCycle_Time_OutEquip5:= CT.Cycle_Time_OutEquip5;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip5.PT:= T#9999S;
		Cycle_TimeEquip5.IN:= AT_EquipInterf5;
		Cycle_TimeEquip5();
		CT.Cycle_Time_OutEquip5:= Cycle_TimeEquip5.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip6.CLK:= NOT At_EquipInterf6;
	Cycle_Time_PulseEquip6();
	IF Cycle_Time_PulseEquip6.Q
		THEN
		CT.PrevCycle_Time_OutEquip6:= CT.Cycle_Time_OutEquip6;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip6.PT:= T#9999S;
		Cycle_TimeEquip6.IN:= AT_EquipInterf6;
		Cycle_TimeEquip6();
		CT.Cycle_Time_OutEquip6:= Cycle_TimeEquip6.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip7.CLK:= NOT At_EquipInterf7;
	Cycle_Time_PulseEquip7();
	IF Cycle_Time_PulseEquip7.Q
		THEN
		CT.PrevCycle_Time_OutEquip7:= CT.Cycle_Time_OutEquip7;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip7.PT:= T#9999S;
		Cycle_TimeEquip7.IN:= AT_EquipInterf7;
		Cycle_TimeEquip7();
		CT.Cycle_Time_OutEquip7:= Cycle_TimeEquip7.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseEquip8.CLK:= NOT At_EquipInterf8;
	Cycle_Time_PulseEquip8();
	IF Cycle_Time_PulseEquip8.Q
		THEN
		CT.PrevCycle_Time_OutEquip8:= CT.Cycle_Time_OutEquip8;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeEquip8.PT:= T#9999S;
		Cycle_TimeEquip8.IN:= AT_EquipInterf8;
		Cycle_TimeEquip8();
		CT.Cycle_Time_OutEquip8:= Cycle_TimeEquip8.ET;

(*///////////////////////////////// Human Interferences ////////////////////////////////////*)

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman1.CLK:= NOT At_HumanInterf1;
	Cycle_Time_PulseHuman1();
	IF Cycle_Time_PulseHuman1.Q
		THEN
		CT.PrevCycle_Time_OutHuman1:= CT.Cycle_Time_OutHuman1;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman1.PT:= T#9999S;
		Cycle_TimeHuman1.IN:= AT_HumanInterf1;
		Cycle_TimeHuman1();
		CT.Cycle_Time_OutHuman1:= Cycle_TimeHuman1.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman2.CLK:= NOT AT_HumanInterf2;
	Cycle_Time_PulseHuman2();
	IF Cycle_Time_PulseHuman2.Q
		THEN
		CT.PrevCycle_Time_OutHuman2:= CT.Cycle_Time_OutHuman2;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman2.PT:= T#9999S;
		Cycle_TimeHuman2.IN:= AT_HumanInterf2;
		Cycle_TimeHuman2();
		CT.Cycle_Time_OutHuman2:= Cycle_TimeHuman2.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman3.CLK:= NOT At_HumanInterf3;
	Cycle_Time_PulseHuman3();
	IF Cycle_Time_PulseHuman3.Q
		THEN
		CT.PrevCycle_Time_OutHuman3:= CT.Cycle_Time_OutHuman3;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman3.PT:= T#9999S;
		Cycle_TimeHuman3.IN:= AT_HumanInterf3;
		Cycle_TimeHuman3();
		CT.Cycle_Time_OutHuman3:= Cycle_TimeHuman3.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman4.CLK:= NOT At_HumanInterf4;
	Cycle_Time_PulseHuman4();
	IF Cycle_Time_PulseHuman4.Q
		THEN
		CT.PrevCycle_Time_OutHuman4:= CT.Cycle_Time_OutHuman4;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman4.PT:= T#9999S;
		Cycle_TimeHuman4.IN:= AT_HumanInterf4;
		Cycle_TimeHuman4();
		CT.Cycle_Time_OutHuman4:= Cycle_TimeHuman4.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman5.CLK:= NOT At_HumanInterf5;
	Cycle_Time_PulseHuman5();
	IF Cycle_Time_PulseHuman5.Q
		THEN
		CT.PrevCycle_Time_OutHuman5:= CT.Cycle_Time_OutHuman5;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman5.PT:= T#9999S;
		Cycle_TimeHuman5.IN:= AT_HumanInterf5;
		Cycle_TimeHuman5();
		CT.Cycle_Time_OutHuman5:= Cycle_TimeHuman5.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman6.CLK:= NOT At_HumanInterf6;
	Cycle_Time_PulseHuman6();
	IF Cycle_Time_PulseHuman6.Q
		THEN
		CT.PrevCycle_Time_OutHuman6:= CT.Cycle_Time_OutHuman6;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman6.PT:= T#9999S;
		Cycle_TimeHuman6.IN:= AT_HumanInterf6;
		Cycle_TimeHuman6();
		CT.Cycle_Time_OutHuman6:= Cycle_TimeHuman6.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman7.CLK:= NOT At_HumanInterf7;
	Cycle_Time_PulseHuman7();
	IF Cycle_Time_PulseHuman7.Q
		THEN
		CT.PrevCycle_Time_OutHuman7:= CT.Cycle_Time_OutHuman7;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman7.PT:= T#9999S;
		Cycle_TimeHuman7.IN:= AT_HumanInterf7;
		Cycle_TimeHuman7();
		CT.Cycle_Time_OutHuman7:= Cycle_TimeHuman7.ET;

	(*Move Previous To Register*)
	Cycle_Time_PulseHuman8.CLK:= NOT At_HumanInterf8;
	Cycle_Time_PulseHuman8();
	IF Cycle_Time_PulseHuman8.Q
		THEN
		CT.PrevCycle_Time_OutHuman8:= CT.Cycle_Time_OutHuman8;
	END_IF;
	(*Monitor Current Cycle Time*)
		Cycle_TimeHuman8.PT:= T#9999S;
		Cycle_TimeHuman8.IN:= AT_HumanInterf8;
		Cycle_TimeHuman8();
		CT.Cycle_Time_OutHuman8:= Cycle_TimeHuman8.ET;



	(*Add up total cycle time for robot*)
		CT.Cycle_Time_EquipTotal:= (CT.PrevCycle_Time_OutEquip1 + CT.PrevCycle_Time_OutEquip2 + CT.PrevCycle_Time_OutEquip3 + CT.PrevCycle_Time_OutEquip4
					+ CT.PrevCycle_Time_OutEquip5 + CT.PrevCycle_Time_OutEquip6 + CT.PrevCycle_Time_OutEquip7);
		CT.Cycle_Time_HumanTotal:= (CT.PrevCycle_Time_OutHuman1 + CT.PrevCycle_Time_OutHuman2 + CT.PrevCycle_Time_OutHuman3 + CT.PrevCycle_Time_OutHuman4
					+ CT.PrevCycle_Time_OutHuman5 + CT.PrevCycle_Time_OutHuman6 + CT.PrevCycle_Time_OutHuman7 + CT.PrevCycle_Time_OutHuman8);
		CT.Cycle_Time_Total:= CT.Cycle_Time_EquipTotal + CT.Cycle_Time_HumanTotal;














(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Inputs" Id="{106f5714-1d5a-4424-a965-07fa8bf05de9}">
      <Implementation>
        <ST><![CDATA[(* ------------------------- System Inputs Section ----------------------*)
	Operating:= In_From_ECAT.Robot_OUT[1] OR (FB_In.In_SIM_Mode AND FB_In.SIM_StartWorkAround); (*NOTE: SIM items to be removed once we finalize Process Sim + Office Lite, b.lekx-toniolo*)
	Servos_Are_On:= In_From_ECAT.Robot_OUT[2] OR FB_In.In_SIM_Mode;								(*NOTE: SIM items to be removed once we finalize Process Sim + Office Lite, b.lekx-toniolo*)
	Faulted:= In_From_ECAT.Robot_OUT[4];
	In_AutoExt:= (In_From_ECAT.Robot_OUT[5] AND NOT In_Auto) OR FB_In.In_SIM_Mode;				(*NOTE: Sim items to be removed once we finalize Process Sim + Office Lite, b.lekx-toniolo*)
	In_Auto:= In_From_ECAT.Robot_OUT[6];
	In_T1:= In_From_ECAT.Robot_OUT[7];
	In_T2:= In_From_ECAT.Robot_OUT[8];
	In_Teach:= In_T1 OR In_T2;
	In_Home := In_From_ECAT.Robot_OUT[9];
	In_Home1:= In_From_ECAT.Robot_OUT[10];
	In_Home2:= In_From_ECAT.Robot_OUT[11];
	In_Home3:= In_From_ECAT.Robot_OUT[12];
	In_Home4:= In_From_ECAT.Robot_OUT[13];
	In_Home5:= In_From_ECAT.Robot_OUT[14];
	TQM_Valid:= In_From_ECAT.Robot_OUT[15];
	Holding:= In_From_ECAT.Robot_OUT[16];
	IF (FB_In.Options.Reamer_Amount > 0)
		THEN
		Ream_Reqd:= In_From_ECAT.Robot_OUT[17];		(*Map Ream Req Only if Robot Ream count > 0*)
	END_IF;

	Program_No_Req.0 := In_From_ECAT.Robot_OUT[25];
	Program_No_Req.1 := In_From_ECAT.Robot_OUT[26];
	Program_No_Req.2 := In_From_ECAT.Robot_OUT[27];
	Program_No_Req.3 := In_From_ECAT.Robot_OUT[28];
	Program_No_Req.4 := In_From_ECAT.Robot_OUT[29];
	Program_No_Req.5 := In_From_ECAT.Robot_OUT[30];
	Program_No_Req.6 := In_From_ECAT.Robot_OUT[31];
	Program_No_Req.7 := In_From_ECAT.Robot_OUT[32];
	Master_Test_Reqd:= In_From_ECAT.Robot_OUT[33] ;
	Brake_Test_Reqd:= In_From_ECAT.Robot_OUT[34];
	Brake_Test_Reqd_Internal_Robot:= In_From_ECAT.Robot_OUT[35];
	(*Tip Dress Request - From Medar passed through Robot - Tip Dress Request G1 - Tip Dress Request G2*)
	Tip_Dress_Reqd:=  In_From_ECAT.Robot_OUT[36] OR In_From_ECAT.Robot_OUT[191] OR In_From_ECAT.Robot_OUT[192];
	Tip_DressOn_Req:= In_From_ECAT.Robot_OUT[37];




(*----------------- Standard Input Section------------------------*)

(*Equipment Interf Mapping*)
	Clear_Of_EquipInterf1:= In_From_ECAT.Robot_OUT[41] ;
	Clear_Of_EquipInterf2:= In_From_ECAT.Robot_OUT[42];
	Clear_Of_EquipInterf3:= In_From_ECAT.Robot_OUT[43];
