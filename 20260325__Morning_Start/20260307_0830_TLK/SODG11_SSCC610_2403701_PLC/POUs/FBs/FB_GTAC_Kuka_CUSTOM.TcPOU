	Cycle_TimeHuman5: TON;
	Cycle_Time_PulseHuman5: R_TRIG;
	Cycle_TimeHuman6: TON;
	Cycle_Time_PulseHuman6: R_TRIG;
	Cycle_TimeHuman7: TON;
	Cycle_Time_PulseHuman7: R_TRIG;
	Cycle_TimeHuman8: TON;
