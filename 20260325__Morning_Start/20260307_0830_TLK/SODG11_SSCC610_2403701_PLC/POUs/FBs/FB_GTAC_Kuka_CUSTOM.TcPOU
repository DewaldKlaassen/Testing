	Model_ID_Ack.7:= In_From_ECAT.Robot_OUT[80];
	(*User Outputs from Robot*)
	User_Outputs.0:=In_From_ECAT.Robot_OUT[81];
	User_Outputs.1:=In_From_ECAT.Robot_OUT[82];
	User_Outputs.2:=In_From_ECAT.Robot_OUT[83];
	User_Outputs.3:=In_From_ECAT.Robot_OUT[84];
	User_Outputs.4:=In_From_ECAT.Robot_OUT[85];
	User_Outputs.5:=In_From_ECAT.Robot_OUT[86];
	User_Outputs.6:=In_From_ECAT.Robot_OUT[87];
	User_Outputs.7:=In_From_ECAT.Robot_OUT[88];
	(*Peripheral Requests Mapping*)
	Peripheral_Req.0:= In_From_ECAT.Robot_OUT[89];
