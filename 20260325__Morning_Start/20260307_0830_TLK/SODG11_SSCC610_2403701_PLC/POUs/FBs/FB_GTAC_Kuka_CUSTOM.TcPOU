	Peripheral_Req.6:= In_From_ECAT.Robot_OUT[95];
	Peripheral_Req.7:= In_From_ECAT.Robot_OUT[96];
	(*Various Signal Section Mapping*)
	At_Pounce:= In_From_ECAT.Robot_OUT[97];

	Clear_To_Unclamp:= In_From_ECAT.Robot_OUT[100];
	(*Robot Complete Not Recognized unless At Home*)
	Task_Completed:= In_From_ECAT.Robot_OUT[104] AND At_Home;

	(*Clear of Robot Interference Zones*)
	Clear_Of_RobotInterfs.0:= In_From_ECAT.Robot_OUT[105];	(*Clear of Robot Interf Zone#1*)
	Clear_Of_RobotInterfs.1:= In_From_ECAT.Robot_OUT[106];	(*Clear of Robot Interf Zone#2*)
	Clear_Of_RobotInterfs.2:= In_From_ECAT.Robot_OUT[107];	(*Clear of Robot Interf Zone#3*)
	Clear_Of_RobotInterfs.3:= In_From_ECAT.Robot_OUT[108];	(*Clear of Robot Interf Zone#4*)
	Clear_Of_RobotInterfs.4:= In_From_ECAT.Robot_OUT[109];	(*Clear of Robot Interf Zone#5*)
	Clear_Of_RobotInterfs.5:= In_From_ECAT.Robot_OUT[110];	(*Clear of Robot Interf Zone#6*)
	Clear_Of_RobotInterfs.6:= In_From_ECAT.Robot_OUT[111];	(*Clear of Robot Interf Zone#7*)
	Clear_Of_RobotInterfs.7:= In_From_ECAT.Robot_OUT[112];	(*Clear of Robot Interf Zone#8*)

(* ---------- S-Axis Positional Data (Degrees from Home) Mapping -------------------------*)
S_Axis_Pos_Raw:= FUN_GTAC_BYTEStoINT(In_From_HW.BYTE_[15], In_From_HW.BYTE_[16]);  (*Map bytes associated with OUT[113]  TO OUT[128]*)

(*Pass Robot's Install Zero Position Orientation and Create Indexes in 10 Degree Increments to Trigger UI Animation Images*)
S_Axis_Pos_Indexed:= FUN_GTAC_DEGtoINDEX (S_Axis_Pos_Raw, FB_In.Install_Zero_Orientation);

External_Axis_Pos_Raw:= FUN_GTAC_BYTEStoINT(In_From_HW.BYTE_[58], In_From_HW.BYTE_[59]); (*Map Bytes associated with OUT[457] TO OUT[471]*)
(*-----------------------------------------------------------------------------------------------------------------------*)
	(*EOAT Requests Mapping*)
	EOAT_Req.0:= In_From_ECAT.Robot_OUT[129];
	EOAT_Req.1:= In_From_ECAT.Robot_OUT[130];
	EOAT_Req.2:= In_From_ECAT.Robot_OUT[131];
	EOAT_Req.3:= In_From_ECAT.Robot_OUT[132];
	EOAT_Req.4:= In_From_ECAT.Robot_OUT[133];
	EOAT_Req.5:= In_From_ECAT.Robot_OUT[134];
	EOAT_Req.6:= In_From_ECAT.Robot_OUT[135];
	EOAT_Req.7:= In_From_ECAT.Robot_OUT[136];
	EOAT_Req.8:= In_From_ECAT.Robot_OUT[137];
	EOAT_Req.9:= In_From_ECAT.Robot_OUT[138];
	EOAT_Req.10:= In_From_ECAT.Robot_OUT[139];
	EOAT_Req.11:= In_From_ECAT.Robot_OUT[140];
	EOAT_Req.12:= In_From_ECAT.Robot_OUT[141];
	EOAT_Req.13:= In_From_ECAT.Robot_OUT[142];
	EOAT_Req.14:= In_From_ECAT.Robot_OUT[143];
	EOAT_Req.15:= In_From_ECAT.Robot_OUT[144];

	(*Task ID Ack Mapping*)
	Task_ID_Ack.0:= In_From_ECAT.Robot_OUT[145];
	Task_ID_Ack.1:= In_From_ECAT.Robot_OUT[146];
	Task_ID_Ack.2:= In_From_ECAT.Robot_OUT[147];
	Task_ID_Ack.3:= In_From_ECAT.Robot_OUT[148];
	Task_ID_Ack.4:= In_From_ECAT.Robot_OUT[149];
	Task_ID_Ack.5:= In_From_ECAT.Robot_OUT[150];
	Task_ID_Ack.6:= In_From_ECAT.Robot_OUT[151];
	Task_ID_Ack.7:= In_From_ECAT.Robot_OUT[152];
	Task_ID_Ack.8:= In_From_ECAT.Robot_OUT[153];
	Task_ID_Ack.9:= In_From_ECAT.Robot_OUT[154];
	Task_ID_Ack.10:= In_From_ECAT.Robot_OUT[155];
	Task_ID_Ack.11:= In_From_ECAT.Robot_OUT[156];
	Task_ID_Ack.12:= In_From_ECAT.Robot_OUT[157];
	Task_ID_Ack.13:= In_From_ECAT.Robot_OUT[158];
	Task_ID_Ack.14:= In_From_ECAT.Robot_OUT[159];
	Task_ID_Ack.15:= In_From_ECAT.Robot_OUT[160];

	(*Auxliary Requests Mapping*)
	Aux_Req.0:= In_From_ECAT.Robot_OUT[161];
	Aux_Req.1:= In_From_ECAT.Robot_OUT[162];
	Aux_Req.2:= In_From_ECAT.Robot_OUT[163];
	Aux_Req.3:= In_From_ECAT.Robot_OUT[164];
	Aux_Req.4:= In_From_ECAT.Robot_OUT[165];
	Aux_Req.5:= In_From_ECAT.Robot_OUT[166];
	Aux_Req.6:= In_From_ECAT.Robot_OUT[167];
	Aux_Req.7:= In_From_ECAT.Robot_OUT[168];



(* ---------- Weld Controller Mapping -------------------------*)
	(*Mapping for WTC Resistance Welding Type Controller*)

		(*WCU#1 Inputs*)
		WCU1_NoFaults:= In_From_ECAT.Robot_OUT[170];
		WCU1_Weld_Complete:= In_From_ECAT.Robot_OUT[173];
		WCU1_Weld_InProgress:= In_From_ECAT.Robot_OUT[174];
		WCU1_SteppersAreReset:= In_From_ECAT.Robot_OUT[175];
		WCU1_SteppersApprMax := In_From_ECAT.Robot_OUT[176];
		WCU1_Weld_Init:= In_From_ECAT.Robot_OUT[179];
		WCU1_TipChgReqd_1:= In_From_ECAT.Robot_OUT[185];
		WCU1_StepperAtMax_1:= In_From_ECAT.Robot_OUT[189];
		WCU1_DressReqd_1:= In_From_ECAT.Robot_OUT[191];
		WCU1_TipChgReqd_2:= In_From_ECAT.Robot_OUT[186];
		WCU1_StepperAtMax_2:= In_From_ECAT.Robot_OUT[190];
		WCU1_DressReqd_2:= In_From_ECAT.Robot_OUT[192];

		(*WCU#2 Inputs*)
		WCU2_NoFaults:= In_From_ECAT.Robot_OUT[202];
		WCU2_Weld_Complete:= In_From_ECAT.Robot_OUT[205];
		WCU2_Weld_InProgress:= In_From_ECAT.Robot_OUT[206];
		WCU2_SteppersAreReset:= In_From_ECAT.Robot_OUT[207];
		WCU2_SteppersApprMax := In_From_ECAT.Robot_OUT[208];
		WCU2_Weld_Init:= In_From_ECAT.Robot_OUT[211];
		WCU2_TipChgReqd_1:= In_From_ECAT.Robot_OUT[217];
		WCU2_StepperAtMax_1:= In_From_ECAT.Robot_OUT[221];
		WCU2_DressReqd_1:= In_From_ECAT.Robot_OUT[223];
		WCU2_TipChgReqd_2:= In_From_ECAT.Robot_OUT[218];
		WCU2_StepperAtMax_2:= In_From_ECAT.Robot_OUT[222];
		WCU2_DressReqd_2:= In_From_ECAT.Robot_OUT[224];

		(*WCU#3 Inputs*)
		WCU3_NoFaults:= In_From_ECAT.Robot_OUT[234];
		WCU3_Weld_Complete:= In_From_ECAT.Robot_OUT[237];
		WCU3_Weld_InProgress:= In_From_ECAT.Robot_OUT[238];
		WCU3_SteppersAreReset:= In_From_ECAT.Robot_OUT[239];
		WCU3_SteppersApprMax := In_From_ECAT.Robot_OUT[240];
		WCU3_Weld_Init:= In_From_ECAT.Robot_OUT[243];
		WCU3_TipChgReqd_1:= In_From_ECAT.Robot_OUT[249];
		WCU3_StepperAtMax_1:= In_From_ECAT.Robot_OUT[253];
		WCU3_DressReqd_1:= In_From_ECAT.Robot_OUT[255];
		WCU3_TipChgReqd_2:= In_From_ECAT.Robot_OUT[250];
		WCU3_StepperAtMax_2:= In_From_ECAT.Robot_OUT[254];
		WCU3_DressReqd_2:= In_From_ECAT.Robot_OUT[256];

		(*WCU#4 Inputs*)
		WCU4_NoFaults:= In_From_ECAT.Robot_OUT[266];
		WCU4_Weld_Complete:= In_From_ECAT.Robot_OUT[269];
		WCU4_Weld_InProgress:= In_From_ECAT.Robot_OUT[270];
		WCU4_SteppersAreReset:= In_From_ECAT.Robot_OUT[271];
		WCU4_SteppersApprMax := In_From_ECAT.Robot_OUT[272];
		WCU4_Weld_Init:= In_From_ECAT.Robot_OUT[275];
		WCU4_TipChgReqd_1:= In_From_ECAT.Robot_OUT[281];
		WCU4_StepperAtMax_1:= In_From_ECAT.Robot_OUT[285];
		WCU4_DressReqd_1:= In_From_ECAT.Robot_OUT[289];
		WCU4_TipChgReqd_2:= In_From_ECAT.Robot_OUT[282];
		WCU4_StepperAtMax_2:= In_From_ECAT.Robot_OUT[286];
		WCU4_DressReqd_2:= In_From_ECAT.Robot_OUT[288];

		(*Gather WCU Information, take into account number of WCUs robot is interfaced to*)

		IF FB_In.Options.WeldCont_Amount = 1
			THEN Weld_Controller_FLT:= WCU1_NoFaults;
		ELSIF FB_In.Options.WeldCont_Amount = 2
			THEN Weld_Controller_FLT:= WCU1_NoFaults OR WCU2_NoFaults;
		ELSIF FB_In.Options.WeldCont_Amount = 3
			THEN Weld_Controller_FLT:= WCU1_NoFaults OR WCU2_NoFaults
					OR WCU3_NoFaults;
		ELSIF FB_In.Options.WeldCont_Amount = 4
			THEN Weld_Controller_FLT:= WCU1_NoFaults OR WCU2_NoFaults
					OR WCU3_NoFaults OR WCU4_NoFaults;
		ELSE Weld_Controller_FLT:= FALSE;
		END_IF;
		In_Welding:= WCU1_Weld_Init OR WCU1_Weld_InProgress OR WCU1_Weld_Complete
					OR WCU2_Weld_Init OR WCU2_Weld_InProgress OR WCU2_Weld_Complete
					OR WCU3_Weld_Init OR WCU3_Weld_InProgress OR WCU3_Weld_Complete
					OR WCU4_Weld_Init OR WCU4_Weld_InProgress OR WCU4_Weld_Complete;

	(*Mapping for Fronius TPSi MIG Welding Type Controller*)

		Fronius_PowerSourceReady:= In_From_ECAT.Robot_OUT[298];
		Fronius_Mig_HotKey:= In_From_ECAT.Robot_OUT[299];
		Fronius_ProcessActive:= In_From_ECAT.Robot_OUT[300];
		Fronius_TorchCollision:= In_From_ECAT.Robot_OUT[305];
		Fronius_IgnitionError:= In_From_ECAT.Robot_OUT[315];

	Fronius_Status.Weld_Current:= (FUN_GTAC_BOOLStoINT(In_From_ECAT.Robot_OUT[377],
											In_From_ECAT.Robot_OUT[378],
											In_From_ECAT.Robot_OUT[379],
											In_From_ECAT.Robot_OUT[380],
											In_From_ECAT.Robot_OUT[381],
											In_From_ECAT.Robot_OUT[382],
											In_From_ECAT.Robot_OUT[383],
											In_From_ECAT.Robot_OUT[384],
											In_From_ECAT.Robot_OUT[385],
											In_From_ECAT.Robot_OUT[386],
											In_From_ECAT.Robot_OUT[387],
											In_From_ECAT.Robot_OUT[388],
											In_From_ECAT.Robot_OUT[389],
											In_From_ECAT.Robot_OUT[340],
											In_From_ECAT.Robot_OUT[341],
											In_From_ECAT.Robot_OUT[342],
											))/10;
		Fronius_Status.Weld_Voltage:= (FUN_GTAC_BOOLStoINT(In_From_ECAT.Robot_OUT[361],
											In_From_ECAT.Robot_OUT[362],
											In_From_ECAT.Robot_OUT[363],
											In_From_ECAT.Robot_OUT[364],
											In_From_ECAT.Robot_OUT[365],
											In_From_ECAT.Robot_OUT[366],
											In_From_ECAT.Robot_OUT[367],
											In_From_ECAT.Robot_OUT[368],
											In_From_ECAT.Robot_OUT[369],
											In_From_ECAT.Robot_OUT[370],
											In_From_ECAT.Robot_OUT[371],
											In_From_ECAT.Robot_OUT[372],
											In_From_ECAT.Robot_OUT[373],
											In_From_ECAT.Robot_OUT[374],
											In_From_ECAT.Robot_OUT[375],
											In_From_ECAT.Robot_OUT[376]
											))/100;
		Fronius_Status.Weld_WFS:= (FUN_GTAC_BOOLStoINT(In_From_ECAT.Robot_OUT[393],
											In_From_ECAT.Robot_OUT[394],
											In_From_ECAT.Robot_OUT[395],
											In_From_ECAT.Robot_OUT[396],
											In_From_ECAT.Robot_OUT[397],
											In_From_ECAT.Robot_OUT[398],
											In_From_ECAT.Robot_OUT[399],
											In_From_ECAT.Robot_OUT[400],
											In_From_ECAT.Robot_OUT[401],
											In_From_ECAT.Robot_OUT[402],
											In_From_ECAT.Robot_OUT[403],
											In_From_ECAT.Robot_OUT[404],
											In_From_ECAT.Robot_OUT[405],
											In_From_ECAT.Robot_OUT[406],
											In_From_ECAT.Robot_OUT[407],
											In_From_ECAT.Robot_OUT[408]
											))/100;

		Fronius_Status.Error_Code:= FUN_GTAC_BOOLStoINT(In_From_ECAT.Robot_OUT[425],
											In_From_ECAT.Robot_OUT[426],
											In_From_ECAT.Robot_OUT[427],
											In_From_ECAT.Robot_OUT[428],
											In_From_ECAT.Robot_OUT[429],
											In_From_ECAT.Robot_OUT[430],
											In_From_ECAT.Robot_OUT[431],
											In_From_ECAT.Robot_OUT[432],
											In_From_ECAT.Robot_OUT[433],
											In_From_ECAT.Robot_OUT[434],
											In_From_ECAT.Robot_OUT[435],
											In_From_ECAT.Robot_OUT[436],
											In_From_ECAT.Robot_OUT[437],
											In_From_ECAT.Robot_OUT[438],
											In_From_ECAT.Robot_OUT[439],
											In_From_ECAT.Robot_OUT[440]
											);


		IF FB_In.Options.MIGCont_Amount>0
			THEN
			Weld_Controller_FLT:= Weld_Controller_FLT OR Fronius_Status.Error_Code <> 0 OR NOT Fronius_PowerSourceReady;	(*20170525 - Check RLO of above code in case a WTC has flagged a fault*)
		END_IF;
		In_Welding:= In_Welding OR Fronius_ProcessActive;											(*20170525 - Check RLO of above code in case a WTC has flagged "In_Welding"*)


(*Custom for Volvo Bumpers*)
	TT_at_PickUp_Pos:= In_From_ECAT.Robot_OUT[457];
	TT_at_DropOff_Pos:= In_From_ECAT.Robot_OUT[458];
	
(*Custom for Volvo Bumper -Smart Ray *)
  In_Rxx_From_SmartRay.Alive_Out := In_From_ECAT.Robot_OUT[470];  (*Smart Ray > Robot : Input for our plc*)
  In_Rxx_From_SmartRay.FailureGlobal_Out := In_From_ECAT.Robot_OUT[471];  (*Smart Ray > Robot : Input for our plc*)

  Out_Rxx_To_SmartRay.InspectionCompleted_In := In_From_ECAT.Robot_OUT[472]; (*Robot > Smart Ray : Input for our plc *)	
	





























(*end*)]]></ST>
      </Implementation>
    </Action>
    <Action Name="Outputs" Id="{3f4f0a51-0e46-4455-8625-3614f63afbf4}">
      <Implementation>
        <ST><![CDATA[	(*Transfer Commands to EtherCAT Outputs*)

	(*--------------- System Outputs to Robot System Inputs -------------------------*)
	Out_To_ECAT.Robot_IN[1]:= Start_Robot_Scan;				(*Start Robot Scan*)
	Out_To_ECAT.Robot_IN[2]:= Servos_Req;					(*Turn on Servos*)
	Out_To_ECAT.Robot_IN[3]:= FB_In.Enable_Motion;				(*Motion Enable*)
	Out_To_ECAT.Robot_IN[4]:= FB_In.Alarm_RST;				(*Alarm Reset*)
	Out_To_ECAT.Robot_IN[5]:= NOT Servos_Off_Req;			(*Turn Servo Drives Off, High to Allow Servos*)
	Out_To_ECAT.Robot_IN[6]:= FALSE;							(*Spare*)
	Out_To_ECAT.Robot_IN[7]:= FALSE;							(*Spare*)
	Out_To_ECAT.Robot_IN[8]:= Hold_Robot;						(*Hold Robot, (N.O. IE; High to Hold)*)

	Out_To_ECAT.Robot_IN[9]:= In_From_ICxx.ControlPower1;		(*Weld Point Repeat From Control Power*)
	Out_To_ECAT.Robot_IN[10]:= FB_In.In_DryCycle;				(*Dry Cycle, for Simulating EOAT PP Sensors*)
	Out_To_ECAT.Robot_IN[11]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[12]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[13]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[14]:= FB_In.Under_Construction;		(*Under Construction *)
	Out_To_ECAT.Robot_IN[15]:= FB_In.Low_Speed;				(*Safety Speed Select*)
	Out_To_ECAT.Robot_IN[16]:= FALSE;						(*Spare*)

	Out_To_ECAT.Robot_IN[17]:= FB_In.Speed_Request.0;			(*Speed Request Data Bit 1*)
	Out_To_ECAT.Robot_IN[18]:= FB_In.Speed_Request.1;	   		(*Speed Request Data Bit 2*)
	Out_To_ECAT.Robot_IN[19]:= FB_In.Speed_Request.2;			(*Speed Request Data Bit 4*)
	Out_To_ECAT.Robot_IN[20]:= FB_In.Speed_Request.3;			(*Speed Request Data Bit 8*)
	Out_To_ECAT.Robot_IN[21]:= FB_In.Speed_Request.4;			(*Speed Request Data Bit 16*)
	Out_To_ECAT.Robot_IN[22]:= FB_In.Speed_Request.5;			(*Speed Request Data Bit 32*)
	Out_To_ECAT.Robot_IN[23]:= FB_In.Speed_Request.6;			(*Speed Request Data Bit 64*)
	Out_To_ECAT.Robot_IN[24]:= FB_In.Speed_Request.7;			(*Speed Request Data Bit 128*)

	Out_To_ECAT.Robot_IN[25]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[26]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[27]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[28]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[29]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[30]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[31]:= FALSE;						(*Spare*)
	Out_To_ECAT.Robot_IN[32]:= FALSE;						(*Spare*)

	Out_To_ECAT.Robot_IN[33]:= FB_In.Force_MasterTest_Req;				(*Force Master Test Requirement*)
	Out_To_ECAT.Robot_IN[34]:= FB_In.Force_BrakeTest_Req;					(*Force Brake Test Requirement*)
	Out_To_ECAT.Robot_IN[35]:= FALSE;									(*Spare*)
	Out_To_ECAT.Robot_IN[36]:= FALSE;									(*Spare*)
	Out_To_ECAT.Robot_IN[37]:= Tip_DressOn_Ack AND Tip_DressOn_Req;		(*Tip Dresser Is On*)
	Out_To_ECAT.Robot_IN[38]:= FALSE;									(*Spare*)
	Out_To_ECAT.Robot_IN[39]:= FALSE;									(*Spare*)
	Out_To_ECAT.Robot_IN[40]:= FALSE;									(*Spare*)

	(*------------------------- Standard Outputs to Robot Standard Inputs ----------------------*)

	Out_To_ECAT.Robot_IN[41]:= FB_In.OK_ToEnter_EquipInterf1;			(*OK to Enter Equip Interf Zone#1*)
	Out_To_ECAT.Robot_IN[42]:= FB_In.OK_ToEnter_EquipInterf2;			(*OK to Enter Equip Interf Zone#2*)
	Out_To_ECAT.Robot_IN[43]:= FB_In.OK_ToEnter_EquipInterf3;			(*OK to Enter Equip Interf Zone#3*)
	Out_To_ECAT.Robot_IN[44]:= FB_In.OK_ToEnter_EquipInterf4;			(*OK to Enter Equip Interf Zone#4*)
	Out_To_ECAT.Robot_IN[45]:= FB_In.OK_ToEnter_EquipInterf5;			(*OK to Enter Equip Interf Zone#5*)
	Out_To_ECAT.Robot_IN[46]:= FB_In.OK_ToEnter_EquipInterf6;			(*OK to Enter Equip Interf Zone#6*)
	Out_To_ECAT.Robot_IN[47]:= FB_In.OK_ToEnter_EquipInterf7;			(*OK to Enter Equip Interf Zone#7*)
	Out_To_ECAT.Robot_IN[48]:= FB_In.OK_ToEnter_EquipInterf8;			(*OK to Enter Equip Interf Zone#8*)
	Out_To_ECAT.Robot_IN[98]:= FB_In.OK_ToEnter_EquipInterf9;			(*OK to Enter Equip Interf Zone#9***NEW*)

	Out_To_ECAT.Robot_IN[49]:= FB_In.OK_ToEnter_HumanInterf1;			(*OK to Enter Human Interf Zone#1*)
	Out_To_ECAT.Robot_IN[50]:= FB_In.OK_ToEnter_HumanInterf2;			(*OK to Enter Human Interf Zone#2*)
	Out_To_ECAT.Robot_IN[51]:= FB_In.OK_ToEnter_HumanInterf3;			(*OK to Enter Human Interf Zone#3*)
	Out_To_ECAT.Robot_IN[52]:= FB_In.OK_ToEnter_HumanInterf4;			(*OK to Enter Human Interf Zone#4*)
	Out_To_ECAT.Robot_IN[53]:= FB_In.OK_ToEnter_HumanInterf5;			(*OK to Enter Human Interf Zone#5*)
	Out_To_ECAT.Robot_IN[54]:= FB_In.OK_ToEnter_HumanInterf6;			(*OK to Enter Human Interf Zone#6*)
	Out_To_ECAT.Robot_IN[55]:= FB_In.OK_ToEnter_HumanInterf7;			(*OK to Enter Human Interf Zone#7*)
	Out_To_ECAT.Robot_IN[56]:= FB_In.OK_ToEnter_HumanInterf8;			(*OK to Enter Human Interf Zone#8*)

	Out_To_ECAT.Robot_IN[57]:= EOAT_ID.0;								(*EOAT ID ACK 1*)
	Out_To_ECAT.Robot_IN[58]:= EOAT_ID.1;								(*EOAT ID ACK 2*)
	Out_To_ECAT.Robot_IN[59]:= EOAT_ID.2;								(*EOAT ID ACK 4*)
	Out_To_ECAT.Robot_IN[60]:= EOAT_ID.3;								(*EOAT ID ACK 8*)
	Out_To_ECAT.Robot_IN[61]:= EOAT_ID.4;								(*EOAT ID ACK 16*)
	Out_To_ECAT.Robot_IN[62]:= EOAT_ID.5;								(*EOAT ID ACK 32*)
	Out_To_ECAT.Robot_IN[63]:= EOAT_ID.6;								(*EOAT ID ACK 64*)
	Out_To_ECAT.Robot_IN[64]:= EOAT_ID.7;								(*EOAT ID ACK 128*)

	Out_To_ECAT.Robot_IN[65]:= FB_In.Fix_ID.0;								(*Fixture ID ACK 1*)
	Out_To_ECAT.Robot_IN[66]:= FB_In.Fix_ID.1;								(*Fixture ID ACK 2*)
	Out_To_ECAT.Robot_IN[67]:= FB_In.Fix_ID.2;								(*Fixture ID ACK 4*)
	Out_To_ECAT.Robot_IN[68]:= FB_In.Fix_ID.3;								(*Fixture ID ACK 8*)
	Out_To_ECAT.Robot_IN[69]:= FB_In.Fix_ID.4;								(*Fixture ID ACK 16*)
	Out_To_ECAT.Robot_IN[70]:= FB_In.Fix_ID.5;								(*Fixture ID ACK 32*)
	Out_To_ECAT.Robot_IN[71]:= FB_In.Fix_ID.6;								(*Fixture ID ACK 64*)
	Out_To_ECAT.Robot_IN[72]:= FB_In.Fix_ID.7;								(*Fixture ID ACK 128*)

	Out_To_ECAT.Robot_IN[73]:= FB_In.Model_ID.0;							(*Model ID ACK 1*)
	Out_To_ECAT.Robot_IN[74]:= FB_In.Model_ID.1;							(*Model ID ACK 2*)
	Out_To_ECAT.Robot_IN[75]:= FB_In.Model_ID.2;							(*Model ID ACK 4*)
	Out_To_ECAT.Robot_IN[76]:= FB_In.Model_ID.3;							(*Model ID ACK 8*)
	Out_To_ECAT.Robot_IN[77]:= FB_In.Model_ID.4;							(*Model ID ACK 16*)
	Out_To_ECAT.Robot_IN[78]:= FB_In.Model_ID.5;							(*Model ID ACK 32*)
	Out_To_ECAT.Robot_IN[79]:= FB_In.Model_ID.6;							(*Model ID ACK 64*)
	Out_To_ECAT.Robot_IN[80]:= FB_In.Model_ID.7;							(*Model ID ACK 128*)

	Out_To_ECAT.Robot_IN[81]:= FB_In.User_Inputs.0;							(*User Input *)
	Out_To_ECAT.Robot_IN[82]:= FB_In.User_Inputs.1;							(*User Input *)
	Out_To_ECAT.Robot_IN[83]:= FB_In.User_Inputs.2;							(*User Input *)
	Out_To_ECAT.Robot_IN[84]:= FB_In.User_Inputs.3;							(*User Input *)
	Out_To_ECAT.Robot_IN[85]:= FB_In.User_Inputs.4;							(*User Input *)
	Out_To_ECAT.Robot_IN[86]:= FB_In.User_Inputs.5;							(*User Input *)
	Out_To_ECAT.Robot_IN[87]:= FB_In.User_Inputs.6;							(*User Input *)
	Out_To_ECAT.Robot_IN[88]:= FB_In.User_Inputs.7;							(*User Input *)


	Out_To_ECAT.Robot_IN[89]:= Peripheral_Req.0 AND FB_In.PeripheralReq_Ack.0;			(*Peripheral Equipment Request 1 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[90]:= Peripheral_Req.1 AND FB_In.PeripheralReq_Ack.1;			(*Peripheral Equipment Request 2 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[91]:= Peripheral_Req.2 AND FB_In.PeripheralReq_Ack.2;			(*Peripheral Equipment Request 4 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[92]:= Peripheral_Req.3 AND FB_In.PeripheralReq_Ack.3;			(*Peripheral Equipment Request 8 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[93]:= Peripheral_Req.4 AND FB_In.PeripheralReq_Ack.4;			(*Peripheral Equipment Request 16 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[94]:= Peripheral_Req.5 AND FB_In.PeripheralReq_Ack.5;			(*Peripheral Equipment Request 32 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[95]:= Peripheral_Req.6 AND FB_In.PeripheralReq_Ack.6;			(*Peripheral Equipment Request 64 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[96]:= Peripheral_Req.7 AND FB_In.PeripheralReq_Ack.7;			(*Peripheral Equipment Request 128 (Reposition request etc.)*)

	IF At_Pounce
		AND Fix_ID_Ack<>0 AND Fix_ID_Ack=FB_In.Fix_ID
		AND EOAT_ID_Ack<>0 AND (((FB_In.Robot_Type=Kuka_KRC4_SafeOP_ATI) AND EOAT_ID_Ack=ATI[1].Tool_ID)
								OR ((FB_In.Robot_Type<>Kuka_KRC4_SafeOP_ATI) AND  EOAT_ID_Ack=1))
		AND Model_ID_Ack<>0 AND Model_ID_Ack=FB_In.Model_ID
		AND Task_ID_Ack<>0 AND Task_ID_Ack=FB_In.Task_ID
		AND ((TQM_Valid OR Task_ID_Ack=352) OR FB_In.Under_Construction)
		AND (Peripheral_Req=0) AND (Aux_Req=0) AND NOT Clear_To_Unclamp
		AND (NOT At_Home OR ((Task_ID_Ack>350) AND (Task_ID_Ack<360)))
			THEN
				Out_To_ECAT.Robot_IN[97]:= FB_In.Proceed_From_Pounce;			(*Proceed From Pounce*)
		ELSE
				Out_To_ECAT.Robot_IN[97]:= FALSE;								(*Proceed From Pounce*)
	END_IF;

	Out_To_ECAT.Robot_IN[100]:= Clear_To_Unclamp;							(*Robot is Clear for Tool to Unclamp Early Ack*)
	Out_To_ECAT.Robot_IN[101]:= FALSE;										(*spare*)
	Out_To_ECAT.Robot_IN[102]:= FALSE;										(*spare*)
	Out_To_ECAT.Robot_IN[103]:= FALSE;										(*spare*)
	Out_To_ECAT.Robot_IN[104]:= Task_Completed AND FB_In.Complete_Ack;		(*Task Completed Ack*)

	Out_To_ECAT.Robot_IN[105]:= FB_In.OK_ToEnter_RobotInterfs.0;		(*OK to Enter Robot Interf Zone#1*)
	Out_To_ECAT.Robot_IN[106]:= FB_In.OK_ToEnter_RobotInterfs.1;		(*OK to Enter Robot Interf Zone#2*)
	Out_To_ECAT.Robot_IN[107]:= FB_In.OK_ToEnter_RobotInterfs.2;		(*OK to Enter Robot Interf Zone#3*)
	Out_To_ECAT.Robot_IN[108]:= FB_In.OK_ToEnter_RobotInterfs.3;		(*OK to Enter Robot Interf Zone#4*)
	Out_To_ECAT.Robot_IN[109]:= FB_In.OK_ToEnter_RobotInterfs.4;		(*OK to Enter Robot Interf Zone#5*)
	Out_To_ECAT.Robot_IN[110]:= FB_In.OK_ToEnter_RobotInterfs.5;		(*OK to Enter Robot Interf Zone#6*)
	Out_To_ECAT.Robot_IN[111]:= FB_In.OK_ToEnter_RobotInterfs.6;		(*OK to Enter Robot Interf Zone#7*)
	Out_To_ECAT.Robot_IN[112]:= FB_In.OK_ToEnter_RobotInterfs.7;		(*OK to Enter Robot Interf Zone#8*)


	Out_To_ECAT.Robot_IN[129]:= EOAT_Req.0 AND FB_In.EOATReq_Ack.0;			(*EOAT ACK 1*)
	Out_To_ECAT.Robot_IN[130]:= EOAT_Req.1 AND FB_In.EOATReq_Ack.1;			(*EOAT ACK 2*)
	Out_To_ECAT.Robot_IN[131]:= EOAT_Req.2 AND FB_In.EOATReq_Ack.2;			(*EOAT ACK  4*)
	Out_To_ECAT.Robot_IN[132]:= EOAT_Req.3 AND FB_In.EOATReq_Ack.3;			(*EOAT ACK  8*)
	Out_To_ECAT.Robot_IN[133]:= EOAT_Req.4 AND FB_In.EOATReq_Ack.4;			(*EOAT ACK  16*)
	Out_To_ECAT.Robot_IN[134]:= EOAT_Req.5 AND FB_In.EOATReq_Ack.5;			(*EOAT ACK  32*)
	Out_To_ECAT.Robot_IN[135]:= EOAT_Req.6 AND FB_In.EOATReq_Ack.6;			(*EOAT ACK  64*)
	Out_To_ECAT.Robot_IN[136]:= EOAT_Req.7 AND FB_In.EOATReq_Ack.7;			(*EOAT ACK  128*)
	Out_To_ECAT.Robot_IN[137]:= EOAT_Req.8 AND FB_In.EOATReq_Ack.8;			(*EOAT ACK 256*)
	Out_To_ECAT.Robot_IN[138]:= EOAT_Req.9 AND FB_In.EOATReq_Ack.9;			(*EOAT ACK 512*)
	Out_To_ECAT.Robot_IN[139]:= EOAT_Req.10 AND FB_In.EOATReq_Ack.10;		(*EOAT ACK  1024*)
	Out_To_ECAT.Robot_IN[140]:= EOAT_Req.11 AND FB_In.EOATReq_Ack.11;		(*EOAT ACK  2048*)
	Out_To_ECAT.Robot_IN[141]:= EOAT_Req.12 AND FB_In.EOATReq_Ack.12;		(*EOAT ACK  4096*)
	Out_To_ECAT.Robot_IN[142]:= EOAT_Req.13 AND FB_In.EOATReq_Ack.13;		(*EOAT ACK  8192*)
	Out_To_ECAT.Robot_IN[143]:= EOAT_Req.14 AND FB_In.EOATReq_Ack.14;		(*EOAT ACK  16384*)
	Out_To_ECAT.Robot_IN[144]:= EOAT_Req.15 AND FB_In.EOATReq_Ack.15;		(*EOAT ACK  31768*)


	Out_To_ECAT.Robot_IN[145]:= FB_In.Task_ID.0;							(*Task ID ACK 1*)
	Out_To_ECAT.Robot_IN[146]:= FB_In.Task_ID.1;							(*Task ID ACK 2*)
	Out_To_ECAT.Robot_IN[147]:= FB_In.Task_ID.2;							(*Task ID ACK 4*)
	Out_To_ECAT.Robot_IN[148]:= FB_In.Task_ID.3;							(*Task ID ACK 8*)
	Out_To_ECAT.Robot_IN[149]:= FB_In.Task_ID.4;							(*Task ID ACK 16*)
	Out_To_ECAT.Robot_IN[150]:= FB_In.Task_ID.5;							(*Task ID ACK 32*)
	Out_To_ECAT.Robot_IN[151]:= FB_In.Task_ID.6;							(*Task ID ACK 64*)
	Out_To_ECAT.Robot_IN[152]:= FB_In.Task_ID.7;							(*Task ID ACK 128*)
	Out_To_ECAT.Robot_IN[153]:= FB_In.Task_ID.8;							(*Task ID ACK 256*)
	Out_To_ECAT.Robot_IN[154]:= FB_In.Task_ID.9;							(*Task ID ACK 512*)
	Out_To_ECAT.Robot_IN[155]:= FB_In.Task_ID.10;							(*Task ID ACK 1024*)
	Out_To_ECAT.Robot_IN[156]:= FB_In.Task_ID.11;							(*Task ID ACK 2048*)
	Out_To_ECAT.Robot_IN[157]:= FB_In.Task_ID.12;							(*Task ID ACK 4096*)
	Out_To_ECAT.Robot_IN[158]:= FB_In.Task_ID.13;							(*Task ID ACK 8192*)
	Out_To_ECAT.Robot_IN[159]:= FB_In.Task_ID.14;							(*Task ID ACK 16384*)
	Out_To_ECAT.Robot_IN[160]:= FB_In.Task_ID.15;							(*Task ID ACK 32768*)


	Out_To_ECAT.Robot_IN[161]:= Aux_Req.0 AND FB_In.AuxReq_Ack.0;			(*Auxilary Equipment Request 1 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[162]:= Aux_Req.1 AND FB_In.AuxReq_Ack.1;			(*Auxilary Equipment Request 2 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[163]:= Aux_Req.2 AND FB_In.AuxReq_Ack.2;			(*Auxilary Equipment Request 4 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[164]:= Aux_Req.3 AND FB_In.AuxReq_Ack.3;			(*Auxilary Equipment Request 8 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[165]:= Aux_Req.4 AND FB_In.AuxReq_Ack.4;			(*Auxilary Equipment Request 16 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[166]:= Aux_Req.5 AND FB_In.AuxReq_Ack.5;			(*Auxilary Equipment Request 32 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[167]:= Aux_Req.6 AND FB_In.AuxReq_Ack.6;			(*Auxilary Equipment Request 64 (Reposition request etc.)*)
	Out_To_ECAT.Robot_IN[168]:= Aux_Req.7 AND FB_In.AuxReq_Ack.7;			(*Auxilary Equipment Request 128 (Reposition request etc.)*)


	IF FB_In.Robot_Type<>KUKA_KRC4c_SAFEOP_AGILUS
		THEN
			(*WCU#1*)
			Out_To_ECAT.Robot_IN[169]:= NOT FB_In.Weld_Inhibit;											(*To WCU - Weld Enable*)
			Out_To_ECAT.Robot_IN[170]:= FB_In.Alarm_RST;												(*To WCU - Alarm Reset*)
			Out_To_ECAT.Robot_IN[171]:= WS[1].Cooling_OK OR FB_In.Option_Disable_WaterFLT;			(*To WCU - System Cooling OK*)
			Out_To_ECAT.Robot_IN[172]:= FALSE;														(*To WCU - Spare*)
			Out_To_ECAT.Robot_IN[173]:= Safety_PeriReady;												(*To WCU - Control Stop*)
			Out_To_ECAT.Robot_IN[174]:= TRUE;														(*To WCU - Iso Contactor Saver*)
			Out_To_ECAT.Robot_IN[176]:= ((Task_ID_Ack = 354) OR (Task_ID_Ack = 355))
										AND Task_Completed;											(*To WCU - Reset All Steppers*)
			Out_To_ECAT.Robot_IN[185]:= FALSE;														(*To WCU - Reset Stepper GR1*)
			Out_To_ECAT.Robot_IN[186]:= FALSE;														(*To WCU - Reset Stepper GR2*)
			(*WCU#2*)
			Out_To_ECAT.Robot_IN[201]:= NOT FB_In.Weld_Inhibit;											(*To WCU - Weld Enable*)
			Out_To_ECAT.Robot_IN[202]:= FB_In.Alarm_RST;												(*To WCU - Alarm Reset*)
			Out_To_ECAT.Robot_IN[203]:= WS[2].Cooling_OK OR FB_In.Option_Disable_WaterFLT;			(*To WCU - System Cooling OK*)
			Out_To_ECAT.Robot_IN[204]:= FALSE;														(*To WCU - Spare*)
			Out_To_ECAT.Robot_IN[205]:= Safety_PeriReady;												(*To WCU - Control Stop*)
			Out_To_ECAT.Robot_IN[206]:= TRUE;														(*To WCU - Iso Contactor Saver*)
			Out_To_ECAT.Robot_IN[208]:= ((Task_ID_Ack = 354) OR (Task_ID_Ack = 355))
										AND Task_Completed;											(*To WCU - Reset All Steppers*)
			Out_To_ECAT.Robot_IN[217]:= FALSE;														(*To WCU - Reset Stepper GR1*)
			Out_To_ECAT.Robot_IN[218]:= FALSE;														(*To WCU - Reset Stepper GR2*)
			(*WCU#3*)
			Out_To_ECAT.Robot_IN[233]:= NOT FB_In.Weld_Inhibit;											(*To WCU - Weld Enable*)
			Out_To_ECAT.Robot_IN[234]:= FB_In.Alarm_RST;												(*To WCU - Alarm Reset*)
			Out_To_ECAT.Robot_IN[235]:= WS[2].Cooling_OK OR FB_In.Option_Disable_WaterFLT;			(*To WCU - System Cooling OK*) (*de bug will need to tie to WS[3] once it is developed - JVD*)
			Out_To_ECAT.Robot_IN[236]:= FALSE;														(*To WCU - Spare*)
			Out_To_ECAT.Robot_IN[237]:= Safety_PeriReady;												(*To WCU - Control Stop*)
			Out_To_ECAT.Robot_IN[238]:= TRUE;														(*To WCU - Iso Contactor Saver*)
			Out_To_ECAT.Robot_IN[240]:= ((Task_ID_Ack = 354) OR (Task_ID_Ack = 355))
										AND Task_Completed;											(*To WCU - Reset All Steppers*)
			Out_To_ECAT.Robot_IN[249]:= FALSE;														(*To WCU - Reset Stepper GR1*)
			Out_To_ECAT.Robot_IN[250]:= FALSE;														(*To WCU - Reset Stepper GR2*)
			(*WCU#4*)
			Out_To_ECAT.Robot_IN[265]:= NOT FB_In.Weld_Inhibit;											(*To WCU - Weld Enable*)
			Out_To_ECAT.Robot_IN[266]:= FB_In.Alarm_RST;												(*To WCU - Alarm Reset*)
			Out_To_ECAT.Robot_IN[267]:= WS[2].Cooling_OK OR FB_In.Option_Disable_WaterFLT;			(*To WCU - System Cooling OK*)(*de bug will need to tie to WS[4] once it is developed - JVD*)
			Out_To_ECAT.Robot_IN[268]:= FALSE;														(*To WCU - Spare*)
			Out_To_ECAT.Robot_IN[269]:= Safety_PeriReady;												(*To WCU - Control Stop*)
			Out_To_ECAT.Robot_IN[270]:= TRUE;														(*To WCU - Iso Contactor Saver*)
			Out_To_ECAT.Robot_IN[272]:= ((Task_ID_Ack = 354) OR (Task_ID_Ack = 355))
										AND Task_Completed;											(*To WCU - Reset All Steppers*)
			Out_To_ECAT.Robot_IN[281]:= FALSE;														(*To WCU - Reset Stepper GR1*)
			Out_To_ECAT.Robot_IN[282]:= FALSE;														(*To WCU - Reset Stepper GR2*)

			(*NOTE: New Fronius TPSi, b.lekx-toniolo (20170531)*)
			Out_To_ECAT.Robot_IN[313]:=  FB_In.Weld_Inhibit;
			Out_To_ECAT.Robot_IN[314]:= FB_In.Alarm_RST;

			(*NOTE: old Fronius CMT, b.lekx-toniolo (20170531)*)
			(*
			Out_To_ECAT.Robot_IN[353]:= NOT FB_In.Weld_Inhibit;
			Out_To_ECAT.Robot_IN[354]:= FB_In.Alarm_RST;
			*)

	ELSE (*Map as required for other robot type*)
			Out_To_ECAT.Robot_IN[169]:= FALSE;
			Out_To_ECAT.Robot_IN[170]:= FALSE;
			Out_To_ECAT.Robot_IN[171]:= FALSE;
			Out_To_ECAT.Robot_IN[172]:= FALSE;
			Out_To_ECAT.Robot_IN[173]:= FALSE;
			Out_To_ECAT.Robot_IN[174]:= FALSE;
			Out_To_ECAT.Robot_IN[176]:= FALSE;
			Out_To_ECAT.Robot_IN[185]:= FALSE;
			Out_To_ECAT.Robot_IN[186]:= FALSE;

			Out_To_ECAT.Robot_IN[201]:= FALSE;
			Out_To_ECAT.Robot_IN[202]:= FALSE;
			Out_To_ECAT.Robot_IN[203]:= FALSE;
			Out_To_ECAT.Robot_IN[204]:= FALSE;
			Out_To_ECAT.Robot_IN[205]:= FALSE;
			Out_To_ECAT.Robot_IN[208]:= FALSE;
			Out_To_ECAT.Robot_IN[217]:= FALSE;
			Out_To_ECAT.Robot_IN[218]:= FALSE;

	END_IF;





















(*end*)]]></ST>
      </Implementation>
    </Action>
    <LineIds Name="FB_GTAC_Kuka_CUSTOM">
