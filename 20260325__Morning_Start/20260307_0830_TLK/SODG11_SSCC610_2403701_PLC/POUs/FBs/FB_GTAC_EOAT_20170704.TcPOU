	ACK_AllSensors_ON: BOOL;
	ACK_SensorsOFF_Grp1: BOOL;
	ACK_SensorsON_Grp1: BOOL;
	ACK_SensorsOFF_Grp2: BOOL;
	ACK_SensorsON_Grp2: BOOL;
