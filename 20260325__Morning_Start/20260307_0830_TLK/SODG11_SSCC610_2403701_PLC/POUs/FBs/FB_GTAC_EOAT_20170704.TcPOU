			(*All sensor input mapping and solenoid mapping is done external to FB by end deployment*)
			Home_Sensor:= MAP_Clamp17_HomeSens,
			Work_Sensor:= MAP_Clamp17_WorkSens,
			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp17_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp17_WorkReqd),
			Home_Delay:= T#0.1s,
			Work_Delay:= T#0.1s ,
			Fault_Delay:= T#3s ,
			In_Home_Position=> Clamp17HOME,
			In_Work_Position=> Clamp17WORK,
			);
			CLFaults1.17:= Clamp17FB.Faulted AND Clamp_Count>=17; 		(*Interlock Clamp Fault with Clamp Count Configuration Data*)
		(*Clamp18*)
		Clamp18FB(
			(*All sensor input mapping and solenoid mapping is done external to FB by end deployment*)
			Home_Sensor:= MAP_Clamp18_HomeSens,
			Work_Sensor:= MAP_Clamp18_WorkSens,
			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp18_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp18_WorkReqd),
			Home_Delay:= T#0.1s,
			Work_Delay:= T#0.1s ,
			Fault_Delay:= T#3s ,
			In_Home_Position=> Clamp18HOME,
			In_Work_Position=> Clamp18WORK,
			);
			CLFaults1.18:= Clamp18FB.Faulted AND Clamp_Count>=18; 		(*Interlock Clamp Fault with Clamp Count Configuration Data*)
		(*Clamp19*)
		Clamp19FB(
			(*All sensor input mapping and solenoid mapping is done external to FB by end deployment*)
			Home_Sensor:= MAP_Clamp19_HomeSens,
			Work_Sensor:= MAP_Clamp19_WorkSens,
			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp19_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp19_WorkReqd),
			Home_Delay:= T#0.1s,
			Work_Delay:= T#0.1s ,
			Fault_Delay:= T#3s ,
			In_Home_Position=> Clamp19HOME,
			In_Work_Position=> Clamp19WORK,
			);
			CLFaults1.19:= Clamp19FB.Faulted AND Clamp_Count>=19; 		(*Interlock Clamp Fault with Clamp Count Configuration Data*)
		(*Clamp20*)
		Clamp20FB(
			(*All sensor input mapping and solenoid mapping is done external to FB by end deployment*)
			Home_Sensor:= MAP_Clamp20_HomeSens,
			Work_Sensor:= MAP_Clamp20_WorkSens,
			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp20_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp20_WorkReqd),
			Home_Delay:= T#0.1s,
			Work_Delay:= T#0.1s ,
			Fault_Delay:= T#3s ,
			In_Home_Position=> Clamp20HOME,
			In_Work_Position=> Clamp20WORK,
			);
			CLFaults1.20:= Clamp20FB.Faulted AND Clamp_Count>=20; 		(*Interlock Clamp Fault with Clamp Count Configuration Data*)

(*---------------------------------------------------- Group Clamp Sensors ----------------------------------------------------------------*)

	(*Tool All Home*)
	Tool_At_Home.0:= (Clamp1HOME OR Clamp_Count<1)
						AND (Clamp2HOME OR Clamp_Count<2)
						AND (Clamp3HOME OR Clamp_Count<3)
						AND (Clamp4HOME OR Clamp_Count<4)
						AND (Clamp5HOME OR Clamp_Count<5)
						AND (Clamp6HOME OR Clamp_Count<6)
						AND (Clamp7HOME OR Clamp_Count<7)
						AND (Clamp8HOME OR Clamp_Count<8)
						AND (Clamp9HOME OR Clamp_Count<9)
						AND (Clamp10HOME OR Clamp_Count<10)
						AND (Clamp11HOME OR Clamp_Count<11)
						AND (Clamp12HOME OR Clamp_Count<12)
						AND (Clamp13HOME OR Clamp_Count<13)
						AND (Clamp14HOME OR Clamp_Count<14)
						AND (Clamp15HOME OR Clamp_Count<15)
						AND (Clamp16HOME OR Clamp_Count<16)
						AND (Clamp17HOME OR Clamp_Count<17)
						AND (Clamp18HOME OR Clamp_Count<18)
						AND (Clamp19HOME OR Clamp_Count<19)
						AND (Clamp20HOME OR Clamp_Count<20);
	(*Tool All Work*)
	Tool_At_Work.0:= (Clamp1WORK OR Clamp_Count<1)
						AND (Clamp2WORK OR Clamp_Count<2)
						AND (Clamp3WORK OR Clamp_Count<3)
						AND (Clamp4WORK OR Clamp_Count<4)
						AND (Clamp5WORK OR Clamp_Count<5)
						AND (Clamp6WORK OR Clamp_Count<6)
						AND (Clamp7WORK OR Clamp_Count<7)
						AND (Clamp8WORK OR Clamp_Count<8)
						AND (Clamp9WORK OR Clamp_Count<9)
						AND (Clamp10WORK OR Clamp_Count<10)
						AND (Clamp11WORK OR Clamp_Count<11)
						AND (Clamp12WORK OR Clamp_Count<12)
						AND (Clamp13WORK OR Clamp_Count<13)
						AND (Clamp14WORK OR Clamp_Count<14)
						AND (Clamp15WORK OR Clamp_Count<15)
						AND (Clamp16WORK OR Clamp_Count<16)
						AND (Clamp17WORK OR Clamp_Count<17)
						AND (Clamp18WORK OR Clamp_Count<18)
						AND (Clamp19WORK OR Clamp_Count<19)
						AND (Clamp20WORK OR Clamp_Count<20);

(*Note: The remaining Tool_At bits are used for groups and are mapped outside of FB by end deployment*)
	(*Group 1*)
	Tool_At_Home.1:= Tool_At_Home_Grp1;
	Tool_At_Work.1:= Tool_At_Work_Grp1;
	(*Group 2*)
	Tool_At_Home.2:= Tool_At_Home_Grp2;
	Tool_At_Work.2:= Tool_At_Work_Grp2;
	(*Group 3*)
	Tool_At_Home.3:= Tool_At_Home_Grp3;
	Tool_At_Work.3:= Tool_At_Work_Grp3;
	(*Group 4*)
	Tool_At_Home.4:= Tool_At_Home_Grp4;
	Tool_At_Work.4:= Tool_At_Work_Grp4;
	(*Group 5*)
	Tool_At_Home.5:= Tool_At_Home_Grp5;
	Tool_At_Work.5:= Tool_At_Work_Grp5;
	(*Group 6*)
	Tool_At_Home.6:= Tool_At_Home_Grp6;
	Tool_At_Work.6:= Tool_At_Work_Grp6;
	(*Group 7*)
	Tool_At_Home.7:= Tool_At_Home_Grp7;
	Tool_At_Work.7:= Tool_At_Work_Grp7;
	(*Group 8*)
	Tool_At_Home.8:= Tool_At_Home_Grp8;
	Tool_At_Work.8:= Tool_At_Work_Grp8;

(*------------------------------------------------------------ Gather Part Present Sensor Inputs -----------------------------------------------*)
(*Part Present Inputs*)

	(*Part 1 Present*)
		Part_Present1FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP1_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP1_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP1_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present1,
			);
			PPFaults.1:= Part_Present1FB.Faulted AND Part_Present_Count>=1;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 2 Present*)
		Part_Present2FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP2_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP2_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP2_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present2,
			);
			PPFaults.2:= Part_Present2FB.Faulted AND Part_Present_Count>=2;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 3 Present*)
		Part_Present3FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP3_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP3_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP3_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present3,
			);
			PPFaults.3:= Part_Present3FB.Faulted AND Part_Present_Count>=3;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 4 Present*)
		Part_Present4FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP4_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP4_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP4_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present4,
			);
			PPFaults.4:= Part_Present4FB.Faulted AND Part_Present_Count>=4;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 5 Present*)
		Part_Present5FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP5_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP5_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP5_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present5,
			);
			PPFaults.5:= Part_Present5FB.Faulted AND Part_Present_Count>=5;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 6 Present*)
		Part_Present6FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP6_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP6_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP6_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present6,
			);
			PPFaults.6:= Part_Present6FB.Faulted AND Part_Present_Count>=6;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 7 Present*)
		Part_Present7FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP7_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP7_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP7_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present7,
			);
			PPFaults.7:= Part_Present7FB.Faulted AND Part_Present_Count>=7;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)
	(*Part 8 Present*)
		Part_Present8FB(
			(*All Sensor Input mapping and Trigger on/off_1 mapping done external to FB by end deloyment*)
			Sensor_Input:= MAP_PP8_Sens,
			On_Trigger1:= CMD_CheckAllSensors_ON OR MAP_PP8_ReqdOn,
			On_Trigger2:= TRUE,
			Off_Trigger1:= CMD_CheckAllSensors_OFF OR MAP_PP8_ReqdOff,
			On_Trigger2:= TRUE,
			Disable_Faults:= FALSE,
			Fault_Delay:= T#1.5s,
			Status=> Part_Present8,
			);
			PPFaults.8:= Part_Present8FB.Faulted AND Part_Present_Count>=8;		(*Interlock Part Present Fault with Part Present Count Configuration Data*)

(*---------------------------------------------------- Group Part Present Sensors ----------------------------------------------------------------*)

	(*All Sensors Off*)
	All_Sensors_Off.0:= NOT Part_Present1 AND NOT Part_Present2 AND NOT  Part_Present3
					AND NOT Part_Present4 AND NOT Part_Present5 AND NOT Part_Present6
					AND NOT Part_Present7 AND NOT Part_Present8;
	(*All Sensors On*)
	All_Sensors_On.0:= ((Part_Present1 OR Part_Present_Count<1)
						AND (Part_Present2 OR Part_Present_Count<2)
						AND (Part_Present3 OR Part_Present_Count<3)
						AND (Part_Present4 OR Part_Present_Count<4)
						AND (Part_Present5 OR Part_Present_Count<5)
						AND (Part_Present6 OR Part_Present_Count<6)
						AND (Part_Present7 OR Part_Present_Count<7)
						AND (Part_Present8 OR Part_Present_Count<8))
					OR (All_Sensors_Off.0 AND Dry_Cycle);

(*Note: The remaining All_Sensors_On bits are used for groups and are mapped outside of FB by end deployment*)

	(*All Sensors On Designated for Group 1*)
	All_Sensors_On.1:= (All_Sensors_On_Grp1 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.1:= All_Sensors_Off_Grp1;

	(*All Sensors On Designated for Group 2*)
	All_Sensors_On.2:= (All_Sensors_On_Grp2 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.2:= All_Sensors_Off_Grp2;

	(*All Sensors On Designated for Group 3*)
	All_Sensors_On.3:= (All_Sensors_On_Grp3 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.3:= All_Sensors_Off_Grp3;

	(*All Sensors On Designated for Group 4*)
	All_Sensors_On.4:= (All_Sensors_On_Grp4 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.4:= All_Sensors_Off_Grp4;

	(*All Sensors On Designated for Group 5*)
	All_Sensors_On.5:= (All_Sensors_On_Grp5 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.5:= All_Sensors_Off_Grp5;

	(*All Sensors On Designated for Group 6*)
	All_Sensors_On.6:= (All_Sensors_On_Grp6 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.6:= All_Sensors_Off_Grp6;

	(*All Sensors On Designated for Group 7*)
	All_Sensors_On.7:= (All_Sensors_On_Grp7 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.7:= All_Sensors_Off_Grp7;

	(*All Sensors On Designated for Group 8*)
	All_Sensors_On.8:= (All_Sensors_On_Grp8 AND NOT Dry_Cycle)
					OR (All_Sensors_Off.0 AND Dry_Cycle);
	(*All Sensors Off Designated for Group 1*)
	All_Sensors_Off.8:= All_Sensors_Off_Grp8;



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Faults $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Clamp/Cylinder Faults*)
		IF CLFaults1>0
			THEN CLFaulted.1:=TRUE;
		ELSE
			CLFaulted.1:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults2>0
			THEN CLFaulted.2:=TRUE;
		ELSE
			CLFaulted.2:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults3>0
			THEN CLFaulted.3:=TRUE;
		ELSE
			CLFaulted.3:=FALSE;
		END_IF;
	(*Spare Fault Word*)
		IF CLFaults4>0
			THEN CLFaulted.4:=TRUE;
		ELSE
			CLFaulted.4:=FALSE;
		END_IF;
	(*Bit 0 is designated as ANY Clamp Fault Word Faulted*)
	IF CLFaulted.1 OR CLFaulted.2 OR CLFaulted.3
		THEN CLFaulted.0:= TRUE;
	ELSE CLFaulted.0 := FALSE;
	END_IF;

	(*Part Present Sensor Faults*)
		IF PPFaults>0
			THEN PPFaulted.0:=TRUE;
		ELSE
			PPFaulted.0:=FALSE;
		END_IF;



(*$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ Transfer Standard Outputs $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$*)
	(*Transfer General Status and I/O Images for Display On HMI*)
	Discrete_Image.CLFaults1:= CLFaults1;
	Discrete_Image.CLFaults2:= CLFaults2;
	Discrete_Image.CLFaults3:= CLFaults3;
	Discrete_Image.CLFaults4:= CLFaults4;
	Discrete_Image.CLFaulted:= CLFaulted;
	Discrete_Image.PPFaults:= PPFaults;
	Discrete_Image.PPFaulted:= PPFaulted;

	Discrete_Image.N01:=N01;
	Discrete_Image.N02:=N02;
	Discrete_Image.N03:=N03;
	Discrete_Image.N04:=N04;
	Discrete_Image.N05:=N05;
	Discrete_Image.N06:=N06;
	Discrete_Image.N07:=N07;
	Discrete_Image.N08:=N08;
	Discrete_Image.N09:=N09;
	Discrete_Image.N100:=N100;
	Discrete_Image.N100_STAT:=N100_STAT;

	Discrete_Image.ECatSlave_Cable_Breaks:= ECatSlave_Cable_Breaks;
	Discrete_Image.Input_Node_Count:= Input_Node_Count;
	Discrete_Image.VB_Node_Count:= VB_Node_Count;

(*---------------------------------------------------------------------------------------- Transfer ACKS Back to external of FB ----------------------------------------------------------*)

	ACK_AllSensors_OFF:= CMD_CheckAllSensors_OFF AND All_Sensors_Off.0;
	ACK_AllSensors_ON:= CMD_CheckAllSensors_ON AND All_Sensors_On.0;

	ACK_SensorsOFF_Grp1:= CMD_CheckSensorsOFF_Grp1 AND All_Sensors_Off.1;
	ACK_SensorsON_Grp1:= CMD_CheckSensorsON_Grp1 AND All_Sensors_On.1;
	ACK_SensorsOFF_Grp2:= CMD_CheckSensorsOFF_Grp2 AND All_Sensors_Off.2;
	ACK_SensorsON_Grp2:= CMD_CheckSensorsON_Grp2 AND All_Sensors_On.2;
	ACK_SensorsOFF_Grp3:= CMD_CheckSensorsOFF_Grp3 AND All_Sensors_Off.3;
	ACK_SensorsON_Grp3:= CMD_CheckSensorsON_Grp3 AND All_Sensors_On.3;
	ACK_SensorsOFF_Grp4:= CMD_CheckSensorsOFF_Grp4 AND All_Sensors_Off.4;
	ACK_SensorsON_Grp4:= CMD_CheckSensorsON_Grp4 AND All_Sensors_On.4;
	ACK_SensorsOFF_Grp5:= CMD_CheckSensorsOFF_Grp5 AND All_Sensors_Off.5;
	ACK_SensorsON_Grp5:= CMD_CheckSensorsON_Grp5 AND All_Sensors_On.5;
	ACK_SensorsOFF_Grp6:= CMD_CheckSensorsOFF_Grp6 AND All_Sensors_Off.6;
	ACK_SensorsON_Grp6:= CMD_CheckSensorsON_Grp6 AND All_Sensors_On.6;
	ACK_SensorsOFF_Grp7:= CMD_CheckSensorsOFF_Grp7 AND All_Sensors_Off.7;
	ACK_SensorsON_Grp7:= CMD_CheckSensorsON_Grp7 AND All_Sensors_On.7;
	ACK_SensorsOFF_Grp8:= CMD_CheckSensorsOFF_Grp8 AND All_Sensors_Off.8;
	ACK_SensorsON_Grp8:= CMD_CheckSensorsON_Grp8 AND All_Sensors_On.8;

	IF LH_Part_In_EOAT_Grp AND NOT LH_EOAT_Empty_Grp
		THEN LH_Part_In_EOAT:= TRUE;
	ELSIF  LH_EOAT_Empty_Grp
		THEN LH_Part_In_EOAT:= FALSE;
	END_IF;

	IF RH_Part_In_EOAT_Grp AND NOT RH_EOAT_Empty_Grp
		THEN RH_Part_In_EOAT:= TRUE;
	ELSIF  RH_EOAT_Empty_Grp
		THEN RH_Part_In_EOAT:= FALSE;
	END_IF;

	IF (LH_Part_In_EOAT_Grp AND RH_Part_In_EOAT_Grp)
		AND (NOT LH_EOAT_Empty_Grp AND NOT RH_EOAT_Empty_Grp)
		THEN Part_In_EOAT:= TRUE;
	ELSIF  (LH_EOAT_Empty_Grp AND RH_EOAT_Empty_Grp)
		THEN Part_In_EOAT:= FALSE;
	END_IF;

	ACK_Tool_At_WORK:= CMD_Tool_To_WORK AND Tool_At_WORK.0;
	ACK_Tool_At_HOME:= CMD_Tool_To_HOME AND Tool_At_HOME.0;

	ACK_ClampsAtWORK_Grp1:= CMD_ClampsToWORK_Grp1 AND Tool_At_WORK.1;
	ACK_ClampsAtHOME_Grp1:= CMD_ClampsToHOME_Grp1 AND Tool_At_HOME.1;
	ACK_ClampsAtWORK_Grp2:= CMD_ClampsToWORK_Grp2 AND Tool_At_WORK.2;
	ACK_ClampsAtHOME_Grp2:= CMD_ClampsToHOME_Grp2 AND Tool_At_HOME.2;
	ACK_ClampsAtWORK_Grp3:= CMD_ClampsToWORK_Grp3 AND Tool_At_WORK.3;
	ACK_ClampsAtHOME_Grp3:= CMD_ClampsToHOME_Grp3 AND Tool_At_HOME.3;
	ACK_ClampsAtWORK_Grp4:= CMD_ClampsToWORK_Grp4 AND Tool_At_WORK.4;
	ACK_ClampsAtHOME_Grp4:= CMD_ClampsToHOME_Grp4 AND Tool_At_HOME.4;
	ACK_ClampsAtWORK_Grp5:= CMD_ClampsToWORK_Grp5 AND Tool_At_WORK.5;
	ACK_ClampsAtHOME_Grp5:= CMD_ClampsToHOME_Grp5 AND Tool_At_HOME.5;
	ACK_ClampsAtWORK_Grp6:= CMD_ClampsToWORK_Grp6 AND Tool_At_WORK.6;
	ACK_ClampsAtHOME_Grp6:= CMD_ClampsToHOME_Grp6 AND Tool_At_HOME.6;
	ACK_ClampsAtWORK_Grp7:= CMD_ClampsToWORK_Grp7 AND Tool_At_WORK.7;
	ACK_ClampsAtHOME_Grp7:= CMD_ClampsToHOME_Grp7 AND Tool_At_HOME.7;
	ACK_ClampsAtWORK_Grp8:= CMD_ClampsToWORK_Grp8 AND Tool_At_WORK.8;
	ACK_ClampsAtHOME_Grp8:= CMD_ClampsToHOME_Grp8 AND Tool_At_HOME.8;


(*-----------------------------------------------------------------------------------------Transfer Valve Outputs --------------------------------------------------------------------------------*)

	(*Valve 1, A+B*)
	(*Clamp Group 1*)
		Valve1FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= FALSE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.1S,
			Enable_Auto_Commands:= Enable_Motion,
			In_Auto_SideA_Command:= CMD_Tool_To_WORK OR CMD_ClampsToWORK_Grp1,
			In_Auto_SideB_Command:= CMD_Tool_To_HOME OR CMD_ClampsToHOME_Grp1,
			Enable_Manual_Commands:= FALSE,
			In_Manual_SideA_Command:= FALSE,
			In_Manual_SideB_Command:= FALSE,
			SideA_Indicator:= Tool_At_WORK.1,
			SideB_Indicator:= Tool_At_HOME.1,
			TurnOn_SideA_SOL=> N100.Q.0,
			TurnOn_SideB_SOL=> N100.Q.1,
			TurnOn_SideA_Indicator=> ,
			TurnOn_SideB_Indicator=>
			 );
	(*Valve 2, A+B*)
