			Home_Sensor:= MAP_Clamp16_HomeSens,
			Work_Sensor:= MAP_Clamp16_WorkSens,
			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp16_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp16_WorkReqd),
