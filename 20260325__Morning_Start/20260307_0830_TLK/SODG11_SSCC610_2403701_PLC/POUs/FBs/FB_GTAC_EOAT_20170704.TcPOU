			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.1S,
			Enable_Auto_Commands:= Enable_Motion,
			In_Auto_SideA_Command:= CMD_ClampsToWORK_Grp3,
			In_Auto_SideB_Command:= CMD_ClampsToHome_Grp3,
			Enable_Manual_Commands:= FALSE,
			In_Manual_SideA_Command:= FALSE,
			In_Manual_SideB_Command:= FALSE,
			SideA_Indicator:= Tool_At_WORK.3,
			SideB_Indicator:= Tool_At_HOME.3,
			TurnOn_SideA_SOL=> N100.Q.4,
			TurnOn_SideB_SOL=> N100.Q.5,
			TurnOn_SideA_Indicator=> ,
			TurnOn_SideB_Indicator=>
			 );
	(*Valve 4, A+B*)
	(*Clamp Group 4*)
		Valve4FB
			(
			Enable_Motion:= Enable_Motion ,
			Enable_Latch:= FALSE,					(*Enabling Runs Valve as detent type (maintained solenoids*)
			Enable_SideA_PreCharge:= FALSE,		(*Enabling Turns Side A PreCharge Active, reset when Side B is energized in Auto*)
			Enable_SideB_PreCharge:= FALSE,		(*Enabling Turns Side B PreCharge Active, reset when Side A is energized in Auto*)
			PreCharge_Time:= T#0.1S,
			Enable_Auto_Commands:= Enable_Motion,
			In_Auto_SideA_Command:= CMD_ClampsToWORK_Grp4,
			In_Auto_SideB_Command:= CMD_ClampsToHome_Grp4,
			Enable_Manual_Commands:= FALSE,
			In_Manual_SideA_Command:= FALSE,
			In_Manual_SideB_Command:= FALSE,
			SideA_Indicator:= Tool_At_WORK.4,
			SideB_Indicator:= Tool_At_HOME.4,
			TurnOn_SideA_SOL=> N100.Q.6,
			TurnOn_SideB_SOL=> N100.Q.7,
			TurnOn_SideA_Indicator=> ,
			TurnOn_SideB_Indicator=>
			 );
	(*Valve 5, A+B*)
