		Clamp17FB: FB_Clamp_Status;
		Clamp18FB: FB_Clamp_Status;
		Clamp19FB: FB_Clamp_Status;
		Clamp20FB: FB_Clamp_Status;
		Part_Present1FB: FB_PP_Sensor;
