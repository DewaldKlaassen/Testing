			Home_Solenoid:= Enable_Motion AND (CMD_Tool_To_HOME OR MAP_Clamp13_HomeReqd),
			Work_Solenoid:= Enable_Motion AND (CMD_Tool_To_WORK OR MAP_Clamp13_WorkReqd),
