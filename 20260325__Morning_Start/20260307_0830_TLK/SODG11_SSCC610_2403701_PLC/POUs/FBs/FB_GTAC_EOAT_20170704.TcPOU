VAR
(*Hardware Related Data Types*)
			(*Develop "Beckhoff Nodes"*)
			N01 AT %I*: udt_EP1008_002_v2;
			N02 AT %I*: udt_EP1008_002_v2;
			N03 AT %I*: udt_EP1008_002_v2;
			N04 AT %I*: udt_EP1008_002_v2;
			N05 AT %I*: udt_EP1008_002_v2;
			N06 AT %I*: udt_EP1008_002_v2;
			N07 AT %I*: udt_EP1008_002_v2;
			N08 AT %I*: udt_EP1008_002_v2;
			N09 AT %I*: udt_EP1008_002_v2;
			N100 AT %Q*: udt_SMC_EX260_ValveBank;
			N100_STAT AT %I*:udt_SMC_EX260_Stat;

(* Nodes States*)
	DiscreteNode_OK: BOOL;
(* Cable Break States*)
	ECatSlave_Cable_Breaks: UDINT;

(*Standard Internal Variables*)
		(*Generic Sensor Variables*)
		All_Sensors_On: UINT;
		All_Sensors_Off: UINT;
		(*Generic Position Variables*)
		Tool_At_Home: UINT;
		Tool_At_Work: UINT;
		(*General Internals*)
		CLFaulted: UDINT;
		PPFaulted: UDINT;

(*Non-Standard Variables*)

		(*FB Instances*)
		Clamp1FB: FB_Clamp_Status;
		Clamp2FB: FB_Clamp_Status;
		Clamp3FB: FB_Clamp_Status;
		Clamp4FB: FB_Clamp_Status;
		Clamp5FB: FB_Clamp_Status;
