		Valve6FB: FB_GTAC_Valve_20170704;
		Valve7FB: FB_GTAC_Valve_20170704;
		Valve8FB: FB_GTAC_Valve_20170704;

		(*Tool Positions*)
			Clamp1WORK: BOOL;
			Clamp1HOME: BOOL;
			Clamp2WORK: BOOL;
			Clamp2HOME: BOOL;
			Clamp3WORK: BOOL;
			Clamp3HOME: BOOL;
