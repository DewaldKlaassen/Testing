	SICMarker_Outputs.Output1_1[5].1 :=TRUE;

	END_CASE

	(*Increase Variable counter *)
	IF Y < 10 THEN
		Y:=Y+1;
	END_IF

	(*Wait for all PLC variables to match their registers *)
	IF Y > 10 THEN
		AllVariablesOK := (SICMarker_Inputs.Input0_1[2].0  OR Variables[1] = '')
					AND (SICMarker_Inputs.Input0_1[2].1 OR Variables[2] = '')
					AND (SICMarker_Inputs.Input0_1[2].2 OR Variables[3] = '') 
					AND (SICMarker_Inputs.Input0_1[2].3 OR Variables[4] = '')
					AND (SICMarker_Inputs.Input0_1[2].4 OR Variables[5] = '') 
