					AND (SICMarker_Inputs.Input0_1[2].6 OR Variables[7] = '')
					AND (SICMarker_Inputs.Input0_1[2].7 OR Variables[8] = '')
					AND (SICMarker_Inputs.Input0_1[3].0 OR Variables[9] = '') 
					AND (SICMarker_Inputs.Input0_1[2].1 OR Variables[10] = '');
	END_IF

	(*Reset the Bits to send Variable changes, and Variable Counter *)
	IF Y >= 10 AND LoadFile_bool THEN
		Y:=1;
		SICMarker_Outputs.Output1_1[4] :=0;
		SICMarker_Outputs.Output1_1[5] :=0;
	END_IF

