                "symbolExpression": "%ctrl%uc_GTAC_DB_Content::Tooltip%/ctrl%",
                "value": {
                  "objectType": "Symbol",
                  "valueType": "tchmi:general#/definitions/String",
                  "symbolExpression": "%s%GTAC_TcUI_PostgreSQL.CONNECT%/s%"
                },
                "asyncWait": true
              },
              {
                "objectType": "Condition",
                "active": true,
                "parts": [
                  {
                    "if": [
                      {
                        "compare1": {
                          "objectType": "Symbol",
                          "valueType": "string",
                          "symbolExpression": "%pp%Op_DB_Count%/pp%"
                        },
                        "compare2": {
                          "objectType": "StaticValue",
                          "valueType": "tchmi:general#/definitions/UINT",
