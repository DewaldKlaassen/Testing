<div id="img_Kuka_Orng_1" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiImage" data-tchmi-left="38" data-tchmi-left-unit="px" data-tchmi-src="Images/GTAC/Icons/ico_robot_Kuka.png" data-tchmi-top="10" data-tchmi-top-unit="px" data-tchmi-is-enabled="true" data-tchmi-width-mode="Value" data-tchmi-height-mode="Value" data-tchmi-width="46" data-tchmi-height="102" data-tchmi-creator-visibility="Visible">



