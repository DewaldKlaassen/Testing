                "symbolExpression": "%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_455::message%/ctrl%",
                "value": {
                  "objectType": "Symbol",
                  "valueType": "tchmi:general#/definitions/String",
                  "symbolExpression": "%l%RobotTipChange%/l%"
