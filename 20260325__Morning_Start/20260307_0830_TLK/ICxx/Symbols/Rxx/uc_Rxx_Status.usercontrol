              {
                "objectType": "Comment",
                "comment": "Add in custom message below in pure JS"
              },
              {
                "objectType": "JavaScript",
                "active": true,
                "sourceLines": [
                  "// Write various Locale keys to message",
                  "// (locale keys can not be tied directly to the messages, hence the reason to write this way)",
                  "",
                  "//Human Fixtures",
                  "let temp = TcHmi.Symbol.readEx(\"%l%Welding%/l%\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_111::message%/ctrl%\", temp +\" Fix01\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_121::message%/ctrl%\", temp +\" Fix02\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_131::message%/ctrl%\", temp +\" Fix03\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_141::message%/ctrl%\", temp +\" Fix04\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_151::message%/ctrl%\", temp +\" Fix05\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_161::message%/ctrl%\", temp +\" Fix06\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_171::message%/ctrl%\", temp +\" Fix07\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_181::message%/ctrl%\", temp +\" Fix08\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_191::message%/ctrl%\", temp +\" Fix09\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_201::message%/ctrl%\", temp +\" Fix10\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_211::message%/ctrl%\", temp +\" Fix11\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_221::message%/ctrl%\", temp +\" Fix12\");",
                  "TcHmi.Symbol.writeEx(\"%ctrl%Rxx_Status_SmartMessage::message_objects::message_obj_231::message%/ctrl%\", temp +\" Fix13\");",
