          "valueType": "tchmi:general#/definitions/String",
          "symbolExpression": "%f%TcHmi.Functions.ICxx.GTAC_GetSymValue(TcHmi.Functions.ICxx.GTAC_Model_IDUPdater('Fix' +TcHmi.Functions.ICxx.GTAC_ZeroStringPad(%pp%Location_ID%/pp%), %pp%ArrayTarget::Product_Model_ID%/pp%),-1,'l' )%/f%"
