<div id="InShiftChange_Toggle" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-height="30" data-tchmi-height-unit="px" data-tchmi-left="293" data-tchmi-left-unit="px" data-tchmi-target-user-control="Symbols/GTAC Standard UI Controls/uc_GTAC_Toggle_Button.usercontrol" data-tchmi-top="104" data-tchmi-top-unit="px" data-tchmi-width="30" data-tchmi-width-unit="px" data-tchmi-monitor_data="%f%TcHmi.Functions.ICxx.GTAC_ReturnBinary_Bit(%s%PLC1..Out_To_ICxx::ProdConfig_Common::Config_Option_Flags%/s%, 0)%/f%" data-tchmi-disable="%f%%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Source%/s% == 0%/f%">

<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "InShiftChange_Toggle.onMouseUp",
    "actions": [
      {
        "objectType": "SwitchCase",
        "active": true,
        "compare": {
          "objectType": "Symbol",
          "valueType": "tchmi:general#/definitions/String",
          "symbolExpression": "%f%TcHmi.Functions.ICxx.GTAC_ReturnBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Option_Flags%/s%, 0)%/f%"
        },
        "cases": [
          {
            "caseValue": {
              "objectType": "StaticValue",
              "valueType": "tchmi:general#/definitions/String",
              "value": "False"
            },
            "actions": [
              {
                "objectType": "WriteToSymbol",
                "active": true,
                "symbolExpression": "%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Option_Flags%/s%",
                "value": {
                  "objectType": "FunctionExpression",
                  "functionExpression": "TcHmi.Functions.ICxx.GTAC_SetBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Option_Flags%/s%, 0)"
                },
                "asyncWait": true
              }
            ]
          },
          {
            "caseValue": {
              "objectType": "StaticValue",
              "valueType": "tchmi:general#/definitions/String",
              "value": "True"
            },
            "actions": [
              {
                "objectType": "WriteToSymbol",
                "active": true,
                "symbolExpression": "%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Option_Flags%/s%",
                "value": {
                  "objectType": "FunctionExpression",
                  "functionExpression": "TcHmi.Functions.ICxx.GTAC_ClearBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Config_Option_Flags%/s%, 0)"
                },
                "asyncWait": true
              }
            ]
          }
        ],
        "asyncWait": true
      }
    ]
  }
]
</script>
</div>
