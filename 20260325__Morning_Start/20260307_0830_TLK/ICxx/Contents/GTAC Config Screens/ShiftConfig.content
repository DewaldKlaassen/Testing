                "value": {
                  "objectType": "FunctionExpression",
                  "functionExpression": "TcHmi.Functions.ICxx.GTAC_SetBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Shift_Enables%/s%, 1)"
