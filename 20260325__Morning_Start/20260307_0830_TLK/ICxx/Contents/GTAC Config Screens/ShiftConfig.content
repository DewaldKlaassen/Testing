            ]
          },
          {
            "caseValue": {
              "objectType": "StaticValue",
              "valueType": "tchmi:general#/definitions/String",
              "value": "true"
            },
            "actions": [
              {
                "objectType": "WriteToSymbol",
                "active": true,
                "symbolExpression": "%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Shift_Enables%/s%",
                "value": {
                  "objectType": "FunctionExpression",
                  "functionExpression": "TcHmi.Functions.ICxx.GTAC_ClearBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Shift_Enables%/s%, 1)"
                },
