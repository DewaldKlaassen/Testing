        "active": true,
        "compare": {
          "objectType": "Symbol",
          "valueType": "tchmi:general#/definitions/String",
          "symbolExpression": "%f%TcHmi.Functions.ICxx.GTAC_ReturnBinary_Bit(%s%PLC1..In_From_ICxx_Pers::ProdConfig_Common::Shift_Enables%/s%, 1)%/f%"
        },
