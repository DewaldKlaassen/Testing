<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "Content_UI_Config.onAttached",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%FaultRegion::TargetContent%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/ContentPath",
          "value": null
        },
        "asyncWait": true
      },
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//Drop Fault region right off screen                       ",
          "$('#FaultRegion').animate({",
          "                          \ttop: '768px',",
          "                          \t\t});"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  },
  {
    "event": "Content_UI_Config.onDetached",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%FaultRegion::TargetContent%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/ContentPath",
          "value": "Contents/Fault Screens/Faults_Current.content"
        },
        "asyncWait": true
      },
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//Bring Fault region back into exsistance                         ",
          "$('#FaultRegion').animate({",
          "                          \ttop: '669px',",
          "                          \t\t});"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
<div id="Fault_Theme_Selection_Image" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiImage" data-tchmi-height="80" data-tchmi-height-unit="px" data-tchmi-left="301" data-tchmi-left-unit="px" data-tchmi-top="340" data-tchmi-top-unit="px" data-tchmi-width="80" data-tchmi-width-unit="px" data-tchmi-background-image-width="80" data-tchmi-background-image-height="80" data-tchmi-src="Images/GTAC/Icons/UI_Conf_Icons/ico_AlarmTheme1.png">





<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%i%Pulse_500ms%/i%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//Update Image",
          "if (TcHmi.Functions.ICxx.GTAC_EatCookie(\"alarm_textvsbg\", silence_console = true) ==\"red_on_black\") {",
          "\tTcHmi.Symbol.writeEx(\"%ctrl%Fault_Theme_Selection_Image::Src%/ctrl%\", \"Images/GTAC/Icons/UI_Conf_Icons/ico_AlarmTheme1.png\");",
          "} else if (TcHmi.Functions.ICxx.GTAC_EatCookie(\"alarm_textvsbg\", silence_console = true) ==\"black_on_red\") {",
          "\tTcHmi.Symbol.writeEx(\"%ctrl%Fault_Theme_Selection_Image::Src%/ctrl%\", \"Images/GTAC/Icons/UI_Conf_Icons/ico_AlarmTheme2.png\");",
          "}"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>
