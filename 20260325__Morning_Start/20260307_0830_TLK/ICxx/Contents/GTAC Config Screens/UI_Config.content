            "value": null
          }
        ],
        "asyncWait": true
      }
    ]
  },
  {
    "event": "Fault_Theme_Selection_Combobox.onAttached",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//Preload the proper text of the current value of the cookie",
          "if(TcHmi.Functions.ICxx.GTAC_EatCookie(\"alarm_textvsbg\", silence_console = true) == \"red_on_black\"){",
          "\tTcHmi.Symbol.writeEx(\"%ctrl%Fault_Theme_Selection_Combobox::ComboboxText%/ctrl%\", TcHmi.Symbol.readEx(\"%l%red_on_black%/l%\"));",
          "}else if (TcHmi.Functions.ICxx.GTAC_EatCookie(\"alarm_textvsbg\", silence_console = true) == \"black_on_red\"){",
          "\tTcHmi.Symbol.writeEx(\"%ctrl%Fault_Theme_Selection_Combobox::ComboboxText%/ctrl%\", TcHmi.Symbol.readEx(\"%l%black_on_red%/l%\"));",
          "}"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
