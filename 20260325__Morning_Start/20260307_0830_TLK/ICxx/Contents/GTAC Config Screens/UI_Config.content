[
  {
    "event": "Fault_Theme_Selection_Combobox.onSelectionChanged",
    "actions": [
      {
        "objectType": "Function",
        "active": true,
        "fn": "TcHmi.Functions.ICxx.GTAC_BakeCookie",
        "fnParams": [
          {
            "objectType": "StaticValue",
            "valueType": "tchmi:general#/definitions/String",
            "value": "alarm_textvsbg"
          },
          {
            "objectType": "Symbol",
            "valueType": "tchmi:general#/definitions/String",
