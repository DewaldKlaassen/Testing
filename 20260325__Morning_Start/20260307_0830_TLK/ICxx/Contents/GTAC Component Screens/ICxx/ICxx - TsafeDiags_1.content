      &quot;stop&quot;: &quot;50%&quot;
    },
    {
      &quot;color&quot;: &quot;rgba(0, 0, 0, 1)&quot;,
      &quot;stop&quot;: &quot;100%&quot;
    }
  ]
}"
</script>
