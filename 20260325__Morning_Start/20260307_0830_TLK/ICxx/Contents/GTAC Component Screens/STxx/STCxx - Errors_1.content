<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%i%Pulse_500ms%/i%",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%STCxx_Error_Code::Text%/ctrl%",
        "value": {
          "objectType": "Symbol",
          "valueType": "tchmi:general#/definitions/String",
          "symbolExpression": "%f%\"Current Error Code (dec):      \" + (TcHmi.Functions.ICxx.GTAC_GetSymValue(\"PLC1..Out_To_ICxx::Stud[\"+%i%Component_Num%/i%+\"]::In_Image::Byte4\") +  ((TcHmi.Functions.ICxx.GTAC_GetSymValue(\"PLC1..Out_To_ICxx::Stud[\"+%i%Component_Num%/i%+\"]::In_Image::Byte5\")<<8) & 256))%/f%"
        },
        "asyncWait": true
      }
    ]
  }
]
</script>
</div>

