<div id="Fault_CurrentHistroy_SwapperContent" data-tchmi-type="TcHmi.Controls.System.TcHmiContent" data-tchmi-top="0" data-tchmi-left="0" data-tchmi-width="150" data-tchmi-height="75" data-tchmi-zindex="1">

<div id="Faults_History_PB" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiImage" data-tchmi-height="70" data-tchmi-height-unit="px" data-tchmi-left="80" data-tchmi-left-unit="px" data-tchmi-top="0" data-tchmi-top-unit="px" data-tchmi-width="70" data-tchmi-width-unit="px" data-tchmi-is-enabled="true" data-tchmi-zindex="1970" data-tchmi-background-image="Images/GTAC/Icons/ico_warning_history.png" data-tchmi-background-image-width="60" data-tchmi-background-image-height="60" data-tchmi-opacity="0.6">
<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "Faults_History_PB.onPressed",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%FaultRegion::TargetContent%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/ContentPath",
          "value": "Contents/Fault Screens/Faults_History.content"
        },
        "asyncWait": true
      },
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%Faults_History_PB::Opacity%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/Fraction",
          "value": 1.0
        },
        "asyncWait": true
      },
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%Faults_Current_PB::Opacity%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/Fraction",
          "value": 0.6
        },
        "asyncWait": true
      }
    ]
  }
]
</script>



<script data-tchmi-target-attribute="data-tchmi-background-color" type="application/json">
{
  "color": "rgba(255, 253, 253, 1)"
}
</script>
</div>
<div id="Faults_Current_PB" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiImage" data-tchmi-height="70" data-tchmi-height-unit="px" data-tchmi-left="0" data-tchmi-left-unit="px" data-tchmi-top="0" data-tchmi-top-unit="px" data-tchmi-width="70" data-tchmi-width-unit="px" data-tchmi-is-enabled="true" data-tchmi-zindex="0" data-tchmi-background-image="Images/GTAC/Icons/ico_warning_prompt.png" data-tchmi-background-image-width="50" data-tchmi-background-image-height="50">
<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
