          "valueType": "tchmi:framework#/definitions/Fraction",
          "value": 1.0
        },
        "asyncWait": true
      },
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%Faults_History_PB::Opacity%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/Fraction",
          "value": 0.6
        },
        "asyncWait": true
      }
    ]
  }
]
</script>



