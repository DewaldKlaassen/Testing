<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "PB_ForceWriteCurrentProdReport.onPressed",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//Call Function to capture Current Production Report Information and store to DB",
          "TcHmi.Symbol.writeEx(\"%i%Prod_Report_Forced%/i%\", 1);",
          "let Targeted_Fixture = TcHmi.Symbol.readEx(\"%i%ProdFixXX_Selection%/i%\");",
          "Log_Production_Report(Targeted_Fixture, \"Curr\", \"%ctrl%TB_CaptureProdReport_Result::Text%/ctrl%\");"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>



